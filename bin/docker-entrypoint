#!/bin/bash -e

# If running the rails server then create or migrate existing database
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  # Check if database exists and has tables
  if ./bin/rails db:version 2>/dev/null; then
    # Database exists with schema, run migrations
    ./bin/rails db:migrate
  else
    # Fresh deployment - load schema directly (includes Solid Queue tables)
    ./bin/rails db:schema:load
  fi
  
  # Ensure Solid Queue tables exist (for both fresh and existing deployments)
  if [ -f db/queue_schema.rb ]; then
    ./bin/rails runner 'load Rails.root.join("db", "queue_schema.rb")' 2>/dev/null || true
  fi
fi

exec "${@}"

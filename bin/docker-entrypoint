#!/bin/bash -e

# Always prepare database when running in production mode with database configured
if [ "$RAILS_ENV" == "production" ]; then
  # Check if database exists and has tables
  if ./bin/rails db:version 2>/dev/null; then
    echo "Database exists, running migrations..."
    ./bin/rails db:migrate
  else
    echo "Fresh deployment, loading schema..."
    ./bin/rails db:schema:load
  fi
  
  # Ensure Solid Queue tables exist
  if [ -f db/queue_schema.rb ]; then
    echo "Loading Solid Queue schema..."
    ./bin/rails runner 'load Rails.root.join("db", "queue_schema.rb")' 2>/dev/null || true
  fi
fi

exec "${@}"

<div class="space-y-6">
  <h1 class="text-2xl font-bold text-primary dark:text-primary-dark dark:text-primary-dark"><%= t("recurring.title") %></h1>

  <div class="flex justify-end">
    <%= link_to t("recurring.new_recurring"), new_recurring_path, class: "bg-inverse text-white px-4 py-2 rounded hover:bg-inverse-hover" %>
  </div>

  <div class="bg-container dark:bg-container-dark rounded-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-surface dark:bg-surface-dark dark:bg-gray-900">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-secondary dark:text-secondary-dark dark:text-secondary-dark uppercase"><%= t("transactions.type") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-secondary dark:text-secondary-dark dark:text-secondary-dark uppercase"><%= t("transactions.amount") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-secondary dark:text-secondary-dark dark:text-secondary-dark uppercase"><%= t("transactions.category") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-secondary dark:text-secondary-dark dark:text-secondary-dark uppercase"><%= t("transactions.account") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-secondary dark:text-secondary-dark dark:text-secondary-dark uppercase"><%= t("recurring.frequency") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-secondary dark:text-secondary-dark dark:text-secondary-dark uppercase"><%= t("recurring.next_date") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-secondary dark:text-secondary-dark dark:text-secondary-dark uppercase"><%= t("recurring.status") %></th>
          <th class="px-6 py-3 actions"></th>
        </tr>
      </thead>
      <tbody class="bg-container dark:bg-container-dark divide-y divide-gray-200">
        <% @recurring.each do |r| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="px-2 py-1 rounded text-xs <%= r.transaction_type == "INCOME" ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800" %>">
                <%= r.transaction_type == "INCOME" ? t("transactions.income") : t("transactions.expense") %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap font-medium">¥<%= r.amount.to_s("%.2f") %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm"><%= r.category&.name || "-" %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm"><%= r.account&.name || "-" %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm capitalize"><%= t("recurring.#{r.frequency}") %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm"><%= r.next_date.strftime("%Y-%m-%d") if r.next_date %></td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="px-2 py-1 rounded text-xs <%= r.active? ? "bg-green-100 text-green-800" : "bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark dark:text-secondary-dark" %>">
                <%= r.active? ? t("recurring.active") : t("recurring.paused") %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm space-x-2">
              <%= button_to t("recurring.execute"), execute_recurring_path(r), method: :post, class: "text-green-600 hover:text-green-900" %>
              <%= link_to t("common.edit"), edit_recurring_path(r), class: "text-primary dark:text-primary-dark hover:text-primary dark:text-primary-dark" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @recurring.empty? %>
      <div class="p-8 text-center text-secondary dark:text-secondary-dark dark:text-secondary-dark">
        <%= t("recurring.no_recurring_transactions") %>
      </div>
    <% end %>
  </div>
</div>

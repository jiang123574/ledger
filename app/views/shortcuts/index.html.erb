<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h1 class="text-2xl font-bold text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark">快捷键设置</h1>
    <%= link_to "恢复默认", reset_shortcuts_path, method: :post, data: { turbo_confirm: "确定恢复默认快捷键？" }, class: "text-red-600 hover:text-red-800" %>
  </div>

  <div class="bg-surface dark:bg-gray-900 border border-border dark:border-border-dark dark:border-border dark:border-border dark:border-border-dark-dark-dark rounded-lg p-4">
    <div class="flex items-start gap-3">
      <div class="text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark text-2xl">⌨️</div>
      <div>
        <h3 class="font-medium text-gray-800">提示</h3>
        <p class="text-sm text-primary dark:text-primary dark:text-primary-dark-dark">按 <kbd class="bg-surface dark:bg-surface-dark px-2 py-0.5 rounded">?</kbd> 随时查看快捷键帮助</p>
      </div>
    </div>
  </div>

  <%= form_with url: shortcuts_path, method: :patch, local: true, class: "space-y-6" do |f| %>
    <% @shortcuts.group_by { |s| s[:group] }.each do |group, shortcuts| %>
      <div class="bg-container dark:bg-container dark:bg-container-dark-dark rounded-lg shadow overflow-hidden">
        <div class="px-6 py-4 bg-surface dark:bg-gray-900 border-b">
          <h2 class="font-semibold text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark"><%= group %></h2>
        </div>
        
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-surface dark:bg-gray-900">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark uppercase">功能</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark uppercase">快捷键</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark uppercase">说明</th>
            </tr>
          </thead>
          <tbody class="bg-container dark:bg-container dark:bg-container-dark-dark divide-y divide-gray-200">
            <% shortcuts.each do |shortcut| %>
              <tr class="hover:bg-surface dark:bg-gray-900">
                <td class="px-6 py-4 whitespace-nowrap font-medium text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark">
                  <%= shortcut[:description] %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center gap-2">
                    <% shortcut[:key].split.map do |key| %>
                      <kbd class="bg-surface dark:bg-surface-dark border border-border dark:border-border-dark dark:border-border dark:border-border dark:border-border-dark-dark-dark rounded px-2 py-1 text-sm font-mono">
                        <%= key %>
                      </kbd>
                      <% unless key == shortcut[:key].split.last %>
                        <span class="text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark">+</span>
                      <% end %>
                    <% end %>
                  </div>
                </td>
                <td class="px-6 py-4 text-sm text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark">
                  按 <%= shortcut[:key] %> <%= shortcut[:description].downcase %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <div class="flex justify-end">
      <%= f.submit "保存设置", class: "bg-inverse text-white px-4 py-2 rounded-lg hover:bg-inverse-hover" %>
    </div>
  <% end %>
</div>

<!-- Keyboard Shortcuts JavaScript -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  const shortcuts = <%= @shortcuts.to_json.html_safe %>;
  let keyBuffer = '';
  let keyBufferTimeout = null;

  function clearKeyBuffer() {
    keyBuffer = '';
    if (keyBufferTimeout) {
      clearTimeout(keyBufferTimeout);
      keyBufferTimeout = null;
    }
  }

  document.addEventListener('keydown', function(e) {
    // Ignore if typing in input fields
    if (['INPUT', 'TEXTAREA', 'SELECT'].includes(document.activeElement.tagName)) {
      if (e.key !== 'Escape') return;
    }

    // Build key string
    const key = [];
    if (e.ctrlKey || e.metaKey) key.push('Ctrl');
    if (e.shiftKey) key.push('Shift');
    if (e.altKey) key.push('Alt');

    // For modifier-only shortcuts, use the buffer approach for 'g' prefix
    const baseKey = e.key.length === 1 ? e.key.toLowerCase() : e.key;

    // Handle 'g' prefix for navigation shortcuts
    if (baseKey === 'g' && !e.ctrlKey && !e.metaKey && !e.altKey) {
      e.preventDefault();
      e.stopPropagation();
      keyBuffer = 'g';
      // Clear buffer after 1 second of inactivity
      keyBufferTimeout = setTimeout(clearKeyBuffer, 1000);
      return;
    }

    // If we have 'g' in buffer, check for follow-up key
    if (keyBuffer === 'g' && !e.ctrlKey && !e.metaKey && !e.altKey) {
      const gShortcut = 'g ' + baseKey;
      switch (gShortcut) {
        case 'g t':
          e.preventDefault();
          e.stopPropagation();
          clearKeyBuffer();
          window.location.href = '<%= transactions_path %>';
          return;
        case 'g a':
          e.preventDefault();
          e.stopPropagation();
          clearKeyBuffer();
          window.location.href = '<%= accounts_path %>';
          return;
        case 'g r':
          e.preventDefault();
          e.stopPropagation();
          clearKeyBuffer();
          window.location.href = '<%= reports_path %>';
          return;
        case 'g b':
          e.preventDefault();
          e.stopPropagation();
          clearKeyBuffer();
          window.location.href = '<%= budgets_path %>';
          return;
        case 'g s':
          e.preventDefault();
          e.stopPropagation();
          clearKeyBuffer();
          window.location.href = '<%= settings_path %>';
          return;
        default:
          clearKeyBuffer();
      }
    }

    // Build full key string for single-key shortcuts
    key.push(baseKey);
    const keyStr = key.join(' ');

    // Handle single-key shortcuts
    switch (keyStr) {
      case 'n':
        if (!e.ctrlKey && !e.metaKey) {
          e.preventDefault();
          e.stopPropagation();
          window.location.href = '<%= new_transaction_path %>';
        }
        break;
      case 's':
        if (!e.ctrlKey && !e.metaKey) {
          e.preventDefault();
          e.stopPropagation();
          document.querySelector('#search-input')?.focus();
        }
        break;
      case '/':
        e.preventDefault();
        e.stopPropagation();
        document.querySelector('#search-input')?.focus();
        break;
      case '?':
        e.preventDefault();
        e.stopPropagation();
        showShortcutsHelp();
        break;
      case 'Escape':
        clearKeyBuffer();
        // Close any modal or cancel action
        const modal = document.querySelector('.modal, [role="dialog"]');
        if (modal) {
          modal.querySelector('[data-dismiss]')?.click();
        }
        break;
    }
  });

  function showShortcutsHelp() {
    // Create help modal
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50';
    modal.innerHTML = `
      <div class="bg-container dark:bg-container dark:bg-container-dark-dark rounded-lg shadow-xl max-w-2xl w-full max-h-[80vh] overflow-auto m-4">
        <div class="p-6">
          <div class="flex justify-between items-center mb-4">
            <h2 class="text-xl font-bold"><%= t('shortcuts.title', default: '键盘快捷键') %></h2>
            <button onclick="this.closest('.fixed').remove()" class="text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark hover:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark text-2xl">&times;</button>
          </div>
          <div class="grid gap-4">
            ${shortcuts.map(s => `
              <div class="flex items-center justify-between py-2 border-b">
                <span class="text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark">${s.description}</span>
                <div class="flex gap-1">
                  ${s.key.split(' ').map(k => `<kbd class="bg-surface dark:bg-surface-dark border border-border dark:border-border-dark dark:border-border dark:border-border dark:border-border-dark-dark-dark rounded px-2 py-1 text-sm font-mono">${k}</kbd>`).join('<span class="text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark mx-1">+</span>')}
                </div>
              </div>
            `).join('')}
          </div>
        </div>
      </div>
    `;
    document.body.appendChild(modal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.remove();
    });
  }
});
</script>
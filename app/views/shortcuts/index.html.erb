<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h1 class="text-2xl font-bold text-gray-900">快捷键设置</h1>
    <%= link_to "恢复默认", reset_shortcuts_path, method: :post, data: { turbo_confirm: "确定恢复默认快捷键？" }, class: "text-red-600 hover:text-red-800" %>
  </div>

  <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
    <div class="flex items-start gap-3">
      <div class="text-blue-500 text-2xl">⌨️</div>
      <div>
        <h3 class="font-medium text-blue-800">提示</h3>
        <p class="text-sm text-blue-600">按 <kbd class="bg-blue-100 px-2 py-0.5 rounded">?</kbd> 随时查看快捷键帮助</p>
      </div>
    </div>
  </div>

  <%= form_with url: shortcuts_path, method: :patch, local: true, class: "space-y-6" do |f| %>
    <% @shortcuts.group_by { |s| s[:group] }.each do |group, shortcuts| %>
      <div class="bg-white rounded-lg shadow overflow-hidden">
        <div class="px-6 py-4 bg-gray-50 border-b">
          <h2 class="font-semibold text-gray-900"><%= group %></h2>
        </div>
        
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">功能</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">快捷键</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">说明</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% shortcuts.each do |shortcut| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-900">
                  <%= shortcut[:description] %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center gap-2">
                    <% shortcut[:key].split.map do |key| %>
                      <kbd class="bg-gray-100 border border-gray-300 rounded px-2 py-1 text-sm font-mono">
                        <%= key %>
                      </kbd>
                      <% unless key == shortcut[:key].split.last %>
                        <span class="text-gray-400">+</span>
                      <% end %>
                    <% end %>
                  </div>
                </td>
                <td class="px-6 py-4 text-sm text-gray-500">
                  按 <%= shortcut[:key] %> <%= shortcut[:description].downcase %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <div class="flex justify-end">
      <%= f.submit "保存设置", class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700" %>
    </div>
  <% end %>
</div>

<!-- Keyboard Shortcuts JavaScript -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  const shortcuts = <%= @shortcuts.to_json.html_safe %>;

  document.addEventListener('keydown', function(e) {
    // Ignore if typing in input fields
    if (['INPUT', 'TEXTAREA', 'SELECT'].includes(document.activeElement.tagName)) {
      if (e.key !== 'Escape') return;
    }

    // Find matching shortcut
    const key = [];
    if (e.ctrlKey || e.metaKey) key.push('Ctrl');
    if (e.shiftKey) key.push('Shift');
    if (e.altKey) key.push('Alt');
    key.push(e.key.length === 1 ? e.key.toLowerCase() : e.key);

    const keyStr = key.join(' ');

    // Handle shortcuts
    switch (keyStr) {
      case 'n':
        if (!e.ctrlKey && !e.metaKey) {
          e.preventDefault();
          window.location.href = '<%= new_transaction_path %>';
        }
        break;
      case 's':
        if (!e.ctrlKey && !e.metaKey) {
          e.preventDefault();
          document.querySelector('#search-input')?.focus();
        }
        break;
      case '/':
        e.preventDefault();
        document.querySelector('#search-input')?.focus();
        break;
      case 'g t':
        e.preventDefault();
        window.location.href = '<%= transactions_path %>';
        break;
      case 'g a':
        e.preventDefault();
        window.location.href = '<%= accounts_path %>';
        break;
      case 'g r':
        e.preventDefault();
        window.location.href = '<%= reports_path %>';
        break;
      case 'g b':
        e.preventDefault();
        window.location.href = '<%= budgets_path %>';
        break;
      case 'g s':
        e.preventDefault();
        window.location.href = '<%= settings_path %>';
        break;
      case '?':
        e.preventDefault();
        showShortcutsHelp();
        break;
      case 'Escape':
        // Close any modal or cancel action
        const modal = document.querySelector('.modal, [role="dialog"]');
        if (modal) {
          modal.querySelector('[data-dismiss]')?.click();
        }
        break;
    }
  });

  function showShortcutsHelp() {
    // Create help modal
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50';
    modal.innerHTML = `
      <div class="bg-white rounded-lg shadow-xl max-w-2xl w-full max-h-[80vh] overflow-auto m-4">
        <div class="p-6">
          <div class="flex justify-between items-center mb-4">
            <h2 class="text-xl font-bold">键盘快捷键</h2>
            <button onclick="this.closest('.fixed').remove()" class="text-gray-500 hover:text-gray-700 text-2xl">&times;</button>
          </div>
          <div class="grid gap-4">
            ${shortcuts.map(s => `
              <div class="flex items-center justify-between py-2 border-b">
                <span class="text-gray-700">${s.description}</span>
                <div class="flex gap-1">
                  ${s.key.split(' ').map(k => `<kbd class="bg-gray-100 border border-gray-300 rounded px-2 py-1 text-sm font-mono">${k}</kbd>`).join('<span class="text-gray-400 mx-1">+</span>')}
                </div>
              </div>
            `).join('')}
          </div>
        </div>
      </div>
    `;
    document.body.appendChild(modal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.remove();
    });
  }
});
</script>
<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h1 class="text-2xl font-bold text-primary dark:text-primary-dark">快捷键设置</h1>
    <%= link_to "恢复默认", reset_shortcuts_path, method: :post,
      data: {
        controller: "confirm-form",
        action: "click->confirm-form#confirm",
        confirm_form_title_value: "确认恢复",
        confirm_form_content_value: "确定恢复默认快捷键吗？",
        confirm_form_confirm_text_value: "恢复"
      },
      class: "text-red-600 hover:text-red-800" %>
  </div>

  <div class="bg-surface dark:bg-surface-dark dark:bg-gray-900 border border-border dark:border-border-dark rounded-lg p-4">
    <div class="flex items-start gap-3">
      <div class="text-secondary dark:text-secondary-dark text-2xl">⌨️</div>
      <div>
        <h3 class="font-medium text-primary dark:text-primary-dark">提示</h3>
        <p class="text-sm text-primary dark:text-primary-dark">按 <kbd class="bg-surface dark:bg-surface-dark px-2 py-0.5 rounded">?</kbd> 随时查看快捷键帮助</p>
      </div>
    </div>
  </div>

  <%= form_with url: shortcuts_path, method: :patch, local: true, class: "space-y-6" do |f| %>
    <% @shortcuts.group_by { |s| s[:group] }.each do |group, shortcuts| %>
      <div class="bg-container dark:bg-container-dark rounded-lg shadow-sm overflow-x-auto">
        <div class="px-6 py-4 bg-surface dark:bg-surface-dark dark:bg-gray-900 border-b">
          <h2 class="font-semibold text-primary dark:text-primary-dark"><%= group %></h2>
        </div>
        
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-surface dark:bg-surface-dark dark:bg-gray-900">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary dark:text-secondary-dark uppercase">功能</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary dark:text-secondary-dark uppercase">快捷键</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary dark:text-secondary-dark uppercase">说明</th>
            </tr>
          </thead>
          <tbody class="bg-container dark:bg-container-dark divide-y divide-gray-200">
            <% shortcuts.each do |shortcut| %>
              <tr class="hover:bg-surface dark:bg-surface-dark dark:bg-gray-900">
                <td class="px-6 py-4 whitespace-nowrap font-medium text-primary dark:text-primary-dark">
                  <%= shortcut[:description] %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center gap-2">
                    <% shortcut[:key].split.map do |key| %>
                      <kbd class="bg-surface dark:bg-surface-dark border border-border dark:border-border-dark rounded px-2 py-1 text-sm font-mono">
                        <%= key %>
                      </kbd>
                      <% unless key == shortcut[:key].split.last %>
                        <span class="text-secondary dark:text-secondary-dark">+</span>
                      <% end %>
                    <% end %>
                  </div>
                </td>
                <td class="px-6 py-4 text-sm text-secondary dark:text-secondary-dark">
                  按 <%= shortcut[:key] %> <%= shortcut[:description].downcase %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <div class="flex justify-end">
      <%= f.submit "保存设置", class: "bg-inverse text-white px-4 py-2 rounded-lg hover:bg-inverse-hover" %>
    </div>
  <% end %>
</div>

<!-- 快捷键绑定逻辑已移至 layout 全局 JS -->
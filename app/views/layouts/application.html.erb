    <%# Initialize dark mode before page renders to prevent flash %>
    <script>
      // Dark mode initialization
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
        document.documentElement.setAttribute('data-theme', 'dark');
      } else {
        document.documentElement.classList.remove('dark');
        document.documentElement.setAttribute('data-theme', 'light');
      }
      
      // Color theme initialization
      (function() {
        const savedTheme = localStorage.getItem('colorTheme') || 'default';
        const themes = {
          default: { income: '#ef4444', expense: '#22c55e' },  // 默认: 收入红/支出绿
          original: { income: '#22c55e', expense: '#ef4444' }, // 原色: 收入绿/支出红
          blue_orange: { income: '#3b82f6', expense: '#f97316' },
          purple_yellow: { income: '#8b5cf6', expense: '#eab308' },
          cyan_pink: { income: '#06b6d4', expense: '#ec4899' },
          teal_rose: { income: '#14b8a6', expense: '#f43f5e' },
          indigo_amber: { income: '#6366f1', expense: '#f59e0b' }
        };
        
        function hexToRgb(hex) {
          const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
          return result ? {
            r: parseInt(result[1], 16),
            g: parseInt(result[2], 16),
            b: parseInt(result[3], 16)
          } : { r: 0, g: 0, b: 0 };
        }
        
        const theme = themes[savedTheme] || themes.default;
        document.documentElement.style.setProperty('--color-income', theme.income);
        document.documentElement.style.setProperty('--color-expense', theme.expense);
        
        // 设置 RGB 值变量
        const incomeRgb = hexToRgb(theme.income);
        const expenseRgb = hexToRgb(theme.expense);
        document.documentElement.style.setProperty('--color-income-rgb', `${incomeRgb.r}, ${incomeRgb.g}, ${incomeRgb.b}`);
        document.documentElement.style.setProperty('--color-expense-rgb', `${expenseRgb.r}, ${expenseRgb.g}, ${expenseRgb.b}`);
        
        document.documentElement.setAttribute('data-color-theme', savedTheme);
      })();
    </script>
    

<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || t("app_name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="application-name" content="<%= t("app_name") %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= yield :head %>
    <%# PWA Manifest (Web only, not needed for Turbo Native) %>
    <% unless turbo_native_app? %>
    <link rel="manifest" href="/manifest.json">
    <% end %>
    <meta name="theme-color" content="#1a1a1a">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Turbo Native 配置 %>
    <%= turbo_native_config(title: content_for(:title) || t("app_name")) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    
    <%# Initialize dark mode before page renders to prevent flash %>
    <script>
      // Dark mode initialization
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
        document.documentElement.setAttribute('data-theme', 'dark');
      } else {
        document.documentElement.classList.remove('dark');
        document.documentElement.setAttribute('data-theme', 'light');
      }
      
      // Color theme initialization
      (function() {
        const savedTheme = localStorage.getItem('colorTheme') || 'default';
        const themes = {
          default: { income: '#ef4444', expense: '#22c55e' },  // 默认: 收入红/支出绿
          original: { income: '#22c55e', expense: '#ef4444' }, // 原色: 收入绿/支出红
          blue_orange: { income: '#3b82f6', expense: '#f97316' },
          purple_yellow: { income: '#8b5cf6', expense: '#eab308' },
          cyan_pink: { income: '#06b6d4', expense: '#ec4899' },
          teal_rose: { income: '#14b8a6', expense: '#f43f5e' },
          indigo_amber: { income: '#6366f1', expense: '#f59e0b' }
        };
        
        function hexToRgb(hex) {
          const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
          return result ? {
            r: parseInt(result[1], 16),
            g: parseInt(result[2], 16),
            b: parseInt(result[3], 16)
          } : { r: 0, g: 0, b: 0 };
        }
        
        const theme = themes[savedTheme] || themes.default;
        document.documentElement.style.setProperty('--color-income', theme.income);
        document.documentElement.style.setProperty('--color-expense', theme.expense);
        
        // 设置 RGB 值变量
        const incomeRgb = hexToRgb(theme.income);
        const expenseRgb = hexToRgb(theme.expense);
        document.documentElement.style.setProperty('--color-income-rgb', `${incomeRgb.r}, ${incomeRgb.g}, ${incomeRgb.b}`);
        document.documentElement.style.setProperty('--color-expense-rgb', `${expenseRgb.r}, ${expenseRgb.g}, ${expenseRgb.b}`);
        
        document.documentElement.setAttribute('data-color-theme', savedTheme);
      })();
    </script>
    
    <%# Tailwind CSS v4 - compiled application.css %>
    <%= stylesheet_link_tag :application %>
    <script src="/assets/chart.js.umd.js"></script>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full antialiased font-sans" style="background-color: var(--color-surface); color: var(--color-primary);" data-controller="mobile-layout page-transition page-skeleton theme">
    <div class="page-skeleton" data-page-skeleton-target="overlay" aria-hidden="true">
      <div class="max-w-7xl xl:max-w-[1440px] 2xl:max-w-[1680px] mx-auto px-4 sm:px-6 lg:px-8 xl:px-12 py-6 lg:py-8">
        <div class="skeleton-block" style="width: 160px;"></div>
        <div class="mt-4 space-y-3">
          <div class="skeleton-block" style="width: 100%; height: 18px;"></div>
          <div class="skeleton-block" style="width: 92%; height: 18px;"></div>
          <div class="skeleton-block" style="width: 78%; height: 18px;"></div>
        </div>
        <div class="mt-6 grid gap-4">
          <div class="skeleton-block" style="width: 100%; height: 120px; border-radius: 16px;"></div>
          <div class="skeleton-block" style="width: 100%; height: 120px; border-radius: 16px;"></div>
        </div>
      </div>
    </div>
    <div class="flex flex-col lg:flex-row min-h-full">
      <%# Desktop Sidebar (hidden on mobile and Turbo Native) %>
      <% unless turbo_native_app? %>
      <%= render "layouts/sidebar" %>
      <% end %>

      <%# Mobile Sidebar Overlay %>
      <% unless turbo_native_app? %>
      <div
        id="sidebar-overlay"
        class="lg:hidden fixed inset-0 z-40 bg-black/50 opacity-0 pointer-events-none transition-opacity duration-300"
        data-mobile-layout-target="overlay"
        data-action="click->mobile-layout#closeSidebar">
      </div>

      <%# Mobile Sidebar %>
      <aside
        id="mobile-sidebar"
        class="lg:hidden fixed inset-y-0 left-0 z-50 w-72 bg-container dark:bg-container-dark shadow-xl transform -translate-x-full transition-transform duration-300 ease-out"
        data-mobile-layout-target="sidebar">
        <%# Mobile Sidebar Header with Safe Area %>
        <div class="pt-[calc(env(safe-area-inset-top)+0.5rem)]">
          <div class="h-14 flex items-center justify-between px-4 border-b border-border dark:border-border-dark">
            <%= link_to dashboard_path, class: "flex items-center gap-3 min-h-[44px]" do %>
              <div class="w-8 h-8 bg-linear-to-br from-emerald-500 to-teal-600 rounded-lg flex items-center justify-center shadow-xs">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                </svg>
              </div>
              <span class="font-semibold text-primary dark:text-primary-dark"><%= t("app_name") %></span>
            <% end %>
            <button
              type="button"
              data-action="click->mobile-layout#closeSidebar"
              class="p-2 -mr-2 text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark dark:hover:text-primary dark:text-primary-dark min-w-[44px] min-h-[44px] flex items-center justify-center rounded-lg hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-colors"
              aria-label="关闭菜单">
              <%= render(Ds::IconComponent.new(name: "x", size: :md)) %>
            </button>
          </div>
        </div>

        <%# Mobile Sidebar Navigation %>
        <nav class="p-4 space-y-1">
          <%= nav_item(:dashboard, t("nav.dashboard"), dashboard_path, "home") %>
          <%= nav_item(:accounts, t("nav.accounts"), accounts_path, "folder") %>
          <%= nav_item(:budgets, t("nav.budgets"), budgets_path, "map") %>
          <%= nav_item(:plans, t("nav.plans"), plans_path, "calendar") %>
          <%= nav_item(:receivables, "应收款", receivables_path, "inbox") %>
          <%= nav_item(:payables, "应付款", payables_path, "wallet") %>
        </nav>


      </aside>
      <% end %>

      <%# Mobile Top Header (hidden in Turbo Native - native toolbar replaces it) %>
      <% unless turbo_native_app? %>
        <div class="pt-[calc(env(safe-area-inset-top)+0.5rem)]">
          <div class="flex items-center justify-between h-14 px-4">
            <%# Menu Button %>
            <button
              type="button"
              data-action="click->mobile-layout#toggle"
              class="p-2 -ml-2 text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark dark:hover:text-primary dark:text-primary-dark min-w-[44px] min-h-[44px] flex items-center justify-center rounded-lg hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-colors"
              aria-label="打开菜单">
              <%= render(Ds::IconComponent.new(name: "menu", size: :md)) %>
            </button>

            <%# Page Title %>
            <span class="font-semibold text-primary dark:text-primary-dark truncate"><%= content_for(:title) || t("app_name") %></span>

            <%# Quick Action Button %>
            <%= link_to accounts_path(open_modal: true), class: "p-2 -mr-2 text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark dark:hover:text-primary dark:text-primary-dark min-w-[44px] min-h-[44px] flex items-center justify-center rounded-lg hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-colors" do %>
              <%= render(Ds::IconComponent.new(name: "plus", size: :md)) %>
            <% end %>
          </div>
        </div>
      </header>
      <% end %>

      <%# Main Content (Turbo Native: no extra padding for headers/nav) %>
      <main class="flex-1<%= turbo_native_app? ? '' : ' lg:pt-0 pt-[calc(3rem+env(safe-area-inset-top))] pb-[calc(5rem+env(safe-area-inset-bottom))] lg:pb-0' %> min-h-screen">
<div class="max-w-7xl xl:max-w-[1440px] 2xl:max-w-[1680px] mx-auto px-4 sm:px-6 lg:px-8 xl:px-12 py-6 lg:py-8">
          <% if notice %>
            <div class="mb-4 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-400 rounded-lg" role="alert">
              <%= notice %>
            </div>
          <% end %>
          <% if alert %>
            <div class="mb-4 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 rounded-lg" role="alert">
              <%= alert %>
            </div>
          <% end %>
          <%= yield %>
        </div>
      </main>

      <%# Mobile Bottom Navigation %>
      <%= render "layouts/mobile_nav" %>
    </div>

    <%# Global Keyboard Shortcuts %>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
      var keyBuffer = '';
      var keyBufferTimeout = null;

      function clearKeyBuffer() {
        keyBuffer = '';
        if (keyBufferTimeout) {
          clearTimeout(keyBufferTimeout);
          keyBufferTimeout = null;
        }
      }

      document.addEventListener('keydown', function(e) {
        // Ignore if typing in input fields (except Escape)
        if (['INPUT', 'TEXTAREA', 'SELECT'].includes(document.activeElement.tagName)) {
          if (e.key !== 'Escape') return;
        }

        // Build key string
        if (e.ctrlKey || e.metaKey || e.altKey) return;

        var baseKey = e.key.length === 1 ? e.key.toLowerCase() : e.key;

        // Handle 'g' prefix for navigation shortcuts
        if (baseKey === 'g') {
          e.preventDefault();
          e.stopPropagation();
          keyBuffer = 'g';
          keyBufferTimeout = setTimeout(clearKeyBuffer, 1000);
          return;
        }

        // If we have 'g' in buffer, check for follow-up key
        if (keyBuffer === 'g') {
          var gShortcut = 'g ' + baseKey;
          switch (gShortcut) {
            case 'g a':
              e.preventDefault();
              e.stopPropagation();
              clearKeyBuffer();
              window.location.href = '/accounts';
              return;
            case 'g r':
              e.preventDefault();
              e.stopPropagation();
              clearKeyBuffer();
              window.location.href = '/reports';
              return;
            case 'g b':
              e.preventDefault();
              e.stopPropagation();
              clearKeyBuffer();
              window.location.href = '/budgets';
              return;
            case 'g s':
              e.preventDefault();
              e.stopPropagation();
              clearKeyBuffer();
              window.location.href = '/settings';
              return;
            default:
              clearKeyBuffer();
          }
        }

        // Handle single-key shortcuts
        switch (baseKey) {
          case 'n':
            e.preventDefault();
            e.stopPropagation();
            // 打开新建交易弹窗（优先）或跳转到新建页面
            if (typeof openNewTransactionModal === 'function') {
              openNewTransactionModal();
            } else {
              var newBtn = document.querySelector('#e9, button[onclick*="openNewTransactionModal"]');
              if (newBtn) {
                newBtn.click();
              } else {
                window.location.href = '/accounts?open_new_transaction=1';
              }
            }
            break;
          case 'a':
            e.preventDefault();
            e.stopPropagation();
            if (typeof openNewTransactionModal === 'function') {
              if (typeof transactionMode !== 'undefined' && transactionMode === 'transfer') {
                toggleTransferMode();
              }
              openNewTransactionModal();
            } else {
              window.location.href = '/accounts?open_new_transaction=1';
            }
            break;
          case 'z':
            e.preventDefault();
            e.stopPropagation();
            if (typeof openNewTransactionModal === 'function') {
              openNewTransactionModal();
              toggleTransferMode();
            } else {
              window.location.href = '/accounts?open_new_transaction=1&transfer=1';
            }
            break;
          case 'd':
            e.preventDefault();
            e.stopPropagation();
            if (typeof openNewReceivableModal === 'function') {
              openNewReceivableModal();
            } else {
              window.location.href = '/receivables?open_modal=true';
            }
            break;
          case 'b':
            e.preventDefault();
            e.stopPropagation();
            if (typeof openSettleReceivableModal === 'function') {
              openSettleReceivableModal();
            } else {
              window.location.href = '/accounts?open_settle_receivable=1';
            }
            break;
          case 's':
            e.preventDefault();
            e.stopPropagation();
            var searchInput = document.querySelector('#search-input');
            if (searchInput) searchInput.focus();
            break;
          case '/':
            e.preventDefault();
            e.stopPropagation();
            var searchInput2 = document.querySelector('#search-input');
            if (searchInput2) searchInput2.focus();
            break;
          case '?':
            e.preventDefault();
            e.stopPropagation();
            showShortcutsHelp();
            break;
          case 'Escape':
            clearKeyBuffer();
            // Close any visible modal
            var modals = document.querySelectorAll('#add-transaction-modal:not(.hidden), #edit-transaction-modal:not(.hidden), #add-account-modal:not(.hidden), #category-filter-modal:not(.hidden), #pixiu-import-modal:not(.hidden), .fixed.inset-0:not(.hidden)');
            if (modals.length > 0) {
              modals[modals.length - 1].classList.add('hidden');
            }
            break;
        }
      });

      function showShortcutsHelp() {
        var shortcuts = [
          { key: 'n', description: '新建交易' },
          { key: 'a', description: '新增收支' },
          { key: 'z', description: '新增转账' },
          { key: 'd', description: '新增应收款' },
          { key: 'b', description: '报销应收款' },
          { key: 's', description: '搜索' },
          { key: '/', description: '快速搜索' },
          { key: 'g a', description: '账户' },
          { key: 'g r', description: '报表' },
          { key: 'g b', description: '预算' },
          { key: 'g s', description: '设置' },
          { key: '?', description: '快捷键帮助' },
          { key: 'Escape', description: '关闭弹窗' }
        ];
        var modal = document.createElement('div');
        modal.className = 'fixed inset-0 bg-black/50 flex items-center justify-center z-60';
        modal.innerHTML = '<div class="bg-container dark:bg-container-dark rounded-lg shadow-xl max-w-md w-full mx-4 p-6">' +
          '<div class="flex justify-between items-center mb-4">' +
            '<h2 class="text-lg font-bold text-primary dark:text-primary-dark">键盘快捷键</h2>' +
            '<button onclick="this.closest(\'.fixed\').remove()" class="text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark text-2xl leading-none">&times;</button>' +
          '</div>' +
          '<div class="space-y-2">' +
            shortcuts.map(function(s) {
              var keys = s.key.split(' ');
              var kbdHtml = keys.map(function(k) {
                return '<kbd class="bg-surface dark:bg-surface-dark border border-border dark:border-border-dark rounded px-2 py-0.5 text-xs font-mono">' + k + '</kbd>';
              }).join('<span class="text-secondary dark:text-secondary-dark mx-0.5">+</span>');
              return '<div class="flex items-center justify-between py-1.5">' +
                '<span class="text-sm text-primary dark:text-primary-dark">' + s.description + '</span>' +
                '<div class="flex gap-1">' + kbdHtml + '</div>' +
              '</div>';
            }).join('') +
          '</div>' +
        '</div>';
        document.body.appendChild(modal);
        modal.addEventListener('click', function(e) {
          if (e.target === modal) modal.remove();
        });
      }
    });
    </script>
  </body>
</html>

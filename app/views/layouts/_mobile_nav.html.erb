<%# Mobile Bottom Navigation - hidden in Turbo Native (native tab bar replaces it) %>
<% unless turbo_native_app? %>
<nav class="lg:hidden fixed bottom-0 left-0 right-0 z-50 bg-container dark:bg-container-dark border-t border-border dark:border-border-dark safe-area-bottom">
  <%# Subtle top border glow %>
  <div class="h-px bg-linear-to-r from-transparent via-border dark:via-border-dark to-transparent"></div>
  
  <div class="flex items-stretch justify-around min-h-[64px] pb-[calc(0.5rem+env(safe-area-inset-bottom))]">
    <%= mobile_nav_item(:dashboard, t("nav.dashboard"), dashboard_path, "home") %>
    <%= mobile_nav_item(:accounts, t("nav.accounts"), accounts_path, "folder") %>
    <%= mobile_nav_item(:budgets, "预算", budgets_path, "map") %>
    <%= mobile_nav_item(:receivables, "应收", receivables_path, "receipt") %>
    <%= mobile_nav_item(:payables, "应付", payables_path, "wallet") %>
    <%= mobile_nav_item(:settings, t("nav.settings"), settings_path, "cog") %>
  </div>
</nav>

<style>
/* Ensure touch targets are at least 44px */
nav a, nav button {
  min-height: 44px;
  min-width: 44px;
}

/* Safe area padding for notched devices */
@supports (padding-bottom: env(safe-area-inset-bottom)) {
  .safe-area-bottom {
    padding-bottom: env(safe-area-inset-bottom);
  }
}
</style>
<% end %>

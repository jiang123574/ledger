<%# Desktop Sidebar (hidden on mobile) %>
<aside class="hidden lg:flex flex-col w-64 shrink-0 bg-container border-r border-border min-h-screen sticky top-0">
  <%# Logo %>
  <div class="h-16 flex items-center px-6 border-b border-border">
    <%= link_to dashboard_path, class: "flex items-center gap-3 min-h-[44px]" do %>
      <div class="w-8 h-8 bg-surface dark:bg-gray-900 rounded-lg flex items-center justify-center">
        <span class="text-white font-bold text-sm">账</span>
      </div>
      <span class="font-semibold text-primary">记账本</span>
    <% end %>
  </div>

  <%# Navigation %>
  <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
    <div class="mb-2">
      <span class="text-xs font-medium text-gray-400 uppercase tracking-wider px-3">主要功能</span>
    </div>
    <%= nav_item(:dashboard, "仪表盘", dashboard_path, "home") %>
    <%= nav_item(:transactions, "交易记录", transactions_path, "credit-card") %>
    <%= nav_item(:accounts, "账户管理", accounts_path, "folder") %>
    
    <div class="mt-4 mb-2">
      <span class="text-xs font-medium text-gray-400 uppercase tracking-wider px-3">财务规划</span>
    </div>
    <%= nav_item(:budgets, "预算管理", budgets_path, "map") %>
    <%= nav_item(:plans, "计划管理", plans_path, "calendar") %>
    <%= nav_item(:receivables, "应收款", receivables_path, "inbox") %>
    
    <div class="mt-4 mb-2">
      <span class="text-xs font-medium text-gray-400 uppercase tracking-wider px-3">数据分析</span>
    </div>
    <%= nav_item(:reports, "报表统计", reports_path, "bar-chart-2") %>
  </nav>

  <%# Footer %>
  <div class="p-4 border-t border-border">
    <%= link_to settings_path, class: "flex items-center gap-3 px-3 py-3 min-h-[44px] rounded-lg text-secondary hover:bg-surface-hover hover:text-primary transition-colors" do %>
      <%= render(Ds::IconComponent.new(name: "cog", size: :md)) %>
      <span class="text-sm font-medium">设置</span>
    <% end %>
  </div>
</aside>
<div class="space-y-6">
  <div class="flex items-center gap-4">
    <%= link_to t("common.back"), @single_budget, class: "text-primary dark:text-primary-dark hover:text-inverse" %>
    <h1 class="text-2xl font-bold text-primary dark:text-primary-dark"><%= t("single_budgets.new_item") %></h1>
  </div>

  <div class="bg-container dark:bg-container-dark rounded-lg shadow p-6">
    <%= form_with model: [@single_budget, @budget_item], url: single_budget_budget_items_path(@single_budget), local: true, class: "space-y-4" do |f| %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5"><%= t("single_budgets.item_name") %></label>
          <%= render Ds::InputComponent.new(form: f, field: :name, required: true) %>
        </div>
        <div>
          <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5"><%= t("single_budgets.category") %></label>
          <%= render Ds::InputComponent.new(form: f, field: :category) %>
        </div>
        <div>
          <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5"><%= t("single_budgets.amount") %></label>
          <%= render Ds::InputComponent.new(form: f, field: :amount, type: :number, placeholder: "0.00", prefix: "¥", required: true) %>
        </div>
        <div>
          <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5"><%= t("single_budgets.spent") %></label>
          <%= render Ds::InputComponent.new(form: f, field: :spent_amount, type: :number, placeholder: "0.00", prefix: "¥") %>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5"><%= t("single_budgets.notes") %></label>
        <%= render Ds::InputComponent.new(form: f, field: :notes, type: :textarea) %>
      </div>
      <div class="flex justify-end gap-3">
        <%= link_to t("common.cancel"), @single_budget, class: "px-4 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth btn-modern" %>
        <button type="submit" class="px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover dark:hover:bg-inverse-dark-hover transition-smooth btn-modern">
          <%= t("common.create") %>
        </button>
      </div>
    <% end %>
  </div>
</div>

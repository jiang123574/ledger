<section class="bg-container dark:bg-container-dark rounded-lg shadow-border-xs dark:shadow-dark-border-xs card-hover">
  <div class="p-4 border-b border-border dark:border-border-dark flex items-center justify-between">
    <h2 class="text-lg font-semibold text-primary dark:text-primary-dark">分类标签</h2>
    <button type="button" onclick="document.getElementById('add-category-modal').classList.remove('hidden')" class="px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover dark:hover:bg-inverse-dark-hover transition-smooth btn-modern">+ 添加分类</button>
  </div>
  <div class="p-4">
    <% if @categories.any? %>
      <div class="space-y-8">
        <div>
          <h3 class="text-sm font-medium text-secondary dark:text-secondary-dark mb-3 uppercase tracking-wide">支出</h3>
          <div class="space-y-4">
            <% Category.roots.expense.order(:sort_order, :name).each do |root| %>
              <div class="bg-surface-inset dark:bg-surface-dark-inset rounded-xl p-4">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-xl bg-rose-500/10 dark:bg-rose-500/20 flex items-center justify-center">
                      <svg class="w-6 h-6 text-rose-600 dark:text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
                    </div>
                    <div>
                      <h4 class="font-semibold text-primary dark:text-primary-dark text-lg"><%= root.name %></h4>
                    </div>
                  </div>
                  <%= button_to category_path(root), method: :delete, 
                      onclick: "if(!confirm('确定删除该分类？')) return false",
                      class: "p-2 rounded-lg text-secondary dark:text-secondary-dark hover:bg-rose-100 hover:text-rose-600 dark:hover:bg-rose-900/50 transition-smooth",
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                  <% end %>
                </div>
                <% if root.children.any? %>
                  <div class="mt-4 pl-4 space-y-2 border-l-2 border-rose-500/30 dark:border-rose-500/40 ml-6">
                    <% root.children.order(:sort_order, :name).each do |child| %>
                      <div class="flex items-center justify-between py-2 px-3 bg-surface dark:bg-surface-dark rounded-lg">
                        <div class="flex items-center gap-3">
                          <div class="w-8 h-8 rounded-lg bg-rose-500/10 dark:bg-rose-500/20 flex items-center justify-center">
                            <svg class="w-4 h-4 text-rose-500 dark:text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
                          </div>
                          <span class="font-medium text-primary dark:text-primary-dark"><%= child.name %></span>
                        </div>
                        <%= button_to category_path(child), method: :delete, 
                            onclick: "if(!confirm('确定删除该分类？')) return false",
                            class: "p-1.5 rounded-lg text-secondary dark:text-secondary-dark hover:bg-rose-100 hover:text-rose-600 dark:hover:bg-rose-900/50 transition-smooth",
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>

        <div>
          <h3 class="text-sm font-medium text-secondary dark:text-secondary-dark mb-3 uppercase tracking-wide">收入</h3>
          <div class="space-y-4">
            <% Category.roots.income.order(:sort_order, :name).each do |root| %>
              <div class="bg-surface-inset dark:bg-surface-dark-inset rounded-xl p-4">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-xl bg-emerald-500/10 dark:bg-emerald-500/20 flex items-center justify-center">
                      <svg class="w-6 h-6 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
                    </div>
                    <div>
                      <h4 class="font-semibold text-primary dark:text-primary-dark text-lg"><%= root.name %></h4>
                    </div>
                  </div>
                  <%= button_to category_path(root), method: :delete, 
                      onclick: "if(!confirm('确定删除该分类？')) return false",
                      class: "p-2 rounded-lg text-secondary dark:text-secondary-dark hover:bg-rose-100 hover:text-rose-600 dark:hover:bg-rose-900/50 transition-smooth",
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                  <% end %>
                </div>
                <% if root.children.any? %>
                  <div class="mt-4 pl-4 space-y-2 border-l-2 border-emerald-500/30 dark:border-emerald-500/40 ml-6">
                    <% root.children.order(:sort_order, :name).each do |child| %>
                      <div class="flex items-center justify-between py-2 px-3 bg-surface dark:bg-surface-dark rounded-lg">
                        <div class="flex items-center gap-3">
                          <div class="w-8 h-8 rounded-lg bg-emerald-500/10 dark:bg-emerald-500/20 flex items-center justify-center">
                            <svg class="w-4 h-4 text-emerald-500 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
                          </div>
                          <span class="font-medium text-primary dark:text-primary-dark"><%= child.name %></span>
                        </div>
                        <%= button_to category_path(child), method: :delete, 
                            onclick: "if(!confirm('确定删除该分类？')) return false",
                            class: "p-1.5 rounded-lg text-secondary dark:text-secondary-dark hover:bg-rose-100 hover:text-rose-600 dark:hover:bg-rose-900/50 transition-smooth",
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="text-center py-8">
        <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-surface-inset dark:bg-surface-dark-inset flex items-center justify-center">
          <svg class="w-8 h-8 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
        </div>
        <p class="text-secondary dark:text-secondary-dark">暂无分类</p>
        <p class="text-sm text-secondary dark:text-secondary-dark mt-1">添加分类来更好地管理您的交易</p>
      </div>
    <% end %>
  </div>
</section>

<!-- Add Category Modal -->
<div id="add-category-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('add-category-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-lg shadow-xl w-full max-w-md p-6">
      <h3 class="text-lg font-semibold text-primary dark:text-primary-dark mb-4">添加分类</h3>
      <%= form_with model: Category.new, url: categories_path, method: :post, local: true do |f| %>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">分类名称</label>
            <%= render Ds::InputComponent.new(form: f, field: :name, placeholder: "例如：餐饮", required: true) %>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">类型</label>
            <%= render Ds::InputComponent.new(form: f, field: :category_type, type: :select, 
                  choices: [["支出", "EXPENSE"], ["收入", "INCOME"]],
                  include_blank: false,
                  html_class: "category-type-select") %>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">父分类（可选）</label>
            <%= render Ds::InputComponent.new(form: f, field: :parent_id, type: :select, 
                  choices: [["无", ""]] + Category.roots.expense.order(:sort_order, :name).pluck(:name, :id),
                  include_blank: false,
                  html_class: "parent-category-select") %>
          </div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="document.getElementById('add-category-modal').classList.add('hidden')" class="px-4 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">取消</button>
          <%= f.submit "添加", class: "px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover dark:hover:bg-inverse-dark-hover transition-smooth" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const typeSelect = document.querySelector('.category-type-select select');
  const parentSelect = document.querySelector('.parent-category-select select');
  
  const expenseParents = <%= raw Category.roots.expense.order(:sort_order, :name).pluck(:name, :id).to_json %>;
  const incomeParents = <%= raw Category.roots.income.order(:sort_order, :name).pluck(:name, :id).to_json %>;
  
  function updateParentOptions() {
    const selectedType = typeSelect.value;
    const parents = selectedType === 'INCOME' ? incomeParents : expenseParents;
    const options = [['无', ''], ...parents];
    
    parentSelect.innerHTML = options.map(o => `<option value="${o[1]}">${o[0]}</option>`).join('');
  }
  
  if (typeSelect && parentSelect) {
    typeSelect.addEventListener('change', updateParentOptions);
    updateParentOptions();
  }
});
</script>

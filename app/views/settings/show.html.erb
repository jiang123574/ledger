<div class="space-y-6">
  <h1 class="text-2xl font-bold text-gray-900"><%= t("settings.title") %></h1>

  <div class="bg-white rounded-lg shadow p-6 space-y-6">
    <div>
      <h3 class="font-medium text-lg mb-4"><%= t("settings.currency") %></h3>
      <table class="min-w-full">
        <thead>
          <tr>
            <th class="text-left"><%= t("settings.code") %></th>
            <th class="text-left"><%= t("settings.name") %></th>
            <th class="text-left"><%= t("settings.symbol") %></th>
            <th class="text-left"><%= t("settings.rate") %></th>
          </tr>
        </thead>
        <tbody>
          <% @currencies.each do |currency| %>
            <tr class="border-t">
              <td class="py-2"><%= currency.code %></td>
              <td class="py-2"><%= currency.name %></td>
              <td class="py-2"><%= currency.symbol %></td>
              <td class="py-2"><%= currency.exchange_rate %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <% if @currencies.empty? %>
        <p class="text-gray-500"><%= t("settings.no_currencies_configured") %></p>
      <% end %>
    </div>
  </div>
</div>

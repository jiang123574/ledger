<% content_for :title, t("nav.settings") %>

<% current_section = params[:section] || 'general' %>

<div class="flex gap-6 h-[calc(100vh-8rem)]">
  <!-- Left Sidebar -->
  <aside class="w-56 shrink-0">
    <div class="bg-container dark:bg-container dark:bg-container dark:bg-container dark:bg-container dark:bg-container dark:bg-container-dark-dark-dark-dark-dark-dark rounded-lg shadow-border-xs dark:shadow-dark-border-xs dark:shadow-dark-border-xs dark:shadow-dark-border-xs dark:shadow-dark-border-xs dark:shadow-dark-border-xs dark:shadow-dark-border-xs card-hover sticky top-20">
      <nav class="p-2 space-y-1">
        <a href="<%= settings_path(section: 'general') %>" class="settings-nav-item <%= current_section == 'general' ? 'active' : '' %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          <span>通用设置</span>
        </a>
        <a href="<%= settings_path(section: 'currencies') %>" class="settings-nav-item <%= current_section == 'currencies' ? 'active' : '' %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <span>货币设置</span>
        </a>
        <a href="<%= settings_path(section: 'categories') %>" class="settings-nav-item <%= current_section == 'categories' ? 'active' : '' %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
          <span>分类标签</span>
        </a>
        <a href="<%= settings_path(section: 'data') %>" class="settings-nav-item <%= current_section == 'data' ? 'active' : '' %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path></svg>
          <span>数据管理</span>
        </a>
        <a href="<%= settings_path(section: 'contacts') %>" class="settings-nav-item <%= current_section == 'contacts' ? 'active' : '' %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
          <span>联系人管理</span>
        </a>
        <a href="<%= settings_path(section: 'shortcuts') %>" class="settings-nav-item <%= current_section == 'shortcuts' ? 'active' : '' %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
          <span>快捷键</span>
        </a>
        <a href="<%= settings_path(section: 'danger') %>" class="settings-nav-item danger <%= current_section == 'danger' ? 'active' : '' %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
          <span>危险区域</span>
        </a>
      </nav>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="flex-1 overflow-y-auto">
    <% case current_section %>
    <% when 'general' %>
      <%= render "settings/general_content" %>
    <% when 'currencies' %>
      <%= render "settings/currencies_content" %>
    <% when 'categories' %>
      <%= render "settings/categories_content" %>
    <% when 'data' %>
      <%= render "settings/data_content" %>
    <% when 'contacts' %>
      <%= render "settings/contacts_content" %>
    <% when 'shortcuts' %>
      <%= render "settings/shortcuts_content" %>
    <% when 'danger' %>
      <%= render "settings/danger_content" %>
    <% else %>
      <%= render "settings/general_content" %>
    <% end %>
  </main>
</div>

<style>
  .settings-nav-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-secondary);
    transition: all 150ms ease;
  }
  .settings-nav-item:hover {
    background-color: var(--color-surface-hover);
    color: var(--color-primary);
  }
  .settings-nav-item.active {
    background-color: var(--color-surface-inset);
    color: var(--color-primary);
  }
  .settings-nav-item.danger {
    color: #dc2626;
  }
  .settings-nav-item.danger:hover,
  .settings-nav-item.danger.active {
    background-color: #fef2f2;
    color: #dc2626;
  }
  html.dark .settings-nav-item {
    color: var(--color-secondary-dark, #9ca3af);
  }
  html.dark .settings-nav-item:hover {
    background-color: var(--color-surface-dark-hover, #262626);
    color: var(--color-primary-dark, #f8f9fa);
  }
  html.dark .settings-nav-item.active {
    background-color: var(--color-surface-dark-inset, #262626);
    color: var(--color-primary-dark, #f8f9fa);
  }
  html.dark .settings-nav-item.danger {
    color: #ef4444;
  }
  html.dark .settings-nav-item.danger:hover,
  html.dark .settings-nav-item.danger.active {
    background-color: rgba(239, 68, 68, 0.15);
    color: #ef4444;
  }
</style>

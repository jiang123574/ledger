<section class="bg-container dark:bg-container-dark rounded-lg shadow-border-xs dark:shadow-dark-border-xs card-hover border border-red-200 dark:border-red-800">
  <div class="p-4 border-b border-red-200 dark:border-red-800">
    <h2 class="text-lg font-semibold text-red-600 dark:text-red-400">危险操作</h2>
    <p class="text-sm text-secondary dark:text-secondary-dark mt-1">以下操作不可逆，请谨慎操作</p>
  </div>
  <div class="p-4 space-y-4">
    <div class="py-3 border-b border-red-100 dark:border-red-900/30">
      <div class="mb-3">
        <h3 class="font-medium text-primary dark:text-primary-dark">清除所有数据</h3>
        <p class="text-sm text-secondary dark:text-secondary-dark">删除所有交易、账户和分类数据</p>
      </div>
      <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-3">
        <p class="text-xs text-red-700 dark:text-red-400 mb-3">⚠️ 此操作将删除所有数据且不可恢复，请输入确认密码</p>
        <%= form_with url: clear_all_data_path, method: :post, local: true,
              data: {
                controller: "loading-button",
                action: "submit->loading-button#showLoading",
                loading_button_loading_text_value: "清除中..."
              } do |f| %>
          <div class="flex items-center gap-3">
            <%= f.password_field :confirm_password, placeholder: "输入确认密码", class: "flex-1 text-sm text-primary dark:text-primary-dark border border-red-300 dark:border-red-700 rounded-lg p-2 bg-white dark:bg-container-dark", required: true %>
            <%= f.submit "清除数据", class: "px-4 py-1.5 text-sm font-medium rounded-lg bg-red-600 text-white hover:bg-red-700 transition-smooth btn-modern",
                data: {
                  loading_button_target: "button",
                  controller: "confirm-form",
                  action: "click->confirm-form#confirm",
                  confirm_form_title_value: "确认清除",
                  confirm_form_content_value: "确定要清除所有数据吗？此操作不可恢复！",
                  confirm_form_confirm_text_value: "清除",
                  confirm_form_danger_value: true
                } %>
          </div>
        <% end %>
      </div>
    </div>
    <div class="flex items-center justify-between py-3">
      <div>
        <h3 class="font-medium text-primary dark:text-primary-dark">重置应用</h3>
        <p class="text-sm text-secondary dark:text-secondary-dark">恢复所有设置为默认值</p>
      </div>
      <button class="px-4 py-1.5 text-sm font-medium rounded-lg bg-red-100 dark:bg-red-900/20 text-red-600 dark:text-red-400 hover:bg-red-200 dark:hover:bg-red-900/30 transition-smooth btn-modern">重置</button>
    </div>
  </div>
</section>

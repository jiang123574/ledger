<section class="bg-container dark:bg-container-dark rounded-lg shadow-border-xs dark:shadow-dark-border-xs card-hover">
  <div class="p-4 border-b border-border dark:border-border-dark flex items-center justify-between">
    <div>
      <h2 class="text-lg font-semibold text-primary dark:text-primary-dark">联系人管理</h2>
      <p class="text-sm text-secondary dark:text-secondary-dark mt-1">管理与你有资金往来的人或机构</p>
    </div>
    <button type="button" onclick="document.getElementById('add-counterparty-modal').classList.remove('hidden')" class="px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover dark:hover:bg-inverse-dark-hover transition-smooth btn-modern">+ 新建联系人</button>
  </div>
  
  <!-- Stats -->
  <% if @counterparties.any? %>
    <div class="p-4 border-b border-border dark:border-border-dark">
      <div class="grid grid-cols-3 gap-4">
        <div class="text-center">
          <div class="text-2xl font-bold text-primary dark:text-primary-dark"><%= @counterparties.size %></div>
          <div class="text-xs text-secondary dark:text-secondary-dark">联系人总数</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-primary dark:text-primary-dark"><%= @counterparties.select { |c| c.respond_to?(:receivables_count) && c.receivables_count > 0 }.size %></div>
          <div class="text-xs text-secondary dark:text-secondary-dark">关联应收款</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-emerald-600 dark:text-emerald-400"><%= @counterparties.select { |c| c.respond_to?(:receivables_count) && c.receivables_count > 0 }.size %></div>
          <div class="text-xs text-secondary dark:text-secondary-dark">有往来对象</div>
        </div>
      </div>
    </div>
  <% end %>

  <% if @counterparties.empty? %>
    <div class="p-8 text-center">
      <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-surface-inset dark:bg-surface-dark-inset flex items-center justify-center">
        <svg class="w-8 h-8 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
      </div>
      <p class="text-secondary dark:text-secondary-dark">暂无联系人</p>
      <p class="text-sm text-secondary dark:text-secondary-dark mt-1">添加常往来的人或机构，方便统计和管理</p>
      <button type="button" onclick="document.getElementById('add-counterparty-modal').classList.remove('hidden')" class="inline-block mt-4 px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover dark:hover:bg-inverse-dark-hover transition-smooth btn-modern">添加第一个联系人</button>
    </div>
  <% else %>
    <div class="overflow-x-auto">
      <table class="min-w-full">
        <thead class="bg-surface-inset dark:bg-surface-dark-inset">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-secondary dark:text-secondary-dark uppercase">名称</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-secondary dark:text-secondary-dark uppercase">联系方式</th>
            <th class="px-4 py-3 text-center text-xs font-medium text-secondary dark:text-secondary-dark uppercase">应收款</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-secondary dark:text-secondary-dark uppercase">操作</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border dark:divide-border-dark">
          <% @counterparties.each do |counterparty| %>
            <tr class="hover:bg-surface-hover dark:hover:bg-surface-dark-hover">
              <td class="px-4 py-3">
                <div class="font-medium text-primary dark:text-primary-dark"><%= counterparty.name %></div>
                <% if counterparty.note.present? %>
                  <div class="text-xs text-secondary dark:text-secondary-dark"><%= truncate(counterparty.note, length: 40) %></div>
                <% end %>
              </td>
              <td class="px-4 py-3 text-sm text-secondary dark:text-secondary-dark">
                <%= counterparty.contact.presence || '-' %>
              </td>
              <td class="px-4 py-3 text-center">
                <% if counterparty.respond_to?(:receivables_count) && counterparty.receivables_count > 0 %>
                  <span class="px-2 py-1 rounded-full text-xs bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark">
                    <%= counterparty.receivables_count %> 笔
                  </span>
                <% else %>
                  <span class="text-secondary dark:text-secondary-dark text-xs">-</span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-right text-sm">
                <button type="button" onclick="openEditModal(<%= counterparty.id %>, '<%= j counterparty.name %>', '<%= j counterparty.contact || '' %>', '<%= j counterparty.note || '' %>')" class="px-3 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth btn-modern">编辑</button>
                <button type="button" onclick="openDeleteModal(<%= counterparty.id %>, '<%= j counterparty.name %>')" class="px-3 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-red-600 dark:text-red-400 hover:bg-red-100 dark:hover:bg-red-900/20 transition-smooth btn-modern ml-2">删除</button>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</section>

<!-- Edit Counterparty Modal -->
<div id="edit-counterparty-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('edit-counterparty-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-lg shadow-xl w-full max-w-md p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-primary dark:text-primary-dark">编辑联系人</h3>
        <button type="button" onclick="document.getElementById('edit-counterparty-modal').classList.add('hidden')" class="p-1 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <%= form_with url: counterparty_path(0), method: :put, local: true, id: "edit-counterparty-form" do |f| %>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">名称 *</label>
            <%= render Ds::InputComponent.new(form: f, field: :name, placeholder: "输入联系人名称", required: true, id: "edit-counterparty-name") %>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">联系方式</label>
            <%= render Ds::InputComponent.new(form: f, field: :contact, placeholder: "电话或邮箱", id: "edit-counterparty-contact") %>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">备注</label>
            <%= render Ds::InputComponent.new(form: f, field: :note, type: :textarea, placeholder: "备注信息", id: "edit-counterparty-note") %>
          </div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="document.getElementById('edit-counterparty-modal').classList.add('hidden')" class="px-4 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">取消</button>
          <%= f.submit "保存", class: "px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover dark:hover:bg-inverse-dark-hover transition-smooth" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Delete Counterparty Modal -->
<div id="delete-counterparty-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('delete-counterparty-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-lg shadow-xl w-full max-w-sm p-6">
      <div class="text-center">
        <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-red-100 dark:bg-red-900/30 mb-4">
          <svg class="h-6 w-6 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
        </div>
        <h3 class="text-lg font-medium text-primary dark:text-primary-dark mb-2">删除联系人</h3>
        <p class="text-sm text-secondary dark:text-secondary-dark mb-6">确定要删除联系人 "<span id="delete-counterparty-name" class="font-medium"></span>" 吗？此操作不可恢复。</p>
        <div class="flex justify-center gap-3">
          <button type="button" onclick="document.getElementById('delete-counterparty-modal').classList.add('hidden')" class="px-4 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">取消</button>
          <%= button_to "删除", counterparty_path(0), method: :delete, id: "delete-counterparty-btn", class: "px-4 py-2 text-sm font-medium rounded-lg bg-red-600 text-white hover:bg-red-700 transition-smooth" %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Add Counterparty Modal -->
<div id="add-counterparty-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('add-counterparty-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-lg shadow-xl w-full max-w-md p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-primary dark:text-primary-dark">新建联系人</h3>
        <button type="button" onclick="document.getElementById('add-counterparty-modal').classList.add('hidden')" class="p-1 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <%= form_with model: Counterparty.new, url: counterparties_path, method: :post, local: true do |f| %>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">名称 *</label>
            <%= render Ds::InputComponent.new(form: f, field: :name, placeholder: "输入联系人名称", required: true) %>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">联系方式</label>
            <%= render Ds::InputComponent.new(form: f, field: :contact, placeholder: "电话或邮箱") %>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">备注</label>
            <%= render Ds::InputComponent.new(form: f, field: :note, type: :textarea, placeholder: "备注信息") %>
          </div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="document.getElementById('add-counterparty-modal').classList.add('hidden')" class="px-4 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">取消</button>
          <%= f.submit "创建", class: "px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover dark:hover:bg-inverse-dark-hover transition-smooth" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
function openEditModal(id, name, contact, note) {
  document.getElementById('edit-counterparty-name').value = name;
  document.getElementById('edit-counterparty-contact').value = contact;
  document.getElementById('edit-counterparty-note').value = note;
  document.getElementById('edit-counterparty-form').action = '/counterparties/' + id;
  document.getElementById('edit-counterparty-modal').classList.remove('hidden');
}

function openDeleteModal(id, name) {
  document.getElementById('delete-counterparty-name').textContent = name;
  document.getElementById('delete-counterparty-btn').onclick = function() {
    fetch('/counterparties/' + id, {
      method: 'DELETE',
      headers: {
        'X-Requested-With': 'XMLHttpRequest',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
      }
    }).then(response => {
      if (response.ok) {
        window.location.reload();
      }
    });
  };
  document.getElementById('delete-counterparty-modal').classList.remove('hidden');
}
</script>

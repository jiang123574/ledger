<section class="bg-container rounded-lg shadow-border-xs card-hover">
  <div class="p-4 border-b border-border flex items-center justify-between">
    <div>
      <h2 class="text-lg font-semibold text-primary">联系人管理</h2>
      <p class="text-sm text-secondary mt-1">管理与你有资金往来的人或机构</p>
    </div>
    <button type="button" onclick="document.getElementById('add-counterparty-modal').classList.remove('hidden')" class="px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth btn-modern">+ 新建联系人</button>
  </div>
  
  <!-- Stats -->
  <div class="p-4 border-b border-border">
    <div class="grid grid-cols-3 gap-4">
      <div class="text-center">
        <div class="text-2xl font-bold text-primary"><%= @counterparties.size %></div>
        <div class="text-xs text-secondary">联系人总数</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-inverse"><%= @counterparties.select { |c| c.respond_to?(:receivables_count) && c.receivables_count > 0 }.size %></div>
        <div class="text-xs text-secondary">关联应收款</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-emerald-600"><%= @counterparties.select { |c| c.respond_to?(:receivables_count) && c.receivables_count > 0 }.size %></div>
        <div class="text-xs text-secondary">有往来对象</div>
      </div>
    </div>
  </div>

  <% if @counterparties.empty? %>
    <div class="p-8 text-center">
      <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-surface-inset flex items-center justify-center">
        <svg class="w-8 h-8 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
      </div>
      <p class="text-secondary">暂无联系人</p>
      <p class="text-sm text-secondary mt-1">添加常往来的人或机构，方便统计和管理</p>
      <button type="button" onclick="document.getElementById('add-counterparty-modal').classList.remove('hidden')" class="inline-block mt-4 px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth btn-modern">添加第一个联系人</button>
    </div>
  <% else %>
    <div class="overflow-x-auto">
      <table class="min-w-full">
        <thead class="bg-surface-inset dark:bg-gray-800">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-secondary uppercase">名称</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-secondary uppercase">联系方式</th>
            <th class="px-4 py-3 text-center text-xs font-medium text-secondary uppercase">应收款</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-secondary uppercase">操作</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          <% @counterparties.each do |counterparty| %>
            <tr class="hover:bg-surface-hover">
              <td class="px-4 py-3">
                <div class="font-medium text-primary"><%= counterparty.name %></div>
                <% if counterparty.note.present? %>
                  <div class="text-xs text-secondary"><%= truncate(counterparty.note, length: 40) %></div>
                <% end %>
              </td>
              <td class="px-4 py-3 text-sm text-secondary">
                <%= counterparty.contact.presence || '-' %>
              </td>
              <td class="px-4 py-3 text-center">
                <% if counterparty.respond_to?(:receivables_count) && counterparty.receivables_count > 0 %>
                  <span class="px-2 py-1 rounded-full text-xs bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300">
                    <%= counterparty.receivables_count %> 笔
                  </span>
                <% else %>
                  <span class="text-gray-400 text-xs">-</span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-right text-sm">
                <%= link_to "编辑", edit_counterparty_path(counterparty), class: "px-3 py-1.5 text-sm font-medium rounded-lg border border-border text-primary hover:bg-surface-hover transition-smooth btn-modern" %>
                <%= button_to "删除", counterparty_path(counterparty), method: :delete, 
                    data: { turbo_confirm: "确定删除该联系人？" }, 
                    class: "px-3 py-1.5 text-sm font-medium rounded-lg bg-red-100 text-red-600 hover:bg-red-200 transition-smooth btn-modern ml-2" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</section>

<!-- Add Counterparty Modal -->
<div id="add-counterparty-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('add-counterparty-modal').classList.add('hidden')"></div>
    <div class="relative bg-container rounded-lg shadow-xl w-full max-w-md p-6">
      <h3 class="text-lg font-semibold text-primary mb-4">新建联系人</h3>
      <%= form_with model: Counterparty.new, url: counterparties_path, method: :post, local: true do |f| %>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-secondary mb-1">名称 *</label>
            <%= f.text_field :name, placeholder: "输入联系人名称", class: "w-full px-3 py-2 text-sm rounded-lg border border-border focus:ring-blue-500 focus:border-blue-500", required: true %>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary mb-1">联系方式</label>
            <%= f.text_field :contact, placeholder: "电话或邮箱", class: "w-full px-3 py-2 text-sm rounded-lg border border-border focus:ring-blue-500 focus:border-blue-500" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary mb-1">备注</label>
            <%= f.text_area :note, placeholder: "备注信息", rows: 3, class: "w-full px-3 py-2 text-sm rounded-lg border border-border focus:ring-blue-500 focus:border-blue-500" %>
          </div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="document.getElementById('add-counterparty-modal').classList.add('hidden')" class="px-4 py-2 text-sm font-medium rounded-lg border border-border text-primary hover:bg-surface-hover transition-smooth">取消</button>
          <%= f.submit "创建", class: "px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

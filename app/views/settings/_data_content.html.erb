<% if flash[:warning] %>
  <div class="bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 text-yellow-800 dark:text-yellow-400 rounded-lg p-4 mb-6">
    <p class="font-medium"><%= flash[:warning] %></p>
    <% if flash[:import_errors].present? %>
      <ul class="mt-2 text-sm list-disc list-inside">
        <% flash[:import_errors].first(10).each do |error| %>
          <li><%= error %></li>
        <% end %>
        <% if flash[:import_errors].size > 10 %>
          <li>... 还有 <%= flash[:import_errors].size - 10 %> 个错误</li>
        <% end %>
      </ul>
    <% end %>
  </div>
<% end %>

<section class="bg-container dark:bg-container-dark rounded-lg shadow-border-xs dark:shadow-dark-border-xs card-hover">
  <div class="p-4 border-b border-border dark:border-border-dark">
    <h2 class="text-lg font-semibold text-primary dark:text-primary-dark">导入、导出和备份</h2>
    <p class="text-sm text-secondary dark:text-secondary-dark mt-1">管理您的数据</p>
  </div>
  <div class="p-4 space-y-4">
    <div class="flex items-center justify-between py-3 border-b border-border dark:border-border-dark">
      <div>
        <h3 class="font-medium text-primary dark:text-primary-dark">导出数据</h3>
        <p class="text-sm text-secondary dark:text-secondary-dark">下载所有交易记录为 CSV 文件</p>
      </div>
      <%= button_to "导出 CSV", export_transactions_path, method: :post, class: "px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth btn-modern" %>
    </div>
    
    <div class="py-3 border-b border-border dark:border-border-dark">
      <div class="flex items-start justify-between mb-3">
        <div>
          <h3 class="font-medium text-primary dark:text-primary-dark">导入数据</h3>
          <p class="text-sm text-secondary dark:text-secondary-dark">从 CSV 文件导入交易记录</p>
        </div>
      </div>
      <div class="space-y-3">
        <!-- 贔貅导入 -->
        <div class="bg-surface-inset dark:bg-surface-dark-inset rounded-lg p-3">
          <p class="text-sm font-medium text-primary dark:text-primary-dark mb-2">🐷 贔貅记账导入</p>
          <p class="text-xs text-secondary dark:text-secondary-dark mb-3">导入贔貅记账的交易流水（支持转账、自动映射账户和分类）</p>
          <button type="button" onclick="document.getElementById('pixiu-import-modal').classList.remove('hidden')" class="inline-block px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth btn-modern">
            开始导入
          </button>
        </div>
        
        <!-- 通用 CSV 导入 -->
        <div>
          <p class="text-sm font-medium text-primary dark:text-primary-dark mb-2">通用 CSV 导入</p>
          <%= form_with url: import_transactions_path, method: :post, local: true, multipart: true,
                data: {
                  controller: "loading-button",
                  action: "submit->loading-button#showLoading",
                  loading_button_loading_text_value: "导入中..."
                } do |f| %>
            <div class="flex items-center gap-3">
              <%= f.file_field :file, accept: ".csv", class: "text-sm text-primary dark:text-primary-dark border border-border dark:border-border-dark rounded-lg p-2 bg-white dark:bg-container-dark", required: true %>
              <%= f.submit "导入", class: "px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth btn-modern", data: { loading_button_target: "button" } %>
            </div>
            <p class="text-xs text-secondary dark:text-secondary-dark mt-2">
              CSV 格式：日期, 类型(收入/支出), 金额, 账户, 分类, 目标账户, 备注
            </p>
          <% end %>
        </div>
      </div>
    </div>
    
    <div class="py-3">
      <div class="flex items-center justify-between mb-3">
        <div>
          <h3 class="font-medium text-primary dark:text-primary-dark">数据库备份</h3>
          <p class="text-sm text-secondary dark:text-secondary-dark">创建完整的数据库备份</p>
        </div>
        <%= button_to "创建备份", create_backup_path, method: :post,
            class: "px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth btn-modern",
            data: { loading_button_target: "button" },
            form: {
              data: {
                controller: "loading-button",
                action: "submit->loading-button#showLoading",
                loading_button_loading_text_value: "创建中..."
              }
            } %>
      </div>
      <% if @backups.any? %>
        <div class="bg-surface-inset dark:bg-surface-dark-inset rounded-lg p-3">
          <p class="text-xs font-medium text-secondary dark:text-secondary-dark mb-2">最近的备份：</p>
          <ul class="space-y-1">
            <% @backups.each do |backup| %>
              <li class="flex items-center justify-between text-sm">
                <span class="text-secondary dark:text-secondary-dark">
                  <%= backup[:name] %> (<%= number_to_human_size(backup[:size]) %>)
                </span>
                <%= link_to "下载", download_settings_backup_path(backup[:name]), class: "text-primary dark:text-primary-dark hover:text-secondary dark:text-secondary-dark dark:hover:text-secondary dark:text-secondary-dark" %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- 贔貅导入弹窗 -->
<div id="pixiu-import-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('pixiu-import-modal').classList.add('hidden')"></div>
  
  <div class="flex items-center justify-center min-h-screen p-4">
    <div class="relative bg-container dark:bg-container-dark rounded-xl shadow-xl w-full max-w-2xl p-8">
      <!-- 关闭按钮 -->
      <button type="button" onclick="document.getElementById('pixiu-import-modal').classList.add('hidden')" class="absolute top-4 right-4 p-2 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-colors">
        <svg class="w-6 h-6 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>

      <!-- 标题 -->
      <div class="mb-6">
        <h2 class="text-2xl font-bold text-primary dark:text-primary-dark mb-2">
          🐷 贔貅记账导入
        </h2>
        <p class="text-secondary dark:text-secondary-dark">
          导入贔貅记账的交易流水，自动识别账户和分类，支持转账双向记录
        </p>
      </div>

      <!-- 上传区域 -->
      <div class="mb-6">
        <div class="border-2 border-dashed border-border dark:border-border-dark rounded-lg p-8 text-center hover:border-inverse transition-colors cursor-pointer" id="pixiu-drop-zone">
          <div class="text-4xl mb-4">📁</div>
          <p class="text-primary dark:text-primary-dark font-medium mb-2">
            拖拽文件到此处或点击选择
          </p>
          <p class="text-sm text-secondary dark:text-secondary-dark mb-4">
            支持 CSV 格式，文件大小 &lt; 50MB
          </p>
          <input type="file" id="pixiu-file-input" accept=".csv" class="hidden" onchange="pixiuFileSelected(this)">
          <button type="button" class="px-4 py-2 bg-inverse text-white rounded-lg hover:bg-inverse-hover transition-colors" onclick="document.getElementById('pixiu-file-input').click()">
            选择文件
          </button>
        </div>

        <div id="pixiu-file-info" class="mt-4 hidden">
          <div class="bg-green-100 dark:bg-green-900/20 border border-green-300 dark:border-green-700 rounded-lg p-4">
            <p class="text-sm text-green-700 dark:text-green-300">
              ✅ 已选择：<span id="pixiu-file-name" class="font-medium"></span>
            </p>
          </div>
        </div>
      </div>

      <!-- 说明 -->
      <div class="bg-surface-inset dark:bg-surface-dark-inset rounded-lg p-4 mb-6">
        <p class="text-sm font-medium text-primary dark:text-primary-dark mb-2">📋 文件要求：</p>
        <ul class="text-sm text-secondary dark:text-secondary-dark space-y-1 ml-4">
          <li>✓ CSV 格式（.csv）</li>
          <li>✓ 编码：UTF-8</li>
          <li>✓ 包含列：日期、收支大类、交易分类、交易类型、流入金额、流出金额、币种、资金账户、标签、备注</li>
          <li>✓ 文件大小 &lt; 50MB</li>
        </ul>
      </div>

      <!-- 按钮 -->
      <div class="flex gap-4">
        <button type="button" onclick="document.getElementById('pixiu-import-modal').classList.add('hidden')" class="flex-1 px-4 py-2 border border-border dark:border-border-dark text-primary dark:text-primary-dark rounded-lg hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-colors font-medium">
          取消
        </button>
        <button type="button" id="pixiu-submit-btn" onclick="submitPixiuImport()" class="flex-1 px-4 py-2 bg-inverse text-white rounded-lg hover:bg-inverse-hover transition-colors font-medium disabled:opacity-50 disabled:cursor-not-allowed" disabled>
          下一步
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  function pixiuFileSelected(input) {
    if (!input.files || input.files.length === 0) return;
    const name = input.files[0].name;
    document.getElementById('pixiu-file-name').textContent = name;
    document.getElementById('pixiu-file-info').classList.remove('hidden');
    document.getElementById('pixiu-submit-btn').disabled = false;
  }

  // 拖拽支持
  document.addEventListener('dragover', function(e) {
    const dz = document.getElementById('pixiu-drop-zone');
    if (dz && dz.contains(e.target)) {
      e.preventDefault();
      dz.classList.add('border-inverse', 'bg-surface-inset');
    }
  });
  document.addEventListener('dragleave', function(e) {
    const dz = document.getElementById('pixiu-drop-zone');
    if (dz && !dz.contains(e.relatedTarget)) {
      dz.classList.remove('border-inverse', 'bg-surface-inset');
    }
  });
  document.addEventListener('drop', function(e) {
    const dz = document.getElementById('pixiu-drop-zone');
    if (dz && dz.contains(e.target)) {
      e.preventDefault();
      dz.classList.remove('border-inverse', 'bg-surface-inset');
      const files = e.dataTransfer.files;
      if (files.length > 0) {
        const input = document.getElementById('pixiu-file-input');
        // DataTransfer 赋值
        const dt = new DataTransfer();
        dt.items.add(files[0]);
        input.files = dt.files;
        pixiuFileSelected(input);
      }
    }
  });

  function submitPixiuImport() {
    const input = document.getElementById('pixiu-file-input');
    if (!input || input.files.length === 0) {
      alert('请先选择文件');
      return;
    }

    const btn = document.getElementById('pixiu-submit-btn');
    const formData = new FormData();
    formData.append('file', input.files[0]);

    btn.disabled = true;
    btn.textContent = '上传中...';

    fetch('<%= pixiu_upload_imports_path %>', {
      method: 'POST',
      body: formData,
      headers: {
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
        'Accept': 'text/html'
      }
    })
    .then(res => {
      if (res.redirected) {
        window.location.href = res.url;
      } else if (res.ok) {
        window.location.href = '<%= pixiu_imports_path %>';
      } else {
        return res.text().then(t => { throw new Error(t); });
      }
    })
    .catch(err => {
      console.error(err);
      alert('上传失败，请重试');
      btn.disabled = false;
      btn.textContent = '下一步';
    });
  }
</script>

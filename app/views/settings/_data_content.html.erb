<% if flash[:warning] %>
  <div class="bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 text-yellow-800 dark:text-yellow-400 rounded-lg p-4 mb-6">
    <p class="font-medium"><%= flash[:warning] %></p>
    <% if flash[:import_errors].present? %>
      <ul class="mt-2 text-sm list-disc list-inside">
        <% flash[:import_errors].first(10).each do |error| %>
          <li><%= error %></li>
        <% end %>
        <% if flash[:import_errors].size > 10 %>
          <li>... 还有 <%= flash[:import_errors].size - 10 %> 个错误</li>
        <% end %>
      </ul>
    <% end %>
  </div>
<% end %>

<section class="bg-container dark:bg-container-dark rounded-lg shadow-border-xs dark:shadow-dark-border-xs card-hover">
  <div class="p-4 border-b border-border dark:border-border-dark">
    <h2 class="text-lg font-semibold text-primary dark:text-primary-dark">导入、导出和备份</h2>
    <p class="text-sm text-secondary dark:text-secondary-dark mt-1">管理您的数据</p>
  </div>
  <div class="p-4 space-y-4">
    <div class="flex items-center justify-between py-3 border-b border-border dark:border-border-dark">
      <div>
        <h3 class="font-medium text-primary dark:text-primary-dark">导出数据</h3>
        <p class="text-sm text-secondary dark:text-secondary-dark">下载所有交易记录为 CSV 文件</p>
      </div>
      <%= button_to "导出 CSV", export_transactions_path, method: :post, class: "px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth btn-modern" %>
    </div>
    
    <div class="py-3 border-b border-border dark:border-border-dark">
      <div class="flex items-start justify-between mb-3">
        <div>
          <h3 class="font-medium text-primary dark:text-primary-dark">导入数据</h3>
          <p class="text-sm text-secondary dark:text-secondary-dark">从 CSV 文件导入交易记录</p>
        </div>
      </div>
      <%= form_with url: import_transactions_path, method: :post, local: true, multipart: true,
            data: {
              controller: "loading-button",
              action: "submit->loading-button#showLoading",
              loading_button_loading_text_value: "导入中..."
            } do |f| %>
        <div class="flex items-center gap-3">
          <%= f.file_field :file, accept: ".csv", class: "text-sm text-primary dark:text-primary-dark border border-border dark:border-border-dark rounded-lg p-2 bg-white dark:bg-container-dark", required: true %>
          <%= f.submit "导入", class: "px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth btn-modern", data: { loading_button_target: "button" } %>
        </div>
        <p class="text-xs text-secondary dark:text-secondary-dark mt-2">
          CSV 格式：日期, 类型(收入/支出), 金额, 账户, 分类, 目标账户, 备注
        </p>
      <% end %>
    </div>
    
    <div class="py-3">
      <div class="flex items-center justify-between mb-3">
        <div>
          <h3 class="font-medium text-primary dark:text-primary-dark">数据库备份</h3>
          <p class="text-sm text-secondary dark:text-secondary-dark">创建完整的数据库备份</p>
        </div>
        <%= button_to "创建备份", create_backup_path, method: :post,
            class: "px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth btn-modern",
            data: { loading_button_target: "button" },
            form: {
              data: {
                controller: "loading-button",
                action: "submit->loading-button#showLoading",
                loading_button_loading_text_value: "创建中..."
              }
            } %>
      </div>
      <% if @backups.any? %>
        <div class="bg-surface-inset dark:bg-surface-dark-inset rounded-lg p-3">
          <p class="text-xs font-medium text-secondary dark:text-secondary-dark mb-2">最近的备份：</p>
          <ul class="space-y-1">
            <% @backups.each do |backup| %>
              <li class="flex items-center justify-between text-sm">
                <span class="text-secondary dark:text-secondary-dark">
                  <%= backup[:name] %> (<%= number_to_human_size(backup[:size]) %>)
                </span>
                <%= link_to "下载", download_settings_backup_path(backup[:name]), class: "text-primary dark:text-primary-dark hover:text-secondary dark:hover:text-secondary-dark" %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  </div>
</section>

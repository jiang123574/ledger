<div class="group">
  <div class="bg-container dark:bg-container-dark rounded-lg shadow-border-xs dark:shadow-dark-border-xs <%= 'ml-8' if level > 0 %>">
    <div class="p-3 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-full <%= category.type == "INCOME" ? "bg-income/10" : "bg-expense/10" %> flex items-center justify-center">
          <% if category.children.any? %>
            <svg class="w-4 h-4 <%= category.type == "INCOME" ? "text-income" : "text-expense" %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path></svg>
          <% else %>
            <svg class="w-4 h-4 <%= category.type == "INCOME" ? "text-income" : "text-expense" %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
          <% end %>
        </div>
        <div>
          <h3 class="font-medium text-primary dark:text-primary-dark text-sm">
            <%= category.name %>
            <% if level > 0 %>
              <span class="text-xs text-secondary dark:text-secondary-dark ml-1">→ <%= category.parent.name %></span>
            <% end %>
          </h3>
          <div class="flex items-center gap-2">
            <% if category.children.any? %>
              <span class="text-xs text-secondary dark:text-secondary-dark"><%= category.children.count %> 个子分类</span>
            <% end %>
          </div>
        </div>
      </div>
      <div class="flex items-center gap-1">
        <button onclick="openEditCategoryModal(<%= category.id %>, '<%= j category.name %>', '<%= category.type %>', <%= category.parent_id || 'null' %>)" 
                class="p-1.5 rounded-lg hover:bg-surface-hover dark:hover:bg-surface-dark-hover text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark transition-smooth opacity-0 group-hover:opacity-100">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
        </button>
        <button onclick="openDeleteCategoryModal(<%= category.id %>, '<%= j category.name %>', <%= category.children.any? %>)"
                class="p-1.5 rounded-lg hover:bg-red-100 dark:hover:bg-red-900/30 text-secondary dark:text-secondary-dark hover:text-red-600 dark:hover:text-red-400 transition-smooth opacity-0 group-hover:opacity-100">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
        </button>
      </div>
    </div>
  </div>
  
  <% if category.children.any? %>
    <div class="mt-1 space-y-1">
      <% category.children.order(:sort_order, :name).each do |child| %>
        <%= render partial: "categories/category_tree", locals: { category: child, level: level + 1 } %>
      <% end %>
    </div>
  <% end %>
</div>

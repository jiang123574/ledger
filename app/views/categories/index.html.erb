<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h1 class="text-2xl font-bold text-gray-900"><%= t("categories.title") %></h1>
  </div>

  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="p-4 border-b">
      <h3 class="font-medium"><%= t("categories.add_new_category") %></h3>
      <%= form_with model: @category, local: true, class: "flex gap-4 mt-2" do |f| %>
        <%= f.text_field :name, placeholder: t("categories.category_name"), class: "border rounded px-3 py-2 flex-1" %>
        <%= f.text_field :type, placeholder: "EXPENSE/INCOME", class: "border rounded px-3 py-2 w-32" %>
        <%= f.submit t("categories.add"), class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
      <% end %>
    </div>

    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t("accounts.name") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t("transactions.type") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t("categories.parent") %></th>
          <th class="px-6 py-3 actions"></th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @categories.each do |category| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap font-medium"><%= category.name %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm"><%= category.type || "-" %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm"><%= category.parent&.name || "-" %></td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
              <%= link_to t("categories.delete"), category, method: :delete, data: { confirm: t("categories.are_you_sure") }, class: "text-red-600 hover:text-red-900" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @categories.empty? %>
      <div class="p-8 text-center text-gray-500">
        <%= t("categories.no_categories_yet") %>
      </div>
    <% end %>
  </div>
</div>

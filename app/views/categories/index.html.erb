<div class="space-y-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
    <h1 class="text-2xl font-semibold text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark"><%= t("categories.title") %></h1>
  </div>

  <!-- Add Category Form -->
  <div class="bg-container dark:bg-container dark:bg-container-dark-dark rounded-lg shadow-border-xs dark:shadow-dark-border-xs dark:shadow-dark-border-xs p-6">
    <h3 class="font-medium text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark mb-4"><%= t("categories.add_new_category") %></h3>
    <%= form_with model: @category, local: true, class: "flex flex-wrap gap-4 items-end" do |f| %>
      <div class="flex-1 min-w-[200px]">
        <label class="block text-sm font-medium text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark mb-1"><%= t("categories.category_name") %></label>
        <%= f.text_field :name, placeholder: "例如：餐饮", class: "w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border dark:border-border-dark-dark bg-white dark:bg-container-dark text-primary dark:text-primary dark:text-primary-dark-dark focus:ring-blue-500 dark:focus:ring-blue-400 focus:border-blue-500 dark:focus:border-blue-500" %>
      </div>
      <div class="w-40">
        <label class="block text-sm font-medium text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark mb-1">类型</label>
        <%= f.select :type, options_for_select([["支出", "EXPENSE"], ["收入", "INCOME"]]), {}, 
            class: "w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border dark:border-border-dark-dark bg-white dark:bg-container-dark text-primary dark:text-primary dark:text-primary-dark-dark focus:ring-blue-500 dark:focus:ring-blue-400 focus:border-blue-500 dark:focus:border-blue-500" %>
      </div>
      <div>
        <%= submit_tag t("categories.add"), class: "px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover dark:hover:bg-inverse-dark-hover transition-smooth btn-modern" %>
      </div>
    <% end %>
  </div>

  <!-- Categories List -->
  <% if @categories.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @categories.each do |category| %>
        <div class="group">
          <div class="bg-container dark:bg-container dark:bg-container-dark-dark rounded-lg shadow-border-xs dark:shadow-dark-border-xs dark:shadow-dark-border-xs">
            <div class="p-4 flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full <%= category.type == "INCOME" ? "bg-income/10" : "bg-expense/10" %> flex items-center justify-center">
                  <svg class="w-5 h-5 <%= category.type == "INCOME" ? "text-income dark:text-income" : "text-expense dark:text-expense" %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
                </div>
                <div>
                  <h3 class="font-medium text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark"><%= category.name %></h3>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= category.type == "INCOME" ? "bg-income/10 text-income" : "bg-expense/10 text-expense" %>">
                    <%= category.type == "INCOME" ? "收入" : "支出" %>
                  </span>
                </div>
              </div>
              <%= button_to category, method: :delete, 
                  data: { confirm: t("categories.are_you_sure") },
                  class: "opacity-0 group-hover:opacity-100 p-2 rounded-lg bg-red-100 dark:bg-red-900/20 text-red-600 dark:text-red-400 hover:bg-red-200 dark:hover:bg-red-900/30 transition-smooth btn-modern" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-container dark:bg-container dark:bg-container-dark-dark rounded-lg shadow-border-xs dark:shadow-dark-border-xs dark:shadow-dark-border-xs p-12 text-center">
      <svg class="w-12 h-12 mx-auto text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
      <p class="text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark font-medium mb-1"><%= t("categories.no_categories_yet") %></p>
      <p class="text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark text-sm">添加分类来更好地组织您的交易</p>
    </div>
  <% end %>
</div>

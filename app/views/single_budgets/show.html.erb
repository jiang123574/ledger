<div class="space-y-6">
  <!-- Header -->
  <div class="flex justify-between items-center">
    <div class="flex items-center gap-4">
      <%= link_to single_budgets_path, class: "p-2 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth" do %>
        <svg class="w-5 h-5 text-primary dark:text-primary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
      <% end %>
      <h1 class="text-2xl font-bold text-primary dark:text-primary-dark"><%= @single_budget.name %></h1>
      <span class="text-xs px-2 py-0.5 rounded <%= 
        case @single_budget.status_color
        when 'red' then 'bg-expense/10 text-expense'
        when 'yellow' then 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900 dark:text-yellow-300'
        when 'green' then 'bg-income/10 text-income'
        else 'bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark'
        end
      %>"><%= @single_budget.status_text %></span>
    </div>
    <div class="flex gap-2">
      <% if @single_budget.planning? %>
        <%= button_to t("single_budgets.start"), start_single_budget_path(@single_budget), method: :patch, class: "px-4 py-2 text-sm font-medium rounded-lg bg-income text-white hover:bg-green-600 transition-smooth" %>
      <% end %>
      <% if @single_budget.active? %>
        <%= button_to t("single_budgets.complete"), complete_single_budget_path(@single_budget), method: :patch, class: "px-4 py-2 text-sm font-medium rounded-lg bg-income text-white hover:bg-green-600 transition-smooth" %>
        <%= button_to t("single_budgets.cancel"), cancel_single_budget_path(@single_budget), method: :patch, class: "px-4 py-2 text-sm font-medium rounded-lg bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark hover:bg-surface-hover transition-smooth" %>
      <% end %>
    </div>
  </div>

  <!-- Time Range & Category Settings -->
  <div class="bg-container dark:bg-container-dark rounded-lg shadow p-4">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">开始日期</label>
        <p class="text-primary dark:text-primary-dark font-medium"><%= @single_budget.start_date.strftime("%Y-%m-%d") %></p>
      </div>
      <div>
        <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">结束日期</label>
        <p class="text-primary dark:text-primary-dark font-medium"><%= @single_budget.end_date&.strftime("%Y-%m-%d") || "未设置" %></p>
      </div>
      <div>
        <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">涵盖分类</label>
        <p class="text-primary dark:text-primary-dark font-medium">
          <% if @single_budget.category %>
            <%= @single_budget.category.name %>（含子分类）
          <% else %>
            全部分类
          <% end %>
        </p>
      </div>
    </div>
  </div>

  <!-- Main Budget Overview -->
  <div class="bg-container dark:bg-container-dark rounded-lg shadow p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-primary dark:text-primary-dark">总预算</h2>
      <span class="text-2xl font-bold text-primary dark:text-primary-dark"><%= format_currency(@single_budget.total_amount) %></span>
    </div>
    
    <div class="mb-4">
      <div class="flex justify-between text-sm mb-1">
        <span class="text-secondary dark:text-secondary-dark">已花费</span>
        <span class="<%= @single_budget.overspent? ? 'text-expense' : 'text-primary dark:text-primary-dark' %> font-medium">
          <%= format_currency(@single_budget.spent_amount) %> / <%= format_currency(@single_budget.total_amount) %>
        </span>
      </div>
      <div class="w-full bg-surface dark:bg-surface-dark rounded-full h-4">
        <div class="h-4 rounded-full transition-all <%= @single_budget.overspent? ? 'bg-expense' : 'bg-income' %>" 
             style="width: <%= [@single_budget.progress_percentage, 100].min %>%"></div>
      </div>
      <div class="flex justify-between text-xs mt-1">
        <span class="<%= @single_budget.remaining_amount >= 0 ? 'text-income' : 'text-expense' %>">
          <%= @single_budget.remaining_amount >= 0 ? "剩余 #{format_currency(@single_budget.remaining_amount)}" : "超支 #{format_currency(@single_budget.remaining_amount.abs)}" %>
        </span>
        <span class="text-secondary dark:text-secondary-dark"><%= @single_budget.progress_percentage %>%</span>
      </div>
    </div>
  </div>

  <!-- Budget Items -->
  <div class="bg-container dark:bg-container-dark rounded-lg shadow p-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-lg font-semibold text-primary dark:text-primary-dark">子预算</h2>
      <%= link_to new_single_budget_budget_item_path(@single_budget), class: "px-3 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth" do %>
        <span class="flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
          添加子预算
        </span>
      <% end %>
    </div>
    
    <% if @budget_items.any? %>
      <div class="space-y-4">
        <% @budget_items.each do |item| %>
          <% percentage = item.progress_percentage %>
          <div class="border border-border dark:border-border-dark rounded-lg p-4 hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">
            <div class="flex items-center justify-between mb-3">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-income-soft flex items-center justify-center">
                  <svg class="w-5 h-5 text-income" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
                </div>
                <div>
                  <h3 class="font-medium text-primary dark:text-primary-dark"><%= item.name %></h3>
                  <p class="text-xs text-secondary dark:text-secondary-dark">
                    <%= item.category&.name || "无分类" %>
                  </p>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-lg font-bold <%= item.overspent? ? 'text-expense' : 'text-primary dark:text-primary-dark' %>">
                  <%= format_currency(item.amount) %>
                </span>
                <div class="flex gap-1">
                  <%= link_to edit_single_budget_budget_item_path(@single_budget, item), class: "p-1.5 rounded-lg hover:bg-surface dark:hover:bg-surface-dark text-secondary dark:text-secondary-dark hover:text-primary transition-smooth" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                  <% end %>
                  <%= button_to [@single_budget, item], method: :delete, onclick: "if(!confirm('确定删除此子预算？')) return false", class: "p-1.5 rounded-lg hover:bg-expense-light text-secondary dark:text-secondary-dark hover:text-expense transition-smooth" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                  <% end %>
                </div>
              </div>
            </div>
            
            <div class="mb-2">
              <div class="flex justify-between text-xs mb-1">
                <span class="text-secondary dark:text-secondary-dark">已花费 <%= format_currency(item.spent_amount) %></span>
                <span class="<%= item.overspent? ? 'text-expense' : 'text-secondary dark:text-secondary-dark' %>"><%= percentage %>%</span>
              </div>
              <div class="w-full bg-surface dark:bg-surface-dark rounded-full h-2">
                <div class="h-2 rounded-full transition-all <%= item.overspent? ? 'bg-expense' : 'bg-income' %>" 
                     style="width: <%= [percentage, 100].min %>%"></div>
              </div>
            </div>
            
            <div class="flex justify-between text-xs">
              <span class="text-secondary dark:text-secondary-dark">剩余</span>
              <span class="<%= item.remaining_amount >= 0 ? 'text-income' : 'text-expense' %>">
                <%= format_currency(item.remaining_amount) %>
              </span>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-8">
        <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-surface dark:bg-surface-dark flex items-center justify-center">
          <svg class="w-6 h-6 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
        </div>
        <p class="text-secondary dark:text-secondary-dark">暂无子预算</p>
        <p class="text-xs text-secondary dark:text-secondary-dark mt-1">点击上方按钮添加子预算</p>
      </div>
    <% end %>
  </div>
</div>

<div class="space-y-6">
  <div class="flex items-center gap-4">
    <%= link_to t("common.back"), single_budgets_path, class: "text-primary hover:text-inverse" %>
    <h1 class="text-2xl font-bold text-primary dark:text-primary dark:text-primary-dark-dark"><%= t("single_budgets.new") %></h1>
  </div>

  <div class="bg-container dark:bg-container dark:bg-container-dark-dark rounded-lg shadow p-6">
    <%= form_with model: @single_budget, url: single_budgets_path, local: true, class: "space-y-4" do |f| %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <%= f.label :name, t("single_budgets.name"), class: "block text-sm font-medium text-primary dark:text-primary-dark dark:text-secondary-dark mb-1" %>
          <%= f.text_field :name, class: "w-full border rounded-lg px-3 py-2.5 text-base dark:bg-surface-dark dark:border-gray-600 dark:text-white", required: true %>
        </div>
        <div>
          <%= f.label :currency, t("single_budgets.currency"), class: "block text-sm font-medium text-primary dark:text-primary-dark dark:text-secondary-dark mb-1" %>
          <%= f.select :currency, ["CNY", "USD", "EUR", "GBP", "JPY"], { selected: "CNY" }, class: "w-full border rounded-lg px-3 py-2.5 text-base dark:bg-surface-dark dark:border-gray-600 dark:text-white" %>
        </div>
        <div>
          <%= f.label :total_amount, t("single_budgets.total_amount"), class: "block text-sm font-medium text-primary dark:text-primary-dark dark:text-secondary-dark mb-1" %>
          <%= f.number_field :total_amount, step: "0.01", class: "w-full border rounded-lg px-3 py-2.5 text-base dark:bg-surface-dark dark:border-gray-600 dark:text-white", required: true %>
        </div>
        <div>
          <%= f.label :status, t("single_budgets.status"), class: "block text-sm font-medium text-primary dark:text-primary-dark dark:text-secondary-dark mb-1" %>
          <%= f.select :status, [[t("single_budgets.status_planning"), "planning"], [t("single_budgets.status_active"), "active"]], { selected: "planning" }, class: "w-full border rounded-lg px-3 py-2.5 text-base dark:bg-surface-dark dark:border-gray-600 dark:text-white" %>
        </div>
        <div>
          <%= f.label :start_date, t("single_budgets.start_date"), class: "block text-sm font-medium text-primary dark:text-primary-dark dark:text-secondary-dark mb-1" %>
          <%= f.date_field :start_date, class: "w-full border rounded-lg px-3 py-2.5 text-base dark:bg-surface-dark dark:border-gray-600 dark:text-white", required: true %>
        </div>
        <div>
          <%= f.label :end_date, t("single_budgets.end_date"), class: "block text-sm font-medium text-primary dark:text-primary-dark dark:text-secondary-dark mb-1" %>
          <%= f.date_field :end_date, class: "w-full border rounded-lg px-3 py-2.5 text-base dark:bg-surface-dark dark:border-gray-600 dark:text-white" %>
        </div>
      </div>
      <div>
        <%= f.label :description, t("single_budgets.description"), class: "block text-sm font-medium text-primary dark:text-primary-dark dark:text-secondary-dark mb-1" %>
        <%= f.text_area :description, rows: 3, class: "w-full border rounded-lg px-3 py-2.5 text-base dark:bg-surface-dark dark:border-gray-600 dark:text-white" %>
      </div>
      <div class="flex justify-end gap-2">
        <%= link_to t("common.cancel"), single_budgets_path, class: "px-4 py-2.5 text-base font-medium rounded-lg border border-border text-primary hover:bg-surface-hover transition-smooth btn-modern dark:border-gray-600 dark:text-secondary-dark" %>
        <%= f.submit t("common.create"), class: "px-4 py-2.5 text-base font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth btn-modern" %>
      </div>
    <% end %>
  </div>
</div>

<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h1 class="text-2xl font-bold text-primary dark:text-primary-dark"><%= t("single_budgets.title") %></h1>
    <%= link_to t("single_budgets.new"), new_single_budget_path, class: "px-4 py-2.5 text-base font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth btn-modern" %>
  </div>

  <div class="flex items-center space-x-2 mb-4">
    <%= link_to t("single_budgets.all"), single_budgets_path, class: "px-3 py-1.5 text-sm font-medium rounded-lg border #{params[:status].blank? ? 'bg-inverse text-white' : 'border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover'}" %>
    <%= link_to t("single_budgets.planning"), single_budgets_path(status: "planning"), class: "px-3 py-1.5 text-sm font-medium rounded-lg border #{params[:status] == 'planning' ? 'bg-inverse text-white' : 'border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover'}" %>
    <%= link_to t("single_budgets.active"), single_budgets_path(status: "active"), class: "px-3 py-1.5 text-sm font-medium rounded-lg border #{params[:status] == 'active' ? 'bg-inverse text-white' : 'border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover'}" %>
    <%= link_to t("single_budgets.completed"), single_budgets_path(status: "completed"), class: "px-3 py-1.5 text-sm font-medium rounded-lg border #{params[:status] == 'completed' ? 'bg-inverse text-white' : 'border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover'}" %>
    <%= link_to t("single_budgets.cancelled"), single_budgets_path(status: "cancelled"), class: "px-3 py-1.5 text-sm font-medium rounded-lg border #{params[:status] == 'cancelled' ? 'bg-inverse text-white' : 'border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover'}" %>
  </div>

  <% if @total_budget > 0 %>
    <div class="bg-container dark:bg-container-dark rounded-lg shadow p-6">
      <div class="flex justify-between items-center mb-4">
        <h3 class="font-medium"><%= t("single_budgets.total") %></h3>
        <span class="text-sm <%= (@total_budget - @total_spent) < 0 ? 'text-expense' : 'text-income' %>">
          <%= (@total_budget - @total_spent) < 0 ? "已超支" : "剩余 #{format_currency(@total_budget - @total_spent)}" %>
        </span>
      </div>
      <div class="flex items-center gap-4">
        <div class="flex-1">
          <div class="flex justify-between text-sm mb-1">
            <span class="text-secondary dark:text-secondary-dark"><%= t("single_budgets.spent") %></span>
            <span class="font-medium"><%= format_currency(@total_spent) %> / <%= format_currency(@total_budget) %></span>
          </div>
          <div class="w-full bg-surface dark:bg-surface-dark rounded-full h-4 dark:bg-surface-dark">
            <% percentage = @total_budget > 0 ? (@total_spent.to_f / @total_budget * 100).round : 0 %>
            <div class="<%= percentage > 100 ? 'bg-red-500' : (percentage > 80 ? 'bg-yellow-500' : 'bg-inverse') %> h-4 rounded-full transition-all" style="width: <%= [percentage, 100].min %>%"></div>
          </div>
          <div class="flex justify-between text-xs text-secondary dark:text-secondary-dark mt-1">
            <span>0%</span>
            <span class="<%= percentage > 100 ? 'text-expense font-medium' : '' %>"><%= percentage %>%</span>
            <span>100%</span>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid gap-4">
    <% @single_budgets.each do |budget| %>
      <% percentage = budget.progress_percentage %>
      <div class="bg-container dark:bg-container-dark rounded-lg shadow p-4">
        <div class="flex justify-between items-center mb-2">
          <div class="flex items-center gap-2">
            <span class="font-medium"><%= budget.name %></span>
            <span class="text-xs px-2 py-0.5 rounded <%= 
              case budget.status_color
              when 'red' then 'bg-red-100 text-red-700 dark:bg-red-900 dark:text-red-300'
              when 'yellow' then 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900 dark:text-yellow-300'
              when 'green' then 'bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300'
              else 'bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark dark:text-secondary-dark'
              end
            %>"><%= budget.status_text %></span>
          </div>
          <div class="text-right">
            <span class="font-medium"><%= format_currency(budget.total_amount) %></span>
            <span class="text-sm text-secondary dark:text-secondary-dark"><%= t("single_budgets.budget") %></span>
          </div>
        </div>
        
        <% if budget.description.present? %>
          <p class="text-sm text-secondary dark:text-secondary-dark mb-2"><%= budget.description %></p>
        <% end %>
        
        <div class="flex items-center gap-4 text-sm text-secondary dark:text-secondary-dark mb-2">
          <span><%= budget.start_date.strftime("%Y-%m-%d") %></span>
          <% if budget.end_date.present? %>
            <span>~ <%= budget.end_date.strftime("%Y-%m-%d") %></span>
          <% end %>
          <% if budget.budget_items.any? %>
            <span><%= budget.budget_items.count %> <%= t("single_budgets.items") %></span>
          <% end %>
        </div>
        
        <div class="w-full bg-surface dark:bg-surface-dark rounded-full h-3 dark:bg-surface-dark">
          <div class="<%= budget.status_color == 'red' ? 'bg-red-500' : (budget.status_color == 'yellow' ? 'bg-yellow-500' : 'bg-inverse') %> h-3 rounded-full transition-all" style="width: <%= [percentage, 100].min %>%"></div>
        </div>
        <div class="flex justify-between text-sm mt-2">
          <span class="text-secondary dark:text-secondary-dark"><%= t("single_budgets.spent") %>: <%= format_currency(budget.spent_amount) %></span>
          <span class="<%= budget.overspent? ? 'text-expense font-medium' : 'text-secondary dark:text-secondary-dark' %>">
            <%= budget.overspent? ? t("single_budgets.overspent", amount: format_currency(budget.remaining_amount.abs)) : t("single_budgets.remaining", amount: format_currency(budget.remaining_amount)) %>
          </span>
        </div>
        <div class="flex justify-end gap-2 mt-2">
          <%= link_to t("single_budgets.view"), single_budget_path(budget), class: "px-3 py-1.5 text-sm font-medium rounded-lg bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth btn-modern" %>
          <%= link_to t("single_budgets.edit"), edit_single_budget_path(budget), class: "px-3 py-1.5 text-sm font-medium rounded-lg bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth btn-modern" %>
          <%= link_to t("single_budgets.delete"), budget, method: :delete, onclick: "if(confirm('确定删除？')) { this.nextElementSibling.submit() }" form: { style: "display:inline" }, class: "px-3 py-1.5 text-sm font-medium rounded-lg bg-red-100 text-expense hover:bg-red-200 transition-smooth btn-modern dark:bg-red-900 dark:text-red-300" %>
        </div>
      </div>
    <% end %>
  </div>

  <% if @single_budgets.empty? %>
    <div class="bg-container dark:bg-container-dark rounded-lg shadow p-8 text-center text-secondary dark:text-secondary-dark">
      <%= t("single_budgets.no_single_budgets") %>
    </div>
  <% end %>
</div>

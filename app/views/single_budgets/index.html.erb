<% content_for :page_title, t("single_budgets.title") %>

<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h1 class="text-2xl font-bold text-primary dark:text-primary-dark"><%= t("single_budgets.title") %></h1>
    <button onclick="document.getElementById('new-single-budget-modal').classList.remove('hidden')" class="px-4 py-2.5 text-base font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth btn-modern">
      <%= t("single_budgets.new") %>
    </button>
  </div>

  <div class="flex items-center space-x-2 mb-4">
    <%= link_to t("single_budgets.all"), single_budgets_path, class: "px-3 py-1.5 text-sm font-medium rounded-lg border #{params[:status].blank? ? 'bg-inverse text-white' : 'border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover'}" %>
    <%= link_to t("single_budgets.planning"), single_budgets_path(status: "planning"), class: "px-3 py-1.5 text-sm font-medium rounded-lg border #{params[:status] == 'planning' ? 'bg-inverse text-white' : 'border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover'}" %>
    <%= link_to t("single_budgets.active"), single_budgets_path(status: "active"), class: "px-3 py-1.5 text-sm font-medium rounded-lg border #{params[:status] == 'active' ? 'bg-inverse text-white' : 'border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover'}" %>
    <%= link_to t("single_budgets.completed"), single_budgets_path(status: "completed"), class: "px-3 py-1.5 text-sm font-medium rounded-lg border #{params[:status] == 'completed' ? 'bg-inverse text-white' : 'border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover'}" %>
    <%= link_to t("single_budgets.cancelled"), single_budgets_path(status: "cancelled"), class: "px-3 py-1.5 text-sm font-medium rounded-lg border #{params[:status] == 'cancelled' ? 'bg-inverse text-white' : 'border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover'}" %>
  </div>

  <% if @total_budget > 0 %>
    <div class="bg-container dark:bg-container-dark rounded-lg shadow p-6">
      <div class="flex justify-between items-center mb-4">
        <h3 class="font-medium"><%= t("single_budgets.total") %></h3>
        <span class="text-sm <%= (@total_budget - @total_spent) < 0 ? 'text-expense' : 'text-income' %>">
          <%= (@total_budget - @total_spent) < 0 ? "已超支" : "剩余 #{format_currency(@total_budget - @total_spent)}" %>
        </span>
      </div>
      <div class="flex items-center gap-4">
        <div class="flex-1">
          <div class="flex justify-between text-sm mb-1">
            <span class="text-secondary dark:text-secondary-dark"><%= t("single_budgets.spent") %></span>
            <span class="font-medium"><%= format_currency(@total_spent) %> / <%= format_currency(@total_budget) %></span>
          </div>
          <div class="w-full bg-surface dark:bg-surface-dark rounded-full h-4">
            <% percentage = @total_budget > 0 ? (@total_spent.to_f / @total_budget * 100).round : 0 %>
            <div class="<%= percentage > 100 ? 'bg-red-500' : (percentage > 80 ? 'bg-yellow-500' : 'bg-inverse') %> h-4 rounded-full transition-all" style="width: <%= [percentage, 100].min %>%"></div>
          </div>
          <div class="flex justify-between text-xs text-secondary dark:text-secondary-dark mt-1">
            <span>0%</span>
            <span class="<%= percentage > 100 ? 'text-expense font-medium' : '' %>"><%= percentage %>%</span>
            <span>100%</span>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid gap-4">
    <% @single_budgets.each do |budget| %>
      <% percentage = budget.progress_percentage %>
      <div class="bg-container dark:bg-container-dark rounded-lg shadow p-4">
        <div class="flex justify-between items-center mb-2">
          <div class="flex items-center gap-2">
            <span class="font-medium"><%= budget.name %></span>
            <span class="text-xs px-2 py-0.5 rounded <%= 
              case budget.status_color
              when 'red' then 'bg-red-100 text-red-700 dark:bg-red-900 dark:text-red-300'
              when 'yellow' then 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900 dark:text-yellow-300'
              when 'green' then 'bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300'
              else 'bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark'
              end
            %>"><%= budget.status_text %></span>
          </div>
          <div class="text-right">
            <span class="font-medium"><%= format_currency(budget.total_amount) %></span>
            <span class="text-sm text-secondary dark:text-secondary-dark"><%= t("single_budgets.budget") %></span>
          </div>
        </div>

        <% if budget.description.present? %>
          <p class="text-sm text-secondary dark:text-secondary-dark mb-2"><%= budget.description %></p>
        <% end %>

        <div class="flex items-center gap-4 text-sm text-secondary dark:text-secondary-dark mb-2">
          <span><%= budget.start_date.strftime("%Y-%m-%d") %></span>
          <% if budget.end_date.present? %>
            <span>~ <%= budget.end_date.strftime("%Y-%m-%d") %></span>
          <% end %>
          <% if budget.budget_items.any? %>
            <span><%= budget.budget_items.count %> <%= t("single_budgets.items") %></span>
          <% end %>
        </div>

        <div class="w-full bg-surface dark:bg-surface-dark rounded-full h-3">
          <div class="<%= budget.status_color == 'red' ? 'bg-red-500' : (budget.status_color == 'yellow' ? 'bg-yellow-500' : 'bg-inverse') %> h-3 rounded-full transition-all" style="width: <%= [percentage, 100].min %>%"></div>
        </div>
        <div class="flex justify-between text-sm mt-2">
          <span class="text-secondary dark:text-secondary-dark"><%= t("single_budgets.spent") %>: <%= format_currency(budget.spent_amount) %></span>
          <span class="<%= budget.overspent? ? 'text-expense font-medium' : 'text-secondary dark:text-secondary-dark' %>">
            <%= budget.overspent? ? t("single_budgets.overspent", amount: format_currency(budget.remaining_amount.abs)) : t("single_budgets.remaining", amount: format_currency(budget.remaining_amount)) %>
          </span>
        </div>
        <div class="flex justify-end gap-2 mt-2">
          <%= link_to t("single_budgets.view"), single_budget_path(budget), class: "px-3 py-1.5 text-sm font-medium rounded-lg bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth btn-modern" %>
          <button onclick="openEditSingleBudgetModal(<%= budget.id %>, '<%= j budget.name %>', '<%= budget.category_id %>', '<%= budget.currency %>', '<%= budget.total_amount %>', '<%= budget.status %>', '<%= budget.start_date %>', '<%= budget.end_date %>', '<%= j(budget.description || '') %>')" class="px-3 py-1.5 text-sm font-medium rounded-lg bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth btn-modern">
            <%= t("single_budgets.edit") %>
          </button>
          <%= button_to t("single_budgets.delete"), budget, method: :delete, onclick: "if(!confirm('确定删除？')) return false", class: "px-3 py-1.5 text-sm font-medium rounded-lg bg-red-100 text-expense hover:bg-red-200 transition-smooth btn-modern dark:bg-red-900 dark:text-red-300" %>
        </div>
      </div>
    <% end %>
  </div>

  <% if @single_budgets.empty? %>
    <div class="bg-container dark:bg-container-dark rounded-lg shadow p-8 text-center text-secondary dark:text-secondary-dark">
      <%= t("single_budgets.no_single_budgets") %>
    </div>
  <% end %>
</div>

<!-- 新建单次预算弹窗 -->
<div id="new-single-budget-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('new-single-budget-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-xl shadow-xl w-full max-w-lg p-6 max-h-[90vh] overflow-y-auto">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-primary dark:text-primary-dark"><%= t("single_budgets.new") %></h3>
        <button type="button" onclick="document.getElementById('new-single-budget-modal').classList.add('hidden')" class="p-1 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <form id="new-single-budget-form" method="post" action="<%= single_budgets_path %>">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <div class="space-y-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1"><%= t("single_budgets.name") %></label>
              <input type="text" name="single_budget[name]" required class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">分类</label>
              <select name="single_budget[category_id]" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
                <option value="">全部分类</option>
                <% Category.all.each do |cat| %>
                  <option value="<%= cat.id %>"><%= cat.full_name %></option>
                <% end %>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1"><%= t("single_budgets.currency") %></label>
              <select name="single_budget[currency]" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
                <option value="CNY">CNY</option>
                <option value="USD">USD</option>
                <option value="EUR">EUR</option>
                <option value="GBP">GBP</option>
                <option value="JPY">JPY</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1"><%= t("single_budgets.total_amount") %></label>
              <input type="number" name="single_budget[total_amount]" step="0.01" required class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1"><%= t("single_budgets.status") %></label>
              <select name="single_budget[status]" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
                <option value="planning"><%= t("single_budgets.status_planning") %></option>
                <option value="active"><%= t("single_budgets.status_active") %></option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1"><%= t("single_budgets.start_date") %></label>
              <input type="date" name="single_budget[start_date]" required class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
            </div>
            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1"><%= t("single_budgets.end_date") %></label>
              <input type="date" name="single_budget[end_date]" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1"><%= t("single_budgets.description") %></label>
            <textarea name="single_budget[description]" rows="3" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500"></textarea>
          </div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="document.getElementById('new-single-budget-modal').classList.add('hidden')" class="px-4 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth"><%= t("common.cancel") %></button>
          <button type="submit" class="px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth"><%= t("common.create") %></button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- 编辑单次预算弹窗 -->
<div id="edit-single-budget-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('edit-single-budget-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-xl shadow-xl w-full max-w-lg p-6 max-h-[90vh] overflow-y-auto">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-primary dark:text-primary-dark"><%= t("single_budgets.edit") %></h3>
        <button type="button" onclick="document.getElementById('edit-single-budget-modal').classList.add('hidden')" class="p-1 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <form id="edit-single-budget-form" method="post">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <input type="hidden" name="_method" value="patch">
        <div class="space-y-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1"><%= t("single_budgets.name") %></label>
              <input type="text" id="edit-single-budget-name" name="single_budget[name]" required class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">分类</label>
              <select id="edit-single-budget-category" name="single_budget[category_id]" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
                <option value="">全部分类</option>
                <% Category.all.each do |cat| %>
                  <option value="<%= cat.id %>"><%= cat.full_name %></option>
                <% end %>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1"><%= t("single_budgets.currency") %></label>
              <select id="edit-single-budget-currency" name="single_budget[currency]" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
                <option value="CNY">CNY</option>
                <option value="USD">USD</option>
                <option value="EUR">EUR</option>
                <option value="GBP">GBP</option>
                <option value="JPY">JPY</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1"><%= t("single_budgets.total_amount") %></label>
              <input type="number" id="edit-single-budget-total" name="single_budget[total_amount]" step="0.01" required class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1"><%= t("single_budgets.status") %></label>
              <select id="edit-single-budget-status" name="single_budget[status]" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
                <option value="planning"><%= t("single_budgets.status_planning") %></option>
                <option value="active"><%= t("single_budgets.status_active") %></option>
                <option value="completed"><%= t("single_budgets.status_completed") %></option>
                <option value="cancelled"><%= t("single_budgets.status_cancelled") %></option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1"><%= t("single_budgets.start_date") %></label>
              <input type="date" id="edit-single-budget-start-date" name="single_budget[start_date]" required class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
            </div>
            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1"><%= t("single_budgets.end_date") %></label>
              <input type="date" id="edit-single-budget-end-date" name="single_budget[end_date]" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1"><%= t("single_budgets.description") %></label>
            <textarea id="edit-single-budget-description" name="single_budget[description]" rows="3" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500"></textarea>
          </div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="document.getElementById('edit-single-budget-modal').classList.add('hidden')" class="px-4 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth"><%= t("common.cancel") %></button>
          <button type="submit" class="px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth"><%= t("common.save") %></button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function openEditSingleBudgetModal(id, name, categoryId, currency, totalAmount, status, startDate, endDate, description) {
    const form = document.getElementById('edit-single-budget-form')
    form.action = '/single_budgets/' + id
    document.getElementById('edit-single-budget-name').value = name
    document.getElementById('edit-single-budget-category').value = categoryId || ''
    document.getElementById('edit-single-budget-currency').value = currency
    document.getElementById('edit-single-budget-total').value = totalAmount
    document.getElementById('edit-single-budget-status').value = status
    document.getElementById('edit-single-budget-start-date').value = startDate
    document.getElementById('edit-single-budget-end-date').value = endDate || ''
    document.getElementById('edit-single-budget-description').value = description
    document.getElementById('edit-single-budget-modal').classList.remove('hidden')
  }
</script>

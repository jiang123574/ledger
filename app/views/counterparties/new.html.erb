<div class="space-y-6">
  <div class="flex items-center gap-4">
    <%= link_to "← 返回", counterparties_path, class: "text-gray-500 hover:text-gray-700" %>
    <h1 class="text-2xl font-bold text-gray-900">新建交易对方</h1>
  </div>

  <div class="bg-white rounded-lg shadow p-6 max-w-xl">
    <%= form_with model: @counterparty, local: true, class: "space-y-4" do |f| %>
      <% if @counterparty.errors.any? %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded">
          <ul class="list-disc list-inside">
            <% @counterparty.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, "名称", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :name, placeholder: "例如: 张三、某公司", class: "mt-1 block w-full border border-gray-300 rounded-lg px-3 py-1.5 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :contact, "联系方式", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :contact, placeholder: "手机号、微信等", class: "mt-1 block w-full border border-gray-300 rounded-lg px-3 py-1.5 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :note, "备注", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_area :note, rows: 3, placeholder: "可选备注信息...", class: "mt-1 block w-full border border-gray-300 rounded-lg px-3 py-1.5 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="flex justify-end space-x-4 pt-4 border-t">
        <%= link_to "取消", counterparties_path, class: "px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50" %>
        <%= f.submit "创建", class: "bg-inverse text-white px-4 py-2 rounded-lg hover:bg-inverse-hover" %>
      </div>
    <% end %>
  </div>
</div>
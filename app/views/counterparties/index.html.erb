<% content_for :page_title, "交易对方" %>

<div class="space-y-6">
  <div class="flex justify-between items-center">
    <div>
      <h1 class="text-2xl font-bold text-primary dark:text-primary-dark">交易对方</h1>
      <p class="text-secondary dark:text-secondary-dark text-sm mt-1">管理与你有资金往来的人或机构</p>
    </div>
    <button onclick="document.getElementById('new-counterparty-modal').classList.remove('hidden')" class="bg-inverse text-white px-4 py-2 rounded-lg hover:bg-inverse-hover transition btn-modern">
      新建交易对方
    </button>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="bg-container dark:bg-container-dark rounded-lg shadow p-4">
      <div class="text-sm text-secondary dark:text-secondary-dark">交易对方总数</div>
      <div class="text-2xl font-bold text-primary dark:text-primary-dark"><%= @total_counterparties %></div>
    </div>
    <div class="bg-container dark:bg-container-dark rounded-lg shadow p-4">
      <div class="text-sm text-secondary dark:text-secondary-dark">关联应收款</div>
      <div class="text-2xl font-bold text-primary dark:text-primary-dark"><%= @total_receivables %></div>
    </div>
    <div class="bg-container dark:bg-container-dark rounded-lg shadow p-4">
      <div class="text-sm text-secondary dark:text-secondary-dark">有往来的对象</div>
      <div class="text-2xl font-bold text-income"><%= @counterparties.select { |c| c.receivables_count > 0 }.size %></div>
    </div>
  </div>

  <% if @counterparties.empty? %>
    <div class="bg-container dark:bg-container-dark rounded-lg shadow p-8 text-center">
      <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-surface dark:bg-surface-dark flex items-center justify-center">
        <%= render(Ds::IconComponent.new(name: "user", size: :xl, color: :secondary)) %>
      </div>
      <p class="text-secondary dark:text-secondary-dark">暂无交易对方</p>
      <p class="text-secondary dark:text-secondary-dark text-sm mt-2">添加常往来的人或机构，方便统计和管理</p>
      <button onclick="document.getElementById('new-counterparty-modal').classList.remove('hidden')" class="inline-block mt-4 bg-inverse text-white px-4 py-2 rounded-lg hover:bg-inverse-hover btn-modern">
        添加第一个交易对方
      </button>
    </div>
  <% else %>
    <div class="bg-container dark:bg-container-dark rounded-lg shadow overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-surface dark:bg-surface-dark">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-secondary dark:text-secondary-dark uppercase tracking-wider">名称</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-secondary dark:text-secondary-dark uppercase tracking-wider">联系方式</th>
            <th class="px-6 py-3 text-center text-xs font-medium text-secondary dark:text-secondary-dark uppercase tracking-wider">应收款数</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-secondary dark:text-secondary-dark uppercase tracking-wider">待收金额</th>
            <th class="px-6 py-3 actions"></th>
          </tr>
        </thead>
        <tbody class="bg-container dark:bg-container-dark divide-y divide-gray-200">
          <% @counterparties.each do |counterparty| %>
            <tr class="hover:bg-surface dark:hover:bg-surface-dark">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="font-medium text-primary dark:text-primary-dark"><%= counterparty.name %></div>
                <% if counterparty.note.present? %>
                  <div class="text-sm text-secondary dark:text-secondary-dark"><%= truncate(counterparty.note, length: 50) %></div>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary dark:text-secondary-dark">
                <%= counterparty.contact || '-' %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-center">
                <% if counterparty.receivables_count > 0 %>
                  <span class="bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark px-2 py-1 rounded-full text-sm">
                    <%= counterparty.receivables_count %> 笔
                  </span>
                <% else %>
                  <span class="text-secondary dark:text-secondary-dark">-</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right">
                <% pending = counterparty.pending_receivable_amount %>
                <% if pending > 0 %>
                  <span class="text-income font-medium"><%= format_currency(pending, 'CNY') %></span>
                <% else %>
                  <span class="text-secondary dark:text-secondary-dark">-</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                <div class="flex items-center justify-end gap-2">
                  <button onclick="openEditCounterpartyModal(<%= counterparty.id %>, '<%= j counterparty.name %>', '<%= j(counterparty.contact || '') %>', '<%= j(counterparty.note || '') %>')" 
                      class="text-primary dark:text-primary-dark hover:text-secondary dark:hover:text-secondary-dark">
                    编辑
                  </button>
                  <%= button_to "删除", counterparty_path(counterparty), method: :delete, 
                      onclick: "if(!confirm('确定删除此交易对方？')) return false",
                      class: "text-red-600 hover:text-red-800" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>

<!-- 新建交易对方弹窗 -->
<div id="new-counterparty-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('new-counterparty-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-xl shadow-xl w-full max-w-md p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-primary dark:text-primary-dark">新建交易对方</h3>
        <button type="button" onclick="document.getElementById('new-counterparty-modal').classList.add('hidden')" class="p-1 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <form id="new-counterparty-form" method="post" action="<%= counterparties_path %>">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">名称 *</label>
            <input type="text" name="counterparty[name]" required class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" placeholder="例如：张三、某某公司">
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">联系方式</label>
            <input type="text" name="counterparty[contact]" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" placeholder="手机、邮箱等">
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">备注</label>
            <textarea name="counterparty[note]" rows="3" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" placeholder="可选备注"></textarea>
          </div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="document.getElementById('new-counterparty-modal').classList.add('hidden')" class="px-4 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">取消</button>
          <button type="submit" class="px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">创建</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- 编辑交易对方弹窗 -->
<div id="edit-counterparty-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('edit-counterparty-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-xl shadow-xl w-full max-w-md p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-primary dark:text-primary-dark">编辑交易对方</h3>
        <button type="button" onclick="document.getElementById('edit-counterparty-modal').classList.add('hidden')" class="p-1 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <form id="edit-counterparty-form" method="post">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <input type="hidden" name="_method" value="patch">
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">名称 *</label>
            <input type="text" id="edit-counterparty-name" name="counterparty[name]" required class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">联系方式</label>
            <input type="text" id="edit-counterparty-contact" name="counterparty[contact]" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">备注</label>
            <textarea id="edit-counterparty-note" name="counterparty[note]" rows="3" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500"></textarea>
          </div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="document.getElementById('edit-counterparty-modal').classList.add('hidden')" class="px-4 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">取消</button>
          <button type="submit" class="px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">保存</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function openEditCounterpartyModal(id, name, contact, note) {
    const form = document.getElementById('edit-counterparty-form')
    form.action = '/counterparties/' + id
    document.getElementById('edit-counterparty-name').value = name
    document.getElementById('edit-counterparty-contact').value = contact
    document.getElementById('edit-counterparty-note').value = note
    document.getElementById('edit-counterparty-modal').classList.remove('hidden')
  }
</script>

<div class="space-y-6">
  <div class="flex items-center gap-4">
    <%= link_to accounts_path, class: "p-2 hover:bg-surface-inset rounded-lg transition-smooth" do %>
      <svg class="w-5 h-5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
    <% end %>
    <h1 class="text-2xl font-semibold text-primary"><%= t("accounts.new_account") %></h1>
  </div>

  <div class="bg-container rounded-lg shadow-border-xs">
    <%= form_with model: @account, local: true, class: "p-6 space-y-6" do |f| %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-primary mb-1.5">账户名称</label>
          <%= f.text_field :name, placeholder: "例如：我的银行卡", class: "w-full px-3 py-2 text-sm rounded-lg border border-border focus:ring-blue-500 focus:border-blue-500" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-primary mb-1.5">账户类型</label>
          <%= f.select :type, options_for_select(Account::ACCOUNT_TYPES.map { |k, v| [v, k] }), { prompt: "选择类型" }, class: "w-full px-3 py-2 text-sm rounded-lg border border-border focus:ring-blue-500 focus:border-blue-500" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-primary mb-1.5">初始余额</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary">¥</span>
            <%= f.number_field :initial_balance, step: "0.01", value: "0.00", class: "w-full pl-8 pr-3 py-2 text-sm rounded-lg border border-border focus:ring-blue-500 focus:border-blue-500" %>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-primary mb-1.5">货币</label>
          <%= f.select :currency, 
            Currency.active.map { |c| ["#{c.code} - #{c.name}", c.code] },
            { selected: @account.currency || "CNY" },
            class: "w-full px-3 py-2 text-sm rounded-lg border border-border focus:ring-blue-500 focus:border-blue-500" %>
        </div>
      </div>

      <div class="flex justify-end gap-3 pt-4 border-t border-border">
        <%= link_to "取消", accounts_path, class: "px-4 py-2 text-sm font-medium text-secondary hover:bg-surface-inset rounded-lg transition-smooth" %>
        <button type="submit" class="px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth">
          <%= t("common.create") %>
        </button>
      </div>
    <% end %>
  </div>
</div>

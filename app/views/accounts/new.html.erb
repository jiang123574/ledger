<div class="space-y-6" data-controller="credit-card-form">
  <div class="flex items-center gap-4">
    <%= link_to accounts_path, class: "p-2 hover:bg-surface-inset dark:hover:bg-surface-dark-inset rounded-lg transition-smooth" do %>
      <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
    <% end %>
    <h1 class="text-2xl font-semibold text-primary dark:text-primary-dark"><%= t("accounts.new_account") %></h1>
  </div>

  <div class="bg-container dark:bg-container-dark rounded-lg shadow-border-xs dark:shadow-dark-border-xs">
    <%= form_with model: @account, local: true, class: "p-6 space-y-6" do |f| %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">账户名称</label>
          <%= render Ds::InputComponent.new(form: f, field: :name, placeholder: "例如：我的银行卡") %>
        </div>

        <div>
          <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">账户类型</label>
          <%= render Ds::InputComponent.new(form: f, field: :type, type: :select, 
                choices: Account::ACCOUNT_TYPES.map { |k, v| [v, k] },
                include_blank: "选择类型") %>
        </div>

        <div>
          <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">初始余额</label>
          <%= render Ds::InputComponent.new(form: f, field: :initial_balance, type: :number, 
                placeholder: "0.00", prefix: "¥") %>
        </div>

        <div>
          <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">货币</label>
          <%= render Ds::InputComponent.new(form: f, field: :currency, type: :select,
                choices: Currency.active.map { |c| ["#{c.code} - #{c.name}", c.code] },
                include_blank: false) %>
        </div>
      </div>

      <div data-credit-card-form-target="creditCardFields" class="hidden">
        <h3 class="text-lg font-medium text-primary dark:text-primary-dark mb-4">信用卡设置</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">信用额度</label>
            <%= render Ds::InputComponent.new(form: f, field: :credit_limit, type: :number, 
                  placeholder: "0.00", prefix: "¥") %>
          </div>

          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">账单日</label>
            <%= render Ds::InputComponent.new(form: f, field: :billing_day, type: :select,
                  choices: (1..28).map { |d| ["每月#{d}日", d] },
                  include_blank: false) %>
          </div>

          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">账单日交易计入</label>
            <%= render Ds::InputComponent.new(form: f, field: :billing_day_mode, type: :select,
                  choices: [["本期账单", "current"], ["下期账单", "next"]],
                  include_blank: false) %>
          </div>

          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">还款日类型</label>
            <%= render Ds::InputComponent.new(form: f, field: :due_day_mode, type: :select,
                  choices: [["固定日期", "fixed"], ["账单日后N天", "relative"]],
                  include_blank: false,
                  data: { "credit-card-form-target": "dueDayModeSelect", action: "change->credit-card-form#toggleDueDayMode" }) %>
          </div>

          <div data-credit-card-form-target="dueDayFixed">
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">还款日（固定）</label>
            <%= render Ds::InputComponent.new(form: f, field: :due_day, type: :select,
                  choices: (1..28).map { |d| ["每月#{d}日", d] },
                  include_blank: false) %>
          </div>

          <div data-credit-card-form-target="dueDayRelative" class="hidden">
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">账单日后天数</label>
            <%= render Ds::InputComponent.new(form: f, field: :due_day_offset, type: :number, 
                  placeholder: "1-28", min: 1, max: 28) %>
          </div>
        </div>
      </div>

      <div class="flex justify-end gap-3 pt-4 border-t border-border dark:border-border-dark">
        <%= link_to "取消", accounts_path, class: "px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth btn-modern" %>
        <button type="submit" class="px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover dark:hover:bg-inverse-dark-hover transition-smooth btn-modern">
          <%= t("common.create") %>
        </button>
      </div>
    <% end %>
  </div>
</div>

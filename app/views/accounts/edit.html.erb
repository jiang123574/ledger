<div class="space-y-6">
  <h1 class="text-2xl font-bold text-gray-900">Edit Account</h1>

  <div class="bg-white rounded-lg shadow p-6">
    <%= form_with model: @account, local: true, class: "space-y-4" do |f| %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_field :name, class: "mt-1 block w-full border rounded-md px-3 py-2" %>
        </div>

        <div>
          <%= f.label :type, class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_field :type, placeholder: "CASH, BANK, CREDIT", class: "mt-1 block w-full border rounded-md px-3 py-2" %>
        </div>

        <div>
          <%= f.label :initial_balance, class: "block text-sm font-medium text-gray-700" %>
          <%= f.number_field :initial_balance, step: "0.01", class: "mt-1 block w-full border rounded-md px-3 py-2" %>
        </div>

        <div>
          <%= f.label :currency, class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_field :currency, maxlength: 3, class: "mt-1 block w-full border rounded-md px-3 py-2" %>
        </div>
      </div>

      <div class="flex justify-end space-x-4">
        <%= link_to "Cancel", accounts_path, class: "px-4 py-2 border rounded-md hover:bg-gray-50" %>
        <%= f.submit "Update", class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
      </div>
    <% end %>
  </div>
</div>

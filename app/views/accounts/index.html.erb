</div>

<script type="module">
import { initSelectorWithData } from 'selectors';

// 防止 turbo:render 导致重复初始化
if (!window.modalSelectorsInitialized) {
  window.modalSelectorsInitialized = true;

  // 解析数据源
  const modalAccountsDataEl = document.getElementById('accounts-data');
  const modalCategoriesDataEl = document.getElementById('modal-categories-data');

  const modalAccountsData = modalAccountsDataEl ? JSON.parse(modalAccountsDataEl.textContent) : [];
  const modalCategoriesData = modalCategoriesDataEl ? JSON.parse(modalCategoriesDataEl.textContent) : [];

  // 转换分类数据格式
  const modalCategoryData = modalCategoriesData.map(function(cat) {
    return {
      id: cat.name,
      name: cat.name,
      full_name: cat.full_name || cat.name,
      pinyin: cat.pinyin || ''
    };
  });

  // 抽取公共初始化函数
  function initModalSelectors(modalType) {
    // 初始化账户选择器
    initSelectorWithData({
      searchInputId: `new-${modalType}-account-search`,
      dropdownId: `new-${modalType}-account-dropdown`,
      filterInputId: `new-${modalType}-account-filter`,
      optionsId: `new-${modalType}-account-options`,
      hiddenInputId: `new-${modalType}-account-id`,
      dataSource: modalAccountsData,
      noMatchText: '无匹配账户'
    });
    
    // 初始化分类选择器
    initSelectorWithData({
      searchInputId: `new-${modalType}-category-search`,
      dropdownId: `new-${modalType}-category-dropdown`,
      filterInputId: `new-${modalType}-category-filter`,
      optionsId: `new-${modalType}-category-options`,
      hiddenInputId: `new-${modalType}-category-id`,
      dataSource: modalCategoryData,
      emptyOption: { label: '不设置分类', value: '', display: '' },
      noMatchText: '无匹配分类'
    });
    
    // 初始化资金来源选择器（仅应收款）
    if (modalType === 'receivable') {
      initSelectorWithData({
        searchInputId: 'new-receivable-funding-account-search',
        dropdownId: 'new-receivable-funding-account-dropdown',
        filterInputId: 'new-receivable-funding-account-filter',
        optionsId: 'new-receivable-funding-account-options',
        hiddenInputId: 'new-receivable-funding-account-id',
        dataSource: modalAccountsData,
        noMatchText: '无匹配账户'
      });
    }
  }

  function openNewReceivableModal() {
    const form = document.getElementById('new-receivable-form');
    if (form) {
      form.reset();
      const dateInput = form.querySelector('input[name="receivable[date]"]');
      if (dateInput) dateInput.value = '<%= Date.today.to_s %>';
    }
    
    // 重置资金来源字段
    const fundingAccountIdInput = document.getElementById('new-receivable-funding-account-id');
    const fundingAccountSearchInput = document.getElementById('new-receivable-funding-account-search');
    if (fundingAccountIdInput) fundingAccountIdInput.value = '';
    if (fundingAccountSearchInput) fundingAccountSearchInput.value = '';
    
    initModalSelectors('receivable');
    
    const modal = document.getElementById('add-receivable-modal');
    if (modal) modal.classList.remove('hidden');
  }

  function openSettleReceivableModal() {
    const form = document.getElementById('settle-receivable-form');
    if (form) {
      form.reset();
      const dateInput = form.querySelector('input[name="settlement_date"]');
      if (dateInput) dateInput.value = '<%= Date.today.to_s %>';
    }
    
    initSettleReceivableSelectors();
    
    const modal = document.getElementById('settle-receivable-modal');
    if (modal) modal.classList.remove('hidden');
  }

  function initSettleReceivableSelectors() {
    const receivablesDataEl = document.getElementById('receivables-data');
    const receivablesData = receivablesDataEl ? JSON.parse(receivablesDataEl.textContent) : [];

    initSelectorWithData({
      searchInputId: 'settle-receivable-search',
      dropdownId: 'settle-receivable-dropdown',
      filterInputId: 'settle-receivable-filter',
      optionsId: 'settle-receivable-options',
      hiddenInputId: 'settle-receivable-id',
      dataSource: receivablesData,
      noMatchText: '无匹配应收款'
    });

    initSelectorWithData({
      searchInputId: 'settle-account-search',
      dropdownId: 'settle-account-dropdown',
      filterInputId: 'settle-account-filter',
      optionsId: 'settle-account-options',
      hiddenInputId: 'settle-account-id',
      dataSource: modalAccountsData,
      noMatchText: '无匹配账户'
    });
  }

  window.setFullAmount = function() {
    const receivableId = document.getElementById('settle-receivable-id').value;
    if (receivableId) {
      const receivablesDataEl = document.getElementById('receivables-data');
      const receivablesData = receivablesDataEl ? JSON.parse(receivablesDataEl.textContent) : [];
      const receivable = receivablesData.find(function(r) { return r.id == receivableId; });
      if (receivable) {
        document.getElementById('settle-amount').value = receivable.remaining_amount;
      }
    }
  };

  document.getElementById('settle-receivable-id').addEventListener('change', function() {
    window.setFullAmount();
  });

  document.getElementById('settle-receivable-form').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const receivableId = document.getElementById('settle-receivable-id').value;
    const amount = document.getElementById('settle-amount').value;
    const accountId = document.getElementById('settle-account-id').value;
    const settlementDate = document.getElementById('settle-date').value;
    const note = document.querySelector('input[name="note"]').value;
    
    if (!receivableId || !amount || !accountId || !settlementDate) {
      alert('请填写必填字段');
      return;
    }

    const form = e.target;
    const submitBtn = form.querySelector('button[type="submit"]');
    const originalText = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.textContent = '提交中...';
    
    fetch('/receivables/' + receivableId + '/settle', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
        'Accept': 'application/json'
      },
      body: JSON.stringify({
        amount: amount,
        account_id: accountId,
        settlement_date: settlementDate,
        note: note
      })
    })
    .then(function(response) {
      if (response.ok || response.redirected) {
        window.location.reload();
      } else {
        return response.json().then(function(data) {
          throw new Error(data.error || '报销失败');
        });
      }
    })
    .catch(function(error) {
      console.error('Error:', error);
      alert(error.message || '报销失败，请重试');
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    });
  });

  // 暴露函数到全局作用域（供快捷键调用）
  window.openNewReceivableModal = openNewReceivableModal;
  window.openSettleReceivableModal = openSettleReceivableModal;
}
</script>

<!-- ========== 信用卡账单区域 ========== -->

<script>
// 视图模式切换（按日期 / 按账单）
(function() {
  let currentViewMode = '<%= params[:view_mode] %>' || 'date';
  window.currentViewMode = currentViewMode;

  window.switchViewMode = function(mode) {
    currentViewMode = mode;
    window.currentViewMode = mode;

    const wrapper = document.getElementById('credit-bill-wrapper');
    const txList = document.getElementById('transaction-list');
    const summaryBar = document.getElementById('summary-bar');
    const filterBar = document.getElementById('filter-bar');
    const dateBtn = document.getElementById('mode-date-btn');
    const billBtn = document.getElementById('mode-bill-btn');

    if (mode === 'bill') {
      if (wrapper) wrapper.classList.remove('hidden');
      if (txList) txList.classList.add('hidden');
      if (summaryBar) summaryBar.classList.add('hidden');
      if (filterBar) filterBar.classList.add('hidden');
      if (dateBtn) { dateBtn.className = 'px-2.5 py-1 rounded-md transition-smooth text-secondary dark:text-secondary-dark hover:bg-surface-hover'; }
      if (billBtn) { billBtn.className = 'px-2.5 py-1 rounded-md transition-smooth bg-blue-500 text-white font-medium shadow-xs'; }
      if (window.initCreditBills) window.initCreditBills();
    } else {
      if (wrapper) wrapper.classList.add('hidden');
      if (txList) txList.classList.remove('hidden');
      if (summaryBar) summaryBar.classList.remove('hidden');
      if (filterBar) filterBar.classList.remove('hidden');
      if (dateBtn) { dateBtn.className = 'px-2.5 py-1 rounded-md transition-smooth bg-blue-500 text-white font-medium shadow-xs'; }
      if (billBtn) { billBtn.className = 'px-2.5 py-1 rounded-md transition-smooth text-secondary dark:text-secondary-dark hover:bg-surface-hover'; }
    }

    const params = new URLSearchParams(window.location.search);
    if (mode === 'bill') {
      params.set('view_mode', 'bill');
    } else {
      params.delete('view_mode');
    }
    const newUrl = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
    history.replaceState({ mode: mode }, '', newUrl);
  };
})();
</script>




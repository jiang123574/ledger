// 重新初始化页面脚本
function reinitializePageScripts() {
  // 重新初始化 entry-list controller
  const entryListEl = document.getElementById('transaction-list');
  if (entryListEl && window.Stimulus) {
    const controller = window.Stimulus.getControllerForElementAndIdentifier(entryListEl, 'entry-list');
    if (controller) {
      controller.disconnect();
      controller.connect();
    }
  }

  // 重新初始化信用卡账单区域（仅在 Stimulus connect 未自动初始化时兜底）
  if (typeof window.initCreditBills === 'function') {
    const wrapper = document.getElementById('credit-bill-wrapper')
    // 只有当 wrapper 存在且有 accountIdValue 时才调用
    if (wrapper && wrapper.dataset.billStatementAccountIdValue) {
      window.initCreditBills()
    }
  }

  // 重新初始化日期筛选显示
  if (typeof syncPeriodInputType === 'function') syncPeriodInputType();

  // 重新绑定分类筛选按钮事件
  const categoryFilterBtn = document.getElementById('open-category-filter');
  if (categoryFilterBtn && !categoryFilterBtn._bound) {
    categoryFilterBtn._bound = true;
    categoryFilterBtn.addEventListener('click', function() {
      document.getElementById('category-filter-modal').classList.remove('hidden');
      document.getElementById('category-filter-search').value = '';
      document.getElementById('category-filter-search').focus();
      const sections = document.querySelectorAll('.category-type-section');
      sections.forEach(function(s) { s.style.removeProperty('display'); });
      const items = document.querySelectorAll('.category-filter-item');
      items.forEach(function(item) { item.style.removeProperty('display'); });
    });
  }

  // 重新绑定搜索框 IME composition 事件
  const searchInput = document.getElementById('search-input');
  if (searchInput && !searchInput._bound) {
    searchInput._bound = true;
    searchInput._isComposing = false;

    searchInput.addEventListener('compositionstart', function() {
      this._isComposing = true;
    });

    searchInput.addEventListener('compositionend', function() {
      this._isComposing = false;
      debouncedApplyFilters();
    });

    searchInput.addEventListener('input', function() {
      if (this._isComposing) return;
      debouncedApplyFilters();
    });

    searchInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && !this._isComposing) {
        applyFilters();
      }
    });
  }

  // 重新绑定筛选下拉 change 事件
  const periodTypeFilter = document.getElementById('period-type-filter');
  if (periodTypeFilter && !periodTypeFilter._bound) {
    periodTypeFilter._bound = true;
    periodTypeFilter.addEventListener('change', syncPeriodInputType);
    periodTypeFilter.addEventListener('change', applyFilters);
  }
  const typeFilter = document.getElementById('type-filter');
  if (typeFilter && !typeFilter._bound) {
    typeFilter._bound = true;
    typeFilter.addEventListener('change', applyFilters);
  }
}


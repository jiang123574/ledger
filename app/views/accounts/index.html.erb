      is_inflow ? "INCOME" : "EXPENSE"
    end
  else
    entry_type
  end
  # 转账对方账户名称
  transfer_counterpart = if is_inflow
    e.source_account_for_transfer&.name
  else
    e.target_account_for_display&.name
  end
%>
                <div class="flex-1 min-w-0">

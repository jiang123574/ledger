// 初始化账户选择器
function initAccountSelector(searchInputId, dropdownId, filterInputId, optionsId, hiddenInputId, placeholder) {
  var searchInput = document.getElementById(searchInputId);
  var dropdown = document.getElementById(dropdownId);
  var filterInput = document.getElementById(filterInputId);
  var optionsContainer = document.getElementById(optionsId);
  var hiddenInput = document.getElementById(hiddenInputId);
  
  if (!searchInput || !dropdown || !optionsContainer) return;
  
  function renderOptions(filterText) {
    var filtered = allAccounts.filter(function(acc) {
      if (!filterText) return true;
      var query = filterText.toLowerCase();
      if (acc.name && acc.name.toLowerCase().includes(query)) return true;
      if (acc.pinyin && acc.pinyin.includes(query)) return true;
      return false;
    });
    
    if (filtered.length === 0) {
      return '<div class="px-3 py-2 text-sm text-secondary dark:text-secondary-dark">无匹配账户</div>';
    }
    
    return filtered.map(function(acc) {
      var selected = hiddenInput && hiddenInput.value == acc.id ? 'bg-blue-50 dark:bg-blue-900/20' : '';
      // 使用 escapeHtml 防止 XSS
      var escapedName = escapeHtml(acc.name);
      return '<div class="account-option px-3 py-1.5 text-sm cursor-pointer hover:bg-surface-hover dark:hover:bg-surface-dark-hover text-primary dark:text-primary-dark ' + selected + '" data-id="' + acc.id + '" data-name="' + escapedName + '">' +
               escapedName +
             '</div>';
    }).join('');
  }
  
  function updateOptions() {
    var filterText = filterInput ? filterInput.value : '';
    optionsContainer.innerHTML = renderOptions(filterText);
    
    optionsContainer.querySelectorAll('.account-option').forEach(function(option) {
      option.addEventListener('click', function() {
        var id = this.dataset.id;
        var name = this.dataset.name;
        if (hiddenInput) hiddenInput.value = id;
        if (searchInput) searchInput.value = name;
        if (dropdown) dropdown.classList.add('hidden');
        if (filterInput) filterInput.value = '';
      });
    });
  }
  
  if (searchInput) {
    searchInput.addEventListener('click', function() {
      dropdown.classList.toggle('hidden');
      if (!dropdown.classList.contains('hidden')) {
        updateOptions();
        if (filterInput) filterInput.focus();
      }
    });
  }
  
  if (filterInput) {
    filterInput.addEventListener('focus', function() {
      this.placeholder = '';
    });
    filterInput.addEventListener('blur', function() {
      this.placeholder = '搜索账户...';
    });
    filterInput.addEventListener('input', function() {
      updateOptions();
    });
  }
  
  document.addEventListener('click', function(e) {
    if (dropdown && !dropdown.contains(e.target) && e.target !== searchInput) {
      dropdown.classList.add('hidden');
    }
  });
}

// 初始化账户选择器
initAccountSelector('account-search-input', 'account-dropdown', 'account-filter-input', 'account-options', 'transaction_account_id', '选择转出账户');
initAccountSelector('account-search-input-income', 'account-dropdown-income', 'account-filter-input-income', 'account-options-income', 'transaction_account_id_income', '选择账户');
initAccountSelector('funding-account-search-input', 'funding-account-dropdown', 'funding-account-filter-input', 'funding-account-options', 'funding_account_id', '不补记资金来源');
initAccountSelector('target-account-search-input', 'target-account-dropdown', 'target-account-filter-input', 'target-account-options', 'target_account_id', '选择转入账户');

// 表单提交前，根据模式将正确的 account_id 写入 transaction[account_id]
var addTransactionForm = document.querySelector('#add-transaction-modal form');
if (addTransactionForm) {
  addTransactionForm.addEventListener('submit', function(e) {
    if (transactionMode === 'category') {
      // 收支模式：将 income hidden input 的值复制到 account_id
      var incomeHidden = document.getElementById('transaction_account_id_income');
      var transferHidden = document.getElementById('transaction_account_id');
      if (incomeHidden && transferHidden) {
        transferHidden.value = incomeHidden.value;
      }
    }
    // 转账模式：transaction_account_id 已经直接绑定了转出账户选择器
  });
}

// 设置默认账户（如果在某个账户的视图中）
function setDefaultAccount() {
  var urlParams = new URLSearchParams(window.location.search);
  var accountId = urlParams.get('account_id');
  
  if (accountId) {
    // 找到账户名称
    var accountsData = document.getElementById('accounts-data');
    if (accountsData) {
      var accounts = JSON.parse(accountsData.textContent);
      var account = accounts.find(function(acc) { return acc.id == accountId; });
      
      if (account) {
        // 收支模式：设置到 income 账户选择器
        var incomeHidden = document.getElementById('transaction_account_id_income');
        var incomeSearch = document.getElementById('account-search-input-income');
        if (incomeHidden) incomeHidden.value = account.id;
        if (incomeSearch) incomeSearch.value = account.name;

        // 转账模式：设置为默认转出账户
        var transferHidden = document.getElementById('transaction_account_id');
        var transferSearch = document.getElementById('account-search-input');
        if (transferHidden) transferHidden.value = account.id;
        if (transferSearch) transferSearch.value = account.name;
      }
    }
  }
}

// 互换转账的转出和转入账户
function swapTransferAccounts() {
  var sourceHiddenInput = document.getElementById('transaction_account_id');
  var sourceSearchInput = document.getElementById('account-search-input');
  var targetHiddenInput = document.getElementById('target_account_id');
  var targetSearchInput = document.getElementById('target-account-search-input');
  
  if (!sourceHiddenInput || !targetHiddenInput) return;
  
  // 交换值
  var tempId = sourceHiddenInput.value;
  var tempName = sourceSearchInput.value;
  
  sourceHiddenInput.value = targetHiddenInput.value;
  sourceSearchInput.value = targetSearchInput.value;
  
  targetHiddenInput.value = tempId;
  targetSearchInput.value = tempName;
  
  console.log('Accounts swapped');
}

// 设置默认账户
setDefaultAccount();

// 修复 Turbo 缓存导致的 modal 嵌套问题
function fixModalPositions() {
  const modals = ['edit-transaction-modal', 'category-filter-modal'];
  modals.forEach(function(id) {
    const modal = document.getElementById(id);
    if (modal && modal.parentElement && modal.parentElement.id === 'add-transaction-modal') {
      document.body.appendChild(modal);
    }
  });
}

// DOM 加载完成后修复
document.addEventListener('DOMContentLoaded', fixModalPositions);

// Turbo 页面加载后修复
document.addEventListener('turbo:load', fixModalPositions);
document.addEventListener('turbo:render', fixModalPositions);
</script>

<!-- ========== 信用卡账单区域 ========== -->
<div id="credit-bill-wrapper" class="<%= (params[:account_id].present? && current_account&.credit_card? && params[:view_mode] == 'bill') ? '' : 'hidden' %>" data-account-id="<%= params[:account_id].present? && current_account&.credit_card? ? params[:account_id] : '' %>">
  <!-- 账单卡片行 -->
  <div id="bill-cards-container" class="px-3 lg:px-4 py-2 border-b border-border dark:border-border-dark bg-surface-inset dark:bg-surface-dark-inset overflow-x-auto">
    <div class="flex gap-3 min-w-max" id="bill-cards">
      <div class="text-sm text-secondary dark:text-secondary-dark">加载中...</div>
    </div>
  </div>

  <!-- 账单交易明细区域 -->
  <div id="bill-detail-section" class="hidden" data-controller="credit-bill-entries">
    <!-- 账期信息 + 筛选栏 -->
    <div class="px-3 lg:px-4 py-2 border-b border-border dark:border-border-dark flex items-center gap-3 text-xs">
      <span id="bill-period-info" class="font-medium text-primary dark:text-primary-dark"></span>
      <span id="bill-due-info" class="text-secondary dark:text-secondary-dark"></span>
    </div>
    <div class="px-3 lg:px-4 py-1.5 border-b border-border/50 dark:border-border-dark/50 flex items-center gap-2 flex-wrap text-xs">
      <span class="text-secondary dark:text-secondary-dark">筛选：</span>
      <button onclick="filterBillEntries('all')" class="bill-filter-btn px-2 py-0.5 rounded bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400" data-filter="all">全部</button>
      <button onclick="filterBillEntries('repay')" class="bill-filter-btn px-2 py-0.5 rounded hover:bg-surface-hover" data-filter="repay">还款</button>
      <button onclick="filterBillEntries('spend')" class="bill-filter-btn px-2 py-0.5 rounded hover:bg-surface-hover" data-filter="spend">消费</button>
    </div>
    <!-- 交易明细（和按日期模式一致的卡片式布局） -->
    <div class="divide-y divide-border dark:divide-border-dark" id="bill-entries-container" data-credit-bill-entries-target="container"></div>
    <template data-credit-bill-entries-target="template">
      <div class="p-3 hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">
        <div class="flex items-center gap-3">
          <div class="shrink-0 text-xs text-secondary dark:text-secondary-dark w-20" data-field="date"></div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2">
              <span data-field="type"></span>
              <p class="text-sm font-medium text-primary dark:text-primary-dark truncate" data-field="name"></p>
            </div>
            <p class="text-xs text-secondary dark:text-secondary-dark truncate mt-0.5" data-field="note"></p>
          </div>
          <div class="text-right shrink-0">
            <p data-field="amount"></p>
            <p class="text-xs text-secondary dark:text-secondary-dark" data-field="balance"></p>
          </div>
          <div class="flex items-center gap-1 shrink-0">
            <button type="button" data-role="edit" class="p-1.5 rounded-lg hover:bg-surface-hover dark:hover:bg-surface-dark-hover text-secondary dark:text-secondary-dark hover:text-primary transition-smooth">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
            </button>
            <button type="button" data-role="delete" class="p-1.5 rounded-lg hover:bg-expense-light text-secondary dark:text-secondary-dark hover:text-expense transition-smooth">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
            </button>
          </div>
        </div>
      </div>
    </template>
  </div>

  <!-- 默认显示普通交易列表的提示（当未选中任何账单时） -->
  <div id="bill-default-hint" class="p-3 text-center text-xs text-secondary dark:text-secondary-dark hidden">
    点击上方账单卡片查看该期交易明细
  </div>
</div>

<script>
(function() {
  var wrapper = document.getElementById('credit-bill-wrapper');
  var accountId = wrapper?.dataset?.accountId;
  var currentViewMode = '<%= params[:view_mode] %>' || 'date';
  var billFormatters = window.BillFormatters || {};

  function formatBillMoney(value) {
    if (billFormatters.formatMoney) return billFormatters.formatMoney(value);
    var num = parseFloat(value) || 0;
    return num.toLocaleString('zh-CN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function initCreditBills() {
    wrapper = document.getElementById('credit-bill-wrapper');
    accountId = wrapper?.dataset?.accountId;
    if (!accountId || !wrapper) return;

    // 插入到交易列表前面
    var txList = document.getElementById('transaction-list');
    if (txList && !txList.parentElement.contains(wrapper)) {
      txList.parentElement.insertBefore(wrapper, txList);
    }

    // 如果当前模式是账单模式，初始化
    if (currentViewMode === 'bill') {
      wrapper.classList.remove('hidden');
      loadBillCards();
    }
  }

  function getBillDetailSection() {
    return document.getElementById('bill-detail-section');
  }

  function dispatchBillEntriesEvent(eventName, detail) {
    var section = getBillDetailSection();
    if (!section) return false;
    if (section.dataset.creditBillEntriesReady !== 'true') return false;

    section.dispatchEvent(new CustomEvent(eventName, { detail: detail || {} }));
    return true;
  }

  function renderBillEntryList(entries) {
    if (dispatchBillEntriesEvent('credit-bill-entries:render', { entries: entries || [] })) {
      return;
    }
    var container = document.getElementById('bill-entries-container');
    if (container) container.innerHTML = '<div class="p-8 text-center text-secondary dark:text-secondary-dark text-sm">该期暂无交易记录</div>';
  }

  function showBillEntriesLoading() {
    if (dispatchBillEntriesEvent('credit-bill-entries:loading')) {
      return;
    }
    var container = document.getElementById('bill-entries-container');
    if (container) container.innerHTML = '<div class="p-4 text-center text-secondary dark:text-secondary-dark text-sm">加载中...</div>';
  }

  function showBillEntriesError() {
    if (dispatchBillEntriesEvent('credit-bill-entries:error', { message: '加载失败' })) {
      return;
    }
    var container = document.getElementById('bill-entries-container');
    if (container) container.innerHTML = '<div class="p-4 text-center text-red-500 text-sm">加载失败</div>';
  }

  // 切换视图模式（按日期 / 按账单）
  window.switchViewMode = function(mode) {
    currentViewMode = mode;
    var txList = document.getElementById('transaction-list');
    var summaryBar = document.getElementById('summary-bar');
    var filterBar = document.getElementById('filter-bar');
    var dateBtn = document.getElementById('mode-date-btn');
    var billBtn = document.getElementById('mode-bill-btn');

    if (mode === 'bill') {
      // 切到账单模式
      if (wrapper) wrapper.classList.remove('hidden');
      if (txList) txList.classList.add('hidden');
      if (summaryBar) summaryBar.classList.add('hidden');
      if (filterBar) filterBar.classList.add('hidden');
      if (dateBtn) { dateBtn.className = 'px-2.5 py-1 rounded-md transition-smooth text-secondary dark:text-secondary-dark hover:bg-surface-hover'; }
      if (billBtn) { billBtn.className = 'px-2.5 py-1 rounded-md transition-smooth bg-blue-500 text-white font-medium shadow-sm'; }
      loadBillCards();
    } else {
      // 切回日期模式
      if (wrapper) wrapper.classList.add('hidden');
      if (txList) txList.classList.remove('hidden');
      if (summaryBar) summaryBar.classList.remove('hidden');
      if (filterBar) filterBar.classList.remove('hidden');
      if (dateBtn) { dateBtn.className = 'px-2.5 py-1 rounded-md transition-smooth bg-blue-500 text-white font-medium shadow-sm'; }
      if (billBtn) { billBtn.className = 'px-2.5 py-1 rounded-md transition-smooth text-secondary dark:text-secondary-dark hover:bg-surface-hover'; }
    }

    // 更新 URL（不刷新页面）
    var params = new URLSearchParams(window.location.search);
    if (mode === 'bill') {
      params.set('view_mode', 'bill');
    } else {
      params.delete('view_mode');
    }
    var newUrl = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
    history.replaceState({ mode: mode }, '', newUrl);
  };

  // 加载账单卡片
  window.loadBillCards = function() {
    if (!accountId) return;
    fetch('/accounts/' + accountId + '/bills.json?count=4', {
      headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(r => r.json())
    .then(data => {
      renderBillCards(data);
    })
    .catch(err => console.error('Failed to load bills:', err));
  };

  // 渲染账单卡片
  function renderBillCards(data) {
    var container = document.getElementById('bill-cards');
    if (!container || !data.bills || data.bills.length === 0) {
      container.innerHTML = '<div class="text-sm text-secondary dark:text-secondary-dark">暂无账单数据</div>';
      return;
    }

    // 找当前期索引（用于高亮）
    var currentIdx = data.bills.findIndex(b => b.current);

    var html = '';
    data.bills.forEach(function(bill, idx) {
      var isCurrent = bill.current;
      var isUnbilled = idx === 0 && !isCurrent; // 第一张且不是当期 = 未出账单
      var isSelected = selectedBillLabel === bill.label;
      var cardClass = 'flex-shrink-0 p-3 rounded-lg cursor-pointer transition-smooth min-w-[180px] ';
      if (isSelected) {
        cardClass += 'bg-blue-100 dark:bg-blue-900/40 ring-2 ring-blue-400';
      } else if (isUnbilled) {
        // 未出账单 - 特殊样式：橙色调，表示尚未出账
        cardClass += 'bg-orange-50 dark:bg-orange-900/20 border border-orange-200 dark:border-orange-800 hover:border-orange-400';
      } else if (isCurrent) {
        cardClass += 'bg-white dark:bg-surface-dark border border-border dark:border-border-dark hover:border-blue-300';
      } else {
        cardClass += 'bg-gray-50 dark:bg-surface-dark border border-transparent hover:border-border dark:hover:border-border-dark';
      }

      html += '<div class="' + cardClass + '" onclick="selectBill(\'' + escapeHtml(bill.label) + '\', \'' + bill.start_date + '\', \'' + bill.end_date + '\')" data-label="' + escapeHtml(bill.label) + '">';
      // 卡片标题
      html += '<div class="flex items-center justify-between mb-2">';
      if (isUnbilled) {
        html += '<span class="font-semibold text-sm text-orange-600 dark:text-orange-400">未出账单</span>';
        html += '<span class="text-[10px] px-1.5 py-0.5 rounded bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400">进行中</span>';
      } else if (isCurrent) {
        html += '<span class="font-semibold text-sm ' + (isCurrent ? 'text-blue-600 dark:text-blue-400' : 'text-primary dark:text-primary-dark') + '">' + bill.label + '</span>';
        html += '<span class="text-[10px] px-1.5 py-0.5 rounded bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400">当期</span>';
      } else {
        html += '<span class="font-semibold text-sm text-primary dark:text-primary-dark">' + bill.label + '</span>';
      }
      html += '</div>';
      // 账期范围
      html += '<div class="text-xs text-secondary dark:text-secondary-dark mb-1.5">';
      html += '账期：' + bill.start_date + ' ~ ' + bill.end_date;
      html += '</div>';
      // 还款日
      html += '<div class="text-xs text-secondary dark:text-secondary-dark mb-2">';
      html += '账单日 &nbsp;还款日：' + bill.due_date;
      html += '</div>';
      // 金额汇总
      html += '<div class="flex justify-between text-xs pt-1.5 border-t border-border/50 dark:border-border-dark/50">';
      html += '<div><span class="text-secondary dark:text-secondary-dark">消费&取现金额：</span><br/><span class="font-medium text-expense">' + formatBillMoney(bill.spend_amount) + '</span></div>';
      html += '<div class="text-right"><span class="text-secondary dark:text-secondary-dark">还款&退款金额：</span><br/><span class="font-medium text-income">' + formatBillMoney(bill.repay_amount) + '</span></div>';
      html += '</div>';
      // 待还
      if (bill.balance_due > 0) {
        html += '<div class="text-xs mt-1.5 pt-1 border-t border-border/30 dark:border-border-dark/30">';
        html += '<span class="text-secondary dark:text-secondary-dark">待还&退款金额：</span>';
        html += '<span class="font-bold text-expense">' + formatBillMoney(bill.balance_due) + '</span>';
        html += '</div>';
      }
      html += '</div>';
    });

    container.innerHTML = html;

    // 自动选中当前期（如果有的话），否则选未出账单或第一张
    if (!selectedBillLabel) {
      if (currentIdx >= 0) {
        var currentBill = data.bills[currentIdx];
        selectBill(currentBill.label, currentBill.start_date, currentBill.end_date);
      } else if (data.bills.length > 0) {
        var firstBill = data.bills[0];
        selectBill(firstBill.label, firstBill.start_date, firstBill.end_date);
      }
    } else if (selectedBillLabel) {
      loadBillEntries();
    }
  }

  // 当前选中的账单
  var selectedBillLabel = null;
  var selectedStartDate = null;
  var selectedEndDate = null;
  var allBillEntries = [];

  // 选择某期账单
  window.selectBill = function(label, startDate, endDate) {
    selectedBillLabel = label;
    selectedStartDate = startDate;
    selectedEndDate = endDate;

    // 更新卡片选中状态
    document.querySelectorAll('#bill-cards > div').forEach(function(card) {
      var isSelected = card.dataset.label === label;
      if (isSelected) {
        card.className = card.className.replace(/ring-\w+-\d+/g, '').trim() +
          ' bg-blue-100 dark:bg-blue-900/40 ring-2 ring-blue-400';
      } else {
        card.className = card.className.replace(/ring-2 ring-blue-400/g, '').replace(/bg-blue-100 dark:bg-blue-900\/40/g, '');
        // 恢复默认样式...
      }
    });

    // 更新账期信息栏
    var periodInfo = document.getElementById('bill-period-info');
    var dueInfo = document.getElementById('bill-due-info');
    if (periodInfo) periodInfo.textContent = '账期：' + startDate + ' ~ ' + endDate;
    if (dueInfo) dueInfo.textContent = '';

    // 加载交易明细
    loadBillEntries();

    // 显示详情区，隐藏默认提示
    document.getElementById('bill-detail-section')?.classList.remove('hidden');
    document.getElementById('bill-default-hint')?.classList.add('hidden');
  };

  // 加载某期账单的交易明细
  window.loadBillEntries = function() {
    if (!accountId || !selectedStartDate || !selectedEndDate) return;

    showBillEntriesLoading();

    fetch('/accounts/' + accountId + '/bills_entries.json?start_date=' + selectedStartDate + '&end_date=' + selectedEndDate, {
      headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(r => r.json())
    .then(data => {
      allBillEntries = data.entries || [];
      renderBillEntryList(allBillEntries);
    })
    .catch(err => {
      console.error(err);
      showBillEntriesError();
    });
  };

  // 筛选账单交易
  var currentBillFilter = 'all';
  window.filterBillEntries = function(filter) {
    currentBillFilter = filter;
    // 更新按钮样式
    document.querySelectorAll('.bill-filter-btn').forEach(function(btn) {
      if (btn.dataset.filter === filter) {
        btn.className = 'bill-filter-btn px-2 py-0.5 rounded bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400';
      } else {
        btn.className = 'bill-filter-btn px-2 py-0.5 rounded hover:bg-surface-hover text-primary dark:text-primary-dark';
      }
    });
    var filtered = allBillEntries.filter(function(e) {
      if (filter === 'all') return true;
      if (filter === 'repay') return e.is_repayment;
      if (filter === 'spend') return e.is_spend;
      return true;
    });
    renderBillEntryList(filtered);
  }

  // HTML 转义，防止 XSS
  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
              .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  // 初始化
  if (accountId) {
    initCreditBills();
  }
})();
</script>

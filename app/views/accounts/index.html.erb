<div class="space-y-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
    <h1 class="text-2xl font-semibold text-primary"><%= t("accounts.title") %></h1>
    <%= render(Ds::ButtonComponent.new(href: new_account_path, icon: "plus", variant: :primary)) do %>
      <%= t("accounts.new_account") %>
    <% end %>
  </div>

  <!-- Account Cards -->
  <% if @accounts.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @accounts.each do |account| %>
        <%= render(Ds::CardComponent.new, padding: false) do %>
          <div class="p-4">
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-full bg-gray-100 flex items-center justify-center">
                  <span class="text-lg font-bold text-primary"><%= account.name[0] %></span>
                </div>
                <div>
                  <h3 class="font-semibold text-primary"><%= account.name %></h3>
                  <%= render(Ds::BadgeComponent.new(variant: :default, size: :xs)) do %>
                    <%= account.type_name %>
                  <% end %>
                </div>
              </div>
            </div>

            <div class="space-y-2">
              <div class="flex justify-between items-center">
                <span class="text-sm text-secondary"><%= t("accounts.balance") %></span>
                <span class="text-xl font-bold text-primary">¥<%= account.current_balance.to_s("%.2f") %></span>
              </div>
              <% if account.currency.present? %>
                <div class="flex justify-between items-center text-sm">
                  <span class="text-secondary">货币</span>
                  <span class="text-primary"><%= account.currency %></span>
                </div>
              <% end %>
            </div>
          </div>
          <div class="px-4 py-3 bg-surface-inset rounded-b-xl flex justify-end">
            <%= link_to edit_account_path(account), class: "text-sm text-primary hover:text-gray-700 font-medium" do %>
              <%= t("common.edit") %>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <%= render(Ds::CardComponent.new) do %>
      <%= render(Ds::EmptyStateComponent.new(
        icon: "folder",
        title: t("accounts.no_accounts_yet"),
        description: "添加您的第一个账户来开始追踪财务",
        action: new_account_path,
        action_label: t("accounts.new_account")
      )) %>
    <% end %>
  <% end %>
</div>

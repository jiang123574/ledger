const toggleTransferBtn = document.getElementById('toggle-transfer-btn');

// 当前模式: 'category'（收支） 或 'transfer'（转账）
let transactionMode = 'category';

// 切换转账模式
function toggleTransferMode() {
  const categoryFieldWrapper = document.getElementById('category-field-wrapper');
  const targetAccountField = document.getElementById('target-account-field');
  const accountFieldWrapper = document.getElementById('account-field-wrapper');
  const toggleTransferBtn = document.getElementById('toggle-transfer-btn');
  const toggleTransferBtnAlt = document.getElementById('toggle-transfer-btn-alt');
  
  if (transactionMode === 'transfer') {
    // 切回收支模式
    transactionMode = 'category';
    targetAccountField.classList.add('hidden');
    categoryFieldWrapper.classList.remove('hidden');
    accountFieldWrapper.classList.remove('hidden');
    // 重置转账字段值
    const targetHiddenInput = document.getElementById('target_account_id');
    const targetSearchInput = document.getElementById('target-account-search-input');
    const transferAccountHidden = document.getElementById('transaction_account_id');
    const transferAccountSearch = document.getElementById('account-search-input');
    if (targetHiddenInput) targetHiddenInput.value = '';
    if (targetSearchInput) targetSearchInput.value = '';
    if (transferAccountHidden) transferAccountHidden.value = '';
    if (transferAccountSearch) transferAccountSearch.value = '';
  } else {
    // 切到转账模式
    transactionMode = 'transfer';
    categoryFieldWrapper.classList.add('hidden');
    accountFieldWrapper.classList.add('hidden');
    targetAccountField.classList.remove('hidden');
    // 清空收支字段值
    if (categoryHiddenInput) categoryHiddenInput.value = '';
    if (categorySearchInput) categorySearchInput.value = '';
    const incomeAccountHidden = document.getElementById('transaction_account_id_income');
    const incomeAccountSearch = document.getElementById('account-search-input-income');
    if (incomeAccountHidden) incomeAccountHidden.value = '';
    if (incomeAccountSearch) incomeAccountSearch.value = '';
  }
  // 同步 type
  transactionTypeInput.value = transactionMode === 'transfer' ? 'TRANSFER' : (currentCategoryType || 'EXPENSE');
  // 更新资金来源可见性（转账时隐藏）
  updateFundingVisibility();
}

// 根据当前 type 更新资金来源可见性
function updateFundingVisibility() {
  const type = transactionTypeInput?.value || 'EXPENSE';
  if (fundingAccountField && fundingAccountHiddenInput) {
    const showFunding = type === 'EXPENSE';
    fundingAccountField.classList.toggle('hidden', !showFunding);
    if (!showFunding) {
      fundingAccountHiddenInput.value = '';
      if (fundingAccountSearchInput) fundingAccountSearchInput.value = '';
    }
  }
}

// 切换转账按钮（收支模式中的"转账"按钮）
if (toggleTransferBtn) {
  toggleTransferBtn.addEventListener('click', toggleTransferMode);
}
// 切换转账按钮（转账模式中的"收支"按钮）
const toggleTransferBtnAlt = document.getElementById('toggle-transfer-btn-alt');
if (toggleTransferBtnAlt) {
  toggleTransferBtnAlt.addEventListener('click', toggleTransferMode);
}

// 分类选择器逻辑
const categorySearchInput = document.getElementById('category-search-input');
const categoryDropdown = document.getElementById('category-dropdown');
const categoryFilterInput = document.getElementById('category-filter-input');
const categoryOptions = document.getElementById('category-options');
const categoryHiddenInput = document.getElementById('new_transaction_category_id');
let allCategories = [];
let currentCategoryType = 'EXPENSE';

// 从合并数据加载全部分类
const allCategoriesDataEl = document.getElementById('all-categories-data');
if (allCategoriesDataEl) {
  allCategories = JSON.parse(allCategoriesDataEl.textContent);
}

// 渲染分类选项（收支合并，分组显示）
function renderCategoryOptions(filterText) {
  if (!categoryOptions) return '';
  
  const filtered = allCategories.filter(function(cat) {
    if (!filterText) return true;
    const query = filterText.toLowerCase();
    if (cat.full_name && cat.full_name.toLowerCase().includes(query)) return true;
    if (cat.name && cat.name.toLowerCase().includes(query)) return true;
    if (cat.pinyin && cat.pinyin.includes(query)) return true;
    return false;
  });
  
  if (filtered.length === 0) {
    return '<div class="px-3 py-2 text-sm text-secondary dark:text-secondary-dark">无匹配分类</div>';
  }
  
  let html = '';
  let lastType = null;
  
  filtered.forEach(function(cat) {
    // 分组标题
    if (cat.type !== lastType) {
      if (lastType !== null) html += '<div class="border-t border-border dark:border-border-dark my-1"></div>';
      const sectionLabel = cat.type === 'INCOME' ? '收入' : '支出';
      const sectionColor = cat.type === 'INCOME' ? 'text-income' : 'text-expense';
      html += '<div class="px-3 py-1 text-xs font-medium ' + sectionColor + ' uppercase tracking-wide">' + sectionLabel + '</div>';
      lastType = cat.type;
    }
    
    const indent = 'padding-left: ' + (cat.level * 16 + 12) + 'px';
    const selected = categoryHiddenInput && categoryHiddenInput.value == cat.id ? 'bg-blue-50 dark:bg-blue-900/20' : '';
    const escapedName = escapeHtml(cat.full_name);
    html += '<div class="category-option px-3 py-1.5 text-sm cursor-pointer hover:bg-surface-hover dark:hover:bg-surface-dark-hover text-primary dark:text-primary-dark ' + selected + '" style="' + indent + '" data-id="' + cat.id + '" data-name="' + escapedName + '" data-type="' + cat.type + '">' +
             escapedName +
           '</div>';
  });
  
  return html;
}

// 更新分类选项
function updateCategoryOptions() {
  if (!categoryOptions) return;
  const filterText = categoryFilterInput ? categoryFilterInput.value : '';
  categoryOptions.innerHTML = renderCategoryOptions(filterText);
  
  categoryOptions.querySelectorAll('.category-option').forEach(function(option) {
    option.addEventListener('click', function() {
      const id = this.dataset.id;
      const name = this.dataset.name;
      const type = this.dataset.type;
      if (categoryHiddenInput) categoryHiddenInput.value = id;
      if (categorySearchInput) categorySearchInput.value = name;
      if (categoryDropdown) categoryDropdown.classList.add('hidden');
      if (categoryFilterInput) categoryFilterInput.value = '';
      // 根据选中的分类自动推断收支类型
      if (type && type === 'INCOME') {
        currentCategoryType = 'INCOME';
      } else {
        currentCategoryType = 'EXPENSE';
      }
      transactionTypeInput.value = currentCategoryType;
      updateFundingVisibility();
    });
  });
}

// 绑定分类选择器事件
if (categorySearchInput) {
  categorySearchInput.addEventListener('click', function() {
    if (categoryDropdown) {
      categoryDropdown.classList.toggle('hidden');
      if (!categoryDropdown.classList.contains('hidden')) {
        updateCategoryOptions();
        if (categoryFilterInput) categoryFilterInput.focus();
      }
    }
  });
}

if (categoryFilterInput) {
  categoryFilterInput.addEventListener('input', function() {
    updateCategoryOptions();
  });
}

// 点击外部关闭下拉框
document.addEventListener('click', function(e) {
  if (categoryDropdown && !categoryDropdown.contains(e.target) && e.target !== categorySearchInput) {
    categoryDropdown.classList.add('hidden');
  }
});

// 初始化分类选择器
updateCategoryOptions();

function openEditTransactionModal(id) {
  // 先清理旧内容
  const container = document.getElementById('edit-transaction-content');
  container.innerHTML = '';
  
  fetch(`/transactions/${id}/edit`, {
    headers: { 'Accept': 'text/html', 'X-Requested-With': 'XMLHttpRequest' }
  })
  .then(res => res.text())
  .then(html => {
    container.innerHTML = html;
    // 手动执行脚本（innerHTML 不会自动执行 script 标签）
    const scripts = container.querySelectorAll('script');
    scripts.forEach(script => {
      const newScript = document.createElement('script');
      if (script.src) {
        newScript.src = script.src;
      } else {
        newScript.textContent = script.textContent;
      }
      document.body.appendChild(newScript);
      document.body.removeChild(newScript);
    });
    document.getElementById('edit-transaction-modal').classList.remove('hidden');
  })
  .catch(err => console.error('Error loading transaction:', err));
}

function confirmDeleteTransaction(id, name) {
  const label = name || '这笔交易';
  if (!window.confirm(`确定删除${label}吗？`)) return;

  const form = document.createElement('form');
  form.method = 'POST';
  form.action = `/transactions/${id}`;

  const methodInput = document.createElement('input');
  methodInput.type = 'hidden';
  methodInput.name = '_method';
  methodInput.value = 'delete';
  form.appendChild(methodInput);

  const token = document.querySelector('meta[name="csrf-token"]')?.content;
  if (token) {
    const csrfInput = document.createElement('input');
    csrfInput.type = 'hidden';
    csrfInput.name = 'authenticity_token';
    csrfInput.value = token;
    form.appendChild(csrfInput);
  }

  // 保留当前筛选参数，删除后回到原筛选状态
  const currentParams = new URLSearchParams(window.location.search);
  currentParams.forEach(function(value, key) {
    if (value == null || value === '') return;
    const input = document.createElement('input');
    input.type = 'hidden';
    input.name = key;
    input.value = value;
    form.appendChild(input);
  });

  document.body.appendChild(form);
  form.submit();
}

<% if params[:open_new_transaction] == "1" %>
document.getElementById('add-transaction-modal')?.classList.remove('hidden');
<% end %>

// 打开新建交易弹窗
function openNewTransactionModal() {
  document.getElementById('add-transaction-modal')?.classList.remove('hidden');
  // 重置为收支模式
  if (transactionMode === 'transfer') {
    toggleTransferMode();
  }
  if (typeof setDefaultAccount === 'function') setDefaultAccount();
}

// 保存并继续功能 - AJAX 提交，不刷新页面
function submitAndContinue(event) {
  event.preventDefault();
  
  const form = document.querySelector('#add-transaction-modal form');
  if (!form) return;
  
  const amountInput = form.querySelector('input[name="transaction[amount]"]');
  if (!amountInput || !amountInput.value || parseFloat(amountInput.value) <= 0) {
    showErrorToast('请输入有效金额');
    return;
  }
  
  // 收支模式：同步 account_id
  if (transactionMode === 'category') {
    const incomeHidden = document.getElementById('transaction_account_id_income');
    const transferHidden = document.getElementById('transaction_account_id');
    if (incomeHidden && transferHidden) {
      transferHidden.value = incomeHidden.value;
    }
  }
  
  // 获取 CSRF token
  const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content;
  
  // 收集表单数据
  const formData = new FormData(form);
  formData.append('continue_entry', '1');
  
  // 显示加载状态
  const continueBtn = event.target;
  const originalText = continueBtn.textContent;
  continueBtn.textContent = '保存中...';
  continueBtn.disabled = true;
  
  // AJAX 提交（URL 加 .json 确保 Rails 走 JSON 分支）
  fetch(form.action.replace(/\/$/, '') + '.json', {
    method: 'POST',
    headers: {
      'X-CSRF-Token': csrfToken,
      'Accept': 'application/json',
      'X-Requested-With': 'XMLHttpRequest'
    },
    body: formData
  })
  .then(response => {
    if (!response.ok) {
      return response.text().then(text => {
        try { return JSON.parse(text); } catch(e) { return { success: false, error: '服务器错误: ' + response.status }; }
      });
    }
    return response.json();
  })
  .then(data => {
    if (data.success) {
      // 显示成功提示
      showSuccessToast(data.message || '交易已创建，请继续录入');
      
      // 清空部分字段，保持选项不变
      const amountInput = form.querySelector('input[name="transaction[amount]"]');
      const noteInput = form.querySelector('input[name="transaction[note]"]');
      
      if (amountInput) amountInput.value = '';
      if (noteInput) noteInput.value = '';
      
      // 保持账户、分类、类型、日期等选择不变
      // 不关闭弹窗，不刷新页面
    } else {
      // 显示错误提示
      showErrorToast(data.error || '保存失败');
    }
  })
  .catch(error => {
    console.error('Submit error:', error);
    showErrorToast('网络错误，请重试');
  })
  .finally(() => {
    // 恢复按钮状态
    continueBtn.textContent = originalText;
    continueBtn.disabled = false;
  });
}

// 成功提示
function showSuccessToast(message) {
  const toast = document.createElement('div');
  toast.className = 'fixed top-4 right-4 bg-green-500 text-white px-4 py-2 rounded-lg shadow-lg z-50 animate-fade-in';
  toast.textContent = message;
  document.body.appendChild(toast);
  
  setTimeout(function() {
    toast.style.opacity = '0';
    toast.style.transition = 'opacity 0.3s';
    setTimeout(function() { toast.remove(); }, 300);
  }, 2000);
}

// 错误提示
function showErrorToast(message) {
  const toast = document.createElement('div');
  toast.className = 'fixed top-4 right-4 bg-red-500 text-white px-4 py-2 rounded-lg shadow-lg z-50';
  toast.textContent = message;
  document.body.appendChild(toast);
  
  setTimeout(function() {
    toast.style.opacity = '0';
    toast.style.transition = 'opacity 0.3s';
    setTimeout(function() { toast.remove(); }, 300);
  }, 3000);
}

// HTML 转义函数，防止 XSS
function escapeHtml(str) {
  if (!str) return '';
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

// 账户选择器逻辑
let allAccounts = [];
const accountsDataEl = document.getElementById('accounts-data');
if (accountsDataEl) {
  allAccounts = JSON.parse(accountsDataEl.textContent);
}

// 初始化账户选择器
function initAccountSelector(searchInputId, dropdownId, filterInputId, optionsId, hiddenInputId, placeholder) {
  const searchInput = document.getElementById(searchInputId);
  const dropdown = document.getElementById(dropdownId);
  const filterInput = document.getElementById(filterInputId);
  const optionsContainer = document.getElementById(optionsId);
  const hiddenInput = document.getElementById(hiddenInputId);
  
  if (!searchInput || !dropdown || !optionsContainer) return;
  
  function renderOptions(filterText) {
    const filtered = allAccounts.filter(function(acc) {
      if (!filterText) return true;
      const query = filterText.toLowerCase();
      if (acc.name && acc.name.toLowerCase().includes(query)) return true;
      if (acc.pinyin && acc.pinyin.includes(query)) return true;
      return false;
    });
    
    if (filtered.length === 0) {
      return '<div class="px-3 py-2 text-sm text-secondary dark:text-secondary-dark">无匹配账户</div>';
    }
    
    return filtered.map(function(acc) {
      const selected = hiddenInput && hiddenInput.value == acc.id ? 'bg-blue-50 dark:bg-blue-900/20' : '';
      // 使用 escapeHtml 防止 XSS
      const escapedName = escapeHtml(acc.name);
      return '<div class="account-option px-3 py-1.5 text-sm cursor-pointer hover:bg-surface-hover dark:hover:bg-surface-dark-hover text-primary dark:text-primary-dark ' + selected + '" data-id="' + acc.id + '" data-name="' + escapedName + '">' +
               escapedName +
             '</div>';
    }).join('');
  }
  
  function updateOptions() {
    // 确保 allAccounts 已加载（防止时序问题）
    if (allAccounts.length === 0) {
      const accountsDataEl = document.getElementById('accounts-data');
      if (accountsDataEl && accountsDataEl.textContent) {
        try {
          allAccounts = JSON.parse(accountsDataEl.textContent);
        } catch (e) {
          console.error('Failed to parse accounts data:', e);
        }
      }
    }
    
    const filterText = filterInput ? filterInput.value : '';
    optionsContainer.innerHTML = renderOptions(filterText);
    
    optionsContainer.querySelectorAll('.account-option').forEach(function(option) {
      option.addEventListener('click', function() {
        const id = this.dataset.id;
        const name = this.dataset.name;
        if (hiddenInput) hiddenInput.value = id;
        if (searchInput) searchInput.value = name;
        if (dropdown) dropdown.classList.add('hidden');
        if (filterInput) filterInput.value = '';
      });
    });
  }
  
  if (searchInput) {
    searchInput.addEventListener('click', function() {
      dropdown.classList.toggle('hidden');
      if (!dropdown.classList.contains('hidden')) {
        updateOptions();
        if (filterInput) filterInput.focus();
      }
    });
  }
  
  if (filterInput) {
    filterInput.addEventListener('focus', function() {
      this.placeholder = '';
    });
    filterInput.addEventListener('blur', function() {
      this.placeholder = '搜索账户...';
    });
    filterInput.addEventListener('input', function() {
      updateOptions();
    });
  }
  
  document.addEventListener('click', function(e) {
    if (dropdown && !dropdown.contains(e.target) && e.target !== searchInput) {
      dropdown.classList.add('hidden');
    }
  });
}

// 初始化账户选择器
initAccountSelector('account-search-input', 'account-dropdown', 'account-filter-input', 'account-options', 'transaction_account_id', '选择转出账户');
initAccountSelector('account-search-input-income', 'account-dropdown-income', 'account-filter-input-income', 'account-options-income', 'transaction_account_id_income', '选择账户');
initAccountSelector('funding-account-search-input', 'funding-account-dropdown', 'funding-account-filter-input', 'funding-account-options', 'funding_account_id', '不补记资金来源');
initAccountSelector('target-account-search-input', 'target-account-dropdown', 'target-account-filter-input', 'target-account-options', 'target_account_id', '选择转入账户');

// 表单提交前，根据模式将正确的 account_id 写入 transaction[account_id]
const addTransactionForm = document.querySelector('#add-transaction-modal form');
if (addTransactionForm) {
  addTransactionForm.addEventListener('submit', function(e) {
    if (transactionMode === 'category') {
      // 收支模式：将 income hidden input 的值复制到 account_id
      const incomeHidden = document.getElementById('transaction_account_id_income');
      const transferHidden = document.getElementById('transaction_account_id');
      if (incomeHidden && transferHidden) {
        transferHidden.value = incomeHidden.value;
      }
    }
    // 转账模式：transaction_account_id 已经直接绑定了转出账户选择器
  });
}

// 设置默认账户（如果在某个账户的视图中）
function setDefaultAccount() {
  const urlParams = new URLSearchParams(window.location.search);
  const accountId = urlParams.get('account_id');
  
  if (accountId) {
    // 找到账户名称
    const accountsData = document.getElementById('accounts-data');
    if (accountsData) {
      const accounts = JSON.parse(accountsData.textContent);
      const account = accounts.find(function(acc) { return acc.id == accountId; });
      
      if (account) {
        // 收支模式：设置到 income 账户选择器
        const incomeHidden = document.getElementById('transaction_account_id_income');
        const incomeSearch = document.getElementById('account-search-input-income');
        if (incomeHidden) incomeHidden.value = account.id;
        if (incomeSearch) incomeSearch.value = account.name;

        // 转账模式：设置为默认转出账户
        const transferHidden = document.getElementById('transaction_account_id');
        const transferSearch = document.getElementById('account-search-input');
        if (transferHidden) transferHidden.value = account.id;
        if (transferSearch) transferSearch.value = account.name;
      }
    }
  }
}

// 互换转账的转出和转入账户
function swapTransferAccounts() {
  const sourceHiddenInput = document.getElementById('transaction_account_id');
  const sourceSearchInput = document.getElementById('account-search-input');
  const targetHiddenInput = document.getElementById('target_account_id');
  const targetSearchInput = document.getElementById('target-account-search-input');
  
  if (!sourceHiddenInput || !targetHiddenInput) return;
  
  // 交换值
  const tempId = sourceHiddenInput.value;
  const tempName = sourceSearchInput.value;
  
  sourceHiddenInput.value = targetHiddenInput.value;
  sourceSearchInput.value = targetSearchInput.value;
  
  targetHiddenInput.value = tempId;
  targetSearchInput.value = tempName;
  
  console.log('Accounts swapped');
}

// 设置默认账户
setDefaultAccount();

// 修复 Turbo 缓存导致的 modal 嵌套问题
function fixModalPositions() {
  const modals = ['edit-transaction-modal', 'category-filter-modal'];
  modals.forEach(function(id) {
    const modal = document.getElementById(id);
    if (modal && modal.parentElement && modal.parentElement.id === 'add-transaction-modal') {
      document.body.appendChild(modal);
    }
  });
}

// DOM 加载完成后修复
document.addEventListener('DOMContentLoaded', fixModalPositions);

// Turbo 页面加载后修复
document.addEventListener('turbo:load', fixModalPositions);
document.addEventListener('turbo:render', fixModalPositions);

// 全局刷新时移除 skeleton-loader
document.addEventListener('turbo:load', function() {
  document.querySelectorAll('#skeleton-loader').forEach(el => el.remove());
});
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('#skeleton-loader').forEach(el => el.remove());
});

// 暴露 inline handler 需要的函数到 window
window.toggleAccountList = toggleAccountList;
window.viewAllTransactions = viewAllTransactions;
window.filterByAccount = filterByAccount;
window.clearAccountFilter = clearAccountFilter;
window.toggleShowHidden = toggleShowHidden;
window.togglePeriodPicker = togglePeriodPicker;
window.shiftPickerYear = shiftPickerYear;
window.shiftPeriod = shiftPeriod;
window.clearFilters = clearFilters;
window.openNewTransactionModal = openNewTransactionModal;
window.toggleTransferMode = toggleTransferMode;
window.transactionMode = transactionMode;
window.openEditTransactionModal = openEditTransactionModal;
window.submitAndContinue = submitAndContinue;
window.swapTransferAccounts = swapTransferAccounts;
window.confirmDeleteTransaction = confirmDeleteTransaction;
window.applyFilters = applyFilters;
window.syncPeriodInputType = syncPeriodInputType;
window.refreshMainContent = refreshMainContent;
window.updateAccountHighlight = updateAccountHighlight;
window.reinitializePageScripts = reinitializePageScripts;
window.debounce = debounce;
window.selectPickerMonth = selectPickerMonth;
window.selectPickerWeek = selectPickerWeek;
window.selectPickerYear = selectPickerYear;
window.closePeriodPicker = closePeriodPicker;
})();
</script>


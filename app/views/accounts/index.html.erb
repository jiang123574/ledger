// 渲染分类选项（收支合并，分组显示）
function renderCategoryOptions(filterText) {
  if (!categoryOptions) return '';
  
  var filtered = allCategories.filter(function(cat) {
    if (!filterText) return true;
    var query = filterText.toLowerCase();
    if (cat.full_name && cat.full_name.toLowerCase().includes(query)) return true;
    if (cat.name && cat.name.toLowerCase().includes(query)) return true;
    if (cat.pinyin && cat.pinyin.includes(query)) return true;
    return false;
  });
  
  if (filtered.length === 0) {
    return '<div class="px-3 py-2 text-sm text-secondary dark:text-secondary-dark">无匹配分类</div>';
  }
  
  var html = '';
  var lastType = null;
  
  filtered.forEach(function(cat) {
    // 分组标题
    if (cat.type !== lastType) {
      if (lastType !== null) html += '<div class="border-t border-border dark:border-border-dark my-1"></div>';
      var sectionLabel = cat.type === 'INCOME' ? '收入' : '支出';
      var sectionColor = cat.type === 'INCOME' ? 'text-income' : 'text-expense';
      html += '<div class="px-3 py-1 text-xs font-medium ' + sectionColor + ' uppercase tracking-wide">' + sectionLabel + '</div>';
      lastType = cat.type;
    }
    
    var indent = 'padding-left: ' + (cat.level * 16 + 12) + 'px';
    var selected = categoryHiddenInput && categoryHiddenInput.value == cat.id ? 'bg-blue-50 dark:bg-blue-900/20' : '';
    var escapedName = escapeHtml(cat.full_name);
    html += '<div class="category-option px-3 py-1.5 text-sm cursor-pointer hover:bg-surface-hover dark:hover:bg-surface-dark-hover text-primary dark:text-primary-dark ' + selected + '" style="' + indent + '" data-id="' + cat.id + '" data-name="' + escapedName + '" data-type="' + cat.type + '">' +
             escapedName +
           '</div>';
  });
  
  return html;
}


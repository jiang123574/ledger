<script>
// 防抖函数
function debounce(func, wait) {
  var timeout;
  return function executedFunction(...args) {
    var later = () => {
      clearTimeout(timeout);
      func(...args);
    };
    clearTimeout(timeout);
    timeout = setTimeout(later, wait);
  };
}

// 移动端账户列表折叠
function toggleAccountList() {
  var list = document.getElementById('account-list');
  var icon = document.getElementById('account-toggle-icon');
  if (list.classList.contains('hidden')) {
    list.classList.remove('hidden');
    icon.style.transform = 'rotate(180deg)';
  } else {
    list.classList.add('hidden');
    icon.style.transform = 'rotate(0deg)';
  }
}

// 筛选功能
var selectedCategoryIds = selectedCategoryIds || <%= raw selected_category_ids.to_json %>;
var currentPage = currentPage || <%= @page %>;

function applyFilters() {
  var params = new URLSearchParams();
  var search = document.getElementById('search-input').value;
  var type = document.getElementById('type-filter').value;
  var periodType = document.getElementById('period-type-filter').value;
  var periodValue = document.getElementById('period-value-filter').value;
  var accountId = '<%= params[:account_id] %>';
  
  if (search) params.append('search', search);
  if (type) params.append('type', type);
  if (periodType && periodType !== 'all') {
    params.append('period_type', periodType);
    if (periodValue) params.append('period_value', periodValue);
  } else if (periodType === 'all') {
    params.append('period_type', 'all');
  }
  selectedCategoryIds.forEach(function(id) { params.append('category_ids[]', id); });
  if (accountId) params.append('account_id', accountId);
  
  window.location.href = '/accounts?' + params.toString();
}

// 防抖筛选
var debouncedApplyFilters = debounce(applyFilters, 500);

function clearFilters() {
  var accountId = '<%= params[:account_id] %>';
  if (accountId) {
    window.location.href = '/accounts?account_id=' + accountId;
  } else {
    window.location.href = '/accounts';
  }
}

function updateCategoryFilterButtonLabel() {
  var btn = document.getElementById('open-category-filter');
  if (!btn) return;
  btn.textContent = selectedCategoryIds.length > 0 ? '分类筛选 (' + selectedCategoryIds.length + ')' : "分类筛选";
}

function filterByAccount(id) {
  var params = new URLSearchParams(window.location.search);
  params.set('account_id', id);
  window.location.href = '/accounts?' + params.toString();
}

function viewAllTransactions() {
  var params = new URLSearchParams(window.location.search);
  params.delete('account_id');
  window.location.href = '/accounts' + (params.toString() ? '?' + params.toString() : '');
}

function clearAccountFilter() {
  var params = new URLSearchParams(window.location.search);
  params.delete('account_id');
  window.location.href = '/accounts' + (params.toString() ? '?' + params.toString() : '');
}

function toggleShowHidden() {
  var params = new URLSearchParams(window.location.search);
  if (params.get('show_hidden') === 'true') {
    params.delete('show_hidden');
  } else {
    params.set('show_hidden', 'true');
  }
  window.location.href = '/accounts' + (params.toString() ? '?' + params.toString() : '');
}

// 回车搜索
document.getElementById('search-input')?.addEventListener('keypress', function(e) {
  if (e.key === 'Enter') {
    applyFilters();
  }
});

// 搜索输入防抖
document.getElementById('search-input')?.addEventListener('input', debouncedApplyFilters);

function syncPeriodInputType() {
  var periodTypeEl = document.getElementById('period-type-filter');
  var periodValueEl = document.getElementById('period-value-filter');
  var periodValueContainer = document.getElementById('period-value-container');
  if (!periodTypeEl || !periodValueEl) return;

  var periodType = periodTypeEl.value;
  
  if (periodType === 'all') {
    if (periodValueContainer) periodValueContainer.style.display = 'none';
    return;
  } else {
    if (periodValueContainer) periodValueContainer.style.display = '';
  }

  var today = new Date();

  if (periodType === 'week') {
    if (!periodValueEl.value || !/^\d{4}-W\d{2}$/.test(periodValueEl.value)) {
      var temp = new Date(today.getTime());
      temp.setDate(temp.getDate() + 3 - ((temp.getDay() + 6) % 7));
      var weekYear = temp.getFullYear();
      var firstThursday = new Date(weekYear, 0, 4);
      var weekNumber = Math.ceil((((temp - firstThursday) / 86400000) + firstThursday.getDay() + 1) / 7);
      periodValueEl.value = `${weekYear}-W${String(weekNumber).padStart(2, '0')}`;
    }
  } else if (periodType === 'year') {
    var yearValue = parseInt(periodValueEl.value, 10);
    if (!yearValue || yearValue < 2000 || yearValue > 2100) {
      periodValueEl.value = String(today.getFullYear());
    }
  } else {
    if (!/^\d{4}-\d{2}$/.test(periodValueEl.value)) {
      periodValueEl.value = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}`;
    }
  }
  updatePeriodValueDisplay();
}

function formatPeriodValue(value, type) {
  if (type === 'year') {
    return value + '年';
  } else if (type === 'month') {
    var match = value.match(/^(\d{4})-(\d{2})$/);
    if (match) {
      return match[1] + '年' + parseInt(match[2]) + '月';
    }
    return value;
  } else if (type === 'week') {
    var match = value.match(/^(\d{4})-W(\d{2})$/);
    if (match) {
      return match[1] + '年 第' + parseInt(match[2]) + '周';
    }
    return value;
  }
  return value;
}

function updatePeriodValueDisplay() {
  var periodTypeEl = document.getElementById('period-type-filter');
  var periodValueEl = document.getElementById('period-value-filter');
  var displayEl = document.getElementById('period-value-display');
  if (!periodTypeEl || !periodValueEl || !displayEl) return;
  
  displayEl.textContent = formatPeriodValue(periodValueEl.value, periodTypeEl.value);
}

var pickerCurrentYear = new Date().getFullYear();
var pickerPanelOpen = false;

function togglePeriodPicker() {
  var panel = document.getElementById('period-picker-panel');
  if (!panel) return;
  
  if (pickerPanelOpen) {
    closePeriodPicker();
  } else {
    openPeriodPickerPanel();
  }
}

function openPeriodPickerPanel() {
  var panel = document.getElementById('period-picker-panel');
  var periodTypeEl = document.getElementById('period-type-filter');
  var periodValueEl = document.getElementById('period-value-filter');
  
  if (!panel || !periodTypeEl) return;
  
  var periodType = periodTypeEl.value;
  var currentValue = periodValueEl.value;
  
  // 根据类型初始化
  if (periodType === 'month') {
    var parts = currentValue.split('-');
    pickerCurrentYear = parseInt(parts[0]) || new Date().getFullYear();
    renderMonthPicker();
  } else if (periodType === 'year') {
    pickerCurrentYear = parseInt(currentValue) || new Date().getFullYear();
    renderYearPicker();
  } else if (periodType === 'week') {
    var match = currentValue.match(/^(\d{4})-W(\d{2})$/);
    pickerCurrentYear = match ? parseInt(match[1]) : new Date().getFullYear();
    renderWeekPicker();
  }
  
  panel.classList.remove('hidden');
  pickerPanelOpen = true;
}

function closePeriodPicker() {
  var panel = document.getElementById('period-picker-panel');
  if (panel) {
    panel.classList.add('hidden');
  }
  pickerPanelOpen = false;
}

function shiftPickerYear(direction) {
  pickerCurrentYear += direction;
  var periodTypeEl = document.getElementById('period-type-filter');
  if (periodTypeEl.value === 'month') {
    renderMonthPicker();
  } else if (periodTypeEl.value === 'year') {
    renderYearPicker();
  } else if (periodTypeEl.value === 'week') {
    renderWeekPicker();
  }
}

function renderMonthPicker() {
  var yearDisplay = document.getElementById('picker-year-display');
  var monthsGrid = document.getElementById('picker-months-grid');
  var periodValueEl = document.getElementById('period-value-filter');
  
  if (!yearDisplay || !monthsGrid) return;
  
  yearDisplay.textContent = pickerCurrentYear + '年';
  
  var currentMonth = '';
  if (periodValueEl && periodValueEl.value) {
    var match = periodValueEl.value.match(/^(\d{4})-(\d{2})$/);
    if (match && parseInt(match[1]) === pickerCurrentYear) {
      currentMonth = match[2];
    }
  }
  
  var months = ['1月', '2月', '3月', '4月', '5月', '6月', '7月', '8月', '9月', '10月', '11月', '12月'];
  monthsGrid.innerHTML = months.map(function(m, i) {
    var monthNum = String(i + 1).padStart(2, '0');
    var isSelected = currentMonth === monthNum;
    return '<button type="button" onclick="selectPickerMonth(' + monthNum + ')" class="px-2 py-1.5 text-xs rounded transition-smooth ' + 
      (isSelected ? 'bg-blue-500 text-white' : 'hover:bg-surface-hover dark:hover:bg-surface-dark-hover text-primary dark:text-primary-dark') + '">' + m + '</button>';
  }).join('');
}

function renderYearPicker() {

<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
  <meta name="turbo-visit-control" content="reload">
<% end %>

<div class="flex flex-col lg:flex-row gap-4 lg:h-[calc(100vh-8rem)]" data-account-page>
  <!-- 左侧栏 - 账户管理 (移动端: 可折叠，桌面端: 固定) -->
  <div class="lg:w-80 shrink-0 flex flex-col bg-container dark:bg-container-dark rounded-lg shadow overflow-hidden">
    <!-- 移动端折叠按钮 -->
    <div class="lg:hidden p-3 border-b border-border dark:border-border-dark flex items-center justify-between">
      <div>
        <h2 class="text-base font-semibold text-primary dark:text-primary-dark">账户管理</h2>
        <div class="text-xs text-secondary dark:text-secondary-dark mt-0.5">
          总计: <span class="font-medium text-primary dark:text-primary-dark"><%= format_currency(@total_assets) %></span>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <button onclick="toggleShowHidden()" class="p-2 rounded-lg <%= params[:show_hidden] == 'true' ? 'bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-300' : 'bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark' %>">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
        </button>
        <button onclick="document.getElementById('add-account-modal').classList.remove('hidden')" class="p-2 rounded-lg bg-inverse text-white text-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        </button>
        <button onclick="toggleAccountList()" class="p-2 rounded-lg bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark">
          <svg id="account-toggle-icon" class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </button>
      </div>
    </div>

    <!-- 桌面端标题 -->
    <div class="hidden lg:block p-4 border-b border-border dark:border-border-dark">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-lg font-semibold text-primary dark:text-primary-dark">账户管理</h2>
        <div class="flex items-center gap-2">
          <button onclick="toggleShowHidden()" class="p-1.5 rounded-lg <%= params[:show_hidden] == 'true' ? 'bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-300' : 'bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark' %> hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth" title="显示隐藏账户">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
          </button>
          <button onclick="document.getElementById('add-account-modal').classList.remove('hidden')" class="p-1.5 rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
          </button>
        </div>
      </div>
      <div class="text-sm text-secondary dark:text-secondary-dark">
        总计: <span class="font-medium text-primary dark:text-primary-dark"><%= format_currency(@total_assets) %></span>
      </div>
    </div>
    
    <!-- 所有交易入口 -->
    <div class="p-3 border-b border-border dark:border-border-dark">
      <button onclick="viewAllTransactions()" class="w-full flex items-center justify-between p-2 rounded-lg <%= params[:account_id].blank? ? 'bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-300' : 'hover:bg-surface-hover dark:hover:bg-surface-dark-hover text-primary dark:text-primary-dark' %> transition-smooth">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
          <span class="font-medium text-sm">所有交易</span>
        </div>
        <span class="text-xs text-secondary dark:text-secondary-dark"><%= Entry.count %> 笔</span>
      </button>
    </div>

    <!-- 账户列表 -->
    <div id="account-list" class="hidden lg:block flex-1 overflow-y-auto" data-controller="account-sort">
      <% accounts_by_type = @accounts.group_by { |a| [a.type, a.type_name] }.sort_by { |(type, _), _| Account::ACCOUNT_TYPES.keys.index(type) || 999 } %>
      <% accounts_by_type.each do |(type, type_name), accounts| %>
        <div class="border-b border-border dark:border-border-dark">
          <!-- 类型标题 -->
          <div class="px-4 py-2 bg-surface-inset dark:bg-surface-dark-inset flex items-center justify-between">
            <span class="text-xs font-medium text-secondary dark:text-secondary-dark uppercase tracking-wide"><%= type_name || '未分类' %></span>
            <span class="text-xs text-secondary dark:text-secondary-dark"><%= format_currency(accounts.select { |a| a.include_in_total == 1 }.sum { |a| @account_balances[a.id] || 0 }) %></span>
          </div>
          <!-- 该类型的账户列表 -->
          <div class="account-group" data-account-type="<%= type %>">
            <% accounts.sort_by(&:sort_order).each do |account| %>
              <div class="p-3 border-b border-border/50 dark:border-border-dark/50 hover:bg-surface-hover dark:hover:bg-surface-dark-hover group cursor-pointer account-drag-item <%= params[:account_id].to_i == account.id ? 'bg-surface-inset dark:bg-surface-dark-inset' : '' %> <%= account.hidden == 1 ? 'opacity-60' : '' %>"
                   data-account-id="<%= account.id %>"
                   onclick="filterByAccount(<%= account.id %>)">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-surface dark:bg-surface-dark flex items-center justify-center shrink-0">
                    <span class="text-sm font-bold text-primary dark:text-primary-dark"><%= account.name[0] %></span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2">
                      <p class="font-medium text-sm text-primary dark:text-primary-dark truncate"><%= account.name %></p>
                      <% if [SystemAccountSyncService::RECEIVABLE_ACCOUNT_NAME, SystemAccountSyncService::PAYABLE_ACCOUNT_NAME].include?(account.name) %>
                        <span class="text-[10px] px-1 py-0.5 rounded bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-300">系统锁定</span>
                      <% end %>
                      <% if account.hidden == 1 %>
                        <span class="text-[10px] px-1 py-0.5 rounded bg-orange-100 dark:bg-orange-900 text-orange-600 dark:text-orange-300">隐藏</span>
                      <% end %>
                      <% if account.include_in_total != 1 %>
                        <span class="text-[10px] px-1 py-0.5 rounded bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400">不计资产</span>
                      <% end %>
                    </div>
                    <% if account.type == 'CREDIT' && account.credit_limit %>
                      <p class="text-xs text-secondary dark:text-secondary-dark">额度 <%= format_currency(account.credit_limit) %></p>
                    <% end %>
                  </div>
                  <div class="flex items-center gap-1">
                    <p class="font-medium text-sm text-primary dark:text-primary-dark"><%= format_currency(@account_balances[account.id] || 0) %></p>
                    <% if [SystemAccountSyncService::RECEIVABLE_ACCOUNT_NAME, SystemAccountSyncService::PAYABLE_ACCOUNT_NAME].include?(account.name) %>
                      <span class="p-1 rounded text-secondary dark:text-secondary-dark opacity-60" title="系统账户已锁定">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 0h12a2 2 0 002-2v-5a2 2 0 00-2-2h-1V7a5 5 0 00-10 0v1H6a2 2 0 00-2 2v5a2 2 0 002 2zm3-9V7a3 3 0 016 0v1H9z"></path></svg>
                      </span>
                    <% else %>
                      <button onclick="event.stopPropagation(); openEditAccountModal(this)" 
                              data-id="<%= account.id %>"
                              data-name="<%= account.name %>"
                              data-type="<%= account.type %>"
                              data-initial-balance="<%= account.initial_balance || 0 %>"
                              data-include-in-total="<%= account.include_in_total %>"
                              data-hidden="<%= account.hidden %>"
                              data-currency="<%= account.currency %>"
                              data-credit-limit="<%= account.credit_limit || '' %>"
                              data-billing-day="<%= account.billing_day || '' %>"
                              data-billing-day-mode="<%= account.billing_day_mode || 'current' %>"
                              data-due-day-mode="<%= account.due_day_mode || 'fixed' %>"
                              data-due-day="<%= account.due_day || '' %>"
                              data-due-day-offset="<%= account.due_day_offset || '' %>"
                              class="p-1 rounded lg:opacity-0 lg:group-hover:opacity-100 hover:bg-surface-inset dark:hover:bg-surface-dark-inset transition-smooth">
                        <svg class="w-3.5 h-3.5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                      </button>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
      <% if @accounts.empty? %>
        <div class="p-6 text-center text-secondary dark:text-secondary-dark text-sm">
          暂无账户
        </div>
      <% end %>
    </div>
  </div>

  <!-- 右侧栏 - 交易记录 -->
  <div class="flex-1 flex flex-col bg-container dark:bg-container-dark rounded-lg shadow overflow-hidden min-h-[400px] lg:min-h-0">
    <!-- Header -->
    <div class="p-3 lg:p-4 border-b border-border dark:border-border-dark">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 sm:gap-0 mb-3">
        <div class="flex items-center gap-2 flex-wrap">
          <h2 class="text-base lg:text-lg font-semibold text-primary dark:text-primary-dark">
            <% if params[:account_id].present? %>
              <%= @accounts.find { |a| a.id == params[:account_id].to_i }&.name || '未知账户' %>的交易记录
            <% else %>
              所有交易记录
            <% end %>
          </h2>
          <% if params[:account_id].present? %>
            <button onclick="viewAllTransactions()" class="text-xs text-blue-600 dark:text-blue-400 hover:underline">查看全部</button>
          <% end %>
          <!-- 信用卡：按日期/按账单 切换 -->
          <% current_account = @accounts.find { |a| a.id == params[:account_id].to_i } if params[:account_id].present? %>
          <% if params[:account_id].present? && current_account&.credit_card? %>
            <span id="view-mode-switch" class="inline-flex items-center rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark p-0.5 text-xs">
              <button id="mode-date-btn" onclick="switchViewMode('date')" class="px-2.5 py-1 rounded-md transition-smooth <%= params[:view_mode] == 'bill' ? 'text-secondary dark:text-secondary-dark hover:bg-surface-hover' : 'bg-blue-500 text-white font-medium shadow-sm' %>">
                按日期
              </button>
              <button id="mode-bill-btn" onclick="switchViewMode('bill')" class="px-2.5 py-1 rounded-md transition-smooth <%= params[:view_mode] == 'bill' ? 'bg-blue-500 text-white font-medium shadow-sm' : 'text-secondary dark:text-secondary-dark hover:bg-surface-hover' %>">
                按账单
              </button>
            </span>
          <% end %>
          <span class="inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded-full bg-surface-inset dark:bg-surface-dark-inset text-secondary dark:text-secondary-dark">
            <span>余额</span>
            <span class="font-semibold text-primary dark:text-primary-dark"><%= format_currency(@account_balance) %></span>
          </span>
        </div>
        <button onclick="openNewTransactionModal()" class="px-3 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth btn-modern">
          + 新建
        </button>
      </div>
      
      <!-- 搜索筛选 -->
      <div id="filter-bar" class="flex flex-wrap gap-2 items-end <%= (params[:account_id].present? && current_account&.credit_card? && params[:view_mode] == 'bill') ? 'hidden' : '' %>">
        <div class="flex-1 min-w-[140px]">
          <input type="text" id="search-input" placeholder="搜索备注、分类..." value="<%= params[:search] %>" 
                 class="w-full px-3 py-1.5 h-9 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
        </div>
        <div class="w-24 relative" data-controller="select">
          <% selected_period_type = params[:period_type].presence || "month" %>
          <% period_type_labels = { 'all' => '全部', 'week' => '按周', 'month' => '按月', 'year' => '按年' } %>
          <input type="hidden" id="period-type-filter" data-select-target="input" name="period_type" value="<%= selected_period_type %>">
          <button type="button" id="period-type-btn" data-select-target="button" data-action="click->select#toggle"
                  class="w-full px-3 py-1.5 h-9 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth flex items-center justify-between">
            <span><%= period_type_labels[selected_period_type] %></span>
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          <div data-select-target="menu" class="hidden absolute left-0 top-full mt-1 w-full z-20 bg-white dark:bg-surface-dark border border-border dark:border-border-dark rounded-lg shadow-lg py-1 max-h-60 overflow-auto">
            <% period_type_labels.each do |value, label| %>
              <div data-action="click->select#select" data-value="<%= value %>"
                   class="px-3 py-1.5 text-sm cursor-pointer hover:bg-surface-hover dark:hover:bg-surface-dark-hover <%= 'bg-gray-100 dark:bg-gray-700' if selected_period_type == value %>"
                   aria-selected="<%= selected_period_type == value %>">
                <%= label %>
              </div>
            <% end %>
          </div>
        </div>
        <div class="w-[220px]" id="period-value-container" style="<%= selected_period_type == 'all' ? 'display:none' : '' %>">
          <% selected_period_value = params[:period_value].presence || case selected_period_type
             when "year" then Date.current.year.to_s
             when "week" then Date.current.strftime("%G-W%V")
             else Date.current.strftime("%Y-%m")
             end %>
          <input type="hidden" id="period-value-filter" value="<%= selected_period_value %>">
          <div class="flex items-center gap-1 relative">
            <button type="button"
                    id="period-prev-btn"
                    onclick="shiftPeriod(-1)"
                    class="px-2.5 py-1.5 h-9 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth"
                    aria-label="上一期">
              ‹
            </button>
            <div id="period-value-display"
                 class="flex-1 min-w-0 px-3 py-1.5 h-9 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark flex items-center justify-center cursor-pointer hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth relative"
                 onclick="togglePeriodPicker()">
            </div>
            <div id="period-picker-panel" class="hidden absolute left-8 top-full mt-1 z-30 bg-white dark:bg-surface-dark border border-border dark:border-border-dark rounded-lg shadow-lg p-2 w-[200px]">
              <div class="flex items-center justify-between mb-2">
                <button type="button" onclick="shiftPickerYear(-1)" class="p-1 rounded hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                </button>
                <span id="picker-year-display" class="text-sm font-medium text-primary dark:text-primary-dark"></span>
                <button type="button" onclick="shiftPickerYear(1)" class="p-1 rounded hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </button>
              </div>
              <div id="picker-months-grid" class="grid grid-cols-4 gap-1">
              </div>
            </div>
            <button type="button"
                    id="period-next-btn"
                    onclick="shiftPeriod(1)"
                    class="px-2.5 py-1.5 h-9 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth"
                    aria-label="下一期">
              ›
            </button>
          </div>
        </div>
        <div class="w-28 relative" data-controller="select">
          <% type_labels = { '' => '全部类型', 'INCOME' => '收入', 'EXPENSE' => '支出', 'TRANSFER' => '转账' } %>
          <input type="hidden" id="type-filter" data-select-target="input" name="type" value="<%= params[:type].to_s %>">
          <button type="button" id="type-btn" data-select-target="button" data-action="click->select#toggle"
                  class="w-full px-3 py-1.5 h-9 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth flex items-center justify-between">
            <span><%= type_labels[params[:type].to_s] %></span>
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          <div data-select-target="menu" class="hidden absolute left-0 top-full mt-1 w-full z-20 bg-white dark:bg-surface-dark border border-border dark:border-border-dark rounded-lg shadow-lg py-1 max-h-60 overflow-auto">
            <% type_labels.each do |value, label| %>
              <div data-action="click->select#select" data-value="<%= value %>"
                   class="px-3 py-1.5 text-sm cursor-pointer hover:bg-surface-hover dark:hover:bg-surface-dark-hover <%= 'bg-gray-100 dark:bg-gray-700' if params[:type].to_s == value %>"
                   aria-selected="<%= params[:type].to_s == value %>">
                <%= label %>
              </div>
            <% end %>
          </div>
        </div>
        <div class="min-w-[120px]">
          <% selected_category_ids = Array(params[:category_ids]).reject(&:blank?) %>
          <button type="button" id="open-category-filter"
                  class="w-full px-3 py-1.5 h-9 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">
            分类筛选<%= selected_category_ids.any? ? " (#{selected_category_ids.size})" : "" %>
          </button>
        </div>
        <% if params[:search] || params[:type] || params[:period_type] || params[:period_value] || params[:category_ids].present? || params[:account_id] %>
          <button onclick="clearFilters()" class="px-3 py-1.5 h-9 text-sm rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover transition-smooth">
            清除
          </button>
        <% end %>
      </div>
    </div>

    <!-- 汇总信息 -->
    <div id="summary-bar" class="px-3 lg:px-4 py-2 border-b border-border dark:border-border-dark bg-surface-inset dark:bg-surface-dark-inset <%= (params[:account_id].present? && current_account&.credit_card? && params[:view_mode] == 'bill') ? 'hidden' : '' %>">
      <div class="flex items-center gap-4 text-sm">
        <div class="flex items-center gap-1">
          <span class="text-secondary dark:text-secondary-dark">流入</span>
          <span class="font-medium text-income"><%= format_currency(@total_income) %></span>
        </div>
        <div class="flex items-center gap-1">
          <span class="text-secondary dark:text-secondary-dark">流出</span>
          <span class="font-medium text-expense"><%= format_currency(@total_expense) %></span>
        </div>
        <div class="flex items-center gap-1">
          <span class="text-secondary dark:text-secondary-dark">差额</span>
          <span class="font-medium <%= @total_balance >= 0 ? 'text-income' : 'text-expense' %>"><%= format_currency(@total_balance) %></span>
        </div>
      </div>
    </div>

    <!-- 交易列表 -->
    <div id="transaction-list" class="flex-1 overflow-y-auto <%= (params[:account_id].present? && current_account&.credit_card? && params[:view_mode] == 'bill') ? 'hidden' : '' %>" data-page="<%= @page %>" data-per-page="<%= @per_page %>" data-total-count="<%= @total_count %>">
      <% if @entries_with_balance.any? %>
        <%= render 'skeleton' unless @page > 1 %>
        <div class="divide-y divide-border dark:divide-border-dark" id="transactions-container">
          <% @entries_with_balance.each do |e, balance| %>
            <div class="p-3 hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">
              <div class="flex items-center gap-3">
                <div class="shrink-0 text-xs text-secondary dark:text-secondary-dark w-20">
                  <%= e.date&.strftime("%Y-%m-%d") %>
                </div>
<%
  entry_type = e.display_entry_type
  is_transfer = entry_type == 'TRANSFER'
  current_account_filter = params[:account_id].to_s
  # 转账方向：单账户视图下，amount > 0 = 转入（还款），amount < 0 = 转出（消费）
  is_inflow = is_transfer && e.amount.positive?
  display_type = if is_transfer
    if current_account_filter.blank?
      "转账"
    else
      is_inflow ? "转入" : "转出"
    end
  else
    e.display_type_label

// 保存并继续功能 - AJAX 提交，不刷新页面
function submitAndContinue(event) {
  event.preventDefault();
  
  var form = document.querySelector('#add-transaction-modal form');
  if (!form) return;
  
  // 收支模式：同步 account_id
  if (transactionMode === 'category') {
    var incomeHidden = document.getElementById('transaction_account_id_income');
    var transferHidden = document.getElementById('transaction_account_id');
    if (incomeHidden && transferHidden) {
      transferHidden.value = incomeHidden.value;
    }
  }
  
  // 获取 CSRF token
  var csrfToken = document.querySelector('meta[name="csrf-token"]')?.content;
  
  // 收集表单数据
  var formData = new FormData(form);
  formData.append('continue_entry', '1');
  
  // 显示加载状态
  var continueBtn = event.target;
  var originalText = continueBtn.textContent;
  continueBtn.textContent = '保存中...';
  continueBtn.disabled = true;
  
  // AJAX 提交（URL 加 .json 确保 Rails 走 JSON 分支）
  fetch(form.action.replace(/\/$/, '') + '.json', {
    method: 'POST',
    headers: {
      'X-CSRF-Token': csrfToken,
      'Accept': 'application/json',
      'X-Requested-With': 'XMLHttpRequest'
    },
    body: formData
  })
  .then(response => {
    if (!response.ok) {
      return response.text().then(text => {
        try { return JSON.parse(text); } catch(e) { return { success: false, error: '服务器错误: ' + response.status }; }
      });
    }
    return response.json();
  })
  .then(data => {
    if (data.success) {
      // 显示成功提示
      showSuccessToast(data.message || '交易已创建，请继续录入');
      
      // 清空部分字段，保持选项不变
      var amountInput = form.querySelector('input[name="transaction[amount]"]');
      var noteInput = form.querySelector('input[name="transaction[note]"]');
      
      if (amountInput) amountInput.value = '';
      if (noteInput) noteInput.value = '';
      
      // 保持账户、分类、类型、日期等选择不变
      // 不关闭弹窗，不刷新页面
    } else {
      // 显示错误提示
      showErrorToast(data.error || '保存失败');
    }
  })
  .catch(error => {
    console.error('Submit error:', error);
    showErrorToast('网络错误，请重试');
  })
  .finally(() => {
    // 恢复按钮状态
    continueBtn.textContent = originalText;
    continueBtn.disabled = false;
  });
}

// 成功提示
function showSuccessToast(message) {
  var toast = document.createElement('div');
  toast.className = 'fixed top-4 right-4 bg-green-500 text-white px-4 py-2 rounded-lg shadow-lg z-50 animate-fade-in';
  toast.textContent = message;
  document.body.appendChild(toast);
  
  setTimeout(function() {
    toast.style.opacity = '0';
    toast.style.transition = 'opacity 0.3s';
    setTimeout(function() { toast.remove(); }, 300);
  }, 2000);
}

// 错误提示
function showErrorToast(message) {
  var toast = document.createElement('div');
  toast.className = 'fixed top-4 right-4 bg-red-500 text-white px-4 py-2 rounded-lg shadow-lg z-50';
  toast.textContent = message;
  document.body.appendChild(toast);
  
  setTimeout(function() {
    toast.style.opacity = '0';
    toast.style.transition = 'opacity 0.3s';
    setTimeout(function() { toast.remove(); }, 300);
  }, 3000);
}

// HTML 转义函数，防止 XSS
function escapeHtml(str) {
  if (!str) return '';
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}


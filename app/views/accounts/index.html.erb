// 搜索输入 IME composition 处理
// 中文输入法打拼音时，compositionstart 触发后每敲一个字母都会触发 input
// 需要等 compositionend 后才执行搜索
const _searchInput = document.getElementById('search-input');
if (_searchInput && !_searchInput._imeInit) {
  _searchInput._imeInit = true;
  _searchInput._isComposing = false;

  _searchInput.addEventListener('compositionstart', function() {
    this._isComposing = true;
  });

  _searchInput.addEventListener('compositionend', function() {
    this._isComposing = false;
    // 输入法确认后触发搜索
    debouncedApplyFilters();
  });

  _searchInput.addEventListener('input', function(e) {
    // 输入法输入中不触发搜索
    if (this._isComposing) return;
    debouncedApplyFilters();
  });

  _searchInput.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !this._isComposing) {
      applyFilters();
    }
  });
}

function syncPeriodInputType() {
  const periodTypeEl = document.getElementById('period-type-filter');
  const periodValueEl = document.getElementById('period-value-filter');
  const periodValueContainer = document.getElementById('period-value-container');
  if (!periodTypeEl || !periodValueEl) return;

  const periodType = periodTypeEl.value;
  
  if (periodType === 'all') {
    if (periodValueContainer) periodValueContainer.style.display = 'none';
    return;
  } else {
    if (periodValueContainer) periodValueContainer.style.display = '';
  }

  const today = new Date();

  if (periodType === 'week') {
    if (!periodValueEl.value || !/^\d{4}-W\d{2}$/.test(periodValueEl.value)) {
      const temp = new Date(today.getTime());
      temp.setDate(temp.getDate() + 3 - ((temp.getDay() + 6) % 7));
      const weekYear = temp.getFullYear();
      const firstThursday = new Date(weekYear, 0, 4);
      const weekNumber = Math.ceil((((temp - firstThursday) / 86400000) + firstThursday.getDay() + 1) / 7);
      periodValueEl.value = `${weekYear}-W${String(weekNumber).padStart(2, '0')}`;
    }
  } else if (periodType === 'year') {
    const yearValue = parseInt(periodValueEl.value, 10);
    if (!yearValue || yearValue < 2000 || yearValue > 2100) {
      periodValueEl.value = String(today.getFullYear());
    }
  } else {
    if (!/^\d{4}-\d{2}$/.test(periodValueEl.value)) {
      periodValueEl.value = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}`;
    }
  }
  updatePeriodValueDisplay();
}

function formatPeriodValue(value, type) {
  if (type === 'year') {
    return value + '年';
  } else if (type === 'month') {
    const match = value.match(/^(\d{4})-(\d{2})$/);
    if (match) {
      return match[1] + '年' + parseInt(match[2]) + '月';
    }
    return value;
  } else if (type === 'week') {
    const match = value.match(/^(\d{4})-W(\d{2})$/);
    if (match) {
      return match[1] + '年 第' + parseInt(match[2]) + '周';
    }
    return value;
  }
  return value;
}

function updatePeriodValueDisplay() {
  const periodTypeEl = document.getElementById('period-type-filter');
  const periodValueEl = document.getElementById('period-value-filter');
  const displayEl = document.getElementById('period-value-display');
  if (!periodTypeEl || !periodValueEl || !displayEl) return;
  
  displayEl.textContent = formatPeriodValue(periodValueEl.value, periodTypeEl.value);
}

let pickerCurrentYear = new Date().getFullYear();
let pickerPanelOpen = false;

function togglePeriodPicker() {
  const panel = document.getElementById('period-picker-panel');
  if (!panel) return;
  
  if (pickerPanelOpen) {
    closePeriodPicker();
  } else {
    openPeriodPickerPanel();
  }
}

function openPeriodPickerPanel() {
  const panel = document.getElementById('period-picker-panel');
  const periodTypeEl = document.getElementById('period-type-filter');
  const periodValueEl = document.getElementById('period-value-filter');
  
  if (!panel || !periodTypeEl) return;
  
  const periodType = periodTypeEl.value;
  const currentValue = periodValueEl.value;
  
  // 根据类型初始化
  if (periodType === 'month') {
    const parts = currentValue.split('-');
    pickerCurrentYear = parseInt(parts[0]) || new Date().getFullYear();
    renderMonthPicker();
  } else if (periodType === 'year') {
    pickerCurrentYear = parseInt(currentValue) || new Date().getFullYear();
    renderYearPicker();
  } else if (periodType === 'week') {
    const match = currentValue.match(/^(\d{4})-W(\d{2})$/);
    pickerCurrentYear = match ? parseInt(match[1]) : new Date().getFullYear();
    renderWeekPicker();
  }
  
  panel.classList.remove('hidden');
  pickerPanelOpen = true;
}

function closePeriodPicker() {
  const panel = document.getElementById('period-picker-panel');
  if (panel) {
    panel.classList.add('hidden');
  }
  pickerPanelOpen = false;
}

function shiftPickerYear(direction) {
  pickerCurrentYear += direction;
  const periodTypeEl = document.getElementById('period-type-filter');
  if (periodTypeEl.value === 'month') {
    renderMonthPicker();
  } else if (periodTypeEl.value === 'year') {
    renderYearPicker();
  } else if (periodTypeEl.value === 'week') {
    renderWeekPicker();
  }
}

function renderMonthPicker() {
  const yearDisplay = document.getElementById('picker-year-display');
  const monthsGrid = document.getElementById('picker-months-grid');
  const periodValueEl = document.getElementById('period-value-filter');
  
  if (!yearDisplay || !monthsGrid) return;
  
  yearDisplay.textContent = pickerCurrentYear + '年';
  
  let currentMonth = '';
  if (periodValueEl && periodValueEl.value) {
    const match = periodValueEl.value.match(/^(\d{4})-(\d{2})$/);
    if (match && parseInt(match[1]) === pickerCurrentYear) {
      currentMonth = match[2];
    }
  }
  
  const months = ['1月', '2月', '3月', '4月', '5月', '6月', '7月', '8月', '9月', '10月', '11月', '12月'];
  monthsGrid.innerHTML = months.map(function(m, i) {
    const monthNum = String(i + 1).padStart(2, '0');
    const isSelected = currentMonth === monthNum;
    return '<button type="button" onclick="selectPickerMonth(' + monthNum + ')" class="px-2 py-1.5 text-xs rounded transition-smooth ' + 
      (isSelected ? 'bg-blue-500 text-white' : 'hover:bg-surface-hover dark:hover:bg-surface-dark-hover text-primary dark:text-primary-dark') + '">' + m + '</button>';
  }).join('');
}

function renderYearPicker() {
  const yearDisplay = document.getElementById('picker-year-display');
  const monthsGrid = document.getElementById('picker-months-grid');
  const periodValueEl = document.getElementById('period-value-filter');
  
  if (!yearDisplay || !monthsGrid) return;
  
  yearDisplay.textContent = '选择年份';
  
  const currentYear = periodValueEl ? parseInt(periodValueEl.value) : new Date().getFullYear();
  
  // 显示年份范围
  const startYear = pickerCurrentYear - 4;
  const years = [];
  for (let i = 0; i < 9; i++) {
    years.push(startYear + i);
  }
  
  monthsGrid.innerHTML = years.map(function(y) {
    const isSelected = y === currentYear;
    return '<button type="button" onclick="selectPickerYear(' + y + ')" class="px-2 py-1.5 text-xs rounded transition-smooth ' + 
      (isSelected ? 'bg-blue-500 text-white' : 'hover:bg-surface-hover dark:hover:bg-surface-dark-hover text-primary dark:text-primary-dark') + '">' + y + '</button>';
  }).join('');
}

function renderWeekPicker() {
  const yearDisplay = document.getElementById('picker-year-display');
  const monthsGrid = document.getElementById('picker-months-grid');
  const periodValueEl = document.getElementById('period-value-filter');
  
  if (!yearDisplay || !monthsGrid) return;
  
  yearDisplay.textContent = pickerCurrentYear + '年';
  
  let currentWeek = '';
  if (periodValueEl && periodValueEl.value) {
    const match = periodValueEl.value.match(/^(\d{4})-W(\d{2})$/);
    if (match && parseInt(match[1]) === pickerCurrentYear) {
      currentWeek = match[2];
    }
  }
  
  // 显示周（假设一年最多53周）
  let weeksHtml = '';
  for (let i = 1; i <= 53; i++) {
    const weekNum = String(i).padStart(2, '0');
    const isSelected = currentWeek === weekNum;
    weeksHtml += '<button type="button" onclick="selectPickerWeek(' + weekNum + ')" class="px-2 py-1.5 text-xs rounded transition-smooth ' + 
      (isSelected ? 'bg-blue-500 text-white' : 'hover:bg-surface-hover dark:hover:bg-surface-dark-hover text-primary dark:text-primary-dark') + '">W' + i + '</button>';
  }
  monthsGrid.innerHTML = weeksHtml;
}


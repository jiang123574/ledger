<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h1 class="text-2xl font-bold text-gray-900"><%= t("accounts.title") %></h1>
    <%= link_to t("accounts.new_account"), new_account_path, class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
  </div>

  <div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t("accounts.name") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t("accounts.type") %></th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase"><%= t("accounts.balance") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t("accounts.currency") %></th>
          <th class="px-6 py-3 actions"></th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @accounts.each do |account| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap font-medium"><%= account.name %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm"><%= account.type || "-" %></td>
            <td class="px-6 py-4 whitespace-nowrap text-right font-medium">¥<%= account.current_balance.to_s("%.2f") %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm"><%= account.currency %></td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
              <%= link_to t("common.edit"), edit_account_path(account), class: "text-blue-600 hover:text-blue-900" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @accounts.empty? %>
      <div class="p-8 text-center text-gray-500">
        <%= t("accounts.no_accounts_yet") %>
      </div>
    <% end %>
  </div>
</div>

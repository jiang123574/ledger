function filterCategoryOptions(query) {
  const items = document.querySelectorAll('.category-filter-item');
  const sections = document.querySelectorAll('.category-type-section');
  const lowerQuery = query.toLowerCase();
  
  items.forEach(function(item) {
    const name = item.dataset.name.toLowerCase();
    const fullName = item.dataset.fullName.toLowerCase();
    const pinyin = item.dataset.pinyin;
    if (!query || name.includes(lowerQuery) || fullName.includes(lowerQuery) || (pinyin && pinyin.includes(lowerQuery))) {
      item.style.removeProperty('display');
    } else {
      item.style.display = 'none';
    }
  });
  
  sections.forEach(function(section) {
    const visibleItems = section.querySelectorAll('.category-filter-item:not([style*="display: none"])');
    if (visibleItems.length > 0) {
      section.style.removeProperty('display');
    } else {
      section.style.display = 'none';
    }
  });
}


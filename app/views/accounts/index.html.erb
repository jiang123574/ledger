<div class="flex gap-4" style="height: calc(100vh - 8rem);">
  <!-- 左侧栏 - 账户管理 -->
  <div class="w-80 shrink-0 flex flex-col bg-container dark:bg-container-dark rounded-lg shadow overflow-hidden">
    <div class="p-4 border-b border-border dark:border-border-dark">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-lg font-semibold text-primary dark:text-primary-dark">账户管理</h2>
        <button onclick="document.getElementById('add-account-modal').classList.remove('hidden')" class="p-1.5 rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        </button>
      </div>
      <div class="text-sm text-secondary dark:text-secondary-dark">
        总计: <span class="font-medium text-primary dark:text-primary-dark"><%= format_currency(@accounts.sum(&:current_balance)) %></span>
      </div>
    </div>
    
    <!-- 账户列表 -->
    <div class="flex-1 overflow-y-auto" data-controller="account-sort">
      <% accounts_by_type = @accounts.group_by { |a| [a.type, a.type_name] }.sort_by { |(type, _), _| Account::ACCOUNT_TYPES.keys.index(type) || 999 } %>
      <% accounts_by_type.each do |(type, type_name), accounts| %>
        <div class="border-b border-border dark:border-border-dark">
          <!-- 类型标题 -->
          <div class="px-4 py-2 bg-surface-inset dark:bg-surface-dark-inset flex items-center justify-between">
            <span class="text-xs font-medium text-secondary dark:text-secondary-dark uppercase tracking-wide"><%= type_name || '未分类' %></span>
            <span class="text-xs text-secondary dark:text-secondary-dark"><%= format_currency(accounts.sum(&:current_balance)) %></span>
          </div>
          <!-- 该类型的账户列表 -->
          <div class="account-group" data-account-type="<%= type %>">
            <% accounts.sort_by(&:sort_order).each do |account| %>
              <div class="p-3 border-b border-border/50 dark:border-border-dark/50 hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth group cursor-grab active:cursor-grabbing <%= params[:account_id].to_i == account.id ? 'bg-surface-inset dark:bg-surface-dark-inset' : '' %>" 
                   data-account-id="<%= account.id %>"
                   draggable="true"
                   data-action="dragstart->account-sort#start dragover->account-sort#over drop->account-sort#drop dragend->account-sort#end">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-surface dark:bg-surface-dark flex items-center justify-center shrink-0" onclick="filterByAccount(<%= account.id %>)">
                    <span class="text-sm font-bold text-primary dark:text-primary-dark"><%= account.name[0] %></span>
                  </div>
                  <div class="flex-1 min-w-0" onclick="filterByAccount(<%= account.id %>)">
                    <p class="font-medium text-sm text-primary dark:text-primary-dark truncate"><%= account.name %></p>
                    <% if account.type == 'CREDIT' && account.credit_limit %>
                      <p class="text-xs text-secondary dark:text-secondary-dark">额度 <%= format_currency(account.credit_limit) %></p>
                    <% end %>
                  </div>
                  <div class="flex items-center gap-1">
                    <p class="font-medium text-sm text-primary dark:text-primary-dark" onclick="filterByAccount(<%= account.id %>)"><%= format_currency(account.current_balance) %></p>
                    <button onclick="event.stopPropagation(); openEditAccountModal(this)" 
                            data-id="<%= account.id %>"
                            data-name="<%= account.name %>"
                            data-type="<%= account.type %>"
                            data-initial-balance="<%= account.initial_balance || 0 %>"
                            data-currency="<%= account.currency %>"
                            data-credit-limit="<%= account.credit_limit || '' %>"
                            data-billing-day="<%= account.billing_day || '' %>"
                            data-billing-day-mode="<%= account.billing_day_mode || 'current' %>"
                            data-due-day-mode="<%= account.due_day_mode || 'fixed' %>"
                            data-due-day="<%= account.due_day || '' %>"
                            data-due-day-offset="<%= account.due_day_offset || '' %>"
                            class="p-1 rounded opacity-0 group-hover:opacity-100 hover:bg-surface-inset dark:hover:bg-surface-dark-inset transition-smooth">
                      <svg class="w-3.5 h-3.5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                    </button>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
      <% if @accounts.empty? %>
        <div class="p-6 text-center text-secondary dark:text-secondary-dark text-sm">
          暂无账户
        </div>
      <% end %>
    </div>
  </div>

  <!-- 右侧栏 - 交易记录 -->
  <div class="flex-1 flex flex-col bg-container dark:bg-container-dark rounded-lg shadow overflow-hidden">
    <!-- Header -->
    <div class="p-4 border-b border-border dark:border-border-dark">
      <div class="flex items-center justify-between mb-3">
        <div class="flex items-center gap-2">
          <h2 class="text-lg font-semibold text-primary dark:text-primary-dark">交易记录</h2>
          <% if params[:account_id] %>
            <span class="px-2 py-0.5 text-xs rounded-full bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark">
              <%= @accounts.find(params[:account_id])&.name || '未知账户' %>
              <button onclick="clearAccountFilter()" class="ml-1 hover:text-primary">×</button>
            </span>
          <% end %>
        </div>
        <button onclick="document.getElementById('add-transaction-modal').classList.remove('hidden')" class="px-3 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth btn-modern">
          + 新建
        </button>
      </div>
      
      <!-- 搜索筛选 -->
      <div class="flex flex-wrap gap-3 items-end">
        <div class="flex-1 min-w-[200px]">
          <input type="text" id="search-input" placeholder="搜索备注、分类..." value="<%= params[:search] %>" 
                 class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
        </div>
        <div class="w-32">
          <select id="type-filter" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark">
            <option value="">全部类型</option>
            <option value="INCOME" <%= params[:type] == 'INCOME' ? 'selected' : '' %>>收入</option>
            <option value="EXPENSE" <%= params[:type] == 'EXPENSE' ? 'selected' : '' %>>支出</option>
            <option value="TRANSFER" <%= params[:type] == 'TRANSFER' ? 'selected' : '' %>>转账</option>
          </select>
        </div>
        <div class="w-28">
          <input type="date" id="start-date" value="<%= params[:start_date] %>" 
                 class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark">
        </div>
        <div class="w-28">
          <input type="date" id="end-date" value="<%= params[:end_date] %>" 
                 class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark">
        </div>
        <button onclick="applyFilters()" class="px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">
          筛选
        </button>
        <% if params[:search] || params[:type] || params[:start_date] || params[:end_date] || params[:account_id] %>
          <button onclick="clearFilters()" class="px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover transition-smooth">
            清除
          </button>
        <% end %>
      </div>
    </div>

    <!-- 交易列表 -->
    <div class="flex-1 overflow-y-auto">
      <% if @transactions.any? %>
        <table class="min-w-full">
          <thead class="bg-surface-inset dark:bg-surface-dark-inset sticky top-0">
            <tr>
              <th class="px-4 py-2 text-left text-xs font-medium text-secondary dark:text-secondary-dark">日期</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-secondary dark:text-secondary-dark">类型</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-secondary dark:text-secondary-dark">分类</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-secondary dark:text-secondary-dark">账户</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-secondary dark:text-secondary-dark">备注</th>
              <th class="px-4 py-2 text-right text-xs font-medium text-secondary dark:text-secondary-dark">金额</th>
              <th class="px-4 py-2 text-center text-xs font-medium text-secondary dark:text-secondary-dark">操作</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border dark:divide-border-dark">
            <% @transactions.each do |t| %>
              <tr class="hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">
                <td class="px-4 py-3 text-sm text-primary dark:text-primary-dark whitespace-nowrap">
                  <%= t.date&.strftime("%Y-%m-%d") %>
                </td>
                <td class="px-4 py-3">
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= 
                    case t.type
                    when 'INCOME' then 'bg-income-light text-income'
                    when 'EXPENSE' then 'bg-expense-light text-expense'
                    when 'TRANSFER' then 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400'
                    else 'bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300'
                    end %>">
                    <%= t.display_type %>
                  </span>
                </td>
                <td class="px-4 py-3 text-sm text-primary dark:text-primary-dark">
                  <%= t.category&.full_name(separator: ' > ') || '-' %>
                </td>
                <td class="px-4 py-3 text-sm text-secondary dark:text-secondary-dark">
                  <%= t.account_name %>
                </td>
                <td class="px-4 py-3 text-sm text-secondary dark:text-secondary-dark truncate max-w-[200px]">
                  <%= t.note || '-' %>
                </td>
                <td class="px-4 py-3 text-sm font-medium text-right whitespace-nowrap <%= t.type == 'INCOME' ? 'text-income' : 'text-expense' %>">
                  <%= format_currency_with_sign(t.amount, type: t.type) %>
                </td>
                <td class="px-4 py-3 text-center">
                  <div class="flex items-center justify-center gap-2">
                    <%= link_to "javascript:void(0)", onclick: "openEditModal(#{t.id}, '#{j t.date&.strftime("%Y-%m-%d")}', '#{t.amount}', '#{t.account_id}', '#{t.category_id}', '#{j t.note || ''}', '#{t.type}')", class: "p-1.5 rounded-lg hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark" do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                    <% end %>
                    <button type="button" onclick="confirmDeleteTransaction(<%= t.id %>, '<%= j t.category&.name || t.display_type %>')" class="p-1.5 rounded-lg hover:bg-red-100 dark:hover:bg-red-900/30 transition-smooth text-secondary dark:text-secondary-dark hover:text-red-600 dark:hover:text-red-400">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    </button>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="p-8 text-center">
          <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-surface dark:bg-surface-dark flex items-center justify-center">
            <svg class="w-6 h-6 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
          </div>
          <p class="text-secondary dark:text-secondary-dark text-sm">暂无交易记录</p>
          <button onclick="document.getElementById('add-transaction-modal').classList.remove('hidden')" class="mt-3 px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">
            新建第一笔交易
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Edit Transaction Modal -->
<div id="edit-transaction-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('edit-transaction-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-lg shadow-xl w-full max-w-md p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-primary dark:text-primary-dark">编辑交易</h3>
        <button type="button" onclick="document.getElementById('edit-transaction-modal').classList.add('hidden')" class="p-1 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <form id="edit-transaction-form" method="post">
        <input type="hidden" name="_method" value="patch">
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">日期 *</label>
            <input type="date" name="transaction[date]" id="edit_transaction_date" required class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">金额 *</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
              <input type="number" name="transaction[amount]" id="edit_transaction_amount" step="0.01" placeholder="0.00" required class="w-full pl-8 pr-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">类型 *</label>
            <select name="transaction[type]" id="edit_transaction_type" required class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
              <option value="EXPENSE">支出</option>
              <option value="INCOME">收入</option>
              <option value="TRANSFER">转账</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">账户 *</label>
            <select name="transaction[account_id]" id="edit_transaction_account_id" required class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
              <option value="">选择账户</option>
              <% @accounts.each do |a| %>
                <option value="<%= a.id %>"><%= a.name %></option>
              <% end %>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">分类</label>
            <select name="transaction[category_id]" id="edit_transaction_category_id" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
              <%= category_options_for_select(@categories) %>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">备注</label>
            <input type="text" name="transaction[note]" id="edit_transaction_note" placeholder="添加备注" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
          </div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="document.getElementById('edit-transaction-modal').classList.add('hidden')" class="px-4 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover transition-smooth">取消</button>
          <button type="submit" class="px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">保存</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
// Edit account modal
function openEditAccountModal(btn) {
  const id = btn.dataset.id;
  const name = btn.dataset.name;
  const type = btn.dataset.type;
  const initialBalance = btn.dataset.initialBalance;
  const currency = btn.dataset.currency;
  const creditLimit = btn.dataset.creditLimit;
  const billingDay = btn.dataset.billingDay;
  const billingDayMode = btn.dataset.billingDayMode;
  const dueDayMode = btn.dataset.dueDayMode;
  const dueDay = btn.dataset.dueDay;
  const dueDayOffset = btn.dataset.dueDayOffset;
  
  document.getElementById('edit-account-form').action = '/accounts/' + id;
  document.getElementById('edit_account_name').value = name;
  document.getElementById('edit_account_type').value = type;
  document.getElementById('edit_account_initial_balance').value = initialBalance;
  document.getElementById('edit_account_currency').value = currency;
  
  // 信用卡字段
  const isCreditCard = type === 'CREDIT';
  const creditCardFields = document.querySelector('#edit-account-modal [data-credit-card-form-target="creditCardFields"]');
  if (creditCardFields) {
    creditCardFields.classList.toggle('hidden', !isCreditCard);
  }
  
  if (isCreditCard) {
    if (creditLimit) document.getElementById('edit_account_credit_limit').value = creditLimit;
    if (billingDay) document.getElementById('edit_account_billing_day').value = billingDay;
    document.getElementById('edit_account_billing_day_mode').value = billingDayMode || 'current';
    document.getElementById('edit_account_due_day_mode').value = dueDayMode || 'fixed';
    
    // 根据还款日类型显示对应字段
    const dueDayFixed = document.querySelector('#edit-account-modal [data-credit-card-form-target="dueDayFixed"]');
    const dueDayRelative = document.querySelector('#edit-account-modal [data-credit-card-form-target="dueDayRelative"]');
    if (dueDayMode === 'relative') {
      if (dueDayFixed) dueDayFixed.classList.add('hidden');
      if (dueDayRelative) dueDayRelative.classList.remove('hidden');
      if (dueDayOffset) document.getElementById('edit_account_due_day_offset').value = dueDayOffset;
    } else {
      if (dueDayFixed) dueDayFixed.classList.remove('hidden');
      if (dueDayRelative) dueDayRelative.classList.add('hidden');
      if (dueDay) document.getElementById('edit_account_due_day').value = dueDay;
    }
  }
  
  document.getElementById('edit-account-modal').classList.remove('hidden');
}

// Edit transaction modal
function openEditModal(id, date, amount, accountId, categoryId, note, type) {
  document.getElementById('edit-transaction-form').action = '/transactions/' + id;
  document.getElementById('edit_transaction_date').value = date;
  document.getElementById('edit_transaction_amount').value = amount;
  document.getElementById('edit_transaction_type').value = type;
  document.getElementById('edit_transaction_account_id').value = accountId;
  document.getElementById('edit_transaction_category_id').value = categoryId || '';
  document.getElementById('edit_transaction_note').value = note;
  document.getElementById('edit-transaction-modal').classList.remove('hidden');
}

function confirmDeleteTransaction(id, name) {
  if (confirm('确定删除交易 "' + name + '"？')) {
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '/transactions/' + id;
    form.innerHTML = '<input type="hidden" name="_method" value="delete">';
    document.body.appendChild(form);
    form.submit();
  }
}

function applyFilters() {
  const params = new URLSearchParams();
  const search = document.getElementById('search-input').value;
  const type = document.getElementById('type-filter').value;
  const startDate = document.getElementById('start-date').value;
  const endDate = document.getElementById('end-date').value;
  const accountId = '<%= params[:account_id] %>';
  
  if (search) params.append('search', search);
  if (type) params.append('type', type);
  if (startDate) params.append('start_date', startDate);
  if (endDate) params.append('end_date', endDate);
  if (accountId) params.append('account_id', accountId);
  
  window.location.href = '/accounts?' + params.toString();
}

function clearFilters() {
  const accountId = '<%= params[:account_id] %>';
  if (accountId) {
    window.location.href = '/accounts?account_id=' + accountId;
  } else {
    window.location.href = '/accounts';
  }
}

function filterByAccount(id) {
  const params = new URLSearchParams(window.location.search);
  params.set('account_id', id);
  window.location.href = '/accounts?' + params.toString();
}

function clearAccountFilter() {
  const params = new URLSearchParams(window.location.search);
  params.delete('account_id');
  window.location.href = '/accounts' + (params.toString() ? '?' + params.toString() : '');
}

// 回车搜索
document.getElementById('search-input')?.addEventListener('keypress', function(e) {
  if (e.key === 'Enter') {
    applyFilters();
  }
});
</script>

<!-- Add Account Modal -->
<div id="add-account-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('add-account-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-lg shadow-xl w-full max-w-2xl p-6 max-h-[90vh] overflow-y-auto" data-controller="credit-card-form">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-primary dark:text-primary-dark">新建账户</h3>
        <button type="button" onclick="document.getElementById('add-account-modal').classList.add('hidden')" class="p-1 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <%= form_with model: Account.new, url: accounts_path, method: :post, local: true do |f| %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">账户名称</label>
            <%= f.text_field :name, placeholder: "例如：我的银行卡", required: true, class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">账户类型</label>
            <%= f.select :type, Account::ACCOUNT_TYPES.map { |k, v| [v, k] }, { prompt: "选择类型" }, required: true, class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500", data: { action: "change->credit-card-form#toggleCreditCardFields" } %>
          </div>
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">初始余额</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
              <%= f.number_field :initial_balance, step: "0.01", value: "0.00", class: "w-full pl-8 pr-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">货币</label>
            <%= f.select :currency, Currency.active.map { |c| ["#{c.code} - #{c.name}", c.code] }, { selected: "CNY" }, class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
          </div>
        </div>

        <!-- 信用卡专属字段 -->
        <div data-credit-card-form-target="creditCardFields" class="hidden mt-6 pt-4 border-t border-border dark:border-border-dark">
          <h4 class="text-base font-medium text-primary dark:text-primary-dark mb-4">信用卡设置</h4>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">信用额度</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
                <%= f.number_field :credit_limit, step: "0.01", placeholder: "0.00", class: "w-full pl-8 pr-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">账单日</label>
              <%= f.select :billing_day, (1..28).map { |d| ["每月#{d}日", d] }, { selected: 1 }, class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">账单日交易计入</label>
              <%= f.select :billing_day_mode, [["本期账单", "current"], ["下期账单", "next"]], { selected: "current" }, class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">还款日类型</label>
              <%= f.select :due_day_mode, [["固定日期", "fixed"], ["账单日后N天", "relative"]], { selected: "fixed" }, class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500", data: { "credit-card-form-target": "dueDayModeSelect", action: "change->credit-card-form#toggleDueDayMode" } %>
            </div>
            <div data-credit-card-form-target="dueDayFixed">
              <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">还款日（固定）</label>
              <%= f.select :due_day, (1..28).map { |d| ["每月#{d}日", d] }, { selected: 1 }, class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
            </div>
            <div data-credit-card-form-target="dueDayRelative" class="hidden">
              <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">账单日后天数</label>
              <%= f.number_field :due_day_offset, min: 1, max: 28, placeholder: "1-28", class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
            </div>
          </div>
        </div>

        <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-border dark:border-border-dark">
          <button type="button" onclick="document.getElementById('add-account-modal').classList.add('hidden')" class="px-4 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">取消</button>
          <button type="submit" class="px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">保存</button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Edit Account Modal -->
<div id="edit-account-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('edit-account-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-lg shadow-xl w-full max-w-2xl p-6 max-h-[90vh] overflow-y-auto" data-controller="credit-card-form">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-primary dark:text-primary-dark">编辑账户</h3>
        <button type="button" onclick="document.getElementById('edit-account-modal').classList.add('hidden')" class="p-1 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <form id="edit-account-form" method="post">
        <input type="hidden" name="_method" value="patch">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">账户名称</label>
            <input type="text" name="account[name]" id="edit_account_name" required class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">账户类型</label>
            <select name="account[type]" id="edit_account_type" required class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" data-action="change->credit-card-form#toggleCreditCardFields">
              <% Account::ACCOUNT_TYPES.each do |k, v| %>
                <option value="<%= k %>"><%= v %></option>
              <% end %>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">初始余额</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
              <input type="number" name="account[initial_balance]" id="edit_account_initial_balance" step="0.01" class="w-full pl-8 pr-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">货币</label>
            <select name="account[currency]" id="edit_account_currency" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
              <% Currency.active.each do |c| %>
                <option value="<%= c.code %>"><%= c.code %> - <%= c.name %></option>
              <% end %>
            </select>
          </div>
        </div>

        <!-- 信用卡专属字段 -->
        <div data-credit-card-form-target="creditCardFields" class="hidden mt-6 pt-4 border-t border-border dark:border-border-dark">
          <h4 class="text-base font-medium text-primary dark:text-primary-dark mb-4">信用卡设置</h4>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">信用额度</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
                <input type="number" name="account[credit_limit]" id="edit_account_credit_limit" step="0.01" placeholder="0.00" class="w-full pl-8 pr-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">账单日</label>
              <select name="account[billing_day]" id="edit_account_billing_day" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
                <% (1..28).each do |d| %>
                  <option value="<%= d %>">每月<%= d %>日</option>
                <% end %>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">账单日交易计入</label>
              <select name="account[billing_day_mode]" id="edit_account_billing_day_mode" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
                <option value="current">本期账单</option>
                <option value="next">下期账单</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">还款日类型</label>
              <select name="account[due_day_mode]" id="edit_account_due_day_mode" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" data-credit-card-form-target="dueDayModeSelect" data-action="change->credit-card-form#toggleDueDayMode">
                <option value="fixed">固定日期</option>
                <option value="relative">账单日后N天</option>
              </select>
            </div>
            <div data-credit-card-form-target="dueDayFixed">
              <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">还款日（固定）</label>
              <select name="account[due_day]" id="edit_account_due_day" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
                <% (1..28).each do |d| %>
                  <option value="<%= d %>">每月<%= d %>日</option>
                <% end %>
              </select>
            </div>
            <div data-credit-card-form-target="dueDayRelative" class="hidden">
              <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">账单日后天数</label>
              <input type="number" name="account[due_day_offset]" id="edit_account_due_day_offset" min="1" max="28" placeholder="1-28" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
            </div>
          </div>
        </div>

        <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-border dark:border-border-dark">
          <button type="button" onclick="document.getElementById('edit-account-modal').classList.add('hidden')" class="px-4 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">取消</button>
          <button type="submit" class="px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">保存</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Add Transaction Modal -->
<div id="add-transaction-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('add-transaction-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-lg shadow-xl w-full max-w-md p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-primary dark:text-primary-dark">新建交易</h3>
        <button type="button" onclick="document.getElementById('add-transaction-modal').classList.add('hidden')" class="p-1 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <%= form_with model: @transaction, url: transactions_path, method: :post, local: true do |f| %>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">日期 *</label>
            <%= f.date_field :date, required: true, class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">金额 *</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
              <%= f.number_field :amount, step: "0.01", placeholder: "0.00", required: true, class: "w-full pl-8 pr-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">类型 *</label>
            <select name="transaction[type]" id="transaction_type" required class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
              <option value="EXPENSE">支出</option>
              <option value="INCOME">收入</option>
              <option value="TRANSFER">转账</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">账户 *</label>
            <%= f.collection_select :account_id, @accounts, :id, :name, { include_blank: "选择账户" }, required: true, class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">分类</label>
            <select name="transaction[category_id]" id="transaction_category_id" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
              <%= category_options_for_select(@categories) %>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">备注</label>
            <%= f.text_field :note, placeholder: "添加备注", class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
          </div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="document.getElementById('add-transaction-modal').classList.add('hidden')" class="px-4 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover transition-smooth">取消</button>
          <button type="submit" class="px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">保存</button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="flex flex-col lg:flex-row gap-4 h-auto lg:h-[calc(100vh-8rem)]">
  <!-- 左侧栏 - 账户管理 (移动端: 可折叠，桌面端: 固定) -->
  <div class="lg:w-80 shrink-0 flex flex-col bg-container dark:bg-container-dark rounded-lg shadow overflow-hidden">
    <!-- 移动端折叠按钮 -->
    <div class="lg:hidden p-3 border-b border-border dark:border-border-dark flex items-center justify-between">
      <div>
        <h2 class="text-base font-semibold text-primary dark:text-primary-dark">账户管理</h2>
        <div class="text-xs text-secondary dark:text-secondary-dark mt-0.5">
          总计: <span class="font-medium text-primary dark:text-primary-dark"><%= format_currency(Account.included_in_total.sum(&:current_balance)) %></span>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <button onclick="document.getElementById('add-account-modal').classList.remove('hidden')" class="p-2 rounded-lg bg-inverse text-white text-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        </button>
        <button onclick="toggleAccountList()" class="p-2 rounded-lg bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark">
          <svg id="account-toggle-icon" class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </button>
      </div>
    </div>

    <!-- 桌面端标题 -->
    <div class="hidden lg:block p-4 border-b border-border dark:border-border-dark">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-lg font-semibold text-primary dark:text-primary-dark">账户管理</h2>
        <button onclick="document.getElementById('add-account-modal').classList.remove('hidden')" class="p-1.5 rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        </button>
      </div>
      <div class="text-sm text-secondary dark:text-secondary-dark">
        总计: <span class="font-medium text-primary dark:text-primary-dark"><%= format_currency(Account.included_in_total.sum(&:current_balance)) %></span>
      </div>
    </div>
    
    <!-- 账户列表 -->
    <div id="account-list" class="hidden lg:block flex-1 overflow-y-auto" data-controller="account-sort">
      <% accounts_by_type = @accounts.group_by { |a| [a.type, a.type_name] }.sort_by { |(type, _), _| Account::ACCOUNT_TYPES.keys.index(type) || 999 } %>
      <% accounts_by_type.each do |(type, type_name), accounts| %>
        <div class="border-b border-border dark:border-border-dark">
          <!-- 类型标题 -->
          <div class="px-4 py-2 bg-surface-inset dark:bg-surface-dark-inset flex items-center justify-between">
            <span class="text-xs font-medium text-secondary dark:text-secondary-dark uppercase tracking-wide"><%= type_name || '未分类' %></span>
            <span class="text-xs text-secondary dark:text-secondary-dark"><%= format_currency(accounts.select { |a| a.include_in_total == 1 }.sum(&:current_balance)) %></span>
          </div>
          <!-- 该类型的账户列表 -->
          <div class="account-group" data-account-type="<%= type %>">
            <% accounts.sort_by(&:sort_order).each do |account| %>
              <div class="p-3 border-b border-border/50 dark:border-border-dark/50 hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth group cursor-pointer <%= params[:account_id].to_i == account.id ? 'bg-surface-inset dark:bg-surface-dark-inset' : '' %>" 
                   data-account-id="<%= account.id %>"
                   onclick="filterByAccount(<%= account.id %>)"
                   draggable="true"
                   data-action="dragstart->account-sort#start dragover->account-sort#over drop->account-sort#drop dragend->account-sort#end">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-surface dark:bg-surface-dark flex items-center justify-center shrink-0">
                    <span class="text-sm font-bold text-primary dark:text-primary-dark"><%= account.name[0] %></span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2">
                      <p class="font-medium text-sm text-primary dark:text-primary-dark truncate"><%= account.name %></p>
                      <% if account.include_in_total != 1 %>
                        <span class="text-[10px] px-1 py-0.5 rounded bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400">不计资产</span>
                      <% end %>
                    </div>
                    <% if account.type == 'CREDIT' && account.credit_limit %>
                      <p class="text-xs text-secondary dark:text-secondary-dark">额度 <%= format_currency(account.credit_limit) %></p>
                    <% end %>
                  </div>
                  <div class="flex items-center gap-1">
                    <p class="font-medium text-sm text-primary dark:text-primary-dark"><%= format_currency(account.current_balance) %></p>
                    <button onclick="event.stopPropagation(); openEditAccountModal(this)" 
                            data-id="<%= account.id %>"
                            data-name="<%= account.name %>"
                            data-type="<%= account.type %>"
                            data-initial-balance="<%= account.initial_balance || 0 %>"
                            data-include-in-total="<%= account.include_in_total %>"
                            data-currency="<%= account.currency %>"
                            data-credit-limit="<%= account.credit_limit || '' %>"
                            data-billing-day="<%= account.billing_day || '' %>"
                            data-billing-day-mode="<%= account.billing_day_mode || 'current' %>"
                            data-due-day-mode="<%= account.due_day_mode || 'fixed' %>"
                            data-due-day="<%= account.due_day || '' %>"
                            data-due-day-offset="<%= account.due_day_offset || '' %>"
                            class="p-1 rounded lg:opacity-0 lg:group-hover:opacity-100 hover:bg-surface-inset dark:hover:bg-surface-dark-inset transition-smooth">
                      <svg class="w-3.5 h-3.5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                    </button>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
      <% if @accounts.empty? %>
        <div class="p-6 text-center text-secondary dark:text-secondary-dark text-sm">
          暂无账户
        </div>
      <% end %>
    </div>
  </div>

  <!-- 右侧栏 - 交易记录 -->
  <div class="flex-1 flex flex-col bg-container dark:bg-container-dark rounded-lg shadow overflow-hidden min-h-[400px] lg:min-h-0">
    <!-- Header -->
    <div class="p-3 lg:p-4 border-b border-border dark:border-border-dark">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 sm:gap-0 mb-3">
        <div class="flex items-center gap-2">
          <h2 class="text-base lg:text-lg font-semibold text-primary dark:text-primary-dark">交易记录</h2>
          <% if params[:account_id] %>
            <span class="px-2 py-0.5 text-xs rounded-full bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark">
              <%= @accounts.find { |a| a.id == params[:account_id].to_i }&.name || '未知账户' %>
              <button onclick="clearAccountFilter()" class="ml-1 hover:text-primary">×</button>
            </span>
          <% end %>
        </div>
        <button onclick="document.getElementById('add-transaction-modal').classList.remove('hidden'); if(typeof applyTransactionTypeUI==='function'){applyTransactionTypeUI();}" class="px-3 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth btn-modern">
          + 新建
        </button>
      </div>
      
      <!-- 搜索筛选 -->
      <div class="flex flex-wrap gap-2 items-end">
        <div class="flex-1 min-w-[140px]">
          <input type="text" id="search-input" placeholder="搜索备注、分类..." value="<%= params[:search] %>" 
                 class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
        </div>
        <div class="w-24">
          <% selected_period_type = params[:period_type].presence || "month" %>
          <select id="period-type-filter" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark">
            <option value="all" <%= selected_period_type == 'all' ? 'selected' : '' %>>全部</option>
            <option value="week" <%= selected_period_type == 'week' ? 'selected' : '' %>>按周</option>
            <option value="month" <%= selected_period_type == 'month' ? 'selected' : '' %>>按月</option>
            <option value="year" <%= selected_period_type == 'year' ? 'selected' : '' %>>按年</option>
          </select>
        </div>
        <div class="w-[220px]" id="period-value-container" style="<%= selected_period_type == 'all' ? 'display:none' : '' %>">
          <% selected_period_value = params[:period_value].presence || case selected_period_type
             when "year" then Date.current.year.to_s
             when "week" then Date.current.strftime("%G-W%V")
             else Date.current.strftime("%Y-%m")
             end %>
          <div class="flex items-center gap-1">
            <button type="button"
                    id="period-prev-btn"
                    onclick="shiftPeriod(-1)"
                    class="px-2.5 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth"
                    aria-label="上一期">
              ‹
            </button>
<input id="period-value-filter"
                    type="text"
                    value="<%= selected_period_value %>"
                    class="flex-1 min-w-0 px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark">
            <button type="button"
                    id="period-next-btn"
                    onclick="shiftPeriod(1)"
                    class="px-2.5 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth"
                    aria-label="下一期">
              ›
            </button>
          </div>
        </div>
        <div class="w-28">
          <select id="type-filter" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark">
            <option value="">全部类型</option>
            <option value="INCOME" <%= params[:type] == 'INCOME' ? 'selected' : '' %>>收入</option>
            <option value="EXPENSE" <%= params[:type] == 'EXPENSE' ? 'selected' : '' %>>支出</option>
            <option value="TRANSFER" <%= params[:type] == 'TRANSFER' ? 'selected' : '' %>>转账</option>
          </select>
        </div>
        <div class="min-w-[120px]">
          <% selected_category_ids = Array(params[:category_ids]).reject(&:blank?) %>
          <button type="button" id="open-category-filter"
                  class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">
            分类筛选<%= selected_category_ids.any? ? " (#{selected_category_ids.size})" : "" %>
          </button>
        </div>
        <% if params[:search] || params[:type] || params[:period_type] || params[:period_value] || params[:category_ids].present? || params[:account_id] %>
          <button onclick="clearFilters()" class="px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover transition-smooth">
            清除
          </button>
        <% end %>
      </div>
    </div>

    <!-- 账户余额和汇总 -->
    <div class="p-3 lg:p-4 border-b border-border dark:border-border-dark bg-surface-inset dark:bg-surface-dark-inset">
      <div class="flex items-center justify-between mb-2">
        <div class="text-sm">
          <span class="text-secondary dark:text-secondary-dark">账户余额:</span>
          <span class="ml-1 font-semibold text-primary dark:text-primary-dark"><%= format_currency(@account_balance) %></span>
        </div>
      </div>
      <div class="flex items-center justify-between text-sm">
        <div>
          <span class="text-secondary dark:text-secondary-dark">流入:</span>
          <span class="ml-1 font-medium text-income"><%= format_currency(@total_income) %></span>
        </div>
        <div>
          <span class="text-secondary dark:text-secondary-dark">流出:</span>
          <span class="ml-1 font-medium text-expense"><%= format_currency(@total_expense) %></span>
        </div>
        <div>
          <span class="text-secondary dark:text-secondary-dark">差额:</span>
          <span class="ml-1 font-medium <%= @total_balance >= 0 ? 'text-income' : 'text-expense' %>"><%= format_currency(@total_balance) %></span>
        </div>
      </div>
    </div>

    <!-- 交易列表 -->
    <div id="transaction-list" class="flex-1 overflow-y-auto" data-page="<%= @page %>" data-per-page="<%= @per_page %>" data-total-count="<%= @total_count %>">
      <% if @transactions.any? %>
        <%= render 'skeleton' unless @page > 1 %>
        <div class="divide-y divide-border dark:divide-border-dark" id="transactions-container">
          <% @transactions_with_balance.each do |t, balance| %>
            <div class="p-3 hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">
              <div class="flex items-center gap-3">
                <div class="shrink-0 text-xs text-secondary dark:text-secondary-dark w-20">
                  <%= t.date&.strftime("%Y-%m-%d") %>
                </div>
<% 
  is_transfer = t.type == 'TRANSFER'
  current_account_filter = @current_account_id.to_s
  is_outflow = is_transfer && (current_account_filter.blank? || t.account_id.to_s == current_account_filter)
  is_inflow = is_transfer && t.target_account_id.to_s == current_account_filter && current_account_filter.present?
  display_type = if is_transfer
    is_inflow ? "转入" : "转出"
  else
    t.display_type
  end
  display_amount_type = if is_transfer
    is_inflow ? "INCOME" : "EXPENSE"
  else
    t.type
  end
%>
                <div class="ie-icon-chip ie-icon-chip-sm <%= display_amount_type == 'INCOME' ? 'ie-icon-income' : 'ie-icon-expense' %>">
                  <% if display_amount_type == 'INCOME' %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12"></path></svg>
                  <% else %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 13l-5 5m0 0l-5-5m5 5V6"></path></svg>
                  <% end %>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2">
                    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium <%= 
                      case t.type
                      when 'INCOME' then 'bg-income-light text-income'
                      when 'EXPENSE' then 'bg-expense-light text-expense'
                      when 'TRANSFER' then is_inflow ? 'bg-income-light text-income' : 'bg-expense-light text-expense'
                      else 'bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300'
                      end %>">
                      <%= display_type %>
                    </span>
                    <p class="text-sm font-medium text-primary dark:text-primary-dark truncate">
                      <% if is_transfer %>
                        <% if current_account_filter.present? %>
                          <%= is_inflow ? "← #{t.account&.name}" : "→ #{t.target_account&.name}" %>
                        <% else %>
                          <%= "#{t.account&.name} → #{t.target_account&.name}" %>
                        <% end %>
                      <% else %>
                        <%= t.category&.name || '-' %>
                      <% end %>
                    </p>
                  </div>
                  <p class="text-xs text-secondary dark:text-secondary-dark truncate mt-0.5"><%= t.note || t.account_name %></p>
                </div>
                <div class="text-right shrink-0">
                  <% if is_transfer && current_account_filter.blank? %>
                    <p class="text-sm">
                      <span class="text-expense">-<%= format_currency(t.amount) %></span>
                      <span class="mx-1 text-secondary dark:text-secondary-dark">/</span>
                      <span class="text-income">+<%= format_currency(t.amount) %></span>
                    </p>
                  <% else %>
                    <p class="text-sm font-medium <%= display_amount_type == 'INCOME' ? 'text-income' : 'text-expense' %>">
                      <%= format_currency_with_sign(t.amount, type: display_amount_type) %>
                    </p>
                  <% end %>
                  <p class="text-xs text-secondary dark:text-secondary-dark">余额: <%= @page == 1 ? format_currency(balance) : '--' %></p>
                </div>
                <div class="flex items-center gap-1 shrink-0">
                  <button onclick="openEditTransactionModal(<%= t.id %>)" class="p-1.5 rounded-lg hover:bg-surface-hover dark:hover:bg-surface-dark-hover text-secondary dark:text-secondary-dark hover:text-primary transition-smooth">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                  </button>
                  <button onclick="confirmDeleteTransaction(<%= t.id %>, '<%= j t.category&.name || t.display_type %>')" class="p-1.5 rounded-lg hover:bg-expense-light text-secondary dark:text-secondary-dark hover:text-expense transition-smooth">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                  </button>
                </div>
              </div>
            </div>
          <% end %>
        </div>
        <!-- 加载更多触发器 -->
        <div id="load-more-sentinel" class="p-4 text-center <%= @total_count > @page * @per_page ? '' : 'hidden' %>">
          <button id="load-more-btn" onclick="loadMoreTransactions()" class="px-4 py-2 text-sm font-medium rounded-lg bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">
            加载更多
          </button>
        </div>
        <div id="loading-indicator" class="hidden p-4 text-center">
          <div class="inline-block w-6 h-6 border-2 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
          <span class="ml-2 text-sm text-secondary dark:text-secondary-dark">加载中...</span>
        </div>
      <% else %>
        <div class="p-8 text-center">
          <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-surface dark:bg-surface-dark flex items-center justify-center">
            <svg class="w-6 h-6 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
          </div>
          <p class="text-secondary dark:text-secondary-dark text-sm">暂无交易记录</p>
          <button onclick="document.getElementById('add-transaction-modal').classList.remove('hidden'); if(typeof applyTransactionTypeUI==='function'){applyTransactionTypeUI();}" class="mt-3 px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">
            新建第一笔交易
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
let isLoadingMore = false;

function loadMoreTransactions() {
  if (isLoadingMore) return;
  
  const container = document.getElementById('transaction-list');
  const currentPage = parseInt(container.dataset.page);
  const perPage = parseInt(container.dataset.perPage);
  const totalCount = parseInt(container.dataset.totalCount);
  
  if (currentPage * perPage >= totalCount) {
    document.getElementById('load-more-sentinel').classList.add('hidden');
    return;
  }
  
  isLoadingMore = true;
  document.getElementById('load-more-btn').classList.add('hidden');
  document.getElementById('loading-indicator').classList.remove('hidden');
  
  // 构建URL参数
  const params = new URLSearchParams(window.location.search);
  params.set('page', currentPage + 1);
  params.set('per_page', perPage);
  params.set('format', 'turbo'); // 请求HTML片段
  
  fetch('/accounts?' + params.toString())
    .then(response => response.text())
    .then(html => {
      // 解析返回的HTML，提取交易列表
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, 'text/html');
      const newTransactions = doc.querySelectorAll('#transactions-container > div');
      
      if (newTransactions.length > 0) {
        const transactionsContainer = document.getElementById('transactions-container');
        newTransactions.forEach(t => transactionsContainer.appendChild(t));
        
        // 更新分页状态（更新 transaction-list 的 dataset）
        const listContainer = document.getElementById('transaction-list');
        listContainer.dataset.page = currentPage + 1;
        
        // 检查是否还有更多
        const newPage = currentPage + 1;
        if (newPage * perPage >= totalCount) {
          document.getElementById('load-more-sentinel').classList.add('hidden');
        }
      }
      
      document.getElementById('load-more-btn').classList.remove('hidden');
      document.getElementById('loading-indicator').classList.add('hidden');
      isLoadingMore = false;
    })
    .catch(err => {
      console.error('加载失败:', err);
      document.getElementById('load-more-btn').classList.remove('hidden');
      document.getElementById('loading-indicator').classList.add('hidden');
      isLoadingMore = false;
    });
}

// 滚动到底部自动加载 - 使用 IntersectionObserver
document.addEventListener('DOMContentLoaded', function() {
  const sentinel = document.getElementById('load-more-sentinel');
  if (!sentinel) return;
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        loadMoreTransactions();
      }
    });
  }, { rootMargin: '100px' });
  
  observer.observe(sentinel);
});
</script>

<!-- 新建账户弹窗 -->
<div id="add-account-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="closeAccountModal()"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-lg shadow-xl w-full max-w-md p-5">
      <div class="flex items-center justify-between mb-4">
        <h3 id="account-modal-title" class="text-lg font-semibold text-primary dark:text-primary-dark">新建账户</h3>
        <button type="button" onclick="closeAccountModal()" class="p-1 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <%= form_with model: Account.new, url: accounts_path, method: :post, local: true, id: 'account-form' do |f| %>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">账户名称 *</label>
            <%= f.text_field :name, required: true, placeholder: "例如：招商银行卡", id: 'account-name', class: "w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">账户类型</label>
            <%= f.select :type, Account::ACCOUNT_TYPES.map { |k, v| [v, k] }, { include_blank: "选择类型" }, id: 'account-type', class: "w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">初始余额</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
              <%= f.number_field :initial_balance, step: "0.01", placeholder: "0.00", id: 'account-initial-balance', class: "w-full pl-8 pr-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <%= f.check_box :include_in_total, { id: 'account-include-in-total', class: "w-4 h-4 rounded border-border dark:border-border-dark text-blue-600 focus:ring-blue-500" }, 1, 0 %>
            <label for="account-include-in-total" class="text-sm text-primary dark:text-primary-dark">计入资产总额</label>
          </div>
          
          <!-- 信用卡字段 -->
          <div id="credit-card-fields" class="hidden space-y-4 pt-4 border-t border-border dark:border-border-dark">
            <h4 class="text-sm font-medium text-primary dark:text-primary-dark">信用卡设置</h4>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">信用额度</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
                <%= f.number_field :credit_limit, step: "0.01", placeholder: "0.00", id: 'account-credit-limit', class: "w-full pl-8 pr-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">账单日</label>
              <%= f.select :billing_day, (1..28).map { |d| ["每月#{d}日", d] }, { include_blank: "选择账单日" }, id: 'account-billing-day', class: "w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">账单日交易计入</label>
              <%= f.select :billing_day_mode, [["本期账单", "current"], ["下期账单", "next"]], { include_blank: "选择" }, id: 'account-billing-day-mode', class: "w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">还款日类型</label>
              <%= f.select :due_day_mode, [["固定日期", "fixed"], ["账单日后N天", "relative"]], { include_blank: "选择" }, id: 'account-due-day-mode', class: "w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">还款日（固定）</label>
              <%= f.select :due_day, (1..28).map { |d| ["每月#{d}日", d] }, { include_blank: "选择还款日" }, id: 'account-due-day', class: "w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">账单日后天数</label>
              <%= f.number_field :due_day_offset, placeholder: "1-28", min: 1, max: 28, id: 'account-due-day-offset', class: "w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
            </div>
          </div>
        </div>
        <div class="flex justify-between mt-6">
          <div id="delete-account-btn-container"></div>
          <div class="flex gap-3">
            <button type="button" onclick="closeAccountModal()" class="px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover transition-smooth">取消</button>
            <button type="submit" class="px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">保存</button>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
function openEditAccountModal(btn) {
  const id = btn.dataset.id;
  const name = btn.dataset.name;
  const type = btn.dataset.type;
  const initialBalance = btn.dataset.initialBalance;
  const includeInTotal = btn.dataset.includeInTotal;
  
  document.getElementById('account-modal-title').textContent = '编辑账户';
  document.getElementById('account-form').action = '/accounts/' + id;
  document.getElementById('account-form').method = 'post';
  
  // 添加 _method=patch
  let methodInput = document.getElementById('account-method-input');
  if (!methodInput) {
    methodInput = document.createElement('input');
    methodInput.id = 'account-method-input';
    methodInput.type = 'hidden';
    methodInput.name = '_method';
    document.getElementById('account-form').appendChild(methodInput);
  }
  methodInput.value = 'patch';
  
  document.getElementById('account-name').value = name;
  document.getElementById('account-type').value = type;
  document.getElementById('account-initial-balance').value = initialBalance;
  
  // 设置信用卡字段
  document.getElementById('account-credit-limit').value = btn.dataset.creditLimit || '';
  document.getElementById('account-billing-day').value = btn.dataset.billingDay || '';
  document.getElementById('account-billing-day-mode').value = btn.dataset.billingDayMode || '';
  document.getElementById('account-due-day-mode').value = btn.dataset.dueDayMode || '';
  document.getElementById('account-due-day').value = btn.dataset.dueDay || '';
  document.getElementById('account-due-day-offset').value = btn.dataset.dueDayOffset || '';
  
  // 根据账户类型显示/隐藏信用卡字段
  toggleCreditCardFields(type);
  
  // 设置是否计入资产总额
  const includeInTotalCheckbox = document.getElementById('account-include-in-total');
  includeInTotalCheckbox.checked = includeInTotal == 1;
  
  // 添加删除按钮
  const deleteContainer = document.getElementById('delete-account-btn-container');
  deleteContainer.innerHTML = '<button type="button" onclick="confirmDeleteAccount(' + id + ', \'' + name + '\')" class="px-4 py-1.5 text-sm font-medium rounded-lg border border-red-300 text-red-600 dark:border-red-700 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-smooth">删除账户</button>';
  
  document.getElementById('add-account-modal').classList.remove('hidden');
}

function closeAccountModal() {
  document.getElementById('add-account-modal').classList.add('hidden');
  // 重置表单
  document.getElementById('account-modal-title').textContent = '新建账户';
  document.getElementById('account-form').action = '/accounts';
  document.getElementById('account-form').method = 'post';
  const methodInput = document.getElementById('account-method-input');
  if (methodInput) methodInput.remove();
  document.getElementById('account-name').value = '';
  document.getElementById('account-type').value = '';
  document.getElementById('account-initial-balance').value = '';
  document.getElementById('account-include-in-total').checked = true;
  document.getElementById('delete-account-btn-container').innerHTML = '';
  // 重置信用卡字段
  document.getElementById('account-credit-limit').value = '';
  document.getElementById('account-billing-day').value = '';
  document.getElementById('account-billing-day-mode').value = '';
  document.getElementById('account-due-day-mode').value = '';
  document.getElementById('account-due-day').value = '';
  document.getElementById('account-due-day-offset').value = '';
  toggleCreditCardFields('');
}

// 根据账户类型显示/隐藏信用卡字段
function toggleCreditCardFields(type) {
  const creditCardFields = document.getElementById('credit-card-fields');
  if (type === 'CREDIT') {
    creditCardFields.classList.remove('hidden');
  } else {
    creditCardFields.classList.add('hidden');
  }
}

// 账户类型选择变化时显示/隐藏信用卡字段
document.getElementById('account-type')?.addEventListener('change', function() {
  toggleCreditCardFields(this.value);
});

function confirmDeleteAccount(id, name) {
  if (!window.confirm('确定要删除账户 "' + name + '" 吗？\n\n注意：删除账户不会删除相关的交易记录。')) return;
  
  const form = document.createElement('form');
  form.method = 'POST';
  form.action = '/accounts/' + id;
  
  const methodInput = document.createElement('input');
  methodInput.type = 'hidden';
  methodInput.name = '_method';
  methodInput.value = 'delete';
  form.appendChild(methodInput);
  
  const token = document.querySelector('meta[name="csrf-token"]')?.content;
  if (token) {
    const csrfInput = document.createElement('input');
    csrfInput.type = 'hidden';
    csrfInput.name = 'authenticity_token';
    csrfInput.value = token;
    form.appendChild(csrfInput);
  }
  
  document.body.appendChild(form);
  form.submit();
}
</script>

<!-- 新建交易弹窗 -->
<% expense_transaction_categories = @categories.select { |c| c.category_type == "EXPENSE" || c.type == "EXPENSE" } %>
<% income_transaction_categories = @categories.select { |c| c.category_type == "INCOME" || c.type == "INCOME" } %>

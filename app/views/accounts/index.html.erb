function shiftPeriod(direction) {
  var periodTypeEl = document.getElementById('period-type-filter');
  var periodValueEl = document.getElementById('period-value-filter');
  if (!periodTypeEl || !periodValueEl) return;

  var periodType = periodTypeEl.value;
  var currentValue = periodValueEl.value;

  if (periodType === 'year') {
    var year = parseInt(currentValue, 10);
    if (year && year >= 2000 && year <= 2100) {
      var newYear = year + direction;
      if (newYear >= 2000 && newYear <= 2100) {
        periodValueEl.value = String(newYear);
        updatePeriodValueDisplay();
        applyFilters();
      }
    }
  } else if (periodType === 'month') {
    var match = currentValue.match(/^(\d{4})-(\d{2})$/);
    if (match) {
      var year = parseInt(match[1], 10);
      var month = parseInt(match[2], 10) + direction;
      if (month < 1) {
        month = 12;
        year -= 1;
      } else if (month > 12) {
        month = 1;
        year += 1;
      }
      periodValueEl.value = `${year}-${String(month).padStart(2, '0')}`;
      updatePeriodValueDisplay();
      applyFilters();
    }
  } else if (periodType === 'week') {
    var match = currentValue.match(/^(\d{4})-W(\d{2})$/);
    if (match) {
      var isoYear = parseInt(match[1], 10);
      var isoWeek = parseInt(match[2], 10);
      var monday = Date.fromISOWeek(isoYear, isoWeek);
      monday.setDate(monday.getDate() + (direction * 7));
      periodValueEl.value = monday.toISOWeekString();
      updatePeriodValueDisplay();
      applyFilters();
    }
  }
}

Date.fromISOWeek = function(year, week) {
  var jan4 = new Date(year, 0, 4);
  var day = jan4.getDay() || 7;
  var monday = new Date(jan4);
  monday.setDate(jan4.getDate() - day + 1 + ((week - 1) * 7));
  monday.setHours(0, 0, 0, 0);
  return monday;
};

Date.prototype.toISOWeekString = function() {
  var date = new Date(this);
  var day = date.getDay() || 7;
  date.setDate(date.getDate() + 4 - day);
  var yearStart = new Date(date.getFullYear(), 0, 1);
  var week = Math.ceil((((date - yearStart) / 86400000) + 1) / 7);
  return `${date.getFullYear()}-W${String(week).padStart(2, '0')}`;
};


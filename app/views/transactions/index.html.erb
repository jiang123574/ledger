<div class="space-y-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
    <h1 class="text-2xl font-semibold text-primary"><%= t("transactions.title") %></h1>
    <div class="flex items-center gap-3">
      <% if @search.active_filters? %>
        <%= link_to transactions_path, class: "inline-flex items-center gap-2 px-3 py-2 text-sm font-medium rounded-lg border border-border text-secondary hover:bg-surface-hover transition-smooth" do %>
          <%= render Ds::IconComponent.new(name: "x-mark", size: :sm) %>
          清除筛选
        <% end %>
      <% end %>
      <%= link_to new_transaction_path, class: "inline-flex items-center justify-center gap-2 px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth" do %>
        <%= render Ds::IconComponent.new(name: "plus", size: :sm) %>
        <%= t("transactions.new_transaction") %>
      <% end %>
    </div>
  </div>

  <!-- Search & Filter -->
  <div class="bg-container rounded-lg shadow-border-xs">
    <div class="p-4">
      <%= form_tag transactions_path, method: :get, class: "space-y-4", data: { controller: "auto-submit-form" } do %>
        <!-- Search Input -->
        <div>
          <%= text_field_tag :search, @search.search, 
              placeholder: "搜索备注...",
              class: "w-full px-3 py-2 text-sm rounded-lg border border-border focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        </div>

        <!-- Filter Row -->
        <div class="flex flex-wrap gap-3 items-end">
          <div class="flex-1 min-w-[120px]">
            <label class="block text-sm font-medium text-secondary mb-1">开始日期</label>
            <%= date_field_tag :start_date, @search.start_date, 
                class: "w-full px-3 py-2 text-sm rounded-lg border border-border focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          </div>
          <div class="flex-1 min-w-[120px]">
            <label class="block text-sm font-medium text-secondary mb-1">结束日期</label>
            <%= date_field_tag :end_date, @search.end_date, 
                class: "w-full px-3 py-2 text-sm rounded-lg border border-border focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          </div>
          <div class="flex-1 min-w-[120px]">
            <label class="block text-sm font-medium text-secondary mb-1">类型</label>
            <%= select_tag :type, options_for_select([
              ["全部", ""], 
              ["收入", "INCOME"], 
              ["支出", "EXPENSE"]
            ], @search.type), 
                class: "w-full px-3 py-2 text-sm rounded-lg border border-border focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          </div>
          <div class="flex-1 min-w-[120px]">
            <label class="block text-sm font-medium text-secondary mb-1">分类</label>
            <%= select_tag :category_id, options_for_select(
              [["全部", ""]] + @categories.pluck(:name, :id),
              @search.category_id
            ), 
                class: "w-full px-3 py-2 text-sm rounded-lg border border-border focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          </div>
        </div>

        <%= hidden_field_tag :account_id, params[:account_id] if params[:account_id].present? %>
      <% end %>

      <!-- Active Filter Badges -->
      <% if @search.active_filters? %>
        <div class="flex flex-wrap gap-2 pt-3 border-t border-border">
          <%= render Ds::FilterBadgeComponent.new(
            label: "日期",
            value: "#{@search.start_date&.strftime('%m/%d')}-#{@search.end_date&.strftime('%m/%d')}",
            remove_url: transactions_path(@search.to_params.except(:start_date, :end_date).merge(account_id: params[:account_id]))
          ) if @search.start_date && @search.end_date %>
          
          <%= render Ds::FilterBadgeComponent.new(
            label: "类型",
            value: @search.type == "INCOME" ? "收入" : "支出",
            remove_url: transactions_path(@search.to_params.except(:type).merge(account_id: params[:account_id]))
          ) if @search.type.present? %>
          
          <%= render Ds::FilterBadgeComponent.new(
            label: "分类",
            value: @categories.find { |c| c.id == @search.category_id }&.name,
            remove_url: transactions_path(@search.to_params.except(:category_id).merge(account_id: params[:account_id]))
          ) if @search.category_id.present? %>
          
          <%= render Ds::FilterBadgeComponent.new(
            label: "搜索",
            value: @search.search,
            remove_url: transactions_path(@search.to_params.except(:search).merge(account_id: params[:account_id]))
          ) if @search.search.present? %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Summary -->
  <% if @transactions.any? %>
    <div class="grid grid-cols-3 gap-4">
      <div class="bg-container rounded-lg shadow-border-xs p-4">
        <p class="text-sm text-secondary mb-1">总收入</p>
        <p class="text-xl font-semibold text-income">+¥<%= @summary[:total_income].to_s("%.2f") %></p>
      </div>
      <div class="bg-container rounded-lg shadow-border-xs p-4">
        <p class="text-sm text-secondary mb-1">总支出</p>
        <p class="text-xl font-semibold text-expense">-¥<%= @summary[:total_expense].to_s("%.2f") %></p>
      </div>
      <div class="bg-container rounded-lg shadow-border-xs p-4">
        <p class="text-sm text-secondary mb-1">净额</p>
        <p class="text-xl font-semibold <%= @summary[:total_income] - @summary[:total_expense] >= 0 ? 'text-income' : 'text-expense' %>">
          <%= @summary[:total_income] - @summary[:total_expense] >= 0 ? '+' : '' %>¥<%= (@summary[:total_income] - @summary[:total_expense]).to_s("%.2f") %>
        </p>
      </div>
    </div>
  <% end %>

  <!-- Three Column Layout: Account List | Transactions | Account Details -->
  <div class="grid grid-cols-12 gap-4" data-controller="bulk-select">
    <!-- Left Column: Account List -->
    <div class="col-span-12 md:col-span-3 bg-container rounded-lg shadow-border-xs">
      <div class="p-3 border-b border-border flex items-center justify-between">
        <h2 class="text-sm font-semibold text-primary">账户</h2>
        <%= link_to new_account_path, class: "p-1 hover:bg-surface-hover rounded" do %>
          <%= render Ds::IconComponent.new(name: "plus", size: :sm) %>
        <% end %>
      </div>
      <div class="divide-y divide-border max-h-[500px] overflow-y-auto">
        <!-- All Transactions -->
        <%= link_to transactions_path(@search.to_params.except(:account_id)), 
            class: "block p-3 hover:bg-surface transition-smooth #{params[:account_id].blank? ? 'bg-surface-inset' : ''}" do %>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center">
                <%= render Ds::IconComponent.new(name: "bars-3", size: :sm, class: "text-blue-600") %>
              </div>
              <span class="font-medium text-primary text-sm">所有交易</span>
            </div>
            <span class="text-xs text-secondary"><%= @summary[:count] %></span>
          </div>
        <% end %>
        
        <% @accounts.each do |account| %>
          <%= link_to transactions_path(@search.to_params.merge(account_id: account.id)), 
              class: "block p-3 hover:bg-surface transition-smooth #{params[:account_id].to_i == account.id ? 'bg-surface-inset' : ''}" do %>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center">
                  <span class="text-sm font-bold text-blue-600"><%= account.name[0] %></span>
                </div>
                <div>
                  <span class="font-medium text-primary text-sm"><%= account.name %></span>
                  <p class="text-xs text-secondary"><%= account.type_name %></p>
                </div>
              </div>
              <span class="text-xs text-secondary"><%= account.sent_transactions.count %></span>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Middle Column: Selected Account Info -->
    <div class="col-span-12 md:col-span-3 bg-container rounded-lg shadow-border-xs">
      <div class="p-3 border-b border-border">
        <h2 class="text-sm font-semibold text-primary">账户详情</h2>
      </div>
      <div class="p-4">
        <% if params[:account_id].present? && (selected_account = @accounts.find { |a| a.id == params[:account_id].to_i }) %>
          <div class="text-center mb-4">
            <div class="w-16 h-16 rounded-full bg-blue-100 flex items-center justify-center mx-auto mb-2">
              <span class="text-2xl font-bold text-blue-600"><%= selected_account.name[0] %></span>
            </div>
            <h3 class="font-semibold text-primary"><%= selected_account.name %></h3>
            <p class="text-sm text-secondary"><%= selected_account.type_name %></p>
          </div>
          <div class="space-y-3">
            <div class="flex justify-between items-center p-3 bg-surface rounded-lg">
              <span class="text-sm text-secondary">当前余额</span>
              <span class="font-semibold text-primary">¥<%= selected_account.current_balance.to_s("%.2f") %></span>
            </div>
            <div class="flex justify-between items-center p-3 bg-surface rounded-lg">
              <span class="text-sm text-secondary">货币</span>
              <span class="font-medium text-primary"><%= selected_account.currency.presence || "CNY" %></span>
            </div>
            <div class="flex justify-between items-center p-3 bg-surface rounded-lg">
              <span class="text-sm text-secondary">交易数量</span>
              <span class="font-medium text-primary"><%= selected_account.sent_transactions.count %></span>
            </div>
          </div>
          <div class="mt-4">
            <%= link_to edit_account_path(selected_account), class: "block w-full text-center px-4 py-2 text-sm font-medium rounded-lg bg-gray-200 text-primary hover:bg-gray-300 transition-smooth" do %>
              编辑账户
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-8">
            <div class="w-12 h-12 rounded-full bg-surface flex items-center justify-center mx-auto mb-3">
              <%= render Ds::IconComponent.new(name: "credit-card", class: "text-secondary") %>
            </div>
            <p class="text-sm text-secondary">选择左侧账户查看详情</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Right Column: Transaction List -->
    <div class="col-span-12 md:col-span-6 bg-container rounded-lg shadow-border-xs">
      <%= render Ds::SelectionBarComponent.new(
        count: 0,
        delete_url: bulk_destroy_transactions_path,
        edit_url: nil
      ) %>
      <% if @transactions.any? %>
        <!-- Header -->
        <div class="hidden md:grid grid-cols-12 gap-4 px-4 py-3 bg-surface-inset text-xs font-medium text-secondary uppercase tracking-wider rounded-t-lg">
          <div class="col-span-1"></div>
          <div class="col-span-2">日期</div>
          <div class="col-span-2">分类</div>
          <div class="col-span-3">账户</div>
          <div class="col-span-2">备注</div>
          <div class="col-span-2 text-right">金额</div>
        </div>

        <!-- Transactions -->
        <div class="divide-y divide-border max-h-[600px] overflow-y-auto">
          <% @transactions.each do |t| %>
            <div class="group relative">
              <%= link_to edit_transaction_path(t), class: "block" do %>
                <div class="p-4 hover:bg-surface transition-smooth">
                  <div class="md:grid md:grid-cols-12 md:gap-4 md:items-center">
                    <!-- Checkbox -->
                    <div class="col-span-1 mb-2 md:mb-0">
                      <input type="checkbox" 
                             value="<%= t.id %>" 
                             data-bulk-select-target="checkbox"
                             data-action="change->bulk-select#toggleRowSelection"
                             class="w-4 h-4 rounded border-border text-blue-600 focus:ring-blue-500">
                    </div>

                    <!-- Date & Type -->
                    <div class="col-span-2 flex items-center gap-3 mb-2 md:mb-0">
                      <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0 <%= t.type == "INCOME" ? "bg-red-100" : "bg-green-100" %>">
                        <% if t.type == "INCOME" %>
                          <%= render Ds::IconComponent.new(name: "arrow-up-right", size: :sm, class: "text-red-600") %>
                        <% else %>
                          <%= render Ds::IconComponent.new(name: "arrow-down-right", size: :sm, class: "text-green-600") %>
                        <% end %>
                      </div>
                      <div>
                        <p class="font-medium text-primary"><%= t.date&.strftime("%Y-%m-%d") %></p>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= t.type == "INCOME" ? "bg-red-100 text-red-700" : "bg-green-100 text-green-700" %>">
                          <%= t.type == "INCOME" ? "收入" : "支出" %>
                        </span>
                      </div>
                    </div>

                    <!-- Category -->
                    <div class="col-span-2 mb-2 md:mb-0">
                      <p class="font-medium text-primary"><%= t.category&.name || "-" %></p>
                    </div>

                    <!-- Account -->
                    <div class="col-span-3 mb-2 md:mb-0">
                      <p class="text-sm text-secondary"><%= t.account_name %></p>
                      <% if t.target_account_name.present? %>
                        <p class="text-xs text-secondary">→ <%= t.target_account_name %></p>
                      <% end %>
                    </div>

                    <!-- Note -->
                    <div class="col-span-2 mb-2 md:mb-0">
                      <p class="text-sm text-secondary truncate"><%= t.note || "-" %></p>
                    </div>

                    <!-- Amount -->
                    <div class="col-span-2 flex items-center justify-between md:justify-end">
                      <span class="font-semibold <%= t.type == "INCOME" ? "text-income" : "text-expense" %>">
                        <%= t.type == "INCOME" ? "+" : "-" %>¥<%= t.amount.to_s("%.2f") %>
                      </span>
                      <div class="md:hidden opacity-0 group-hover:opacity-100 transition-opacity">
                        <%= render Ds::IconComponent.new(name: "chevron-right", size: :sm, class: "text-secondary") %>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="p-12 text-center">
          <div class="w-12 h-12 rounded-full bg-surface flex items-center justify-center mx-auto mb-4">
            <%= render Ds::IconComponent.new(name: "inbox", class: "text-secondary") %>
          </div>
          <p class="text-primary font-medium mb-1"><%= t("transactions.no_transactions_found") %></p>
          <p class="text-secondary text-sm mb-4">开始添加您的第一笔交易吧</p>
          <%= link_to t("transactions.new_transaction"), new_transaction_path, class: "inline-flex items-center justify-center gap-2 px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

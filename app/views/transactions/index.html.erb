<div class="space-y-4">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <h1 class="text-lg font-semibold text-primary dark:text-primary-dark">交易记录</h1>
    <button onclick="document.getElementById('add-transaction-modal').classList.remove('hidden')" class="px-3 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth btn-modern">
      + 新建
    </button>
  </div>

  <!-- 搜索筛选 -->
  <div class="bg-container dark:bg-container-dark rounded-lg shadow p-3">
    <div class="flex flex-wrap gap-3 items-end">
      <div class="flex-1 min-w-[140px]">
        <label class="block text-xs font-medium text-secondary dark:text-secondary-dark mb-1">开始日期</label>
        <input type="date" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark">
      </div>
      <div class="flex-1 min-w-[140px]">
        <label class="block text-xs font-medium text-secondary dark:text-secondary-dark mb-1">结束日期</label>
        <input type="date" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark">
      </div>
      <div class="flex-1 min-w-[100px]">
        <label class="block text-xs font-medium text-secondary dark:text-secondary-dark mb-1">类型</label>
        <select class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark">
          <option value="">全部</option>
          <option>收入</option>
          <option>支出</option>
          <option>转账</option>
        </select>
      </div>
      <div class="flex-1 min-w-[120px]">
        <label class="block text-xs font-medium text-secondary dark:text-secondary-dark mb-1">账户</label>
        <select class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark">
          <option value="">全部</option>
        </select>
      </div>
    </div>
  </div>

  <!-- 交易列表 -->
  <div class="bg-container dark:bg-container-dark rounded-lg shadow overflow-hidden">
    <% if @entries.any? %>
      <% @entries.each do |e| %>
        <div class="p-3 border-b border-border dark:border-border-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth cursor-pointer" onclick="editTransaction(<%= e.id %>)">
          <div class="flex items-center gap-3">
            <div class="ie-icon-chip ie-icon-chip-sm <%= e.display_entry_type == "INCOME" ? "ie-icon-income" : "ie-icon-expense" %>">
              <% if e.display_entry_type == "INCOME" %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12"></path></svg>
              <% else %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 13l-5 5m0 0l-5-5m5 5V6"></path></svg>
              <% end %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-primary dark:text-primary-dark truncate"><%= e.display_category&.name || e.display_type_label %></p>
              <p class="text-xs text-secondary dark:text-secondary-dark truncate"><%= e.display_note || e.account_name %></p>
            </div>
            <div class="text-right">
              <p class="text-sm font-medium <%= e.display_entry_type == "INCOME" ? "text-income" : "text-expense" %>">
                <%= format_currency_with_sign(e.display_amount, type: e.display_entry_type) %>
              </p>
              <p class="text-xs text-secondary dark:text-secondary-dark"><%= e.date&.strftime("%m/%d") %></p>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="p-8 text-center">
        <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-surface dark:bg-surface-dark flex items-center justify-center">
          <svg class="w-6 h-6 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
        </div>
        <p class="text-secondary dark:text-secondary-dark text-sm">暂无交易记录</p>
      </div>
    <% end %>
  </div>
</div>

<!-- Quick Transaction Modal -->
<% expense_transaction_categories = @categories.select { |c| c.category_type == "EXPENSE" || c.type == "EXPENSE" } %>
<% income_transaction_categories = @categories.select { |c| c.category_type == "INCOME" || c.type == "INCOME" } %>
<% funding_source_accounts = @accounts %>
<div id="add-transaction-modal" class="hidden fixed inset-0 z-50 overflow-y-auto modal-overlay">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('add-transaction-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-lg shadow-xl w-full max-w-md p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-primary dark:text-primary-dark">新建交易</h3>
        <button type="button" onclick="document.getElementById('add-transaction-modal').classList.add('hidden')" class="p-1 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <%= form_with model: @new_transaction, url: transactions_path, method: :post, local: true do |f| %>
        <%= f.hidden_field :currency, value: "CNY" %>
        <%= f.hidden_field :type, value: (@new_transaction.type.presence || "EXPENSE"), id: "transaction-type-input" %>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">类型 *</label>
            <div class="grid grid-cols-3 gap-2" id="transaction-type-cards">
              <button type="button" data-transaction-type="EXPENSE" class="transaction-type-card px-3 py-2 rounded-lg border text-sm font-medium transition-smooth">支出</button>
              <button type="button" data-transaction-type="INCOME" class="transaction-type-card px-3 py-2 rounded-lg border text-sm font-medium transition-smooth">收入</button>
              <button type="button" data-transaction-type="TRANSFER" class="transaction-type-card px-3 py-2 rounded-lg border text-sm font-medium transition-smooth">转账</button>
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">日期 *</label>
            <%= f.date_field :date, value: Date.current, required: true, class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">金额 *</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
              <%= f.number_field :amount, step: "0.01", placeholder: "0.00", required: true, class: "w-full pl-8 pr-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">账户 *</label>
            <%= f.collection_select :account_id, @accounts, :id, :name, { include_blank: "选择账户" }, required: true, class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
          </div>
          <div id="funding-account-field">
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">实际资金来源（可选）</label>
            <%= select_tag :funding_account_id,
                  options_for_select(funding_source_accounts.map { |a| [a.name, a.id] }),
                  include_blank: "不补记资金来源",
                  id: "funding-account-select",
                  class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
            <p class="mt-1 text-xs text-secondary dark:text-secondary-dark">选择后会自动创建“来源账户 → 当前账户”的转账，再记录这笔支出。</p>
          </div>
          <div id="target-account-field" class="hidden">
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">转入账户 *</label>
            <%= f.collection_select :target_account_id, @accounts, :id, :name, { include_blank: "选择转入账户" }, class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
          </div>
          <div id="transaction-category-field">
            <label id="transaction-category-label" class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">支出分类</label>
            <%= f.select :category_id, options_for_select(expense_transaction_categories.map { |c| [c.name, c.id] }), { include_blank: "选择支出分类" }, id: "transaction-category-select", class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">备注</label>
            <%= f.text_field :note, placeholder: "添加备注", class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
          </div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="document.getElementById('add-transaction-modal').classList.add('hidden')" class="px-4 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover transition-smooth">取消</button>
          <button type="submit" name="continue_entry" value="1" class="px-4 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover transition-smooth">保存并继续</button>
          <button type="submit" class="px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">保存</button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- 编辑交易弹窗 -->
<div id="edit-transaction-modal" class="hidden fixed inset-0 z-50 overflow-y-auto modal-overlay">
  <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('edit-transaction-modal').classList.add('hidden')"></div>
  
  <div class="flex items-center justify-center min-h-screen p-4">
    <div class="relative bg-container dark:bg-container-dark rounded-xl shadow-xl w-full max-w-2xl p-8">
      <button type="button" onclick="document.getElementById('edit-transaction-modal').classList.add('hidden')" class="absolute top-4 right-4 p-2 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-colors">
        <svg class="w-6 h-6 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
      <div id="edit-transaction-content"></div>
    </div>
  </div>
</div>

<script>
const expenseCategoryOptions = <%= raw expense_transaction_categories.map { |c| { id: c.id, name: c.name } }.to_json %>;
const incomeCategoryOptions = <%= raw income_transaction_categories.map { |c| { id: c.id, name: c.name } }.to_json %>;
const transactionTypeInput = document.getElementById('transaction-type-input');
const transactionTypeCards = document.querySelectorAll('#transaction-type-cards .transaction-type-card');
const targetAccountField = document.getElementById('target-account-field');
const targetAccountInput = document.querySelector('#add-transaction-modal select[name="transaction[target_account_id]"]');
const fundingAccountField = document.getElementById('funding-account-field');
const fundingAccountSelect = document.getElementById('funding-account-select');
const categoryField = document.getElementById('transaction-category-field');
const categoryLabel = document.getElementById('transaction-category-label');
const categorySelect = document.getElementById('transaction-category-select');

function setCategoryOptions(options, placeholder) {
  if (!categorySelect) return;
  categorySelect.innerHTML = '';
  const blankOption = document.createElement('option');
  blankOption.value = '';
  blankOption.textContent = placeholder;
  categorySelect.appendChild(blankOption);

  options.forEach((option) => {
    const el = document.createElement('option');
    el.value = option.id;
    el.textContent = option.name;
    categorySelect.appendChild(el);
  });
}

function applyTransactionTypeUI() {
  const type = transactionTypeInput?.value || 'EXPENSE';
  const isTransfer = type === 'TRANSFER';
  const isIncome = type === 'INCOME';

  transactionTypeCards.forEach((card) => {
    const active = card.dataset.transactionType === type;
    card.className = active
      ? 'transaction-type-card px-3 py-2 rounded-lg border text-sm font-medium transition-smooth bg-surface-inset dark:bg-surface-dark-inset border-border dark:border-border-dark text-primary dark:text-primary-dark'
      : 'transaction-type-card px-3 py-2 rounded-lg border text-sm font-medium transition-smooth bg-white dark:bg-surface-dark border-border dark:border-border-dark text-secondary dark:text-secondary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover';
  });

  if (targetAccountField && targetAccountInput) {
    targetAccountField.classList.toggle('hidden', !isTransfer);
    targetAccountInput.required = isTransfer;
    if (!isTransfer) targetAccountInput.value = '';
  }

  if (fundingAccountField && fundingAccountSelect) {
    const showFunding = type === 'EXPENSE';
    fundingAccountField.classList.toggle('hidden', !showFunding);
    if (!showFunding) fundingAccountSelect.value = '';
  }

  if (categoryField && categorySelect && categoryLabel) {
    categoryField.classList.toggle('hidden', isTransfer);
    if (isTransfer) {
      categorySelect.required = false;
      categorySelect.value = '';
    } else if (isIncome) {
      categoryLabel.textContent = '收入分类';
      setCategoryOptions(incomeCategoryOptions, '选择收入分类');
      categorySelect.required = true;
    } else {
      categoryLabel.textContent = '支出分类';
      setCategoryOptions(expenseCategoryOptions, '选择支出分类');
      categorySelect.required = true;
    }
  }
}

transactionTypeCards.forEach((card) => {
  card.addEventListener('click', function() {
    if (!transactionTypeInput) return;
    transactionTypeInput.value = this.dataset.transactionType;
    applyTransactionTypeUI();
  });
});

applyTransactionTypeUI();

<% if params[:open_modal] == "true" || params[:open_new_transaction] == "1" %>
document.getElementById('add-transaction-modal')?.classList.remove('hidden');
<% end %>

// 编辑交易弹窗
function editTransaction(transactionId) {
  fetch(`/transactions/${transactionId}/edit`, {
    headers: { 'Accept': 'text/html', 'X-Requested-With': 'XMLHttpRequest' }
  })
  .then(res => res.text())
  .then(html => {
    document.getElementById('edit-transaction-content').innerHTML = html;
    document.getElementById('edit-transaction-modal').classList.remove('hidden');
  })
  .catch(err => console.error('Error loading transaction:', err));
}
</script>

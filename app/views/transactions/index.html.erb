<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h1 class="text-2xl font-bold text-gray-900">Transactions</h1>
    <%= link_to "New Transaction", new_transaction_path, class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
  </div>

  <div class="bg-white rounded-lg shadow">
    <div class="p-4 border-b flex justify-between items-center">
      <%= form_tag transactions_path, method: :get, class: "flex space-x-4" do %>
        <%= date_field_tag :start_date, params[:start_date], class: "border rounded px-2 py-1" %>
        <%= date_field_tag :end_date, params[:end_date], class: "border rounded px-2 py-1" %>
        <%= select_tag :type, options_for_select(["", "INCOME", "EXPENSE"], params[:type]), class: "border rounded px-2 py-1" %>
        <%= submit_tag "Filter", class: "bg-gray-200 px-3 py-1 rounded hover:bg-gray-300" %>
      <% end %>
    </div>

    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Category</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Account</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Note</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Amount</th>
          <th class="px-6 py-3 actions"></th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @transactions.each do |t| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap text-sm"><%= t.date.strftime("%Y-%m-%d") if t.date %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
              <span class="px-2 py-1 rounded text-xs <%= t.transaction_type == "INCOME" ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800" %>">
                <%= t.transaction_type %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm"><%= t.category || "-" %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm"><%= t.account_name %></td>
            <td class="px-6 py-4 text-sm"><%= t.note || "-" %></td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium <%= t.transaction_type == "INCOME" ? "text-green-600" : "text-red-600" %>">
              <%= t.transaction_type == "INCOME" ? "+" : "-" %>¥<%= t.amount.to_s("%.2f") %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
              <%= link_to "Edit", edit_transaction_path(t), class: "text-blue-600 hover:text-blue-900" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @transactions.empty? %>
      <div class="p-8 text-center text-gray-500">
        No transactions found
      </div>
    <% end %>
  </div>
</div>

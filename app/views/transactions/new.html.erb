<div class="space-y-6">
  <div class="flex items-center gap-4">
    <%= link_to transactions_path, class: "p-2 hover:bg-surface-inset dark:hover:bg-surface-dark-inset rounded-lg transition-smooth" do %>
      <%= render(Ds::IconComponent.new(name: "arrow-left", size: :md)) %>
    <% end %>
    <h1 class="text-2xl font-semibold text-primary dark:text-primary-dark"><%= t("transactions.new_transaction") %></h1>
  </div>

  <%= render(Ds::CardComponent.new) do %>
    <%= form_with model: @transaction, local: true, class: "space-y-6" do |f| %>
      <!-- Transaction Type Tabs -->
      <div class="bg-surface-inset dark:bg-surface-dark-inset rounded-lg p-1 flex">
        <button type="button" class="flex-1 px-4 py-1.5 text-sm font-medium rounded-lg transition-smooth btn-modern type-tab" data-type="EXPENSE">
          <span class="flex items-center justify-center gap-2">
            <%= render(Ds::IconComponent.new(name: "minus-circle", size: :sm, color: :expense)) %>
            支出
          </span>
        </button>
        <button type="button" class="flex-1 px-4 py-1.5 text-sm font-medium rounded-lg transition-smooth btn-modern type-tab" data-type="INCOME">
          <span class="flex items-center justify-center gap-2">
            <%= render(Ds::IconComponent.new(name: "plus-circle", size: :sm, color: :income)) %>
            收入
          </span>
        </button>
      </div>
      <%= f.hidden_field :type, id: "transaction_type", value: params[:type] || "EXPENSE" %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5"><%= t("transactions.date") %></label>
          <%= render Ds::InputComponent.new(form: f, field: :date, type: :text) %>
        </div>

        <div>
          <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5"><%= t("transactions.amount") %></label>
          <%= render Ds::InputComponent.new(form: f, field: :amount, type: :number, placeholder: "0.00", prefix: "¥") %>
        </div>

        <div>
          <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5"><%= t("transactions.account") %></label>
          <%= render Ds::InputComponent.new(form: f, field: :account_id, type: :select, 
                choices: @accounts.map { |a| [a.name, a.id] },
                include_blank: "选择账户") %>
        </div>

        <div>
          <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5"><%= t("transactions.category") %></label>
          <%= render Ds::InputComponent.new(form: f, field: :category_id, type: :select,
                choices: @categories.map { |c| [c.name, c.id] },
                include_blank: "选择分类") %>
        </div>

        <div>
          <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">转入账户</label>
          <%= render Ds::InputComponent.new(form: f, field: :target_account_id, type: :select,
                choices: @accounts.map { |a| [a.name, a.id] },
                include_blank: "无") %>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5"><%= t("transactions.note") %></label>
        <%= render Ds::InputComponent.new(form: f, field: :note, type: :textarea, placeholder: "添加备注...") %>
      </div>

      <div class="flex justify-end gap-3 pt-4 border-t border-border dark:border-border-dark">
        <%= link_to t("transactions.cancel"), transactions_path, class: "px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth btn-modern" %>
        <%= render(Ds::ButtonComponent.new(type: :submit, variant: :primary)) do %>
          <%= t("transactions.create") %>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>

<script>
  document.querySelectorAll('.type-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      document.querySelectorAll('.type-tab').forEach(function(t) {
        t.classList.remove('bg-container', 'shadow-sm', 'dark:bg-container-dark');
      });
      tab.classList.add('bg-container', 'dark:bg-container-dark', 'shadow-sm');
      document.getElementById('transaction_type').value = tab.dataset.type;
    });
  });
  // Initialize based on current value
  var currentType = document.getElementById('transaction_type')?.value || 'EXPENSE';
  document.querySelector('.type-tab[data-type="' + currentType + '"]')?.classList.add('bg-container', 'dark:bg-container-dark', 'shadow-sm');
</script>

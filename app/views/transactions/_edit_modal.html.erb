<!-- 交易编辑弹窗内容（与新建交易 UI 一致） -->
<%
  entry_type = @entry.display_entry_type
  is_transfer = entry_type == 'TRANSFER'
  is_income = entry_type == 'INCOME'
  is_expense = entry_type == 'EXPENSE'
%>
<div class="flex items-center justify-between mb-4">
  <h3 class="text-lg font-semibold text-primary dark:text-primary-dark">编辑交易</h3>
  <button type="button" onclick="document.getElementById('edit-transaction-modal').classList.add('hidden')" class="p-1 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth">
    <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
  </button>
</div>

<%= form_with model: @entry, url: transaction_path(@entry), method: :patch, local: false, id: "transaction-edit-form" do |f| %>
  <input type="hidden" id="edit-transaction-type" value="<%= entry_type %>">
  <input type="hidden" name="transaction[category_id]" id="edit_category_id" value="<%= @entry.display_category_id %>">
  <input type="hidden" name="transaction[account_id]" id="transaction_account_id" value="<%= is_transfer ? @entry.source_account_id_for_transfer : @entry.account_id %>">
  <input type="hidden" name="transaction[target_account_id]" id="transaction_target_account_id" value="<%= is_transfer ? @entry.target_account_id_for_display : '' %>">
  <input type="hidden" name="transaction[type]" id="transaction_type_hidden" value="<%= entry_type %>">
  <div class="space-y-4">
    <!-- 1. 分类（收支时显示） -->
    <div id="edit-category-field-wrapper" class="<%= is_transfer ? 'hidden' : '' %>">
      <div class="flex items-center justify-between mb-1.5">
        <label class="block text-sm font-medium text-secondary dark:text-secondary-dark">分类 *</label>
        <button type="button" id="edit-toggle-transfer-btn" class="text-xs text-blue-600 dark:text-blue-400 hover:underline">转账</button>
      </div>
      <div class="relative">
        <input type="text" id="edit-category-search-input"
               class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 cursor-pointer"
               placeholder="选择分类"
               autocomplete="off"
               readonly
               value="<%= @entry.display_category&.full_name || '' %>">
        <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-secondary dark:text-secondary-dark pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
        <div id="edit-category-dropdown" class="hidden absolute z-60 w-full mt-1 bg-white dark:bg-surface-dark rounded-lg border border-border dark:border-border-dark shadow-lg max-h-60 overflow-y-auto">
          <div class="p-2 border-b border-border dark:border-border-dark">
            <input type="text" id="edit-category-filter-input"
                   class="w-full px-2 py-1 text-sm rounded border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500"
                   placeholder="搜索分类..."
                   autocomplete="off">
          </div>
          <div id="edit-category-options" class="py-1"></div>
        </div>
      </div>
    </div>

    <!-- 转账：转出账户（转账时显示） -->
    <div id="edit-transfer-source-field" class="<%= is_transfer ? '' : 'hidden' %>">
      <div class="flex items-center justify-between mb-1.5">
        <label class="block text-sm font-medium text-secondary dark:text-secondary-dark">转出账户 *</label>
        <button type="button" id="edit-toggle-transfer-btn-alt" class="text-xs text-blue-600 dark:text-blue-400 hover:underline">收支</button>
      </div>
      <input type="hidden" id="edit_account_id" value="<%= @entry.source_account_id_for_transfer %>">
      <div class="relative">
        <input type="text" id="edit-account-search-input"
               class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 cursor-pointer"
               placeholder="选择转出账户"
               autocomplete="off"
               readonly
               value="<%= @entry.source_account_for_transfer&.name || '' %>">
        <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-secondary dark:text-secondary-dark pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
        <div id="edit-account-dropdown" class="hidden absolute z-60 w-full mt-1 bg-white dark:bg-surface-dark rounded-lg border border-border dark:border-border-dark shadow-lg max-h-60 overflow-y-auto">
          <div class="p-2 border-b border-border dark:border-border-dark">
            <input type="text" id="edit-account-filter-input"
                   class="w-full px-2 py-1 text-sm rounded border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500"
                   placeholder="搜索账户..."
                   autocomplete="off">
          </div>
          <div id="edit-account-options" class="py-1"></div>
        </div>
      </div>
      <!-- 转入账户 -->
      <div class="mt-3">
        <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">转入账户 *</label>
        <input type="hidden" id="edit_target_account_id" value="<%= @entry.target_account_id_for_display %>">
        <div class="relative">
          <input type="text" id="edit-target-account-search-input"
                 class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 cursor-pointer"
                 placeholder="选择转入账户"
                 autocomplete="off"
                 readonly
                 value="<%= @entry.target_account_for_display&.name || '' %>">
          <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-secondary dark:text-secondary-dark pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
          </svg>
          <div id="edit-target-account-dropdown" class="hidden absolute z-60 w-full mt-1 bg-white dark:bg-surface-dark rounded-lg border border-border dark:border-border-dark shadow-lg max-h-60 overflow-y-auto">
            <div class="p-2 border-b border-border dark:border-border-dark">
              <input type="text" id="edit-target-account-filter-input"
                     class="w-full px-2 py-1 text-sm rounded border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500"
                     placeholder="搜索账户..."
                     autocomplete="off">
            </div>
            <div id="edit-target-account-options" class="py-1"></div>
          </div>
        </div>
      </div>
      <!-- 互换账户按钮 -->
      <button type="button" id="edit-swap-accounts-btn" class="mt-2 w-full py-1.5 text-sm rounded-lg border border-border dark:border-border-dark text-secondary dark:text-secondary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth flex items-center justify-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/>
        </svg>
        互换转出/转入账户
      </button>
    </div>

    <!-- 2. 金额 -->
    <div>
      <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">金额 *</label>
      <div class="relative">
        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
        <%= f.number_field :amount, step: "0.01", placeholder: "0.00", required: true, value: @entry.display_amount, class: "w-full pl-8 pr-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
      </div>
    </div>

    <!-- 3. 账户（收支时显示） -->
    <div id="edit-account-field-wrapper" class="<%= is_transfer ? 'hidden' : '' %>">
      <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">账户 *</label>
      <input type="hidden" id="edit_account_id_income" value="<%= @entry.account_id %>">
      <div class="relative">
        <input type="text" id="edit-account-search-input-income"
               class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 cursor-pointer"
               placeholder="选择账户"
               autocomplete="off"
               readonly
               value="<%= @entry.account&.name || '' %>">
        <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-secondary dark:text-secondary-dark pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
        <div id="edit-account-dropdown-income" class="hidden absolute z-60 w-full mt-1 bg-white dark:bg-surface-dark rounded-lg border border-border dark:border-border-dark shadow-lg max-h-60 overflow-y-auto">
          <div class="p-2 border-b border-border dark:border-border-dark">
            <input type="text" id="edit-account-filter-input-income"
                   class="w-full px-2 py-1 text-sm rounded border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500"
                   placeholder="搜索账户..."
                   autocomplete="off">
          </div>
          <div id="edit-account-options-income" class="py-1"></div>
        </div>
      </div>
    </div>

    <!-- 4. 日期 -->
    <div>
      <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">日期 *</label>
      <%= f.date_field :date, value: @entry.date, required: true, class: "w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
    </div>

    <!-- 备注 -->
    <div>
      <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">备注</label>
      <%= f.text_field :notes, value: @entry.notes, placeholder: "添加备注", class: "w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
    </div>
  </div>

  <div class="flex justify-end gap-3 mt-6">
    <button type="button" onclick="document.getElementById('edit-transaction-modal').classList.add('hidden')" class="px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover transition-smooth">取消</button>
    <button type="submit" class="px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">保存</button>
  </div>
<% end %>

<script nonce="<%= csp_nonce %>">
(function() {
  var allAccounts = <%= raw @accounts.map { |a| { id: a.id, name: a.name, pinyin: PinYin.abbr(a.name).downcase } }.to_json %>;
  var allCategories = <%= raw @categories.map { |c| { id: c.id, name: c.name, full_name: c.full_name, pinyin: PinYin.abbr(c.full_name || c.name).downcase, level: c.level || 0, parent_id: c.parent_id, category_type: c.category_type || c.type } }.to_json %>;

  var currentType = document.getElementById('edit-transaction-type').value;

  // 初始化统一 account_id hidden input
  var unifiedAccountId = document.getElementById('transaction_account_id');
  var unifiedTargetId = document.getElementById('transaction_target_account_id');
  function syncUnifiedInputs() {
    if (currentType === 'TRANSFER') {
      unifiedAccountId.value = document.getElementById('edit_account_id')?.value || '';
      unifiedTargetId.value = document.getElementById('edit_target_account_id')?.value || '';
    } else {
      unifiedAccountId.value = document.getElementById('edit_account_id_income')?.value || '';
      unifiedTargetId.value = '';
    }
  }
  syncUnifiedInputs();

  function escapeHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  // 通用选择器初始化
  function initSelector(config) {
    var searchInput = document.getElementById(config.searchInputId);
    var dropdown = document.getElementById(config.dropdownId);
    var filterInput = document.getElementById(config.filterInputId);
    var optionsContainer = document.getElementById(config.optionsId);
    var hiddenInput = document.getElementById(config.hiddenInputId);
    var onSelect = config.onSelect;  // 选择后的回调函数
    if (!searchInput || !dropdown || !optionsContainer) return;

    function renderOptions(filterText, items) {
      var filtered = items.filter(function(item) {
        if (!filterText) return true;
        var query = filterText.toLowerCase();
        if (item.name && item.name.toLowerCase().includes(query)) return true;
        if (item.full_name && item.full_name.toLowerCase().includes(query)) return true;
        if (item.pinyin && item.pinyin.includes(query)) return true;
        return false;
      });
      if (filtered.length === 0) return '<div class="px-3 py-2 text-sm text-secondary dark:text-secondary-dark">无匹配</div>';
      return filtered.map(function(item) {
        var indent = item.level ? 'padding-left: ' + (item.level * 16 + 12) + 'px;' : '';
        var selected = hiddenInput && hiddenInput.value == item.id ? 'bg-blue-50 dark:bg-blue-900/20' : '';
        var label = escapeHtml(item.full_name || item.name);
        return '<div class="' + config.itemClass + ' px-3 py-1.5 text-sm cursor-pointer hover:bg-surface dark:hover:bg-surface-dark text-primary dark:text-primary-dark ' + selected + '" style="' + indent + '" data-id="' + item.id + '" data-name="' + label + '" data-type="' + (item.category_type || '') + '">' + label + '</div>';
      }).join('');
    }

    function updateOptions() {
      var filterText = filterInput ? filterInput.value : '';
      optionsContainer.innerHTML = renderOptions(filterText, config.items);
      optionsContainer.querySelectorAll('.' + config.itemClass).forEach(function(option) {
        option.addEventListener('click', function() {
          if (hiddenInput) hiddenInput.value = this.dataset.id;
          if (searchInput) searchInput.value = this.dataset.name;
          dropdown.classList.add('hidden');
          if (filterInput) filterInput.value = '';
          // 调用回调，传递选中的 id 和原始数据项
          if (onSelect) {
            var selectedId = this.dataset.id;
            var selectedItem = config.items.find(function(item) { return String(item.id) === selectedId; });
            onSelect(selectedId, selectedItem);
          }
        });
      });
    }

    // 移除旧监听器
    var newSearchInput = searchInput.cloneNode(true);
    searchInput.parentNode.replaceChild(newSearchInput, searchInput);
    searchInput = newSearchInput;
    dropdown.classList.add('hidden');

    searchInput.addEventListener('click', function(e) {
      e.stopPropagation();
      dropdown.classList.toggle('hidden');
      if (!dropdown.classList.contains('hidden')) { updateOptions(); if (filterInput) filterInput.focus(); }
    });
    if (filterInput) {
      filterInput.addEventListener('input', function() { updateOptions(); });
    }
    document.addEventListener('click', function(e) {
      if (dropdown && !dropdown.contains(e.target) && e.target !== searchInput) dropdown.classList.add('hidden');
    });
    // 初始渲染
    updateOptions();
  }

  function getFilteredCategories() {
    return allCategories;  // 显示所有分类
  }

  // 初始化转账模式下的账户选择器
  initSelector({
    searchInputId: 'edit-account-search-input', dropdownId: 'edit-account-dropdown',
    filterInputId: 'edit-account-filter-input', optionsId: 'edit-account-options',
    hiddenInputId: 'edit_account_id', items: allAccounts, itemClass: 'edit-account-opt'
  });
  initSelector({
    searchInputId: 'edit-target-account-search-input', dropdownId: 'edit-target-account-dropdown',
    filterInputId: 'edit-target-account-filter-input', optionsId: 'edit-target-account-options',
    hiddenInputId: 'edit_target_account_id', items: allAccounts, itemClass: 'edit-target-account-opt'
  });

  // 初始化收支模式下的选择器
  if (currentType !== 'TRANSFER') {
    initSelector({
      searchInputId: 'edit-category-search-input', dropdownId: 'edit-category-dropdown',
      filterInputId: 'edit-category-filter-input', optionsId: 'edit-category-options',
      hiddenInputId: 'edit_category_id', items: allCategories, itemClass: 'edit-category-opt',
      onSelect: function(value, item) {
        if (item && item.category_type) {
          currentType = item.category_type;
          document.getElementById('edit-transaction-type').value = currentType;
          document.getElementById('transaction_type_hidden').value = currentType;
        }
      }
    });
    initSelector({
      searchInputId: 'edit-account-search-input-income', dropdownId: 'edit-account-dropdown-income',
      filterInputId: 'edit-account-filter-input-income', optionsId: 'edit-account-options-income',
      hiddenInputId: 'edit_account_id_income', items: allAccounts, itemClass: 'edit-account-opt-income'
    });
  }

  // 转账切换（收支 → 转账）
  document.getElementById('edit-toggle-transfer-btn').addEventListener('click', function() {
    if (currentType !== 'TRANSFER') {
      currentType = 'TRANSFER';
      document.getElementById('edit-category-field-wrapper').classList.add('hidden');
      document.getElementById('edit-transfer-source-field').classList.remove('hidden');
      document.getElementById('edit-account-field-wrapper').classList.add('hidden');
      // 重新初始化转账账户选择器（DOM 被重新显示）
      initSelector({
        searchInputId: 'edit-account-search-input', dropdownId: 'edit-account-dropdown',
        filterInputId: 'edit-account-filter-input', optionsId: 'edit-account-options',
        hiddenInputId: 'edit_account_id', items: allAccounts, itemClass: 'edit-account-opt'
      });
      initSelector({
        searchInputId: 'edit-target-account-search-input', dropdownId: 'edit-target-account-dropdown',
        filterInputId: 'edit-target-account-filter-input', optionsId: 'edit-target-account-options',
        hiddenInputId: 'edit_target_account_id', items: allAccounts, itemClass: 'edit-target-account-opt'
      });
      document.getElementById('edit-transaction-type').value = currentType;
      syncUnifiedInputs();
    }
  });

  // 转账切换（转账 → 收支）
  document.getElementById('edit-toggle-transfer-btn-alt').addEventListener('click', function() {
    if (currentType === 'TRANSFER') {
      currentType = '';  // 清空类型，等待用户选择分类后自动判断
      document.getElementById('edit-category-field-wrapper').classList.remove('hidden');
      document.getElementById('edit-transfer-source-field').classList.add('hidden');
      document.getElementById('edit-account-field-wrapper').classList.remove('hidden');
      // 清空已选分类
      document.getElementById('edit_category_id').value = '';
      document.getElementById('edit-category-search-input').value = '';
      // 重新初始化收支选择器（显示所有分类）
      initSelector({
        searchInputId: 'edit-category-search-input', dropdownId: 'edit-category-dropdown',
        filterInputId: 'edit-category-filter-input', optionsId: 'edit-category-options',
        hiddenInputId: 'edit_category_id', items: allCategories, itemClass: 'edit-category-opt',
        onSelect: function(value, item) {
          if (item && item.category_type) {
            currentType = item.category_type;
            document.getElementById('edit-transaction-type').value = currentType;
            document.getElementById('transaction_type_hidden').value = currentType;
          }
        }
      });
      initSelector({
        searchInputId: 'edit-account-search-input-income', dropdownId: 'edit-account-dropdown-income',
        filterInputId: 'edit-account-filter-input-income', optionsId: 'edit-account-options-income',
        hiddenInputId: 'edit_account_id_income', items: allAccounts, itemClass: 'edit-account-opt-income'
      });
      document.getElementById('edit-transaction-type').value = '';
      syncUnifiedInputs();
    }
  });

  // 互换账户
  document.getElementById('edit-swap-accounts-btn').addEventListener('click', function() {
    var accountId = document.getElementById('edit_account_id');
    var targetId = document.getElementById('edit_target_account_id');
    var accountInput = document.getElementById('edit-account-search-input');
    var targetInput = document.getElementById('edit-target-account-search-input');
    if (!accountId || !targetId) return;

    var tmpId = accountId.value;
    var tmpName = accountInput ? accountInput.value : '';
    accountId.value = targetId.value;
    if (accountInput) accountInput.value = targetInput ? targetInput.value : '';
    targetId.value = tmpId;
    if (targetInput) targetInput.value = tmpName;
  });

  // 表单提交前同步 account_id 并构建 FormData
  document.getElementById('transaction-edit-form').addEventListener('submit', function(e) {
    e.preventDefault();
    syncUnifiedInputs();

    var form = this;
    var formData = new FormData(form);
    
    // 强制覆盖 FormData 中的值（FormData 读取的是 HTML 属性，不是 JS 更新的 value）
    formData.set('transaction[account_id]', document.getElementById('transaction_account_id')?.value || '');
    formData.set('transaction[target_account_id]', document.getElementById('transaction_target_account_id')?.value || '');
    formData.set('transaction[type]', currentType);
    formData.set('transaction[date]', form.querySelector('[name="entry[date]"]')?.value || '');
    formData.set('transaction[amount]', form.querySelector('[name="entry[amount]"]')?.value || '');
    formData.set('transaction[note]', form.querySelector('[name="entry[notes]"]')?.value || '');
    formData.set('transaction[currency]', 'CNY');

    fetch(form.action, {
      method: 'PATCH',
      body: formData,
      headers: {
        'Accept': 'text/html',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content
      }
    })
    .then(function(res) {
      document.getElementById('edit-transaction-modal').classList.add('hidden');
      if (res.redirected) { window.location.href = res.url; }
      else { window.location.reload(); }
    })
    .catch(function(err) { console.error('Error saving transaction:', err); });
  });
})();
</script>

<!-- 交易编辑弹窗 -->
<div id="transaction-edit-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="fixed inset-0 bg-black/50" onclick="closeTransactionModal()"></div>
  
  <div class="flex items-center justify-center min-h-screen p-4">
    <div class="relative bg-container dark:bg-container-dark rounded-xl shadow-xl w-full max-w-2xl p-8">
      <!-- 关闭按钮 -->
      <button type="button" onclick="closeTransactionModal()" class="absolute top-4 right-4 p-2 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-colors">
        <svg class="w-6 h-6 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>

      <!-- 标题 -->
      <div class="mb-6">
        <h2 class="text-2xl font-bold text-primary dark:text-primary-dark mb-2">
          编辑交易
        </h2>
      </div>

      <!-- 表单 -->
      <%= form_with model: @transaction, local: true, id: "transaction-edit-form", class: "space-y-6" do |f| %>
        <!-- Transaction Type Tabs -->
        <div class="bg-surface-inset dark:bg-surface-dark-inset rounded-lg p-1 flex">
          <button type="button" class="flex-1 px-4 py-1.5 text-sm font-medium rounded-lg transition-smooth btn-modern type-tab" data-type="EXPENSE">
            <span class="flex items-center justify-center gap-2">
              <%= render(Ds::IconComponent.new(name: "minus-circle", size: :sm, color: :expense)) %>
              支出
            </span>
          </button>
          <button type="button" class="flex-1 px-4 py-1.5 text-sm font-medium rounded-lg transition-smooth btn-modern type-tab" data-type="INCOME">
            <span class="flex items-center justify-center gap-2">
              <%= render(Ds::IconComponent.new(name: "plus-circle", size: :sm, color: :income)) %>
              收入
            </span>
          </button>
          <button type="button" class="flex-1 px-4 py-1.5 text-sm font-medium rounded-lg transition-smooth btn-modern type-tab" data-type="TRANSFER">
            <span class="flex items-center justify-center gap-2">
              <%= render(Ds::IconComponent.new(name: "arrow-right-left", size: :sm)) %>
              转账
            </span>
          </button>
        </div>
        <%= f.hidden_field :type, id: "transaction_type", value: @transaction.type %>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">日期</label>
            <%= render Ds::InputComponent.new(form: f, field: :date, type: :text) %>
          </div>

          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">金额</label>
            <%= render Ds::InputComponent.new(form: f, field: :amount, type: :number, placeholder: "0.00", prefix: "¥") %>
          </div>

          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">账户</label>
            <%= render Ds::InputComponent.new(form: f, field: :account_id, type: :select, 
                  choices: @accounts.map { |a| [a.name, a.id] },
                  include_blank: "选择账户") %>
          </div>

          <div id="category-field">
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">分类</label>
            <%= render Ds::InputComponent.new(form: f, field: :category_id, type: :select,
                  choices: @categories.map { |c| [c.name, c.id] },
                  include_blank: "选择分类") %>
          </div>

          <div id="target-account-field" class="hidden">
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">转入账户</label>
            <%= render Ds::InputComponent.new(form: f, field: :target_account_id, type: :select,
                  choices: @accounts.map { |a| [a.name, a.id] },
                  include_blank: "选择账户") %>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">备注</label>
          <%= render Ds::InputComponent.new(form: f, field: :note, type: :textarea, placeholder: "添加备注...") %>
        </div>

        <div class="flex justify-end gap-3 pt-4 border-t border-border dark:border-border-dark">
          <button type="button" onclick="closeTransactionModal()" class="px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth btn-modern">
            取消
          </button>
          <%= render(Ds::ButtonComponent.new(type: :submit, variant: :primary)) do %>
            保存
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  function closeTransactionModal() {
    document.getElementById('transaction-edit-modal').classList.add('hidden');
  }

  function openTransactionModal() {
    document.getElementById('transaction-edit-modal').classList.remove('hidden');
  }

  document.querySelectorAll('.type-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      document.querySelectorAll('.type-tab').forEach(function(t) {
        t.classList.remove('bg-container', 'shadow-sm', 'dark:bg-container-dark');
      });
      tab.classList.add('bg-container', 'dark:bg-container-dark', 'shadow-sm');
      document.getElementById('transaction_type').value = tab.dataset.type;
      
      // 根据类型显示/隐藏字段
      const categoryField = document.getElementById('category-field');
      const targetAccountField = document.getElementById('target-account-field');
      
      if (tab.dataset.type === 'TRANSFER') {
        categoryField.classList.add('hidden');
        targetAccountField.classList.remove('hidden');
      } else {
        categoryField.classList.remove('hidden');
        targetAccountField.classList.add('hidden');
      }
    });
  });

  var currentType = '<%= @transaction.type %>';
  document.querySelector('.type-tab[data-type="' + currentType + '"]').classList.add('bg-container', 'dark:bg-container-dark', 'shadow-sm');
  
  // 初始化字段显示
  if (currentType === 'TRANSFER') {
    document.getElementById('category-field').classList.add('hidden');
    document.getElementById('target-account-field').classList.remove('hidden');
  }
</script>

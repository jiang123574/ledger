<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h1 class="text-2xl font-bold text-gray-900"><%= t("budgets.title") %></h1>
    <div class="flex items-center space-x-2">
      <%= form_tag budgets_path, method: :get do %>
        <%= month_field_tag :month, @month, class: "border rounded-lg px-3 py-2.5 text-base" %>
        <%= submit_tag "Go", class: "px-4 py-2.5 text-base font-medium rounded-lg border border-border text-primary hover:bg-surface-hover transition-smooth btn-modern" %>
      <% end %>
    </div>
  </div>

  <div class="bg-container dark:bg-gray-800 rounded-lg shadow p-6">
    <h3 class="font-medium mb-4"><%= t("budgets.add_budget", month: @month) %></h3>
    <%= form_with model: Budget.new, url: budgets_path, local: true, class: "flex gap-4" do |f| %>
      <%= f.hidden_field :month, value: @month %>
      <%= f.collection_select :category_id, @categories, :id, :name, { include_blank: t("dashboard.total_budget") }, class: "border rounded px-3 py-1.5 text-sm" %>
      <%= f.number_field :amount, step: "0.01", placeholder: t("transactions.amount"), class: "border rounded px-3 py-1.5 text-sm" %>
      <%= f.submit t("budgets.add"), class: "px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth btn-modern" %>
    <% end %>
  </div>

  <!-- 总预算进度卡片 -->
  <% if @total_budget > 0 %>
    <div class="bg-container dark:bg-gray-800 rounded-lg shadow p-6">
      <div class="flex justify-between items-center mb-4">
        <h3 class="font-medium"><%= t("budgets.total") %></h3>
        <span class="text-sm <%= (@total_budget - @total_spent) < 0 ? 'text-red-600' : 'text-green-600' %>">
          <%= (@total_budget - @total_spent) < 0 ? "已超支" : "剩余 ¥#{@total_budget - @total_spent}" %>
        </span>
      </div>
      <div class="flex items-center gap-4">
        <div class="flex-1">
          <div class="flex justify-between text-sm mb-1">
            <span class="text-gray-500">已使用</span>
            <span class="font-medium">¥<%= @total_spent %> / ¥<%= @total_budget %></span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-4">
            <% percentage = @total_budget > 0 ? (@total_spent.to_f / @total_budget * 100).round : 0 %>
            <div class="<%= percentage > 100 ? 'bg-red-500' : (percentage > 80 ? 'bg-yellow-500' : 'bg-inverse') %> h-4 rounded-full transition-all" style="width: <%= [percentage, 100].min %>%"></div>
          </div>
          <div class="flex justify-between text-xs text-gray-400 mt-1">
            <span>0%</span>
            <span class="<%= percentage > 100 ? 'text-red-600 font-medium' : '' %>"><%= percentage %>%</span>
            <span>100%</span>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- 分类预算列表 -->
  <div class="grid gap-4">
    <% @budgets.each do |budget| %>
      <% spent = budget.spent_amount %>
      <% percentage = budget.progress_percentage %>
      <div class="bg-container dark:bg-gray-800 rounded-lg shadow p-4">
        <div class="flex justify-between items-center mb-2">
          <div class="flex items-center gap-2">
            <span class="font-medium"><%= budget.category&.name || t("budgets.total") %></span>
            <span class="text-xs px-2 py-0.5 rounded <%= 
              case budget.status_color
              when 'red' then 'bg-red-100 text-red-700'
              when 'yellow' then 'bg-yellow-100 text-yellow-700'
              else 'bg-surface dark:bg-gray-600 text-primary dark:text-gray-300'
              end
            %>"><%= budget.status_text %></span>
          </div>
          <div class="text-right">
            <span class="font-medium"><%= format_currency(budget.amount) %></span>
            <span class="text-sm text-gray-500">预算</span>
          </div>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-3">
          <div class="<%= budget.status_color == 'red' ? 'bg-red-500' : (budget.status_color == 'yellow' ? 'bg-yellow-500' : 'bg-inverse') %> h-3 rounded-full transition-all" style="width: <%= [percentage, 100].min %>%"></div>
        </div>
        <div class="flex justify-between text-sm mt-2">
          <span class="text-gray-500">已支出: <%= format_currency(spent) %></span>
          <span class="<%= budget.overspent? ? 'text-red-600 font-medium' : 'text-gray-500' %>">
            <%= budget.overspent? ? "超支 #{format_currency(budget.remaining_amount.abs)}" : "剩余 #{format_currency(budget.remaining_amount)}" %>
          </span>
        </div>
        <div class="flex justify-end mt-2">
          <%= link_to t("budgets.delete"), budget, method: :delete, data: { confirm: t("budgets.are_you_sure") }, class: "px-3 py-1.5 text-sm font-medium rounded-lg bg-red-100 text-red-600 hover:bg-red-200 transition-smooth btn-modern" %>
        </div>
      </div>
    <% end %>
  </div>

  <% if @budgets.empty? && @total_budget == 0 %>
    <div class="bg-container dark:bg-gray-800 rounded-lg shadow p-8 text-center text-gray-500">
      <%= t("budgets.no_budgets_set") %>
    </div>
  <% end %>
</div>

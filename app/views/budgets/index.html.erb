<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h1 class="text-2xl font-bold text-primary dark:text-primary-dark dark:text-white"><%= t("budgets.title") %></h1>
    <div class="flex items-center space-x-2">
      <%= form_tag budgets_path, method: :get do %>
        <%= month_field_tag :month, @month, class: "border rounded-lg px-3 py-2.5 text-base dark:bg-surface-dark dark:border-border-dark dark:text-white" %>
        <%= hidden_field_tag :tab, params[:tab] || "monthly" %>
        <%= submit_tag "Go", class: "px-4 py-2.5 text-base font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth btn-modern dark:border-border-dark dark:text-secondary-dark dark:hover:bg-gray-700" %>
      <% end %>
    </div>
  </div>

  <div class="border-b border-border dark:border-border-dark">
    <nav class="-mb-px flex space-x-8" aria-label="Tabs">
      <%= link_to budgets_path(month: @month, tab: "monthly"), class: "whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm #{params[:tab] != 'single' ? 'border-inverse text-inverse' : 'border-transparent text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark hover:border-border dark:border-border-dark dark:text-secondary-dark dark:hover:text-gray-300'}" do %>
        <%= t("budgets.monthly") %>
      <% end %>
      <%= link_to budgets_path(month: @month, tab: "single"), class: "whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm #{params[:tab] == 'single' ? 'border-inverse text-inverse' : 'border-transparent text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark hover:border-border dark:border-border-dark dark:text-secondary-dark dark:hover:text-gray-300'}" do %>
        <%= t("single_budgets.title") %>
      <% end %>
    </nav>
  </div>

  <% if params[:tab] == "single" %>
    <div class="flex justify-between items-center">
      <h2 class="text-xl font-semibold text-primary dark:text-primary-dark dark:text-white"><%= t("single_budgets.title") %></h2>
      <%= link_to t("single_budgets.new"), new_single_budget_path, class: "px-4 py-2.5 text-base font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth btn-modern" %>
    </div>

    <div class="flex items-center space-x-2 mb-4">
      <%= link_to budgets_path(tab: "single"), class: "px-3 py-1.5 text-sm font-medium rounded-lg border #{params[:status].blank? ? 'bg-inverse text-white' : 'border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover dark:text-secondary-dark dark:border-border-dark dark:hover:bg-gray-700'} #{params[:status].blank? ? '' : 'dark:bg-surface-dark'}" do %>
        <%= t("single_budgets.all") %>
      <% end %>
      <%= link_to budgets_path(tab: "single", status: "planning"), class: "px-3 py-1.5 text-sm font-medium rounded-lg border #{params[:status] == 'planning' ? 'bg-inverse text-white' : 'border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover dark:text-secondary-dark dark:border-border-dark dark:hover:bg-gray-700'} #{params[:status] == 'planning' ? '' : 'dark:bg-surface-dark'}" do %>
        <%= t("single_budgets.planning") %>
      <% end %>
      <%= link_to budgets_path(tab: "single", status: "active"), class: "px-3 py-1.5 text-sm font-medium rounded-lg border #{params[:status] == 'active' ? 'bg-inverse text-white' : 'border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover dark:text-secondary-dark dark:border-border-dark dark:hover:bg-gray-700'} #{params[:status] == 'active' ? '' : 'dark:bg-surface-dark'}" do %>
        <%= t("single_budgets.active") %>
      <% end %>
      <%= link_to budgets_path(tab: "single", status: "completed"), class: "px-3 py-1.5 text-sm font-medium rounded-lg border #{params[:status] == 'completed' ? 'bg-inverse text-white' : 'border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover dark:text-secondary-dark dark:border-border-dark dark:hover:bg-gray-700'} #{params[:status] == 'completed' ? '' : 'dark:bg-surface-dark'}" do %>
        <%= t("single_budgets.completed") %>
      <% end %>
      <%= link_to budgets_path(tab: "single", status: "cancelled"), class: "px-3 py-1.5 text-sm font-medium rounded-lg border #{params[:status] == 'cancelled' ? 'bg-inverse text-white' : 'border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover dark:text-secondary-dark dark:border-border-dark dark:hover:bg-gray-700'} #{params[:status] == 'cancelled' ? '' : 'dark:bg-surface-dark'}" do %>
        <%= t("single_budgets.cancelled") %>
      <% end %>
    </div>

    <% if @single_total_budget > 0 %>
      <div class="bg-container dark:bg-container-dark rounded-lg shadow p-6">
        <div class="flex justify-between items-center mb-4">
          <h3 class="font-medium dark:text-white"><%= t("single_budgets.total") %></h3>
          <span class="text-sm <%= (@single_total_budget - @single_total_spent) < 0 ? 'text-expense' : 'text-income' %>">
            <%= (@single_total_budget - @single_total_spent) < 0 ? "已超支" : "剩余 #{format_currency(@single_total_budget - @single_total_spent)}" %>
          </span>
        </div>
        <div class="flex items-center gap-4">
          <div class="flex-1">
            <div class="flex justify-between text-sm mb-1">
              <span class="text-secondary dark:text-secondary-dark"><%= t("single_budgets.spent") %></span>
              <span class="font-medium dark:text-white"><%= format_currency(@single_total_spent) %> / <%= format_currency(@single_total_budget) %></span>
            </div>
            <div class="w-full bg-surface dark:bg-surface-dark rounded-full h-4 dark:bg-surface-dark">
              <% percentage = @single_total_budget > 0 ? (@single_total_spent.to_f / @single_total_budget * 100).round : 0 %>
              <div class="<%= percentage > 100 ? 'bg-red-500' : (percentage > 80 ? 'bg-yellow-500' : 'bg-inverse') %> h-4 rounded-full transition-all" style="width: <%= [percentage, 100].min %>%"></div>
            </div>
            <div class="flex justify-between text-xs text-secondary dark:text-secondary-dark mt-1">
              <span>0%</span>
              <span class="<%= percentage > 100 ? 'text-expense font-medium' : '' %>"><%= percentage %>%</span>
              <span>100%</span>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div class="grid gap-4">
      <% @single_budgets.each do |budget| %>
        <% percentage = budget.progress_percentage %>
        <div class="bg-container dark:bg-container-dark rounded-lg shadow p-4">
          <div class="flex justify-between items-center mb-2">
            <div class="flex items-center gap-2">
              <span class="font-medium dark:text-white"><%= budget.name %></span>
              <span class="text-xs px-2 py-0.5 rounded <%= 
                case budget.status_color
                when 'red' then 'bg-expense-light text-expense dark:bg-red-900 dark:text-red-300'
                when 'yellow' then 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900 dark:text-yellow-300'
                when 'green' then 'bg-income-light text-green-700 dark:bg-green-900 dark:text-green-300'
                else 'bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark dark:text-secondary-dark'
                end
              %>"><%= budget.status_text %></span>
            </div>
            <div class="text-right">
              <span class="font-medium dark:text-white"><%= format_currency(budget.total_amount) %></span>
              <span class="text-sm text-secondary dark:text-secondary-dark"><%= t("single_budgets.budget") %></span>
            </div>
          </div>
          
          <% if budget.description.present? %>
            <p class="text-sm text-secondary dark:text-secondary-dark mb-2 dark:text-secondary-dark"><%= budget.description %></p>
          <% end %>
          
          <div class="flex items-center gap-4 text-sm text-secondary dark:text-secondary-dark mb-2 dark:text-secondary-dark">
            <span><%= budget.start_date.strftime("%Y-%m-%d") %></span>
            <% if budget.end_date.present? %>
              <span>~ <%= budget.end_date.strftime("%Y-%m-%d") %></span>
            <% end %>
            <% if budget.budget_items.any? %>
              <span><%= budget.budget_items.count %> <%= t("single_budgets.items") %></span>
            <% end %>
          </div>
          
          <div class="w-full bg-surface dark:bg-surface-dark rounded-full h-3 dark:bg-surface-dark">
            <div class="<%= budget.status_color == 'red' ? 'bg-red-500' : (budget.status_color == 'yellow' ? 'bg-yellow-500' : 'bg-inverse') %> h-3 rounded-full transition-all" style="width: <%= [percentage, 100].min %>%"></div>
          </div>
          <div class="flex justify-between text-sm mt-2">
            <span class="text-secondary dark:text-secondary-dark"><%= t("single_budgets.spent") %>: <%= format_currency(budget.spent_amount) %></span>
            <span class="<%= budget.overspent? ? 'text-expense font-medium' : 'text-secondary dark:text-secondary-dark' %>">
              <%= budget.overspent? ? t("single_budgets.overspent", amount: format_currency(budget.remaining_amount.abs)) : t("single_budgets.remaining", amount: format_currency(budget.remaining_amount)) %>
            </span>
          </div>
          <div class="flex justify-end gap-2 mt-2">
            <%= link_to t("single_budgets.view"), single_budget_path(budget), class: "px-3 py-1.5 text-sm font-medium rounded-lg bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth btn-modern dark:text-secondary-dark" %>
            <%= link_to t("single_budgets.edit"), edit_single_budget_path(budget), class: "px-3 py-1.5 text-sm font-medium rounded-lg bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth btn-modern dark:text-secondary-dark" %>
            <%= button_to t("single_budgets.delete"), budget, method: :delete, onclick: "if(confirm('确定删除此预算？')) { submitDeleteForm(this, '/budgets/' + ' + budget.id) }", class: "px-3 py-1.5 text-sm font-medium rounded-lg bg-expense-light text-expense hover:bg-red-200 transition-smooth btn-modern dark:bg-red-900 dark:text-red-300" %>
          </div>
        </div>
      <% end %>
    </div>

    <% if @single_budgets.empty? %>
      <div class="bg-container dark:bg-container-dark rounded-lg shadow p-8 text-center text-secondary dark:text-secondary-dark">
        <%= t("single_budgets.no_single_budgets") %>
      </div>
    <% end %>

  <% else %>
    <div class="bg-container dark:bg-container-dark rounded-lg shadow p-6">
      <h3 class="font-medium mb-4 dark:text-white"><%= t("budgets.add_budget", month: @month) %></h3>
      <%= form_with model: Budget.new, url: budgets_path, local: true, class: "flex gap-4" do |f| %>
        <%= f.hidden_field :month, value: @month %>
        <%= f.collection_select :category_id, @categories, :id, :name, { include_blank: t("dashboard.total_budget") }, class: "border rounded px-3 py-1.5 text-sm dark:bg-surface-dark dark:border-border-dark dark:text-white" %>
        <%= f.number_field :amount, step: "0.01", placeholder: t("transactions.amount"), class: "border rounded px-3 py-1.5 text-sm dark:bg-surface-dark dark:border-border-dark dark:text-white" %>
        <%= f.submit t("budgets.add"), class: "px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth btn-modern" %>
      <% end %>
    </div>

    <% if @total_budget > 0 %>
      <div class="bg-container dark:bg-container-dark rounded-lg shadow p-6">
        <div class="flex justify-between items-center mb-4">
          <h3 class="font-medium dark:text-white"><%= t("budgets.total") %></h3>
          <span class="text-sm <%= (@total_budget - @total_spent) < 0 ? 'text-expense' : 'text-income' %>">
            <%= (@total_budget - @total_spent) < 0 ? "已超支" : "剩余 ¥#{@total_budget - @total_spent}" %>
          </span>
        </div>
        <div class="flex items-center gap-4">
          <div class="flex-1">
            <div class="flex justify-between text-sm mb-1">
              <span class="text-secondary dark:text-secondary-dark">已使用</span>
              <span class="font-medium dark:text-white">¥<%= @total_spent %> / ¥<%= @total_budget %></span>
            </div>
            <div class="w-full bg-surface dark:bg-surface-dark rounded-full h-4 dark:bg-surface-dark">
              <% percentage = @total_budget > 0 ? (@total_spent.to_f / @total_budget * 100).round : 0 %>
              <div class="<%= percentage > 100 ? 'bg-red-500' : (percentage > 80 ? 'bg-yellow-500' : 'bg-inverse') %> h-4 rounded-full transition-all" style="width: <%= [percentage, 100].min %>%"></div>
            </div>
            <div class="flex justify-between text-xs text-secondary dark:text-secondary-dark mt-1">
              <span>0%</span>
              <span class="<%= percentage > 100 ? 'text-expense font-medium' : '' %>"><%= percentage %>%</span>
              <span>100%</span>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div class="grid gap-4">
      <% @budgets.each do |budget| %>
        <% spent = budget.spent_amount %>
        <% percentage = budget.progress_percentage %>
        <div class="bg-container dark:bg-container-dark rounded-lg shadow p-4">
          <div class="flex justify-between items-center mb-2">
            <div class="flex items-center gap-2">
              <span class="font-medium dark:text-white"><%= budget.category&.name || t("budgets.total") %></span>
              <span class="text-xs px-2 py-0.5 rounded <%= 
                case budget.status_color
                when 'red' then 'bg-expense-light text-expense'
                when 'yellow' then 'bg-yellow-100 text-yellow-700'
                else 'bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark dark:text-secondary-dark'
                end
              %>"><%= budget.status_text %></span>
            </div>
            <div class="text-right">
              <span class="font-medium dark:text-white"><%= format_currency(budget.amount) %></span>
              <span class="text-sm text-secondary dark:text-secondary-dark">预算</span>
            </div>
          </div>
          <div class="w-full bg-surface dark:bg-surface-dark rounded-full h-3 dark:bg-surface-dark">
            <div class="<%= budget.status_color == 'red' ? 'bg-red-500' : (budget.status_color == 'yellow' ? 'bg-yellow-500' : 'bg-inverse') %> h-3 rounded-full transition-all" style="width: <%= [percentage, 100].min %>%"></div>
          </div>
          <div class="flex justify-between text-sm mt-2">
            <span class="text-secondary dark:text-secondary-dark">已支出: <%= format_currency(spent) %></span>
            <span class="<%= budget.overspent? ? 'text-expense font-medium' : 'text-secondary dark:text-secondary-dark' %>">
              <%= budget.overspent? ? "超支 #{format_currency(budget.remaining_amount.abs)}" : "剩余 #{format_currency(budget.remaining_amount)}" %>
            </span>
          </div>
          <div class="flex justify-end mt-2">
            <%= button_to t("budgets.delete"), budget, method: :delete, onclick: "if(confirm('确定删除此预算？')) { this.nextElementSibling.submit() }" form: { style: "display:inline" }, class: "px-3 py-1.5 text-sm font-medium rounded-lg bg-expense-light text-expense hover:bg-red-200 transition-smooth btn-modern" %>
          </div>
        </div>
      <% end %>
    </div>

    <% if @budgets.empty? && @total_budget == 0 %>
      <div class="bg-container dark:bg-container-dark rounded-lg shadow p-8 text-center text-secondary dark:text-secondary-dark">
        <%= t("budgets.no_budgets_set") %>
      </div>
    <% end %>
  <% end %>
</div>
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">预算名称 *</label>
            <%= f.text_field :name, required: true, class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500", placeholder: "例如：装修预算" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">预算总额</label>
            <div class="px-3 py-2 text-sm rounded-lg bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark">
              添加项目后自动计算
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">货币</label>
            <%= f.select :currency, ["CNY", "USD", "EUR", "GBP", "JPY"], { selected: "CNY" }, class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">开始日期 *</label>
            <%= f.date_field :start_date, required: true, value: Date.today, class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">结束日期</label>
            <%= f.date_field :end_date, class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">状态</label>
            <%= f.select :status, [["规划中", "planning"], ["进行中", "active"]], { selected: "planning" }, class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" %>
          </div>
        </div>
        <div class="mt-4">
          <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">描述</label>
          <%= f.text_area :description, rows: 2, class: "w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500", placeholder: "预算描述（可选）" %>
        </div>
        <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-border dark:border-border-dark">
          <button type="button" onclick="document.getElementById('new-budget-modal').classList.add('hidden')" class="px-4 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">取消</button>
          <button type="submit" class="px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">创建预算</button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- 编辑预算弹窗 -->
<div id="edit-budget-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('edit-budget-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-xl shadow-xl w-full max-w-2xl p-6 max-h-[90vh] overflow-y-auto">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-primary dark:text-primary-dark">编辑预算</h3>
        <button type="button" onclick="document.getElementById('edit-budget-modal').classList.add('hidden')" class="p-1 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <% if @selected_budget %>
      <form id="edit-budget-form" method="post" action="<%= single_budget_path(@selected_budget) %>">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <input type="hidden" name="_method" value="patch">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">预算名称 *</label>
            <input type="text" name="single_budget[name]" value="<%= @selected_budget.name %>" required class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">预算总额</label>
            <div class="px-3 py-2 text-sm rounded-lg bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark">
              ¥ <%= format_currency(@selected_budget.budget_items.sum(:amount)) %>
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">货币</label>
            <select name="single_budget[currency]" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
              <option value="CNY" <%= @selected_budget.currency == 'CNY' ? 'selected' : '' %>>CNY</option>
              <option value="USD" <%= @selected_budget.currency == 'USD' ? 'selected' : '' %>>USD</option>
              <option value="EUR" <%= @selected_budget.currency == 'EUR' ? 'selected' : '' %>>EUR</option>
              <option value="GBP" <%= @selected_budget.currency == 'GBP' ? 'selected' : '' %>>JPY</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">开始日期 *</label>
            <input type="date" name="single_budget[start_date]" value="<%= @selected_budget.start_date %>" required class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">结束日期</label>
            <input type="date" name="single_budget[end_date]" value="<%= @selected_budget.end_date %>" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">状态</label>
            <select name="single_budget[status]" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
              <option value="planning" <%= @selected_budget.status == 'planning' ? 'selected' : '' %>>规划中</option>
              <option value="active" <%= @selected_budget.status == 'active' ? 'selected' : '' %>>进行中</option>
              <option value="completed" <%= @selected_budget.status == 'completed' ? 'selected' : '' %>>已完成</option>
              <option value="cancelled" <%= @selected_budget.status == 'cancelled' ? 'selected' : '' %>>已取消</option>
            </select>
          </div>
        </div>
        <div class="mt-4">
          <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">描述</label>
          <textarea name="single_budget[description]" rows="2" class="w-full px-3 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500"><%= @selected_budget.description %></textarea>
        </div>
        <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-border dark:border-border-dark">
          <button type="button" onclick="document.getElementById('edit-budget-modal').classList.add('hidden')" class="px-4 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">取消</button>
          <button type="submit" class="px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">保存修改</button>
        </div>
      </form>
      <% end %>
    </div>
  </div>
</div>


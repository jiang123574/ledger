<div class="space-y-4 sm:space-y-6">
  <div class="flex flex-col gap-1">
    <h1 class="text-xl sm:text-2xl font-semibold text-primary dark:text-primary-dark">预算管理</h1>
    <p class="text-xs sm:text-sm text-secondary dark:text-secondary-dark">查看预算执行进度，按项目精细控制支出</p>
  </div>

<div class="flex flex-col lg:flex-row gap-5">
  <aside class="w-full lg:w-72 shrink-0">
    <div class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs border border-border dark:border-border-dark overflow-hidden sticky top-20">
      <div class="p-3 border-b border-border dark:border-border-dark">
        <div class="flex justify-between items-center mb-3">
          <h2 class="font-semibold text-primary dark:text-primary-dark"><%= t("single_budgets.title") %></h2>
          <button onclick="document.getElementById('new-budget-modal').classList.remove('hidden')" class="p-2 rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth" title="<%= t('single_budgets.new') %>">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
          </button>
        </div>
        <div class="flex flex-wrap gap-1">
          <%= link_to budgets_path(month: @month), class: "px-2 py-1 text-xs font-medium rounded-md #{params[:status].blank? ? 'bg-inverse text-white' : 'bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark hover:bg-surface dark:hover:bg-surface-dark'} transition-smooth" do %>
            <%= t("single_budgets.all") %>
          <% end %>
          <% SingleBudget::STATUSES.each do |status| %>
            <%= link_to budgets_path(month: @month, status: status), class: "px-2 py-1 text-xs font-medium rounded-md #{params[:status] == status ? 'bg-inverse text-white' : 'bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark hover:bg-surface dark:hover:bg-surface-dark'} transition-smooth" do %>
              <%= case status when 'planning' then '规划' when 'active' then '进行' when 'completed' then '完成' when 'cancelled' then '取消' end %>
            <% end %>
          <% end %>
        </div>
      </div>
      <div class="max-h-[calc(100vh-280px)] overflow-y-auto">
        <% @single_budgets.each do |budget| %>
          <button
            type="button"
            data-budget-id="<%= budget.id %>"
            class="budget-nav-item w-full p-3 text-left border-b border-border dark:border-border-dark last:border-b-0 hover:bg-surface dark:hover:bg-surface-dark transition-smooth <%= @selected_budget&.id == budget.id ? 'bg-surface dark:bg-surface-dark' : '' %>"
            onclick="window.selectBudget(<%= budget.id %>)">
            <div class="flex justify-between items-start mb-1">
              <span class="font-medium text-primary dark:text-primary-dark truncate"><%= budget.name %></span>
              <span class="text-xs px-1.5 py-0.5 rounded shrink-0 <%= 
                case budget.status
                when 'planning' then 'bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400'
                when 'active' then 'bg-income-soft text-income'
                when 'completed' then 'bg-income-light text-income'
                when 'cancelled' then 'bg-expense-light text-expense'
                end
              %>">
                <%= budget.status_text %>
              </span>
            </div>
            <div class="flex items-center gap-2 text-xs text-secondary dark:text-secondary-dark">
              <span><%= budget.category&.name || "全部分类" %></span>
              <span>•</span>
              <span><%= budget.budget_items_count %>项</span>
            </div>
            <% percentage = budget.progress_percentage %>
            <div class="mt-2 h-1.5 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
              <div class="h-full rounded-full <%= percentage > 100 ? 'bg-expense' : (percentage > 80 ? 'bg-yellow-500' : 'bg-income') %>" style="width: <%= [percentage, 100].min %>%"></div>
            </div>
          </button>
        <% end %>
        <% if @single_budgets.empty? %>
          <div class="p-6 text-center text-secondary dark:text-secondary-dark text-sm">
            <%= t("single_budgets.no_single_budgets") %>
          </div>
        <% end %>
      </div>
    </div>
  </aside>

  <div class="flex-1 min-w-0">
    <div class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs border border-border dark:border-border-dark overflow-hidden">
      <div class="p-3 border-b border-border dark:border-border-dark flex flex-wrap items-center gap-2.5">
        <div class="flex items-center gap-2">
          <select id="budget-select" class="border border-border dark:border-border-dark rounded-lg px-3 py-1.5 text-sm bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <% @single_budgets.each_with_index do |budget, index| %>
              <option value="<%= budget.id %>" <%= (@selected_budget&.id == budget.id || (@selected_budget.blank? && index == 0)) ? 'selected' : '' %>><%= budget.name %></option>
            <% end %>
          </select>
          <% if @selected_budget %>
            <button onclick="document.getElementById('edit-budget-modal').classList.remove('hidden')" class="p-2 rounded-lg border border-border dark:border-border-dark bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark hover:bg-surface dark:hover:bg-surface-dark transition-smooth" title="编辑">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
            </button>
            <button onclick="if(confirm('确定删除此预算？')) { document.getElementById('delete-budget-form').submit() }" class="p-2 rounded-lg border border-border dark:border-border-dark bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark hover:bg-expense-light hover:text-expense transition-smooth" title="删除">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
            </button>
            <form action="<%= single_budget_path(@selected_budget) %>" method="post" id="delete-budget-form" style="display:none">
              <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
              <input type="hidden" name="_method" value="delete">
            </form>
          <% end %>
        </div>
        <div class="flex-1"></div>
        <div class="flex items-center gap-2">
          <label class="flex items-center gap-2 text-sm text-secondary dark:text-secondary-dark cursor-pointer">
            <input type="checkbox" id="hide-zero" class="w-4 h-4 rounded border-border dark:border-border-dark text-secondary focus:ring-gray-400" <%= params[:hide_zero] == '1' ? 'checked' : '' %>>
            <span>隐藏零金额</span>
          </label>
        </div>
      </div>

      <div class="p-3">
        <div id="budget-overview" class="mb-6">
          <% budget = @selected_budget || @single_budgets.first %>
          <% if budget %>
            <% total_amount = budget.total_amount %>
            <% spent_amount = budget.spent_amount %>
            <% remaining = budget.remaining_amount %>
            <% percentage = budget.progress_percentage %>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
              <div class="bg-surface dark:bg-surface-dark rounded-xl p-3 border border-border dark:border-border-dark">
                <div class="text-xs font-medium text-secondary dark:text-secondary-dark mb-1">预算总额</div>
                <div class="text-2xl font-bold text-primary dark:text-primary-dark"><%= format_currency(total_amount) %></div>
              </div>
              <div class="bg-spent-soft rounded-xl p-3 border border-spent-soft">
                <div class="text-xs font-medium text-spent mb-1">已支出</div>
                <div class="text-2xl font-bold text-spent"><%= format_currency(spent_amount) %></div>
              </div>
              <div class="bg-remaining-soft border-remaining-soft rounded-xl p-3 border">
                <div class="text-xs font-medium text-remaining mb-1">剩余</div>
                <div class="text-2xl font-bold text-remaining"><%= remaining >= 0 ? '' : '-' %><%= format_currency(remaining.abs) %></div>
              </div>
            </div>
            <div class="mt-4">
              <div class="flex justify-between text-sm mb-2">
                <span class="text-secondary dark:text-secondary-dark">执行进度</span>
                <span class="font-medium <%= percentage > 100 ? 'text-expense' : (percentage > 80 ? 'text-yellow-600 dark:text-yellow-400' : 'text-income') %>"><%= percentage %>%</span>
              </div>
              <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
                <div class="h-full rounded-full <%= percentage > 100 ? 'bg-expense' : (percentage > 80 ? 'bg-yellow-500' : 'bg-income') %> transition-all" style="width: <%= [percentage, 100].min %>%"></div>
              </div>
            </div>
          <% else %>
            <div class="text-center py-8 text-secondary dark:text-secondary-dark">
              <p>暂无选中预算</p>
            </div>
          <% end %>
        </div>

        <div id="budget-items-table">
          <div class="flex justify-between items-center mb-4">
            <h3 class="font-semibold text-primary dark:text-primary-dark">预算明细</h3>
            <button id="add-item-btn" data-budget-id="" onclick="if(window.currentBudgetId) openAddItemModal(window.currentBudgetId)" class="hidden px-3 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth flex items-center gap-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
              添加明细
            </button>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-border dark:border-border-dark">
                  <th class="text-left py-1.5 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">分类</th>
                  <th class="text-right py-1.5 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">预算</th>
                  <th class="text-right py-1.5 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">已支</th>
                  <th class="text-right py-1.5 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">剩余</th>
                  <th class="text-right py-1.5 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">进度</th>
                </tr>
              </thead>
              <tbody>
                <% if @selected_budget&.budget_items&.any? %>
                  <% @selected_budget.budget_items.each do |item| %>
                    <% item_percentage = item.progress_percentage %>
                    <% item_remaining = item.remaining_amount %>
                    <tr class="border-b border-border dark:border-border-dark hover:bg-surface dark:hover:bg-surface-dark transition-smooth">
<td class="py-1.5 px-2">
                        <span class="text-xs font-medium text-primary dark:text-primary-dark"><%= item.category&.full_name || item.name %></span>
                      </td>
                      <td class="py-1.5 px-2 text-right text-xs font-medium text-primary dark:text-primary-dark"><%= format_currency(item.amount) %></td>
                      <td class="py-1.5 px-2 text-right text-xs text-spent"><%= format_currency(item.spent_amount) %></td>
                      <td class="py-1.5 px-2 text-right text-xs font-medium text-remaining"><%= item_remaining >= 0 ? '' : '-' %><%= format_currency(item_remaining.abs) %></td>
                      <td class="py-1.5 px-2">
                        <div class="flex items-center gap-2">
                          <div class="flex-1 flex items-center gap-2">
                            <div class="flex-1 h-1.5 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
                              <div class="h-full rounded-full <%= item_percentage > 100 ? 'bg-expense' : (item_percentage > 80 ? 'bg-yellow-500' : 'bg-income') %>" style="width: <%= [item_percentage, 100].min %>%"></div>
                            </div>
                            <span class="text-xs w-12 text-right <%= item_percentage > 100 ? 'text-expense' : (item_percentage > 80 ? 'text-yellow-600 dark:text-yellow-400' : 'text-secondary dark:text-secondary-dark') %>"><%= item_percentage %>%</span>
                          </div>
                          <div class="flex items-center gap-1">
                            <button onclick="openEditItemModal(<%= item.id %>, <%= item.category_id || 'null' %>, '<%= j(item.category&.full_name || '') %>', <%= item.amount %>, '<%= j(item.notes || '') %>')" class="p-1 rounded hover:bg-surface dark:hover:bg-surface-dark text-secondary dark:text-secondary-dark hover:text-primary transition-smooth" title="编辑">
                              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                            </button>
                            <form action="/single_budgets/<%= @selected_budget.id %>/budget_items/<%= item.id %>" method="post" style="display:inline" onsubmit="if(!confirm('确定删除此项目？')) return false">
                              <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
                              <input type="hidden" name="_method" value="delete">
                              <button type="submit" class="p-1 rounded hover:bg-expense-light text-secondary dark:text-secondary-dark hover:text-expense transition-smooth" title="删除">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                              </button>
                            </form>
                          </div>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                <% elsif @selected_budget %>
                  <tr>
                    <td colspan="5" class="py-8 text-center text-secondary dark:text-secondary-dark">
                      <%= t("single_budgets.no_items") %>
                    </td>
                  </tr>
                <% else %>
                  <tr>
                    <td colspan="5" class="py-8 text-center text-secondary dark:text-secondary-dark">
                      <p>从左侧选择一个预算查看详情</p>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- 分类数据（用于 JavaScript） -->
<script id="expense-categories-data" type="application/json">
  <%= raw @categories_json %>
</script>

<script>
  window.authToken = '<%= form_authenticity_token %>';
  
  function escapeHtml(str) {
    if (!str) return '';
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }
  
  window.selectBudget = function(budgetId) {
    if (window.currentBudgetId === budgetId) return;
    
    document.querySelectorAll('.budget-nav-item').forEach(function(item) {
      if (item.dataset.budgetId == budgetId) {
        item.classList.add('bg-surface', 'dark:bg-surface-dark');
      } else {
        item.classList.remove('bg-surface', 'dark:bg-surface-dark');
      }
    });
    var select = document.getElementById('budget-select');
    if (select) select.value = budgetId;
    window.currentBudgetId = budgetId;
    var addBtn = document.getElementById('add-item-btn');
    if (addBtn) {
      addBtn.classList.remove('hidden');
      addBtn.dataset.budgetId = budgetId;
    }
    // 更新删除表单的 action
    var deleteForm = document.getElementById('delete-budget-form');
    if (deleteForm) {
      deleteForm.action = '/single_budgets/' + budgetId;
    }
    fetch('/budgets/' + budgetId + '/data')
      .then(function(response) { return response.json(); })
      .then(function(data) {
        updateBudgetOverview(data);
        updateBudgetItems(data.items);
      })
      .catch(function() {
        console.error('Failed to load budget data');
      });
  };

  window.openAddItemModal = function(budgetId) {
    var form = document.getElementById('new-item-form');
    form.action = '/single_budgets/' + budgetId + '/budget_items';
    document.getElementById('new-item-modal').classList.remove('hidden');
  };

  window.openEditItemModal = function(itemId, categoryId, categoryName, amount, notes) {
    var form = document.getElementById('edit-item-form');
    form.action = '/single_budgets/' + window.currentBudgetId + '/budget_items/' + itemId;
    document.getElementById('edit-item-category-id').value = categoryId || '';
    document.getElementById('edit-item-category-search').value = categoryName || '';
    document.getElementById('edit-item-amount').value = amount;
    document.getElementById('edit-item-notes').value = notes || '';
    document.getElementById('edit-item-modal').classList.remove('hidden');
  };

  function updateBudgetOverview(data) {
    var container = document.getElementById('budget-overview');
    if (!container || !data) return;
    var remaining = data.total_amount - data.spent_amount;
    var percentage = data.total_amount > 0 ? (data.spent_amount / data.total_amount * 100).toFixed(1) : 0;
    var progressColor = percentage > 100 ? 'bg-expense' : (percentage > 80 ? 'bg-yellow-500' : 'bg-income');
    var progressTextColor = percentage > 100 ? 'text-expense' : (percentage > 80 ? 'text-yellow-600 dark:text-yellow-400' : 'text-income');
    container.innerHTML = 
      '<div class="grid grid-cols-1 sm:grid-cols-3 gap-3">' +
        '<div class="bg-surface dark:bg-surface-dark rounded-xl p-3 border border-border dark:border-border-dark">' +
          '<div class="text-xs font-medium text-secondary dark:text-secondary-dark mb-1">预算总额</div>' +
          '<div class="text-2xl font-bold text-primary dark:text-primary-dark">' + data.formatted_total + '</div>' +
        '</div>' +
        '<div class="bg-spent-soft rounded-xl p-3 border border-spent-soft">' +
          '<div class="text-xs font-medium text-spent mb-1">已支出</div>' +
          '<div class="text-2xl font-bold text-spent">' + data.formatted_spent + '</div>' +
        '</div>' +
        '<div class="bg-remaining-soft border-remaining-soft rounded-xl p-3 border">' +
          '<div class="text-xs font-medium text-remaining mb-1">剩余</div>' +
          '<div class="text-2xl font-bold text-remaining">' + (remaining >= 0 ? '' : '-') + data.currency_symbol + Math.abs(remaining).toFixed(2) + '</div>' +
        '</div>' +
      '</div>' +
      '<div class="mt-4">' +
        '<div class="flex justify-between text-sm mb-2">' +
          '<span class="text-secondary dark:text-secondary-dark">执行进度</span>' +
          '<span class="font-medium ' + progressTextColor + '">' + percentage + '%</span>' +
        '</div>' +
        '<div class="h-4 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">' +
          '<div class="h-full rounded-full ' + progressColor + ' transition-all" style="width: ' + Math.min(percentage, 100) + '%"></div>' +
        '</div>' +
      '</div>';
  }

  function updateBudgetItems(items) {
    var container = document.getElementById('budget-items-table');
    if (!container) return;
    
    var addBtn = document.getElementById('add-item-btn');
    var budgetId = window.currentBudgetId;
    
    if (!items || items.length === 0) {
      container.innerHTML = 
        '<div class="flex justify-between items-center mb-4">' +
          '<h3 class="font-semibold text-primary dark:text-primary-dark">预算明细</h3>' +
          (addBtn ? addBtn.outerHTML : '') +
        '</div>' +
        '<div class="overflow-x-auto">' +
          '<table class="w-full">' +
            '<thead>' +
              '<tr class="border-b border-border dark:border-border-dark">' +
                '<th class="text-left py-1.5 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">分类</th>' +
                '<th class="text-right py-1.5 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">预算</th>' +
                '<th class="text-right py-1.5 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">已支</th>' +
                '<th class="text-right py-1.5 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">剩余</th>' +
                '<th class="text-right py-1.5 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">进度</th>' +
              '</tr>' +
            '</thead>' +
            '<tbody>' +
              '<tr><td colspan="5" class="py-8 text-center text-secondary dark:text-secondary-dark">暂无预算项</td></tr>' +
            '</tbody>' +
          '</table>' +
        '</div>';
      return;
    }
    var rows = items.map(function(item) {
      var remaining = item.amount - item.spent_amount;
      var percentage = item.amount > 0 ? (item.spent_amount / item.amount * 100).toFixed(1) : 0;
      var progressColor = percentage > 100 ? 'bg-expense' : (percentage > 80 ? 'bg-yellow-500' : 'bg-income');
      var progressTextColor = percentage > 100 ? 'text-expense' : (percentage > 80 ? 'text-yellow-600 dark:text-yellow-400' : 'text-secondary dark:text-secondary-dark');
      var escapedNotes = escapeHtml(item.notes || '').replace(/'/g, "\\'").replace(/"/g, '\\"');
      var escapedCategoryName = escapeHtml(item.category_name || item.name || '');
      var escapedCategoryNameForOnclick = (item.category_name || item.name || '').replace(/'/g, "\\'").replace(/"/g, '\\"');
      var escapedAmount = escapeHtml(item.formatted_amount);
      var escapedSpent = escapeHtml(item.formatted_spent);
      return '<tr class="border-b border-border dark:border-border-dark hover:bg-surface dark:hover:bg-surface-dark transition-smooth">' +
        '<td class="py-1.5 px-2"><span class="text-xs font-medium text-primary dark:text-primary-dark">' + escapedCategoryName + '</span></td>' +
        '<td class="py-1.5 px-2 text-right text-xs font-medium text-primary dark:text-primary-dark">' + escapedAmount + '</td>' +
        '<td class="py-1.5 px-2 text-right text-xs text-spent">' + escapedSpent + '</td>' +
        '<td class="py-1.5 px-2 text-right text-xs font-medium text-remaining">' + (remaining >= 0 ? '' : '-') + escapeHtml(item.currency_symbol) + Math.abs(remaining).toFixed(2) + '</td>' +
        '<td class="py-1.5 px-2">' +
          '<div class="flex items-center gap-2">' +
            '<div class="flex-1 flex items-center gap-2">' +
              '<div class="flex-1 h-1.5 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">' +
                '<div class="h-full rounded-full ' + progressColor + '" style="width: ' + Math.min(percentage, 100) + '%"></div>' +
              '</div>' +
              '<span class="text-xs w-12 text-right ' + progressTextColor + '">' + percentage + '%</span>' +
            '</div>' +
            '<div class="flex items-center gap-1">' +
              '<button onclick="openEditItemModal(' + item.id + ', ' + item.category_id + ', \'' + escapedCategoryNameForOnclick + '\', ' + item.amount + ', \'' + escapedNotes + '\')" class="p-1 rounded hover:bg-surface dark:hover:bg-surface-dark text-secondary dark:text-secondary-dark hover:text-primary transition-smooth" title="编辑">' +
                '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>' +
              '</button>' +
              '<form action="/single_budgets/' + budgetId + '/budget_items/' + item.id + '" method="post" style="display:inline" onsubmit="if(!confirm(\'确定删除此项目？\')) return false">' +
                '<input type="hidden" name="authenticity_token" value="' + window.authToken + '">' +
                '<input type="hidden" name="_method" value="delete">' +
                '<button type="submit" class="p-1 rounded hover:bg-expense-light text-secondary dark:text-secondary-dark hover:text-expense transition-smooth" title="删除">' +
                  '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>' +
                '</button>' +
              '</form>' +
            '</div>' +
          '</div>' +
        '</td>' +
      '</tr>';
    }).join('');
    container.innerHTML = 
      '<div class="flex justify-between items-center mb-4">' +
        '<h3 class="font-semibold text-primary dark:text-primary-dark">预算明细</h3>' +
        (addBtn ? addBtn.outerHTML : '') +
      '</div>' +
      '<div class="overflow-x-auto">' +
        '<table class="w-full">' +
          '<thead>' +
            '<tr class="border-b border-border dark:border-border-dark">' +
              '<th class="text-left py-3 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">分类</th>' +
              '<th class="text-right py-3 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">预算</th>' +
              '<th class="text-right py-3 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">已支</th>' +
              '<th class="text-right py-3 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">剩余</th>' +
              '<th class="text-right py-3 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">进度</th>' +
            '</tr>' +
          '</thead>' +
          '<tbody>' + rows + '</tbody>' +
        '</table>' +
      '</div>';
  }

  document.addEventListener('turbo:load', function() {
    var select = document.getElementById('budget-select');
    var addBtn = document.getElementById('add-item-btn');
    
    if (select && select.value) {
      window.currentBudgetId = parseInt(select.value, 10);
      if (addBtn) {
        addBtn.classList.remove('hidden');
        addBtn.dataset.budgetId = select.value;
      }
    }
    
    if (select) {
      select.addEventListener('change', function() {
        var id = this.value;
        if (id) {
          window.selectBudget(parseInt(id));
          if (addBtn) {
            addBtn.classList.remove('hidden');
          }
        } else {
          if (addBtn) {
            addBtn.classList.add('hidden');
          }
        }
      });
    }
  });

  // 分类选择器逻辑（带拼音搜索）
  var expenseCategories = [];
  var expenseCategoriesDataEl = document.getElementById('expense-categories-data');
  if (expenseCategoriesDataEl) {
    expenseCategories = JSON.parse(expenseCategoriesDataEl.textContent);
  }

  function initCategorySelector(searchInputId, dropdownId, filterInputId, optionsId, hiddenInputId) {
    var searchInput = document.getElementById(searchInputId);
    var dropdown = document.getElementById(dropdownId);
    var filterInput = document.getElementById(filterInputId);
    var optionsContainer = document.getElementById(optionsId);
    var hiddenInput = document.getElementById(hiddenInputId);

    if (!searchInput || !dropdown || !optionsContainer) return;

    function renderOptions(filterText) {
      var filtered = expenseCategories.filter(function(cat) {
        if (!filterText) return true;
        var query = filterText.toLowerCase();
        if (cat.full_name && cat.full_name.toLowerCase().includes(query)) return true;
        if (cat.name && cat.name.toLowerCase().includes(query)) return true;
        if (cat.pinyin && cat.pinyin.includes(query)) return true;
        return false;
      });

      if (filtered.length === 0) {
        return '<div class="px-3 py-2 text-sm text-secondary dark:text-secondary-dark">无匹配分类</div>';
      }

      return filtered.map(function(cat) {
        var indent = 'padding-left: ' + (cat.level * 16 + 12) + 'px';
        var selected = hiddenInput && hiddenInput.value == cat.id ? 'bg-blue-50 dark:bg-blue-900/20' : '';
        // 使用 escapeHtml 防止 XSS
        var escapedName = escapeHtml(cat.full_name);
        return '<div class="category-option px-3 py-1.5 text-sm cursor-pointer hover:bg-surface dark:hover:bg-surface-dark text-primary dark:text-primary-dark ' + selected + '" style="' + indent + '" data-id="' + cat.id + '" data-name="' + escapedName + '">' +
                 escapedName +
               '</div>';
      }).join('');
    }

    function updateOptions() {
      var filterText = filterInput ? filterInput.value : '';
      optionsContainer.innerHTML = renderOptions(filterText);

      optionsContainer.querySelectorAll('.category-option').forEach(function(option) {
        option.addEventListener('click', function() {
          var id = this.dataset.id;
          var name = this.dataset.name;
          if (hiddenInput) hiddenInput.value = id;
          if (searchInput) searchInput.value = name;
          if (dropdown) dropdown.classList.add('hidden');
          if (filterInput) filterInput.value = '';
        });
      });
    }

    if (searchInput) {
      searchInput.addEventListener('click', function() {
        dropdown.classList.toggle('hidden');
        if (!dropdown.classList.contains('hidden')) {
          updateOptions();
          if (filterInput) filterInput.focus();
        }
      });
    }

    if (filterInput) {
      filterInput.addEventListener('focus', function() {
        this.placeholder = '';
      });
      filterInput.addEventListener('blur', function() {
        this.placeholder = '搜索分类...';
      });
      filterInput.addEventListener('input', function() {
        updateOptions();
      });
    }

    document.addEventListener('click', function(e) {
      if (dropdown && !dropdown.contains(e.target) && e.target !== searchInput) {
        dropdown.classList.add('hidden');
      }
    });
  }
</script>


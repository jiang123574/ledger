<div class="flex flex-col lg:flex-row gap-6">
  <aside class="w-full lg:w-72 flex-shrink-0">
    <div class="bg-container dark:bg-container-dark rounded-xl shadow-sm border border-border dark:border-border-dark sticky top-20">
      <div class="p-4 border-b border-border dark:border-border-dark">
        <div class="flex justify-between items-center mb-3">
          <h2 class="font-semibold text-primary dark:text-primary-dark"><%= t("single_budgets.title") %></h2>
          <button onclick="document.getElementById('new-budget-modal').classList.remove('hidden')" class="p-2 rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-colors" title="<%= t('single_budgets.new') %>">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
          </button>
        </div>
        <div class="flex flex-wrap gap-1">
          <%= link_to budgets_path(month: @month), class: "px-2 py-1 text-xs font-medium rounded-md #{params[:status].blank? ? 'bg-inverse text-white' : 'bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover'}" do %>
            <%= t("single_budgets.all") %>
          <% end %>
          <% SingleBudget::STATUSES.each do |status| %>
            <%= link_to budgets_path(month: @month, status: status), class: "px-2 py-1 text-xs font-medium rounded-md #{params[:status] == status ? 'bg-inverse text-white' : 'bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover'}" do %>
              <%= case status when 'planning' then '规划' when 'active' then '进行' when 'completed' then '完成' when 'cancelled' then '取消' end %>
            <% end %>
          <% end %>
        </div>
      </div>
      <div class="max-h-[calc(100vh-280px)] overflow-y-auto">
        <% @single_budgets.each do |budget| %>
          <button
            type="button"
            data-budget-id="<%= budget.id %>"
            class="budget-nav-item w-full p-4 text-left border-b border-border dark:border-border-dark last:border-b-0 hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-colors <%= @selected_budget&.id == budget.id ? 'bg-surface dark:bg-surface-dark' : '' %>"
            onclick="window.selectBudget(<%= budget.id %>)">
            <div class="flex justify-between items-start mb-1">
              <span class="font-medium text-primary dark:text-primary-dark truncate"><%= budget.name %></span>
              <span class="text-xs px-1.5 py-0.5 rounded flex-shrink-0 <%= 
                case budget.status
                when 'planning' then 'bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400'
                when 'active' then 'bg-blue-100 text-blue-700 dark:bg-blue-900/50 dark:text-blue-400'
                when 'completed' then 'bg-green-100 text-green-700 dark:bg-green-900/50 dark:text-green-400'
                when 'cancelled' then 'bg-red-100 text-red-700 dark:bg-red-900/50 dark:text-red-400'
                end
              %>">
                <%= budget.status_text %>
              </span>
            </div>
            <div class="flex items-center gap-2 text-xs text-secondary dark:text-secondary-dark">
              <span><%= budget.category&.name || "全部分类" %></span>
              <span>•</span>
              <span><%= budget.budget_items.count %>项</span>
            </div>
            <% percentage = budget.progress_percentage %>
            <div class="mt-2 h-1.5 bg-surface dark:bg-surface-dark rounded-full overflow-hidden">
              <div class="h-full rounded-full <%= percentage > 100 ? 'bg-red-500' : (percentage > 80 ? 'bg-yellow-500' : 'bg-blue-500') %>" style="width: <%= [percentage, 100].min %>%"></div>
            </div>
          </button>
        <% end %>
        <% if @single_budgets.empty? %>
          <div class="p-6 text-center text-secondary dark:text-secondary-dark text-sm">
            <%= t("single_budgets.no_single_budgets") %>
          </div>
        <% end %>
      </div>
    </div>
  </aside>

  <div class="flex-1 min-w-0">
    <div class="bg-container dark:bg-container-dark rounded-xl shadow-sm border border-border dark:border-border-dark">
      <div class="p-4 border-b border-border dark:border-border-dark flex flex-wrap items-center gap-3">
        <div class="flex items-center gap-2">
          <select id="budget-select" class="border border-border dark:border-border-dark rounded-lg px-3 py-2 text-sm bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <option value=""><%= t("single_budgets.all") %></option>
            <% @single_budgets.each do |budget| %>
              <option value="<%= budget.id %>"><%= budget.name %></option>
            <% end %>
          </select>
          <% if @selected_budget %>
            <button onclick="document.getElementById('edit-budget-modal').classList.remove('hidden')" class="p-2 rounded-lg border border-border dark:border-border-dark bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-colors" title="编辑">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
            </button>
            <button onclick="if(confirm('确定删除此预算？')) { document.getElementById('delete-budget-form').submit() }" class="p-2 rounded-lg border border-border dark:border-border-dark bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark hover:bg-red-100 dark:hover:bg-red-900/30 hover:text-red-600 dark:hover:text-red-400 transition-colors" title="删除">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
            </button>
            <form action="<%= single_budget_path(@selected_budget) %>" method="post" id="delete-budget-form" style="display:none">
              <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
              <input type="hidden" name="_method" value="delete">
            </form>
          <% end %>
        </div>
        <div class="flex-1"></div>
        <div class="flex items-center gap-2">
          <%= form_tag budgets_path, method: :get, class: "flex items-center gap-2" do %>
            <%= month_field_tag :month, @month, class: "border border-border dark:border-border-dark rounded-lg px-3 py-2 text-sm bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
            <%= hidden_field_tag :status, params[:status] if params[:status].present? %>
            <%= submit_tag "跳转", class: "px-3 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-colors" %>
          <% end %>
          <label class="flex items-center gap-2 text-sm text-secondary dark:text-secondary-dark cursor-pointer">
            <input type="checkbox" id="hide-zero" class="w-4 h-4 rounded border-border dark:border-border-dark text-blue-600 focus:ring-blue-500" <%= params[:hide_zero] == '1' ? 'checked' : '' %>>
            <span>隐藏零金额</span>
          </label>
          <button type="button" class="p-2 rounded-lg border border-border dark:border-border-dark bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-colors" title="导出">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
          </button>
        </div>
      </div>

      <div class="p-4">
        <div id="budget-overview" class="mb-6">
          <% budget = @selected_budget || @single_budgets.first %>
          <% if budget %>
            <% total_amount = budget.total_amount %>
            <% spent_amount = budget.spent_amount %>
            <% remaining = budget.remaining_amount %>
            <% percentage = budget.progress_percentage %>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              <div class="bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-900/30 dark:to-blue-800/30 rounded-xl p-4">
                <div class="text-xs font-medium text-blue-600 dark:text-blue-400 mb-1">预算总额</div>
                <div class="text-2xl font-bold text-blue-700 dark:text-blue-300"><%= format_currency(total_amount) %></div>
              </div>
              <div class="bg-gradient-to-br from-orange-50 to-orange-100 dark:from-orange-900/30 dark:to-orange-800/30 rounded-xl p-4">
                <div class="text-xs font-medium text-orange-600 dark:text-orange-400 mb-1">已支出</div>
                <div class="text-2xl font-bold text-orange-700 dark:text-orange-300"><%= format_currency(spent_amount) %></div>
              </div>
              <div class="bg-gradient-to-br <%= remaining >= 0 ? 'from-emerald-50 to-emerald-100 dark:from-emerald-900/30 dark:to-emerald-800/30' : 'from-red-50 to-red-100 dark:from-red-900/30 dark:to-red-800/30' %> rounded-xl p-4">
                <div class="text-xs font-medium <%= remaining >= 0 ? 'text-emerald-600 dark:text-emerald-400' : 'text-red-600 dark:text-red-400' %> mb-1">剩余</div>
                <div class="text-2xl font-bold <%= remaining >= 0 ? 'text-emerald-700 dark:text-emerald-300' : 'text-red-700 dark:text-red-300' %>"><%= format_currency(remaining.abs) %></div>
              </div>
            </div>
            <div class="mt-4">
              <div class="flex justify-between text-sm mb-2">
                <span class="text-secondary dark:text-secondary-dark">执行进度</span>
                <span class="font-medium <%= percentage > 100 ? 'text-red-500' : (percentage > 80 ? 'text-yellow-500' : 'text-blue-500') %>"><%= percentage %>%</span>
              </div>
              <div class="h-4 bg-surface dark:bg-surface-dark rounded-full overflow-hidden">
                <div class="h-full rounded-full <%= percentage > 100 ? 'bg-red-500' : (percentage > 80 ? 'bg-yellow-500' : 'bg-blue-500') %> transition-all" style="width: <%= [percentage, 100].min %>%"></div>
              </div>
            </div>
          <% else %>
            <div class="text-center py-8 text-secondary dark:text-secondary-dark">
              <p>暂无选中预算</p>
            </div>
          <% end %>
        </div>

        <div id="budget-items-table">
          <div class="flex justify-between items-center mb-4">
            <h3 class="font-semibold text-primary dark:text-primary-dark">预算项目</h3>
            <% if @selected_budget %>
              <button onclick="openAddItemModal(<%= @selected_budget.id %>)" class="px-3 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-colors flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                添加项目
              </button>
            <% end %>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-border dark:border-border-dark">
                  <th class="text-left py-3 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">名称</th>
                  <th class="text-right py-3 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">预算</th>
                  <th class="text-right py-3 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">已支</th>
                  <th class="text-right py-3 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">剩余</th>
                  <th class="text-right py-3 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">进度</th>
                </tr>
              </thead>
              <tbody>
                <% if @selected_budget&.budget_items&.any? %>
                  <% @selected_budget.budget_items.each do |item| %>
                    <% item_percentage = item.progress_percentage %>
                    <% item_remaining = item.remaining_amount %>
                    <tr class="border-b border-border dark:border-border-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-colors">
                      <td class="py-3 px-2">
                        <div class="flex items-center gap-2">
                          <span class="font-medium text-primary dark:text-primary-dark"><%= item.name %></span>
                          <% if item.category %>
                            <span class="text-xs px-1.5 py-0.5 rounded bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark"><%= item.category %></span>
                          <% end %>
                        </div>
                      </td>
                      <td class="py-3 px-2 text-right font-medium text-primary dark:text-primary-dark"><%= format_currency(item.amount) %></td>
                      <td class="py-3 px-2 text-right text-secondary dark:text-secondary-dark"><%= format_currency(item.spent_amount) %></td>
                      <td class="py-3 px-2 text-right font-medium <%= item_remaining >= 0 ? 'text-blue-500' : 'text-red-500' %>"><%= format_currency(item_remaining.abs) %></td>
                      <td class="py-3 px-2">
                        <div class="flex items-center gap-2 justify-end">
                          <div class="w-20 h-2 bg-surface dark:bg-surface-dark rounded-full overflow-hidden">
                            <div class="h-full rounded-full <%= item_percentage > 100 ? 'bg-red-500' : (item_percentage > 80 ? 'bg-yellow-500' : 'bg-blue-500') %>" style="width: <%= [item_percentage, 100].min %>%"></div>
                          </div>
                          <span class="text-xs <%= item_percentage > 100 ? 'text-red-500' : (item_percentage > 80 ? 'text-yellow-500' : 'text-secondary dark:text-secondary-dark') %>"><%= item_percentage %>%</span>
                          <button onclick="openEditItemModal(<%= item.id %>, '<%= j item.name %>', <%= item.amount %>, '<%= j(item.category || '') %>', '<%= j(item.notes || '') %>')" class="p-1 rounded hover:bg-surface-hover dark:hover:bg-surface-dark-hover text-secondary dark:text-secondary-dark hover:text-primary transition-smooth" title="编辑">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                          </button>
                          <form action="/single_budgets/<%= @selected_budget.id %>/budget_items/<%= item.id %>" method="post" style="display:inline" onsubmit="if(!confirm('确定删除此项目？')) return false">
                            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
                            <input type="hidden" name="_method" value="delete">
                            <button type="submit" class="p-1 rounded hover:bg-red-100 dark:hover:bg-red-900/30 text-secondary dark:text-secondary-dark hover:text-red-600 dark:hover:text-red-400 transition-smooth" title="删除">
                              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            </button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                <% elsif @selected_budget %>
                  <tr>
                    <td colspan="5" class="py-8 text-center text-secondary dark:text-secondary-dark">
                      <%= t("single_budgets.no_items") %>
                    </td>
                  </tr>
                <% else %>
                  <tr>
                    <td colspan="5" class="py-8 text-center text-secondary dark:text-secondary-dark">
                      <p>从左侧选择一个预算查看详情</p>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  window.selectBudget = function(budgetId) {
    document.querySelectorAll('.budget-nav-item').forEach(function(item) {
      if (item.dataset.budgetId == budgetId) {
        item.classList.add('bg-surface', 'dark:bg-surface-dark');
      } else {
        item.classList.remove('bg-surface', 'dark:bg-surface-dark');
      }
    });
    var select = document.getElementById('budget-select');
    if (select) select.value = budgetId;
    window.currentBudgetId = budgetId;
    fetch('/budgets/' + budgetId + '/data')
      .then(function(response) { return response.json(); })
      .then(function(data) {
        updateBudgetOverview(data);
        updateBudgetItems(data.items);
      })
      .catch(function() {
        console.error('Failed to load budget data');
      });
  };

  window.openAddItemModal = function(budgetId) {
    var form = document.getElementById('new-item-form');
    form.action = '/single_budgets/' + budgetId + '/budget_items';
    document.getElementById('new-item-modal').classList.remove('hidden');
  };

  window.openEditItemModal = function(itemId, name, amount, category, notes) {
    var form = document.getElementById('edit-item-form');
    form.action = '/single_budgets/' + window.currentBudgetId + '/budget_items/' + itemId;
    document.getElementById('edit-item-category').value = category || '';
    document.getElementById('edit-item-name').value = category || '';
    document.getElementById('edit-item-amount').value = amount;
    document.getElementById('edit-item-notes').value = notes || '';
    document.getElementById('edit-item-modal').classList.remove('hidden');
  };

  function updateBudgetOverview(data) {
    var container = document.getElementById('budget-overview');
    if (!container || !data) return;
    var remaining = data.total_amount - data.spent_amount;
    var percentage = data.total_amount > 0 ? (data.spent_amount / data.total_amount * 100).toFixed(1) : 0;
    var colorClass = percentage > 100 ? 'from-red-50 to-red-100 dark:from-red-900/30 dark:to-red-800/30' : 
                     (percentage > 80 ? 'from-yellow-50 to-yellow-100 dark:from-yellow-900/30 dark:to-yellow-800/30' : 'from-emerald-50 to-emerald-100 dark:from-emerald-900/30 dark:to-emerald-800/30');
    var remainingColor = remaining >= 0 ? 'text-emerald-700 dark:text-emerald-300' : 'text-red-700 dark:text-red-300';
    container.innerHTML = 
      '<div class="grid grid-cols-1 sm:grid-cols-3 gap-4">' +
        '<div class="bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-900/30 dark:to-blue-800/30 rounded-xl p-4">' +
          '<div class="text-xs font-medium text-blue-600 dark:text-blue-400 mb-1">预算总额</div>' +
          '<div class="text-2xl font-bold text-blue-700 dark:text-blue-300">' + data.formatted_total + '</div>' +
        '</div>' +
        '<div class="bg-gradient-to-br from-orange-50 to-orange-100 dark:from-orange-900/30 dark:to-orange-800/30 rounded-xl p-4">' +
          '<div class="text-xs font-medium text-orange-600 dark:text-orange-400 mb-1">已支出</div>' +
          '<div class="text-2xl font-bold text-orange-700 dark:text-orange-300">' + data.formatted_spent + '</div>' +
        '</div>' +
        '<div class="bg-gradient-to-br ' + colorClass + ' rounded-xl p-4">' +
          '<div class="text-xs font-medium ' + remainingColor + ' mb-1">剩余</div>' +
          '<div class="text-2xl font-bold ' + remainingColor + '">' + (remaining >= 0 ? '' : '-') + data.currency_symbol + Math.abs(remaining).toFixed(2) + '</div>' +
        '</div>' +
      '</div>' +
      '<div class="mt-4">' +
        '<div class="flex justify-between text-sm mb-2">' +
          '<span class="text-secondary dark:text-secondary-dark">执行进度</span>' +
          '<span class="font-medium ' + (percentage > 100 ? 'text-red-500' : (percentage > 80 ? 'text-yellow-500' : 'text-blue-500')) + '">' + percentage + '%</span>' +
        '</div>' +
        '<div class="h-4 bg-surface dark:bg-surface-dark rounded-full overflow-hidden">' +
          '<div class="h-full rounded-full ' + (percentage > 100 ? 'bg-red-500' : (percentage > 80 ? 'bg-yellow-500' : 'bg-blue-500')) + ' transition-all" style="width: ' + Math.min(percentage, 100) + '%"></div>' +
        '</div>' +
      '</div>';
  }

  function updateBudgetItems(items) {
    var container = document.getElementById('budget-items-table');
    if (!container) return;
    if (!items || items.length === 0) {
      container.innerHTML = 
        '<div class="overflow-x-auto">' +
          '<table class="w-full">' +
            '<thead>' +
              '<tr class="border-b border-border dark:border-border-dark">' +
                '<th class="text-left py-3 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">名称</th>' +
                '<th class="text-right py-3 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">预算</th>' +
                '<th class="text-right py-3 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">已支</th>' +
                '<th class="text-right py-3 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">剩余</th>' +
                '<th class="text-right py-3 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">进度</th>' +
              '</tr>' +
            '</thead>' +
            '<tbody>' +
              '<tr><td colspan="5" class="py-8 text-center text-secondary dark:text-secondary-dark">暂无预算项</td></tr>' +
            '</tbody>' +
          '</table>' +
        '</div>';
      return;
    }
    var rows = items.map(function(item) {
      var remaining = item.amount - item.spent_amount;
      var percentage = item.amount > 0 ? (item.spent_amount / item.amount * 100).toFixed(1) : 0;
      var progressColor = percentage > 100 ? 'bg-red-500' : (percentage > 80 ? 'bg-yellow-500' : 'bg-blue-500');
      var remainingColor = remaining >= 0 ? 'text-blue-500' : 'text-red-500';
      return '<tr class="border-b border-border dark:border-border-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-colors">' +
        '<td class="py-3 px-2"><span class="font-medium text-primary dark:text-primary-dark">' + item.name + '</span></td>' +
        '<td class="py-3 px-2 text-right font-medium text-primary dark:text-primary-dark">' + item.formatted_amount + '</td>' +
        '<td class="py-3 px-2 text-right text-secondary dark:text-secondary-dark">' + item.formatted_spent + '</td>' +
        '<td class="py-3 px-2 text-right font-medium ' + remainingColor + '">' + (remaining >= 0 ? '' : '-') + item.currency_symbol + Math.abs(remaining).toFixed(2) + '</td>' +
        '<td class="py-3 px-2">' +
          '<div class="flex items-center gap-2 justify-end">' +
            '<div class="w-20 h-2 bg-surface dark:bg-surface-dark rounded-full overflow-hidden">' +
              '<div class="h-full rounded-full ' + progressColor + '" style="width: ' + Math.min(percentage, 100) + '%"></div>' +
            '</div>' +
            '<span class="text-xs ' + (percentage > 100 ? 'text-red-500' : (percentage > 80 ? 'text-yellow-500' : 'text-secondary dark:text-secondary-dark')) + '">' + percentage + '%</span>' +
          '</div>' +
        '</td>' +
      '</tr>';
    }).join('');
    container.innerHTML = 
      '<div class="overflow-x-auto">' +
        '<table class="w-full">' +
          '<thead>' +
            '<tr class="border-b border-border dark:border-border-dark">' +
              '<th class="text-left py-3 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">名称</th>' +
              '<th class="text-right py-3 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">预算</th>' +
              '<th class="text-right py-3 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">已支</th>' +
              '<th class="text-right py-3 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">剩余</th>' +
              '<th class="text-right py-3 px-2 text-xs font-medium text-secondary dark:text-secondary-dark">进度</th>' +
            '</tr>' +
          '</thead>' +
          '<tbody>' + rows + '</tbody>' +
        '</table>' +
      '</div>';
  }

  document.addEventListener('DOMContentLoaded', function() {
    var select = document.getElementById('budget-select');
    if (select) {
      select.addEventListener('change', function() {
        var id = this.value;
        if (id) {
          window.selectBudget(parseInt(id));
        }
      });
    }
  });
</script>

<!-- 新建预算弹窗 -->
<div id="new-budget-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('new-budget-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-xl shadow-xl w-full max-w-2xl p-6 max-h-[90vh] overflow-y-auto">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-primary dark:text-primary-dark">新建预算</h3>
        <button type="button" onclick="document.getElementById('new-budget-modal').classList.add('hidden')" class="p-1 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <%= form_with model: SingleBudget.new, url: single_budgets_path, method: :post, local: true do |f| %>

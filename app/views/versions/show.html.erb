<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <%= link_to '← 返回列表', versions_path, class: 'text-blue-600 dark:text-blue-400 hover:underline' %>
  </div>

  <div class="bg-surface dark:bg-surface-dark rounded-lg shadow-sm">
    <div class="px-6 py-4 border-b border-border dark:border-border-dark">
      <h2 class="text-xl font-bold text-primary dark:text-primary-dark">
        操作详情
      </h2>
      <p class="text-sm text-secondary dark:text-secondary-dark mt-1">
        <%= @operation_log.created_at.strftime('%Y-%m-%d %H:%M:%S') %>
      </p>
    </div>

    <div class="px-6 py-4 space-y-4">
      <!-- 基本信息 -->
      <div>
        <h3 class="text-sm font-medium text-secondary dark:text-secondary-dark uppercase tracking-wider mb-2">基本信息</h3>
        <dl class="grid grid-cols-2 gap-4">
          <div>
            <dt class="text-sm font-medium text-primary dark:text-primary-dark">模型类型</dt>
            <dd class="mt-1 text-sm text-secondary dark:text-secondary-dark"><%= @operation_log.item_type %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-primary dark:text-primary-dark">记录ID</dt>
            <dd class="mt-1 text-sm text-secondary dark:text-secondary-dark"><%= @operation_log.item_id if @operation_log.item_id > 0 %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-primary dark:text-primary-dark">操作类型</dt>
            <dd class="mt-1 text-sm text-secondary dark:text-secondary-dark">
              <%= { 'create' => '创建', 'update' => '更新', 'destroy' => '删除',
                    'settle' => '结算', 'revert' => '撤销', 'execute' => '执行',
                    'import' => '导入', 'export' => '导出' }[@operation_log.action] || @operation_log.action %>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-primary dark:text-primary-dark">描述</dt>
            <dd class="mt-1 text-sm text-secondary dark:text-secondary-dark">
              <%= @operation_log.description %>
            </dd>
          </div>
        </dl>
      </div>

      <!-- 请求信息 -->
      <% if @operation_log.request_path || @operation_log.ip_address %>
        <div>
          <h3 class="text-sm font-medium text-secondary dark:text-secondary-dark uppercase tracking-wider mb-2">请求信息</h3>
          <dl class="grid grid-cols-2 gap-4">
            <div>
              <dt class="text-sm font-medium text-primary dark:text-primary-dark">请求路径</dt>
              <dd class="mt-1 text-sm text-secondary dark:text-secondary-dark font-mono">
                <%= @operation_log.request_method %> <%= @operation_log.request_path %>
              </dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-primary dark:text-primary-dark">IP 地址</dt>
              <dd class="mt-1 text-sm text-secondary dark:text-secondary-dark"><%= @operation_log.ip_address %></dd>
            </div>
            <% if @operation_log.user_agent %>
              <div class="col-span-2">
                <dt class="text-sm font-medium text-primary dark:text-primary-dark">User Agent</dt>
                <dd class="mt-1 text-sm text-secondary dark:text-secondary-dark truncate"><%= @operation_log.user_agent %></dd>
              </div>
            <% end %>
          </dl>
        </div>
      <% end %>

      <!-- 变更内容 -->
      <% if @operation_log.action.in?(['update', 'settle', 'execute']) && @operation_log.changeset.present? %>
        <div>
          <h3 class="text-sm font-medium text-secondary dark:text-secondary-dark uppercase tracking-wider mb-2">变更内容</h3>
          <div class="bg-surface-inset dark:bg-surface-dark-inset rounded-lg p-4">
            <%= @operation_log.changes_summary %>
          </div>
        </div>
      <% end %>

      <!-- 完整数据 (JSON) -->
      <% if @operation_log.changeset.present? %>
        <div>
          <h3 class="text-sm font-medium text-secondary dark:text-secondary-dark uppercase tracking-wider mb-2">完整数据 (JSON)</h3>
          <pre class="bg-surface-inset dark:bg-surface-dark-inset rounded-lg p-4 text-xs overflow-x-auto"><%= JSON.pretty_generate(JSON.parse(@operation_log.changeset)) rescue @operation_log.changeset %></pre>
        </div>
      <% end %>

      <!-- 请求参数 -->
      <% if @operation_log.request_params.present? %>
        <div>
          <h3 class="text-sm font-medium text-secondary dark:text-secondary-dark uppercase tracking-wider mb-2">请求参数</h3>
          <pre class="bg-surface-inset dark:bg-surface-dark-inset rounded-lg p-4 text-xs overflow-x-auto"><%= JSON.pretty_generate(@operation_log.request_params) rescue '无法解析' %></pre>
        </div>
      <% end %>
    </div>
  </div>
</div>
<% display_month = @month.to_s %>
<% display_month = Date.current.strftime("%Y-%m") unless display_month =~ /\A\d{4}-\d{2}\z/ %>
<% current_date = Date.new(display_month[0..3].to_i, display_month[5..6].to_i, 1) %>

<div class="space-y-4 sm:space-y-6" data-controller="chart-visibility" data-chart-visibility-page-value="dashboard" data-chart-visibility-default-visible-value='["recent_transactions", "trend_chart", "expense_chart", "budget_status"]'>
  <!-- Header -->
  <div class="flex flex-col gap-3 sm:flex-row sm:justify-between sm:items-center sm:gap-4">
    <div>
      <h1 class="text-xl sm:text-2xl font-semibold text-primary dark:text-primary-dark"><%= t("dashboard.title") %></h1>
      <p class="text-xs sm:text-sm text-secondary dark:text-secondary-dark mt-0.5 sm:mt-1"><%= t("dashboard.subtitle") %></p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to dashboard_path(month: current_date.prev_month.strftime("%Y-%m")), 
          class: "p-2 rounded-lg hover:bg-surface-inset text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark transition-smooth" do %>
        <%= render(Ds::IconComponent.new(name: "chevron-left", size: :md)) %>
      <% end %>
      <span class="px-4 py-2 bg-container dark:bg-container-dark rounded-lg font-medium min-w-[120px] text-center shadow-border-xs dark:shadow-dark-border-xs">
        <%= display_month %>
      </span>
      <%= link_to dashboard_path(month: current_date.next_month.strftime("%Y-%m")), 
          class: "p-2 rounded-lg hover:bg-surface-inset text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark transition-smooth" do %>
        <%= render(Ds::IconComponent.new(name: "chevron-right", size: :md)) %>
      <% end %>
      <!-- Chart Configuration Button -->
      <div class="relative">
        <button type="button" data-action="click->chart-visibility#toggleDropdown" class="p-2 rounded-lg hover:bg-surface-inset text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark transition-smooth">
          <%= render(Ds::IconComponent.new(name: "settings", size: :md)) %>
        </button>
        <div data-chart-visibility-target="dropdown" class="hidden absolute right-0 mt-2 w-48 bg-container dark:bg-container-dark rounded-lg shadow-lg border border-border dark:border-border-dark z-10">
          <div class="p-3 space-y-2">
            <p class="text-xs font-medium text-secondary dark:text-secondary-dark mb-2">显示图表</p>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" data-chart-visibility-target="checkbox" data-section-key="recent_transactions" data-action="change->chart-visibility#toggleSection" class="w-4 h-4 rounded border-border text-primary focus:ring-primary">
              <span class="text-sm text-primary dark:text-primary-dark">最近交易</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" data-chart-visibility-target="checkbox" data-section-key="trend_chart" data-action="change->chart-visibility#toggleSection" class="w-4 h-4 rounded border-border text-primary focus:ring-primary">
              <span class="text-sm text-primary dark:text-primary-dark">收支趋势</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" data-chart-visibility-target="checkbox" data-section-key="expense_chart" data-action="change->chart-visibility#toggleSection" class="w-4 h-4 rounded border-border text-primary focus:ring-primary">
              <span class="text-sm text-primary dark:text-primary-dark">分类支出</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" data-chart-visibility-target="checkbox" data-section-key="budget_status" data-action="change->chart-visibility#toggleSection" class="w-4 h-4 rounded border-border text-primary focus:ring-primary">
              <span class="text-sm text-primary dark:text-primary-dark">预算仪表盘</span>
            </label>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats Cards (Always visible, not draggable) -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4">
    <%= render(Ds::CardComponent.new) do %>
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between">
        <div class="flex-1">
          <p class="text-xs sm:text-sm font-medium text-secondary dark:text-secondary-dark"><%= t("dashboard.income") %></p>
          <p class="text-lg sm:text-2xl font-semibold text-income mt-0.5 sm:mt-1"><%= format_currency(@total_income) %></p>
        </div>
        <div class="hidden sm:flex w-10 h-10 bg-surface dark:bg-surface-dark rounded-lg items-center justify-center">
          <%= render(Ds::IconComponent.new(name: "trending-up", size: :md, color: :income)) %>
        </div>
      </div>
    <% end %>

    <%= render(Ds::CardComponent.new) do %>
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between">
        <div class="flex-1">
          <p class="text-xs sm:text-sm font-medium text-secondary dark:text-secondary-dark"><%= t("dashboard.expense") %></p>
          <p class="text-lg sm:text-2xl font-semibold text-expense mt-0.5 sm:mt-1"><%= format_currency(@total_expense) %></p>
        </div>
        <div class="hidden sm:flex w-10 h-10 bg-surface dark:bg-surface-dark rounded-lg items-center justify-center">
          <%= render(Ds::IconComponent.new(name: "trending-down", size: :md, color: :expense)) %>
        </div>
      </div>
    <% end %>

    <%= render(Ds::CardComponent.new) do %>
      <div class="flex items-start justify-between">
        <div>
          <p class="text-sm font-medium text-secondary dark:text-secondary-dark"><%= t("dashboard.balance") %></p>
          <% balance_info = format_balance(@total_income - @total_expense) %>
          <p class="text-2xl font-semibold mt-1 <%= balance_info[:css_class] %>">
            <%= balance_info[:amount] %>
          </p>
        </div>
        <div class="w-10 h-10 bg-surface dark:bg-surface-dark rounded-lg flex items-center justify-center">
          <%= render(Ds::IconComponent.new(name: "chart-bar", size: :md, color: :primary)) %>
        </div>
      </div>
    <% end %>

    <%= render(Ds::CardComponent.new) do %>
      <div class="flex items-start justify-between">
        <div>
          <p class="text-sm font-medium text-secondary dark:text-secondary-dark">总资产</p>
          <p class="text-2xl font-semibold text-primary dark:text-primary-dark mt-1"><%= format_currency(@total_assets) %></p>
        </div>
        <div class="w-10 h-10 bg-surface dark:bg-surface-dark rounded-lg flex items-center justify-center">
          <%= render(Ds::IconComponent.new(name: "wallet", size: :md, color: :primary)) %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Draggable Sections Container -->
  <div 
    class="grid grid-cols-1 lg:grid-cols-2 gap-6" 
    data-controller="dashboard-sortable" 
    data-action="dragover->dashboard-sortable#dragOver drop->dashboard-sortable#drop" 
    role="list" 
    aria-label="Dashboard sections">
    
    <!-- Recent Transactions Section -->
    <section
      class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs transition-all group focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2"
      data-dashboard-sortable-target="section"
      data-chart-visibility-target="section"
      data-section-key="recent_transactions"
      data-controller="dashboard-section"
      data-dashboard-section-section-key-value="recent_transactions"
      draggable="true"
      tabindex="0"
      role="listitem"
      aria-grabbed="false"
      data-action="
        dragstart->dashboard-sortable#dragStart
        dragend->dashboard-sortable#dragEnd
        touchstart->dashboard-sortable#touchStart
        touchmove->dashboard-sortable#touchMove
        touchend->dashboard-sortable#touchEnd
        keydown->dashboard-sortable#handleKeyDown">
      
      <!-- Section Header -->
      <div class="px-4 py-3 flex items-center justify-between border-b border-border dark:border-border-dark">
        <div class="flex items-center gap-2">
          <button
            type="button"
            class="text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark transition-colors p-0.5"
            data-action="click->dashboard-section#toggle keydown->dashboard-section#handleToggleKeydown"
            data-dashboard-section-target="button"
            aria-label="<%= t('dashboard.toggle_section') %>"
            aria-expanded="true">
            <%= render(Ds::IconComponent.new(name: "chevron-down", size: :sm, class: "transition-transform", data: { dashboard_section_target: "chevron" })) %>
          </button>
          <h2 class="text-base font-semibold text-primary dark:text-primary-dark">
            <%= t("dashboard.recent_transactions") %>
          </h2>
        </div>
        <div class="flex items-center gap-2">
          <%= link_to t("dashboard.view_all"), accounts_path, 
              class: "text-sm text-primary dark:text-primary-dark hover:text-secondary dark:text-secondary-dark font-medium" %>
          <button
            type="button"
            class="cursor-grab active:cursor-grabbing text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark transition-colors p-0.5 opacity-0 group-hover:opacity-100 hidden lg:block"
            aria-label="<%= t('dashboard.drag_to_reorder') %>">
            <%= render(Ds::IconComponent.new(name: "grip-vertical", size: :sm)) %>
          </button>
        </div>
      </div>
      
      <!-- Section Content -->
      <div class="divide-y divide-border" data-dashboard-section-target="content">
        <% @entries.first(8).each do |e| %>
          <%= link_to transaction_path(e), class: "flex items-center justify-between p-4 hover:bg-surface dark:hover:bg-surface-dark transition-smooth" do %>
            <div class="flex items-center gap-3 min-w-0">
              <div class="ie-icon-chip ie-icon-chip-md <%= e.display_entry_type == "INCOME" ? "ie-icon-income" : "ie-icon-expense" %>">
                <%= render(Ds::IconComponent.new(name: e.display_entry_type == "INCOME" ? "arrow-right" : "arrow-left", size: :md, color: e.display_entry_type == "INCOME" ? :income : :expense)) %>
              </div>
              <div class="min-w-0">
                <p class="font-medium text-primary dark:text-primary-dark truncate"><%= (@category_map && @category_map[e.display_category_id])&.name || t("dashboard.uncategorized") %></p>
                <p class="text-xs text-secondary dark:text-secondary-dark"><%= e.date&.strftime("%Y-%m-%d") %> · <%= e.account_name %></p>
              </div>
            </div>
            <span class="font-medium <%= e.display_entry_type == "INCOME" ? "text-income" : "text-expense" %> shrink-0 ml-2">
              <%= format_currency_with_sign(e.display_amount, type: e.display_entry_type) %>
            </span>
          <% end %>
        <% end %>
        <% if @entries.empty? %>
          <div class="p-8 text-center" data-dashboard-section-target="content">
            <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-surface-inset dark:bg-surface-dark-inset flex items-center justify-center">
              <%= render(Ds::IconComponent.new(name: "receipt", size: :lg, color: :secondary)) %>
            </div>
            <p class="text-secondary dark:text-secondary-dark"><%= t("dashboard.no_transactions_yet") %></p>
          </div>
        <% end %>
      </div>
    </section>

    <!-- Trend Chart Section -->
    <section
      class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs transition-all group focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2"
      data-dashboard-sortable-target="section"
      data-chart-visibility-target="section"
      data-section-key="trend_chart"
      data-controller="dashboard-section"
      data-dashboard-section-section-key-value="trend_chart"
      draggable="true"
      tabindex="0"
      role="listitem"
      aria-grabbed="false"
      data-action="
        dragstart->dashboard-sortable#dragStart
        dragend->dashboard-sortable#dragEnd
        touchstart->dashboard-sortable#touchStart
        touchmove->dashboard-sortable#touchMove
        touchend->dashboard-sortable#touchEnd
        keydown->dashboard-sortable#handleKeyDown">
      
      <div class="px-4 py-3 flex items-center justify-between border-b border-border dark:border-border-dark">
        <div class="flex items-center gap-2">
          <button
            type="button"
            class="text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark transition-colors p-0.5"
            data-action="click->dashboard-section#toggle keydown->dashboard-section#handleToggleKeydown"
            data-dashboard-section-target="button"
            aria-label="<%= t('dashboard.toggle_section') %>"
            aria-expanded="true">
            <%= render(Ds::IconComponent.new(name: "chevron-down", size: :sm, class: "transition-transform", data: { dashboard_section_target: "chevron" })) %>
          </button>
          <h2 class="text-base font-semibold text-primary dark:text-primary-dark">
            本月收支趋势
          </h2>
        </div>
        <button
          type="button"
          class="cursor-grab active:cursor-grabbing text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark transition-colors p-0.5 opacity-0 group-hover:opacity-100 hidden lg:block"
          aria-label="<%= t('dashboard.drag_to_reorder') %>">
          <%= render(Ds::IconComponent.new(name: "grip-vertical", size: :sm)) %>
        </button>
      </div>
      
      <div class="p-4" data-dashboard-section-target="content">
        <% has_trend_data = @trend_chart_data[:income].any? { |v| v > 0 } || @trend_chart_data[:expense].any? { |v| v > 0 } %>
        <% if has_trend_data %>
          <div data-controller="trend-line-chart"
               data-trend-line-chart-labels-value="<%= @trend_chart_data[:labels].to_json %>"
               data-trend-line-chart-income-data-value="<%= @trend_chart_data[:income].to_json %>"
               data-trend-line-chart-expense-data-value="<%= @trend_chart_data[:expense].to_json %>"
               class="h-64">
            <canvas data-trend-line-chart-target="canvas"></canvas>
          </div>
        <% else %>
          <div class="h-64 flex items-center justify-center text-secondary dark:text-secondary-dark">暂无数据</div>
        <% end %>
      </div>
    </section>

    <!-- Expenses by Category Section -->
    <section
      class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs transition-all group focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2"
      data-dashboard-sortable-target="section"
      data-chart-visibility-target="section"
      data-section-key="expense_chart"
      data-controller="dashboard-section"
      data-dashboard-section-section-key-value="expense_chart"
      draggable="true"
      tabindex="0"
      role="listitem"
      aria-grabbed="false"
      data-action="
        dragstart->dashboard-sortable#dragStart
        dragend->dashboard-sortable#dragEnd
        touchstart->dashboard-sortable#touchStart
        touchmove->dashboard-sortable#touchMove
        touchend->dashboard-sortable#touchEnd
        keydown->dashboard-sortable#handleKeyDown">
      
      <div class="px-4 py-3 flex items-center justify-between border-b border-border dark:border-border-dark">
        <div class="flex items-center gap-2">
          <button
            type="button"
            class="text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark transition-colors p-0.5"
            data-action="click->dashboard-section#toggle keydown->dashboard-section#handleToggleKeydown"
            data-dashboard-section-target="button"
            aria-label="<%= t('dashboard.toggle_section') %>"
            aria-expanded="true">
            <%= render(Ds::IconComponent.new(name: "chevron-down", size: :sm, class: "transition-transform", data: { dashboard_section_target: "chevron" })) %>
          </button>
          <h2 class="text-base font-semibold text-primary dark:text-primary-dark">
            支出分类占比
          </h2>
        </div>
        <button
          type="button"
          class="cursor-grab active:cursor-grabbing text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark transition-colors p-0.5 opacity-0 group-hover:opacity-100 hidden lg:block"
          aria-label="<%= t('dashboard.drag_to_reorder') %>">
          <%= render(Ds::IconComponent.new(name: "grip-vertical", size: :sm)) %>
        </button>
      </div>
      
      <div class="p-4" data-dashboard-section-target="content">
        <% if @expense_chart_data.any? %>
          <div data-controller="category-donut-chart"
               data-category-donut-chart-data-value="<%= @expense_chart_data.to_json %>"
               class="h-64">
            <canvas data-category-donut-chart-target="canvas"></canvas>
          </div>
        <% else %>
          <div class="h-64 flex items-center justify-center text-secondary dark:text-secondary-dark">暂无支出数据</div>
        <% end %>
      </div>
    </section>

    <!-- Budget Status Section -->
    <section
      class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs transition-all group focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2"
      data-dashboard-sortable-target="section"
      data-chart-visibility-target="section"
      data-section-key="budget_status"
      data-controller="dashboard-section"
      data-dashboard-section-section-key-value="budget_status"
      draggable="true"
      tabindex="0"
      role="listitem"
      aria-grabbed="false"
      data-action="
        dragstart->dashboard-sortable#dragStart
        dragend->dashboard-sortable#dragEnd
        touchstart->dashboard-sortable#touchStart
        touchmove->dashboard-sortable#touchMove
        touchend->dashboard-sortable#touchEnd
        keydown->dashboard-sortable#handleKeyDown">
      
      <!-- Section Header -->
      <div class="px-4 py-3 flex items-center justify-between border-b border-border dark:border-border-dark">
        <div class="flex items-center gap-2">
          <button
            type="button"
            class="text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark transition-colors p-0.5"
            data-action="click->dashboard-section#toggle keydown->dashboard-section#handleToggleKeydown"
            data-dashboard-section-target="button"
            aria-label="<%= t('dashboard.toggle_section') %>"
            aria-expanded="true">
            <%= render(Ds::IconComponent.new(name: "chevron-down", size: :sm, class: "transition-transform", data: { dashboard_section_target: "chevron" })) %>
          </button>
          <h2 class="text-base font-semibold text-primary dark:text-primary-dark">
            <%= t("dashboard.budget_status") %>
          </h2>
        </div>
        <button
          type="button"
          class="cursor-grab active:cursor-grabbing text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark transition-colors p-0.5 opacity-0 group-hover:opacity-100 hidden lg:block"
          aria-label="<%= t('dashboard.drag_to_reorder') %>">
          <%= render(Ds::IconComponent.new(name: "grip-vertical", size: :sm)) %>
        </button>
      </div>
      
      <!-- Section Content -->
      <div class="p-4" data-dashboard-section-target="content">
        <% if @budgets.any? || @total_budget > 0 %>
          <div class="flex flex-col sm:flex-row items-center gap-6">
            <% if @total_budget > 0 %>
              <% budget_percentage = (@total_spent / @total_budget * 100).round %>
              <div data-controller="budget-gauge"
                   data-budget-gauge-percentage-value="<%= budget_percentage %>"
                   data-budget-gauge-spent-value="<%= @total_spent %>"
                   data-budget-gauge-total-value="<%= @total_budget %>"
                   class="flex flex-col items-center">
                <svg data-budget-gauge-target="gauge" width="120" height="120" class="shrink-0"></svg>
                <div class="text-center mt-2">
                  <p data-budget-gauge-target="percentage" class="text-2xl font-bold"></p>
                </div>
              </div>
              <div class="flex-1 space-y-3">
                <div class="flex justify-between items-center pb-3 border-b border-border dark:border-border-dark">
                  <span class="font-medium text-primary dark:text-primary-dark"><%= t("dashboard.total_budget") %></span>
                  <span class="font-semibold text-primary dark:text-primary-dark"><%= format_currency(@total_budget) %></span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-secondary dark:text-secondary-dark"><%= t("dashboard.spent") %></span>
                  <span class="<%= budget_percentage > 100 ? 'text-expense' : 'text-primary dark:text-primary-dark' %> font-medium">
                    <%= format_currency(@total_spent) %>
                  </span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-secondary dark:text-secondary-dark"><%= t("dashboard.remaining") %></span>
                  <span class="font-medium <%= (@total_budget - @total_spent) >= 0 ? 'text-income' : 'text-expense' %>">
                    <%= format_currency(@total_budget - @total_spent) %>
                  </span>
                </div>
              </div>
            <% else %>
              <div class="flex-1 text-center">
                <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-surface-inset dark:bg-surface-dark-inset flex items-center justify-center">
                  <%= render(Ds::IconComponent.new(name: "target", size: :lg, color: :secondary)) %>
                </div>
                <p class="text-secondary dark:text-secondary-dark"><%= t("dashboard.no_budgets_set") %></p>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-6">
            <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-surface-inset dark:bg-surface-dark-inset flex items-center justify-center">
              <%= render(Ds::IconComponent.new(name: "target", size: :lg, color: :secondary)) %>
            </div>
            <p class="text-secondary dark:text-secondary-dark"><%= t("dashboard.no_budgets_set") %></p>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</div>

<% display_month = @month.to_s %>
<% display_month = "2026-03" unless display_month =~ /\A\d{4}-\d{2}\z/ %>
<% current_date = Date.new(display_month[0..3].to_i, display_month[5..6].to_i, 1) %>

<div class="space-y-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
    <div>
      <h1 class="text-2xl font-semibold text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark"><%= t("dashboard.title") %></h1>
      <p class="text-sm text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark mt-1"><%= t("dashboard.subtitle") %></p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to dashboard_path(month: current_date.prev_month.strftime("%Y-%m")), 
          class: "p-2 rounded-lg hover:bg-surface-inset text-secondary dark:text-secondary dark:text-secondary-dark-dark hover:text-primary dark:text-primary dark:text-primary-dark-dark transition-smooth" do %>
        <%= render(Ds::IconComponent.new(name: "chevron-left", size: :md)) %>
      <% end %>
      <span class="px-4 py-2 bg-container dark:bg-container dark:bg-container-dark-dark rounded-lg font-medium min-w-[120px] text-center shadow-border-xs dark:shadow-dark-border-xs dark:shadow-dark-border-xs">
        <%= display_month %>
      </span>
      <%= link_to dashboard_path(month: current_date.next_month.strftime("%Y-%m")), 
          class: "p-2 rounded-lg hover:bg-surface-inset text-secondary dark:text-secondary dark:text-secondary-dark-dark hover:text-primary dark:text-primary dark:text-primary-dark-dark transition-smooth" do %>
        <%= render(Ds::IconComponent.new(name: "chevron-right", size: :md)) %>
      <% end %>
    </div>
  </div>

  <!-- Stats Cards (Always visible, not draggable) -->
  <div class="grid grid-cols-1 sm:grid-cols-4 gap-4">
    <%= render(Ds::CardComponent.new) do %>
      <div class="flex items-start justify-between">
        <div>
          <p class="text-sm font-medium text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark"><%= t("dashboard.income") %></p>
          <p class="text-2xl font-semibold text-income mt-1"><%= format_currency(@total_income) %></p>
        </div>
        <div class="w-10 h-10 bg-surface dark:bg-surface-dark rounded-lg flex items-center justify-center">
          <%= render(Ds::IconComponent.new(name: "trending-up", size: :md, color: :income)) %>
        </div>
      </div>
    <% end %>

    <%= render(Ds::CardComponent.new) do %>
      <div class="flex items-start justify-between">
        <div>
          <p class="text-sm font-medium text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark"><%= t("dashboard.expense") %></p>
          <p class="text-2xl font-semibold text-expense mt-1"><%= format_currency(@total_expense) %></p>
        </div>
        <div class="w-10 h-10 bg-surface dark:bg-surface-dark rounded-lg flex items-center justify-center">
          <%= render(Ds::IconComponent.new(name: "trending-down", size: :md, color: :expense)) %>
        </div>
      </div>
    <% end %>

    <%= render(Ds::CardComponent.new) do %>
      <div class="flex items-start justify-between">
        <div>
          <p class="text-sm font-medium text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark"><%= t("dashboard.balance") %></p>
          <% balance_info = format_balance(@total_income - @total_expense) %>
          <p class="text-2xl font-semibold mt-1 <%= balance_info[:css_class] %>">
            <%= balance_info[:amount] %>
          </p>
        </div>
        <div class="w-10 h-10 bg-surface dark:bg-surface-dark rounded-lg flex items-center justify-center">
          <%= render(Ds::IconComponent.new(name: "chart-bar", size: :md, color: :primary)) %>
        </div>
      </div>
    <% end %>

    <%= render(Ds::CardComponent.new) do %>
      <div class="flex items-start justify-between">
        <div>
          <p class="text-sm font-medium text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark">总资产</p>
          <p class="text-2xl font-semibold text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark mt-1"><%= format_currency(@total_assets) %></p>
        </div>
        <div class="w-10 h-10 bg-surface dark:bg-surface-dark rounded-lg flex items-center justify-center">
          <%= render(Ds::IconComponent.new(name: "wallet", size: :md, color: :primary)) %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Draggable Sections Container -->
  <div 
    class="grid grid-cols-1 lg:grid-cols-2 gap-6" 
    data-controller="dashboard-sortable" 
    data-action="dragover->dashboard-sortable#dragOver drop->dashboard-sortable#drop" 
    role="list" 
    aria-label="Dashboard sections">
    
    <!-- Recent Transactions Section -->
    <section
      class="bg-container dark:bg-container dark:bg-container-dark-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs dark:shadow-dark-border-xs transition-all group focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2"
      data-dashboard-sortable-target="section"
      data-section-key="recent_transactions"
      data-controller="dashboard-section"
      data-dashboard-section-section-key-value="recent_transactions"
      draggable="true"
      tabindex="0"
      role="listitem"
      aria-grabbed="false"
      data-action="
        dragstart->dashboard-sortable#dragStart
        dragend->dashboard-sortable#dragEnd
        touchstart->dashboard-sortable#touchStart
        touchmove->dashboard-sortable#touchMove
        touchend->dashboard-sortable#touchEnd
        keydown->dashboard-sortable#handleKeyDown">
      
      <!-- Section Header -->
      <div class="px-4 py-3 flex items-center justify-between border-b border-border dark:border-border-dark dark:border-border dark:border-border-dark dark:border-border dark:border-border dark:border-border-dark-dark-dark-dark">
        <div class="flex items-center gap-2">
          <button
            type="button"
            class="text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark hover:text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark transition-colors p-0.5"
            data-action="click->dashboard-section#toggle keydown->dashboard-section#handleToggleKeydown"
            data-dashboard-section-target="button"
            aria-label="<%= t('dashboard.toggle_section') %>"
            aria-expanded="true">
            <%= render(Ds::IconComponent.new(name: "chevron-down", size: :sm, class: "transition-transform", data: { dashboard_section_target: "chevron" })) %>
          </button>
          <h2 class="text-base font-semibold text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark">
            <%= t("dashboard.recent_transactions") %>
          </h2>
        </div>
        <div class="flex items-center gap-2">
          <%= link_to t("dashboard.view_all"), transactions_path, 
              class: "text-sm text-primary dark:text-primary dark:text-primary-dark-dark hover:text-secondary dark:text-secondary dark:text-secondary-dark-dark font-medium" %>
          <button
            type="button"
            class="cursor-grab active:cursor-grabbing text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark hover:text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark transition-colors p-0.5 opacity-0 group-hover:opacity-100 hidden lg:block"
            aria-label="<%= t('dashboard.drag_to_reorder') %>">
            <%= render(Ds::IconComponent.new(name: "grip-vertical", size: :sm)) %>
          </button>
        </div>
      </div>
      
      <!-- Section Content -->
      <div class="divide-y divide-border" data-dashboard-section-target="content">
        <% @transactions.first(8).each do |t| %>
          <%= link_to transaction_path(t), class: "flex items-center justify-between p-4 hover:bg-surface dark:bg-surface-dark transition-smooth" do %>
            <div class="flex items-center gap-3 min-w-0">
              <div class="w-10 h-10 rounded-full bg-surface-inset dark:bg-surface-dark-inset dark:bg-surface-dark-inset flex items-center justify-center shrink-0">
                <%= render(Ds::IconComponent.new(name: t.type == "INCOME" ? "arrow-right" : "arrow-left", size: :md, color: t.type == "INCOME" ? :income : :expense)) %>
              </div>
              <div class="min-w-0">
                <p class="font-medium text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark truncate"><%= t.category&.name || t("dashboard.uncategorized") %></p>
                <p class="text-xs text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark"><%= t.date&.strftime("%Y-%m-%d") %> · <%= t.account_name %></p>
              </div>
            </div>
            <span class="font-medium <%= t.type == "INCOME" ? "text-income" : "text-expense" %> shrink-0 ml-2">
              <%= format_currency_with_sign(t.amount, type: t.type) %>
            </span>
          <% end %>
        <% end %>
        <% if @transactions.empty? %>
          <div class="p-8 text-center" data-dashboard-section-target="content">
            <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-surface-inset dark:bg-surface-dark-inset dark:bg-surface-dark-inset flex items-center justify-center">
              <%= render(Ds::IconComponent.new(name: "receipt", size: :lg, color: :secondary)) %>
            </div>
            <p class="text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark"><%= t("dashboard.no_transactions_yet") %></p>
          </div>
        <% end %>
      </div>
    </section>

    <!-- Account Balances Section -->
    <section
      class="bg-container dark:bg-container dark:bg-container-dark-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs dark:shadow-dark-border-xs transition-all group focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2"
      data-dashboard-sortable-target="section"
      data-section-key="account_balances"
      data-controller="dashboard-section"
      data-dashboard-section-section-key-value="account_balances"
      draggable="true"
      tabindex="0"
      role="listitem"
      aria-grabbed="false"
      data-action="
        dragstart->dashboard-sortable#dragStart
        dragend->dashboard-sortable#dragEnd
        touchstart->dashboard-sortable#touchStart
        touchmove->dashboard-sortable#touchMove
        touchend->dashboard-sortable#touchEnd
        keydown->dashboard-sortable#handleKeyDown">
      
      <!-- Section Header -->
      <div class="px-4 py-3 flex items-center justify-between border-b border-border dark:border-border-dark dark:border-border dark:border-border-dark dark:border-border dark:border-border dark:border-border-dark-dark-dark-dark">
        <div class="flex items-center gap-2">
          <button
            type="button"
            class="text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark hover:text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark transition-colors p-0.5"
            data-action="click->dashboard-section#toggle keydown->dashboard-section#handleToggleKeydown"
            data-dashboard-section-target="button"
            aria-label="<%= t('dashboard.toggle_section') %>"
            aria-expanded="true">
            <%= render(Ds::IconComponent.new(name: "chevron-down", size: :sm, class: "transition-transform", data: { dashboard_section_target: "chevron" })) %>
          </button>
          <h2 class="text-base font-semibold text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark">
            <%= t("dashboard.account_balances") %>
          </h2>
        </div>
        <div class="flex items-center gap-2">
          <%= link_to t("dashboard.manage_accounts"), accounts_path, 
              class: "text-sm text-primary dark:text-primary dark:text-primary-dark-dark hover:text-secondary dark:text-secondary dark:text-secondary-dark-dark font-medium" %>
          <button
            type="button"
            class="cursor-grab active:cursor-grabbing text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark hover:text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark transition-colors p-0.5 opacity-0 group-hover:opacity-100 hidden lg:block"
            aria-label="<%= t('dashboard.drag_to_reorder') %>">
            <%= render(Ds::IconComponent.new(name: "grip-vertical", size: :sm)) %>
          </button>
        </div>
      </div>
      
      <!-- Section Content -->
      <div class="divide-y divide-border" data-dashboard-section-target="content">
        <% @accounts.each do |account| %>
          <%= link_to account_path(account), class: "flex items-center justify-between p-4 hover:bg-surface dark:bg-surface-dark transition-smooth" do %>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-surface dark:bg-surface-dark flex items-center justify-center shrink-0">
                <span class="text-sm font-semibold text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark"><%= account.name[0] %></span>
              </div>
              <div>
                <p class="font-medium text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark"><%= account.name %></p>
                <p class="text-xs text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark"><%= account.type_name %></p>
              </div>
            </div>
            <span class="font-semibold text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark"><%= format_currency(account.current_balance) %></span>
          <% end %>
        <% end %>
        <% if @accounts.empty? %>
          <div class="p-8 text-center">
            <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-surface-inset dark:bg-surface-dark-inset dark:bg-surface-dark-inset flex items-center justify-center">
              <%= render(Ds::IconComponent.new(name: "wallet", size: :lg, color: :secondary)) %>
            </div>
            <p class="text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark"><%= t("dashboard.no_accounts_yet") %></p>
          </div>
        <% end %>
      </div>
    </section>

    <!-- Expenses by Category Section -->
    <section
      class="bg-container dark:bg-container dark:bg-container-dark-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs dark:shadow-dark-border-xs transition-all group focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2"
      data-dashboard-sortable-target="section"
      data-section-key="expenses_by_category"
      data-controller="dashboard-section"
      data-dashboard-section-section-key-value="expenses_by_category"
      draggable="true"
      tabindex="0"
      role="listitem"
      aria-grabbed="false"
      data-action="
        dragstart->dashboard-sortable#dragStart
        dragend->dashboard-sortable#dragEnd
        touchstart->dashboard-sortable#touchStart
        touchmove->dashboard-sortable#touchMove
        touchend->dashboard-sortable#touchEnd
        keydown->dashboard-sortable#handleKeyDown">
      
      <!-- Section Header -->
      <div class="px-4 py-3 flex items-center justify-between border-b border-border dark:border-border-dark dark:border-border dark:border-border-dark dark:border-border dark:border-border dark:border-border-dark-dark-dark-dark">
        <div class="flex items-center gap-2">
          <button
            type="button"
            class="text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark hover:text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark transition-colors p-0.5"
            data-action="click->dashboard-section#toggle keydown->dashboard-section#handleToggleKeydown"
            data-dashboard-section-target="button"
            aria-label="<%= t('dashboard.toggle_section') %>"
            aria-expanded="true">
            <%= render(Ds::IconComponent.new(name: "chevron-down", size: :sm, class: "transition-transform", data: { dashboard_section_target: "chevron" })) %>
          </button>
          <h2 class="text-base font-semibold text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark">
            <%= t("dashboard.expenses_by_category") %>
          </h2>
        </div>
        <button
          type="button"
          class="cursor-grab active:cursor-grabbing text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark hover:text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark transition-colors p-0.5 opacity-0 group-hover:opacity-100 hidden lg:block"
          aria-label="<%= t('dashboard.drag_to_reorder') %>">
          <%= render(Ds::IconComponent.new(name: "grip-vertical", size: :sm)) %>
        </button>
      </div>
      
      <!-- Section Content -->
      <div class="p-4" data-dashboard-section-target="content">
        <% if @expenses_by_category.any? %>
          <div class="space-y-4">
            <% @expenses_by_category.sort_by { |_, v| -v }.first(8).each do |category, amount| %>
              <% percentage = @total_expense > 0 ? (amount / @total_expense * 100).round : 0 %>
              <div>
                <div class="flex justify-between text-sm mb-1.5">
                  <span class="font-medium text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark"><%= category || t("dashboard.uncategorized") %></span>
                  <span class="text-expense font-medium"><%= format_currency(amount) %></span>
                </div>
                <div class="w-full bg-surface dark:bg-surface-dark rounded-full h-2">
                  <div class="bg-expense h-2 rounded-full transition-all" style="width: <%= percentage %>%"></div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-6">
            <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-surface-inset dark:bg-surface-dark-inset dark:bg-surface-dark-inset flex items-center justify-center">
              <%= render(Ds::IconComponent.new(name: "pie-chart", size: :lg, color: :secondary)) %>
            </div>
            <p class="text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark"><%= t("dashboard.no_expenses_this_month") %></p>
          </div>
        <% end %>
      </div>
    </section>

    <!-- Budget Status Section -->
    <section
      class="bg-container dark:bg-container dark:bg-container-dark-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs dark:shadow-dark-border-xs transition-all group focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2"
      data-dashboard-sortable-target="section"
      data-section-key="budget_status"
      data-controller="dashboard-section"
      data-dashboard-section-section-key-value="budget_status"
      draggable="true"
      tabindex="0"
      role="listitem"
      aria-grabbed="false"
      data-action="
        dragstart->dashboard-sortable#dragStart
        dragend->dashboard-sortable#dragEnd
        touchstart->dashboard-sortable#touchStart
        touchmove->dashboard-sortable#touchMove
        touchend->dashboard-sortable#touchEnd
        keydown->dashboard-sortable#handleKeyDown">
      
      <!-- Section Header -->
      <div class="px-4 py-3 flex items-center justify-between border-b border-border dark:border-border-dark dark:border-border dark:border-border-dark dark:border-border dark:border-border dark:border-border-dark-dark-dark-dark">
        <div class="flex items-center gap-2">
          <button
            type="button"
            class="text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark hover:text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark transition-colors p-0.5"
            data-action="click->dashboard-section#toggle keydown->dashboard-section#handleToggleKeydown"
            data-dashboard-section-target="button"
            aria-label="<%= t('dashboard.toggle_section') %>"
            aria-expanded="true">
            <%= render(Ds::IconComponent.new(name: "chevron-down", size: :sm, class: "transition-transform", data: { dashboard_section_target: "chevron" })) %>
          </button>
          <h2 class="text-base font-semibold text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark">
            <%= t("dashboard.budget_status") %>
          </h2>
        </div>
        <button
          type="button"
          class="cursor-grab active:cursor-grabbing text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark hover:text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark transition-colors p-0.5 opacity-0 group-hover:opacity-100 hidden lg:block"
          aria-label="<%= t('dashboard.drag_to_reorder') %>">
          <%= render(Ds::IconComponent.new(name: "grip-vertical", size: :sm)) %>
        </button>
      </div>
      
      <!-- Section Content -->
      <div class="p-4" data-dashboard-section-target="content">
        <% if @budgets.any? || @total_budget > 0 %>
          <div class="flex flex-col sm:flex-row items-center gap-6">
            <% if @total_budget > 0 %>
              <% budget_percentage = (@total_spent / @total_budget * 100).round %>
              <div data-controller="budget-gauge"
                   data-budget-gauge-percentage-value="<%= budget_percentage %>"
                   data-budget-gauge-spent-value="<%= @total_spent %>"
                   data-budget-gauge-total-value="<%= @total_budget %>"
                   class="flex flex-col items-center">
                <svg data-budget-gauge-target="gauge" width="120" height="120" class="shrink-0"></svg>
                <div class="text-center mt-2">
                  <p data-budget-gauge-target="percentage" class="text-2xl font-bold"></p>
                </div>
              </div>
              <div class="flex-1 space-y-3">
                <div class="flex justify-between items-center pb-3 border-b border-border dark:border-border-dark dark:border-border dark:border-border-dark dark:border-border dark:border-border dark:border-border-dark-dark-dark-dark">
                  <span class="font-medium text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark"><%= t("dashboard.total_budget") %></span>
                  <span class="font-semibold text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark"><%= format_currency(@total_budget) %></span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark"><%= t("dashboard.spent") %></span>
                  <span class="<%= budget_percentage > 100 ? 'text-expense' : 'text-primary dark:text-primary-dark dark:text-primary dark:text-primary-dark dark:text-primary dark:text-primary dark:text-primary-dark-dark-dark' %> font-medium">
                    <%= format_currency(@total_spent) %>
                  </span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark"><%= t("dashboard.remaining") %></span>
                  <span class="font-medium <%= (@total_budget - @total_spent) >= 0 ? 'text-income' : 'text-expense' %>">
                    <%= format_currency(@total_budget - @total_spent) %>
                  </span>
                </div>
              </div>
            <% else %>
              <div class="flex-1 text-center">
                <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-surface-inset dark:bg-surface-dark-inset dark:bg-surface-dark-inset flex items-center justify-center">
                  <%= render(Ds::IconComponent.new(name: "target", size: :lg, color: :secondary)) %>
                </div>
                <p class="text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark"><%= t("dashboard.no_budgets_set") %></p>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-6">
            <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-surface-inset dark:bg-surface-dark-inset dark:bg-surface-dark-inset flex items-center justify-center">
              <%= render(Ds::IconComponent.new(name: "target", size: :lg, color: :secondary)) %>
            </div>
            <p class="text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark-dark-dark"><%= t("dashboard.no_budgets_set") %></p>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</div>
<% display_month = @month.to_s %>
<% display_month = Date.current.strftime("%Y-%m") unless display_month =~ /\A\d{4}-\d{2}\z/ %>
<% current_date = Date.new(display_month[0..3].to_i, display_month[5..6].to_i, 1) %>

<div class="space-y-4 sm:space-y-6" data-controller="chart-visibility" data-chart-visibility-page-value="dashboard" data-chart-visibility-default-visible-value='["trend_chart", "expense_chart", "six_month_bar", "net_worth_trend"]'>
  <!-- Header -->
  <div class="flex flex-col gap-3 sm:flex-row sm:justify-between sm:items-center sm:gap-4">
    <div>
      <h1 class="text-xl sm:text-2xl font-semibold text-primary dark:text-primary-dark"><%= t("dashboard.title") %></h1>
      <p class="text-xs sm:text-sm text-secondary dark:text-secondary-dark mt-0.5 sm:mt-1"><%= t("dashboard.subtitle") %></p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to dashboard_path(month: current_date.prev_month.strftime("%Y-%m")), 
          class: "p-2 rounded-lg hover:bg-surface-inset text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark transition-smooth" do %>
        <%= render(Ds::IconComponent.new(name: "chevron-left", size: :md)) %>
      <% end %>
      <span class="px-4 py-2 bg-container dark:bg-container-dark rounded-lg font-medium min-w-[120px] text-center shadow-border-xs dark:shadow-dark-border-xs">
        <%= display_month %>
      </span>
      <%= link_to dashboard_path(month: current_date.next_month.strftime("%Y-%m")), 
          class: "p-2 rounded-lg hover:bg-surface-inset text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark transition-smooth" do %>
        <%= render(Ds::IconComponent.new(name: "chevron-right", size: :md)) %>
      <% end %>
      <!-- Chart Configuration Button -->
      <div class="relative">
        <button type="button" data-action="click->chart-visibility#toggleDropdown" class="p-2 rounded-lg hover:bg-surface-inset text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark transition-smooth">
          <%= render(Ds::IconComponent.new(name: "settings", size: :md)) %>
        </button>
        <div data-chart-visibility-target="dropdown" class="hidden absolute right-0 mt-2 w-48 bg-container dark:bg-container-dark rounded-lg shadow-lg border border-border dark:border-border-dark z-10">
          <div class="p-3 space-y-2">
            <p class="text-xs font-medium text-secondary dark:text-secondary-dark mb-2">显示图表</p>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" data-chart-visibility-target="checkbox" data-section-key="trend_chart" data-action="change->chart-visibility#toggleSection" class="w-4 h-4 rounded border-border text-primary focus:ring-primary">
              <span class="text-sm text-primary dark:text-primary-dark">收支趋势</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" data-chart-visibility-target="checkbox" data-section-key="expense_chart" data-action="change->chart-visibility#toggleSection" class="w-4 h-4 rounded border-border text-primary focus:ring-primary">
              <span class="text-sm text-primary dark:text-primary-dark">分类支出</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" data-chart-visibility-target="checkbox" data-section-key="six_month_bar" data-action="change->chart-visibility#toggleSection" class="w-4 h-4 rounded border-border text-primary focus:ring-primary">
              <span class="text-sm text-primary dark:text-primary-dark">6个月收支</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" data-chart-visibility-target="checkbox" data-section-key="net_worth_trend" data-action="change->chart-visibility#toggleSection" class="w-4 h-4 rounded border-border text-primary focus:ring-primary">
              <span class="text-sm text-primary dark:text-primary-dark">净资产走势</span>
            </label>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats Cards (Always visible, not draggable) -->
  <div class="grid grid-cols-2 sm:grid-cols-4 xl:grid-cols-6 gap-3 sm:gap-4">
    <%= render(Ds::CardComponent.new) do %>
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between">
        <div class="flex-1">
          <p class="text-xs sm:text-sm font-medium text-secondary dark:text-secondary-dark"><%= t("dashboard.income") %></p>
          <p class="text-lg sm:text-2xl font-semibold text-income mt-0.5 sm:mt-1"><%= format_currency(@total_income) %></p>
        </div>
        <div class="hidden sm:flex w-10 h-10 bg-surface dark:bg-surface-dark rounded-lg items-center justify-center">
          <%= render(Ds::IconComponent.new(name: "trending-up", size: :md, color: :income)) %>
        </div>
      </div>
    <% end %>

    <%= render(Ds::CardComponent.new) do %>
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between">
        <div class="flex-1">
          <p class="text-xs sm:text-sm font-medium text-secondary dark:text-secondary-dark"><%= t("dashboard.expense") %></p>
          <p class="text-lg sm:text-2xl font-semibold text-expense mt-0.5 sm:mt-1"><%= format_currency(@total_expense) %></p>
        </div>
        <div class="hidden sm:flex w-10 h-10 bg-surface dark:bg-surface-dark rounded-lg items-center justify-center">
          <%= render(Ds::IconComponent.new(name: "trending-down", size: :md, color: :expense)) %>
        </div>
      </div>
    <% end %>

    <%= render(Ds::CardComponent.new) do %>
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between">
        <div class="flex-1">
          <p class="text-xs sm:text-sm font-medium text-secondary dark:text-secondary-dark"><%= t("dashboard.balance") %></p>
          <% balance_info = format_balance(@total_income - @total_expense) %>
          <p class="text-lg sm:text-2xl font-semibold mt-0.5 sm:mt-1 <%= balance_info[:css_class] %> whitespace-nowrap">
            <%= balance_info[:amount] %>
          </p>
        </div>
        <div class="hidden sm:flex w-10 h-10 bg-surface dark:bg-surface-dark rounded-lg items-center justify-center">
          <%= render(Ds::IconComponent.new(name: "chart-bar", size: :md, color: :primary)) %>
        </div>
      </div>
    <% end %>

    <%= render(Ds::CardComponent.new) do %>
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between">
        <div class="flex-1">
          <p class="text-xs sm:text-sm font-medium text-secondary dark:text-secondary-dark">总资产</p>
          <p class="text-lg sm:text-2xl font-semibold text-primary dark:text-primary-dark mt-0.5 sm:mt-1"><%= format_currency(@total_assets) %></p>
        </div>
        <div class="hidden sm:flex w-10 h-10 bg-surface dark:bg-surface-dark rounded-lg items-center justify-center">
          <%= render(Ds::IconComponent.new(name: "wallet", size: :md, color: :primary)) %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Draggable Sections Container -->
  <div 
    class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-6" 
    data-controller="dashboard-sortable" 
    data-action="dragover->dashboard-sortable#dragOver drop->dashboard-sortable#drop" 
    role="list" 
    aria-label="Dashboard sections">
    
    <!-- Trend Chart Section -->
    <section
      class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs transition-all group focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2"
      data-dashboard-sortable-target="section"
      data-chart-visibility-target="section"
      data-section-key="trend_chart"
      data-controller="dashboard-section"
      data-dashboard-section-section-key-value="trend_chart"
      draggable="true"
      tabindex="0"
      role="listitem"
      aria-grabbed="false"
      data-action="
        dragstart->dashboard-sortable#dragStart
        dragend->dashboard-sortable#dragEnd
        touchstart->dashboard-sortable#touchStart
        touchmove->dashboard-sortable#touchMove
        touchend->dashboard-sortable#touchEnd
        keydown->dashboard-sortable#handleKeyDown">
      
      <div class="px-4 py-3 flex items-center justify-between border-b border-border dark:border-border-dark">
        <div class="flex items-center gap-2">
          <button
            type="button"
            class="text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark transition-colors p-0.5"
            data-action="click->dashboard-section#toggle keydown->dashboard-section#handleToggleKeydown"
            data-dashboard-section-target="button"
            aria-label="<%= t('dashboard.toggle_section') %>"
            aria-expanded="true">
            <%= render(Ds::IconComponent.new(name: "chevron-down", size: :sm, class: "transition-transform", data: { dashboard_section_target: "chevron" })) %>
          </button>
          <h2 class="text-base font-semibold text-primary dark:text-primary-dark">
            本月收支趋势
          </h2>
        </div>
        <button
          type="button"
          class="cursor-grab active:cursor-grabbing text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark transition-colors p-0.5 opacity-0 group-hover:opacity-100 hidden lg:block"
          aria-label="<%= t('dashboard.drag_to_reorder') %>">
          <%= render(Ds::IconComponent.new(name: "grip-vertical", size: :sm)) %>
        </button>
      </div>
      
      <div class="p-4" data-dashboard-section-target="content">
        <% has_trend_data = @trend_chart_data[:income].any? { |v| v > 0 } || @trend_chart_data[:expense].any? { |v| v > 0 } %>
        <% if has_trend_data %>
          <div data-controller="trend-line-chart"
               data-trend-line-chart-labels-value="<%= @trend_chart_data[:labels].to_json %>"
               data-trend-line-chart-income-data-value="<%= @trend_chart_data[:income].to_json %>"
               data-trend-line-chart-expense-data-value="<%= @trend_chart_data[:expense].to_json %>"
               class="h-64">
            <canvas data-trend-line-chart-target="canvas"></canvas>
          </div>
        <% else %>
          <div class="h-64 flex items-center justify-center text-secondary dark:text-secondary-dark">暂无数据</div>
        <% end %>
      </div>
    </section>

    <!-- Expenses by Category Section -->
    <section
      class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs transition-all group focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2"
      data-dashboard-sortable-target="section"
      data-chart-visibility-target="section"
      data-section-key="expense_chart"
      data-controller="dashboard-section"
      data-dashboard-section-section-key-value="expense_chart"
      draggable="true"
      tabindex="0"
      role="listitem"
      aria-grabbed="false"
      data-action="
        dragstart->dashboard-sortable#dragStart
        dragend->dashboard-sortable#dragEnd
        touchstart->dashboard-sortable#touchStart
        touchmove->dashboard-sortable#touchMove
        touchend->dashboard-sortable#touchEnd
        keydown->dashboard-sortable#handleKeyDown">
      
      <div class="px-4 py-3 flex items-center justify-between border-b border-border dark:border-border-dark">
        <div class="flex items-center gap-2">
          <button
            type="button"
            class="text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark transition-colors p-0.5"
            data-action="click->dashboard-section#toggle keydown->dashboard-section#handleToggleKeydown"
            data-dashboard-section-target="button"
            aria-label="<%= t('dashboard.toggle_section') %>"
            aria-expanded="true">
            <%= render(Ds::IconComponent.new(name: "chevron-down", size: :sm, class: "transition-transform", data: { dashboard_section_target: "chevron" })) %>
          </button>
          <h2 class="text-base font-semibold text-primary dark:text-primary-dark">
            支出分类占比
          </h2>
        </div>
        <button
          type="button"
          class="cursor-grab active:cursor-grabbing text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark transition-colors p-0.5 opacity-0 group-hover:opacity-100 hidden lg:block"
          aria-label="<%= t('dashboard.drag_to_reorder') %>">
          <%= render(Ds::IconComponent.new(name: "grip-vertical", size: :sm)) %>
        </button>
      </div>
      
      <div class="p-4" data-dashboard-section-target="content">
        <% if @expense_chart_data.any? %>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <div data-controller="category-donut-chart"
                 data-category-donut-chart-data-value="<%= @expense_chart_data.to_json %>"
                 class="h-64">
              <canvas data-category-donut-chart-target="canvas"></canvas>
            </div>
            <div class="space-y-1 overflow-y-auto max-h-64 pr-1">
              <% total_exp = @expense_chart_data.sum { |d| d[:value] } %>
              <% @expense_chart_data.each_with_index do |cat, idx| %>
                <%
                  percentage = total_exp > 0 ? (cat[:value] / total_exp * 100).round(1) : 0
                  bar_width = [percentage, 95].min
                %>
                <div class="flex items-center gap-2 py-1.5 px-2 rounded-lg hover:bg-surface dark:hover:bg-surface-dark transition-smooth cursor-default group"
                     data-category-row data-category-index="<%= idx %>">
                  <span class="text-xs text-secondary dark:text-secondary-dark w-5 text-right shrink-0"><%= idx + 1 %></span>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between mb-0.5">
                      <span class="text-sm font-medium text-primary dark:text-primary-dark truncate"><%= cat[:label] %></span>
                      <span class="text-xs text-secondary dark:text-secondary-dark ml-2 shrink-0"><%= percentage %>%</span>
                    </div>
                    <div class="w-full h-1.5 bg-surface dark:bg-surface-dark rounded-full overflow-hidden">
                      <div class="h-full rounded-full transition-all duration-300 group-hover:opacity-80"
                           style="width: <%= bar_width %>%; background-color: var(--color-expense, #ef4444); opacity: <%= [0.4 + (idx * 0.05), 1].min %>"></div>
                    </div>
                  </div>
                  <span class="text-sm font-medium text-expense w-20 text-right shrink-0 ml-2"><%= format_currency(cat[:value]) %></span>
                </div>
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="h-64 flex items-center justify-center text-secondary dark:text-secondary-dark">暂无支出数据</div>
        <% end %>
      </div>
    </section>

    <!-- Six Month Bar Chart Section -->
    <section
      class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs transition-all group focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2"
      data-dashboard-sortable-target="section"
      data-chart-visibility-target="section"
      data-section-key="six_month_bar"
      data-controller="dashboard-section"
      data-dashboard-section-section-key-value="six_month_bar"
      draggable="true"
      tabindex="0"
      role="listitem"
      aria-grabbed="false"
      data-action="
        dragstart->dashboard-sortable#dragStart
        dragend->dashboard-sortable#dragEnd
        touchstart->dashboard-sortable#touchStart
        touchmove->dashboard-sortable#touchMove
        touchend->dashboard-sortable#touchEnd
        keydown->dashboard-sortable#handleKeyDown">
      
      <div class="px-4 py-3 flex items-center justify-between border-b border-border dark:border-border-dark">
        <div class="flex items-center gap-2">
          <button
            type="button"
            class="text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark transition-colors p-0.5"
            data-action="click->dashboard-section#toggle keydown->dashboard-section#handleToggleKeydown"
            data-dashboard-section-target="button"
            aria-label="<%= t('dashboard.toggle_section') %>"
            aria-expanded="true">
            <%= render(Ds::IconComponent.new(name: "chevron-down", size: :sm, class: "transition-transform", data: { dashboard_section_target: "chevron" })) %>
          </button>
          <h2 class="text-base font-semibold text-primary dark:text-primary-dark">
            近6个月收支对比
          </h2>
        </div>
        <button
          type="button"
          class="cursor-grab active:cursor-grabbing text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark transition-colors p-0.5 opacity-0 group-hover:opacity-100 hidden lg:block"
          aria-label="<%= t('dashboard.drag_to_reorder') %>">
          <%= render(Ds::IconComponent.new(name: "grip-vertical", size: :sm)) %>
        </button>
      </div>
      
      <div class="p-4" data-dashboard-section-target="content">
        <% has_bar_data = @six_month_bar_data[:income].any? { |v| v > 0 } || @six_month_bar_data[:expense].any? { |v| v > 0 } %>
        <% if has_bar_data %>
          <div data-controller="bar-chart"
               data-bar-chart-labels-value="<%= @six_month_bar_data[:labels].to_json %>"
               data-bar-chart-income-data-value="<%= @six_month_bar_data[:income].to_json %>"
               data-bar-chart-expense-data-value="<%= @six_month_bar_data[:expense].to_json %>"
               class="h-64">
            <canvas data-bar-chart-target="canvas"></canvas>
          </div>
        <% else %>
          <div class="h-64 flex items-center justify-center text-secondary dark:text-secondary-dark">暂无数据</div>
        <% end %>
      </div>
    </section>

    <!-- Net Worth Trend Section -->
    <section
      class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs transition-all group focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2"
      data-dashboard-sortable-target="section"
      data-chart-visibility-target="section"
      data-section-key="net_worth_trend"
      data-controller="dashboard-section"
      data-dashboard-section-section-key-value="net_worth_trend"
      draggable="true"
      tabindex="0"
      role="listitem"
      aria-grabbed="false"
      data-action="
        dragstart->dashboard-sortable#dragStart
        dragend->dashboard-sortable#dragEnd
        touchstart->dashboard-sortable#touchStart
        touchmove->dashboard-sortable#touchMove
        touchend->dashboard-sortable#touchEnd
        keydown->dashboard-sortable#handleKeyDown">
      
      <div class="px-4 py-3 flex items-center justify-between border-b border-border dark:border-border-dark">
        <div class="flex items-center gap-2">
          <button
            type="button"
            class="text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark transition-colors p-0.5"
            data-action="click->dashboard-section#toggle keydown->dashboard-section#handleToggleKeydown"
            data-dashboard-section-target="button"
            aria-label="<%= t('dashboard.toggle_section') %>"
            aria-expanded="true">
            <%= render(Ds::IconComponent.new(name: "chevron-down", size: :sm, class: "transition-transform", data: { dashboard_section_target: "chevron" })) %>
          </button>
          <h2 class="text-base font-semibold text-primary dark:text-primary-dark">
            净资产走势
          </h2>
        </div>
        <button
          type="button"
          class="cursor-grab active:cursor-grabbing text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark transition-colors p-0.5 opacity-0 group-hover:opacity-100 hidden lg:block"
          aria-label="<%= t('dashboard.drag_to_reorder') %>">
          <%= render(Ds::IconComponent.new(name: "grip-vertical", size: :sm)) %>
        </button>
      </div>
      
      <div class="p-4" data-dashboard-section-target="content">
        <% has_net_worth_data = @net_worth_trend_data[:net_worth].any? { |v| v != 0 } %>
        <% if has_net_worth_data %>
          <div data-controller="net-worth-trend"
               data-net-worth-trend-labels-value="<%= @net_worth_trend_data[:labels].to_json %>"
               data-net-worth-trend-net-worth-data-value="<%= @net_worth_trend_data[:net_worth].to_json %>"
               class="h-64">
            <canvas data-net-worth-trend-target="canvas"></canvas>
          </div>
        <% else %>
          <div class="h-64 flex items-center justify-center text-secondary dark:text-secondary-dark">暂无数据</div>
        <% end %>
      </div>
    </section>
  </div>
</div>
<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h1 class="text-2xl font-bold text-gray-900">Plans</h1>
    <%= link_to "New Plan", new_plan_path, class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
  </div>

  <div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Amount</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Account</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-6 py-3 actions"></th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @plans.each do |plan| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap font-medium"><%= plan.name %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm"><%= plan.account_type %></td>
            <td class="px-6 py-4 whitespace-nowrap text-right font-medium">¥<%= plan.amount.to_s("%.2f") %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm"><%= plan.account&.name || "-" %></td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="px-2 py-1 rounded text-xs <%= plan.active? ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-800" %>">
                <%= plan.active? ? "Active" : "Inactive" %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
              <%= link_to "Edit", edit_plan_path(plan), class: "text-blue-600 hover:text-blue-900" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @plans.empty? %>
      <div class="p-8 text-center text-gray-500">
        No plans yet
      </div>
    <% end %>
  </div>
</div>

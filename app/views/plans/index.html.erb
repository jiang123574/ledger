<% content_for :page_title, t('plans.title') %>

<div class="space-y-4">
  <div class="flex justify-between items-center">
    <h1 class="text-xl font-semibold text-primary dark:text-primary-dark"><%= t('plans.title') %></h1>
    <button onclick="openNewPlanModal()" class="inline-flex items-center justify-center gap-2 font-medium transition-smooth btn-modern focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed px-4 py-1.5 text-sm rounded-lg bg-inverse text-white hover:bg-inverse-hover">
      <%= render(Ds::IconComponent.new(name: "plus", size: :sm)) %>
      <%= t('plans.new_plan') %>
    </button>
  </div>

  <% if @plans.empty? %>
    <div class="bg-container dark:bg-container-dark rounded-lg shadow p-8 text-center">
      <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-surface dark:bg-surface-dark flex items-center justify-center">
        <%= render(Ds::IconComponent.new(name: "calendar", size: :xl, color: :secondary)) %>
      </div>
      <p class="text-secondary dark:text-secondary-dark"><%= t('plans.no_plans_yet') %></p>
      <p class="text-secondary dark:text-secondary-dark text-sm mt-2"><%= t('plans.create_first_hint', default: '创建计划来管理分期还款、定期支出等') %></p>
      <button onclick="openNewPlanModal()" class="inline-flex items-center justify-center gap-2 font-medium transition-smooth btn-modern focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed px-4 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover mt-4">
        <%= t('plans.new_plan') %>
      </button>
    </div>
  <% else %>
    <!-- Active Plans -->
    <% if @active_plans.any? %>
      <div class="space-y-3">
        <h2 class="text-base font-semibold text-primary dark:text-primary-dark"><%= t('plans.in_progress', default: '进行中的计划') %></h2>
        <div class="grid gap-3">
          <% @active_plans.each do |plan| %>
            <div class="bg-container dark:bg-container-dark rounded-lg shadow p-3 border-l-4 <%= plan.type == Plan::INSTALLMENT ? 'border-inverse' : 'border-green-500' %>">
              <div class="flex justify-between items-start">
                <div class="flex-1">
                  <div class="flex items-center gap-2">
                    <h3 class="font-semibold text-primary dark:text-primary-dark"><%= plan.name %></h3>
                    <span class="px-2 py-0.5 text-xs rounded-full <%= plan.type == Plan::INSTALLMENT ? 'bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark' : 'bg-green-100 text-green-700' %>">
                      <%= plan.type == Plan::INSTALLMENT ? t('plans.installment') : t('plans.recurring') %>
                    </span>
                  </div>

                  <div class="mt-2 text-sm text-secondary dark:text-secondary-dark">
                    <span class="font-medium"><%= t('plans.amount') %>:</span>
                    <%= format_currency(plan.amount, plan.currency || 'CNY') %>
                    <% if plan.type == Plan::INSTALLMENT %>
                      <span class="text-secondary dark:text-secondary-dark">/期 (<%= t('plans.total', default: '总') %>: <%= format_currency(plan.total_amount, plan.currency || 'CNY') %>)</span>
                    <% end %>
                    <span class="ml-4"><span class="font-medium"><%= t('plans.account') %>:</span> <%= plan.account&.name || '-' %></span>
                    <span class="ml-4"><span class="font-medium"><%= t('plans.day_of_month') %>:</span> <%= plan.day_of_month %><%= t('plans.day', default: '日') %></span>
                  </div>

                  <% if plan.type == Plan::INSTALLMENT %>
                    <div class="mt-3">
                      <div class="flex justify-between text-sm text-secondary dark:text-secondary-dark mb-1">
                        <span><%= t('plans.progress', default: '进度') %>: <%= plan.installments_completed %> / <%= plan.installments_total %> <%= t('plans.periods', default: '期') %></span>
                        <span><%= plan.progress_percentage %>%</span>
                      </div>
                      <div class="w-full bg-surface dark:bg-surface-dark rounded-full h-2">
                        <div class="bg-inverse h-2 rounded-full transition-all" style="width: <%= plan.progress_percentage %>%"></div>
                      </div>
                      <div class="text-xs text-secondary dark:text-secondary-dark mt-1">
                        <%= t('plans.remaining_periods', default: '剩余') %> <%= plan.installments_remaining %> <%= t('plans.periods', default: '期') %>，<%= t('plans.about', default: '约') %> <%= format_currency(plan.amount * plan.installments_remaining, plan.currency || 'CNY') %>
                      </div>
                    </div>
                  <% end %>
                </div>

                <div class="flex items-center gap-2">
                  <% if plan.type == Plan::INSTALLMENT && !plan.completed? %>
                    <%= button_to t('plans.execute', default: '执行'), execute_plan_path(plan), method: :post, class: "px-3 py-1.5 text-sm font-medium rounded-lg bg-green-600 text-white hover:bg-green-700 transition-smooth btn-modern" %>
                  <% elsif plan.type != Plan::INSTALLMENT %>
                    <%= button_to t('plans.execute', default: '执行'), execute_plan_path(plan), method: :post, class: "px-3 py-1.5 text-sm font-medium rounded-lg bg-green-600 text-white hover:bg-green-700 transition-smooth btn-modern" %>
                  <% end %>
                  <button onclick="openEditPlanModal(<%= plan.id %>, '<%= j plan.name %>', '<%= plan.type %>', '<%= plan.account_id %>', '<%= plan.amount %>', '<%= plan.total_amount || '' %>', '<%= plan.installments_total || '' %>', '<%= plan.day_of_month %>', '<%= plan.currency || 'CNY' %>', <%= plan.active %>)" class="px-3 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth btn-modern">
                    <%= t('common.edit') %>
                  </button>
                  <%= button_to t('common.delete'), plan_path(plan), method: :delete, onclick: "if(!confirm('确定删除此计划？')) return false", class: "px-3 py-1.5 text-sm font-medium rounded-lg bg-red-100 text-red-600 hover:bg-red-200 transition-smooth btn-modern" %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Completed Plans -->
    <% if @completed_plans.any? %>
      <div class="space-y-3">
        <h2 class="text-base font-semibold text-secondary dark:text-secondary-dark"><%= t('plans.completed_inactive', default: '已完成/已停用') %></h2>
        <div class="grid gap-3">
          <% @completed_plans.each do |plan| %>
            <div class="bg-surface-inset dark:bg-surface-dark-inset rounded-lg p-3 border-l-4 border-border dark:border-border-dark opacity-75">
              <div class="flex justify-between items-center">
                <div>
                  <div class="flex items-center gap-2">
                    <h3 class="font-semibold text-secondary dark:text-secondary-dark"><%= plan.name %></h3>
                    <span class="px-2 py-0.5 text-xs rounded-full bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark">
                      <%= plan.type == Plan::INSTALLMENT ? t('plans.installment') : t('plans.recurring') %>
                    </span>
                    <% if plan.type == Plan::INSTALLMENT && plan.completed? %>
                      <span class="px-2 py-0.5 text-xs rounded-full bg-green-100 text-green-700">✓ <%= t('plans.completed', default: '已完成') %></span>
                    <% end %>
                  </div>
                  <div class="mt-1 text-sm text-secondary dark:text-secondary-dark">
                    <%= format_currency(plan.amount, plan.currency || 'CNY') %> - <%= plan.account&.name || '-' %>
                  </div>
                </div>
                <div class="flex items-center gap-2">
                  <%= button_to t('plans.activate', default: '启用'), plan_path(plan, plan: { active: true }), method: :patch, class: "px-3 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth btn-modern" %>
                  <%= button_to t('common.delete'), plan_path(plan), method: :delete, onclick: "if(!confirm('确定删除此计划？')) return false", class: "px-3 py-1.5 text-sm font-medium rounded-lg bg-red-100 text-red-600 hover:bg-red-200 transition-smooth btn-modern" %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>

<!-- 新建计划弹窗 -->
<div id="new-plan-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('new-plan-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-xl shadow-xl w-full max-w-2xl p-4 max-h-[90vh] overflow-y-auto">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-base font-semibold text-primary dark:text-primary-dark">新建计划</h3>
        <button type="button" onclick="document.getElementById('new-plan-modal').classList.add('hidden')" class="p-1 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <form id="new-plan-form" method="post" action="<%= plans_path %>">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <div class="space-y-5">
          <!-- Plan Type -->
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-2">计划类型</label>
            <div class="grid grid-cols-2 gap-4">
              <label class="plan-type-label relative flex items-center justify-center p-4 border-2 rounded-lg cursor-pointer hover:bg-surface-inset dark:hover:bg-surface-dark-inset border-border dark:border-border-dark" data-type="INSTALLMENT">
                <input type="radio" name="plan[type]" value="INSTALLMENT" class="sr-only">
                <div class="text-center">
                  <div class="text-2xl mb-1">💳</div>
                  <div class="font-medium text-primary dark:text-primary-dark text-sm">分期还款</div>
                  <div class="text-xs text-secondary dark:text-secondary-dark">信用卡分期等</div>
                </div>
              </label>
              <label class="plan-type-label relative flex items-center justify-center p-4 border-2 rounded-lg cursor-pointer hover:bg-surface-inset dark:hover:bg-surface-dark-inset border-inverse bg-surface dark:bg-surface-dark" data-type="RECURRING">
                <input type="radio" name="plan[type]" value="RECURRING" class="sr-only" checked>
                <div class="text-center">
                  <div class="text-2xl mb-1">🔄</div>
                  <div class="font-medium text-primary dark:text-primary-dark text-sm">周期支出</div>
                  <div class="text-xs text-secondary dark:text-secondary-dark">房租、订阅等</div>
                </div>
              </label>
            </div>
          </div>

          <!-- Basic Info -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">计划名称</label>
              <input type="text" name="plan[name]" required class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" placeholder="例如: 花呗分期">
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">关联账户</label>
              <select name="plan[account_id]" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
                <option value="">选择账户...</option>
                <% @accounts.each do |account| %>
                  <option value="<%= account.id %>"><%= account.name %></option>
                <% end %>
              </select>
            </div>
          </div>

          <!-- Amount Section -->
          <div id="installment-fields" class="hidden space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div class="md:col-span-2">
                <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">总金额</label>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
                  <input type="number" id="new-plan-total-amount" name="plan[total_amount]" step="0.01" class="w-full pl-8 pr-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" placeholder="0.00">
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">期数</label>
                <input type="number" id="new-plan-installments" name="plan[installments_total]" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" placeholder="12">
              </div>
            </div>
            <div class="bg-surface-inset dark:bg-surface-dark-inset rounded-lg p-3 text-sm text-primary dark:text-primary-dark">
              💡 每期还款: <span id="new-per-installment" class="font-semibold">¥0.00</span>
            </div>
            <input type="hidden" id="new-plan-amount" name="plan[amount]">
          </div>

          <div id="amount-field">
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">金额</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
              <input type="number" name="plan[amount]" step="0.01" class="w-full pl-8 pr-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500" placeholder="0.00">
            </div>
          </div>

          <!-- Day of Month -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">每月执行日</label>
              <select name="plan[day_of_month]" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
                <% (1..31).each do |d| %>
                  <option value="<%= d %>"><%= d %>日</option>
                <% end %>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">货币</label>
              <select name="plan[currency]" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
                <option value="CNY">CNY</option>
                <option value="USD">USD</option>
                <option value="EUR">EUR</option>
                <option value="JPY">JPY</option>
                <option value="GBP">GBP</option>
              </select>
            </div>
          </div>

          <!-- Active Status -->
          <div class="flex items-center gap-2">
            <input type="checkbox" name="plan[active]" id="new-plan-active" checked class="h-4 w-4 text-primary dark:text-primary-dark focus:ring-blue-500 border-border dark:border-border-dark rounded">
            <label for="new-plan-active" class="text-sm text-primary dark:text-primary-dark">启用计划</label>
          </div>
        </div>
        <div class="flex justify-end gap-3 mt-5 pt-4 border-t border-border dark:border-border-dark">
          <button type="button" onclick="document.getElementById('new-plan-modal').classList.add('hidden')" class="px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">取消</button>
          <button type="submit" class="px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">创建计划</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- 编辑计划弹窗 -->
<div id="edit-plan-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('edit-plan-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-xl shadow-xl w-full max-w-2xl p-4 max-h-[90vh] overflow-y-auto">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-base font-semibold text-primary dark:text-primary-dark">编辑计划</h3>
        <button type="button" onclick="document.getElementById('edit-plan-modal').classList.add('hidden')" class="p-1 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <form id="edit-plan-form" method="post">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <input type="hidden" name="_method" value="patch">
        <div class="space-y-5">
          <!-- Plan Type (readonly display) -->
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-2">计划类型</label>
            <div id="edit-plan-type-display" class="p-4 border border-border dark:border-border-dark rounded-lg bg-surface-inset dark:bg-surface-dark-inset text-primary dark:text-primary-dark"></div>
          </div>

          <!-- Basic Info -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">计划名称</label>
              <input type="text" id="edit-plan-name" name="plan[name]" required class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">关联账户</label>
              <select id="edit-plan-account" name="plan[account_id]" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
                <option value="">选择账户...</option>
                <% @accounts.each do |account| %>
                  <option value="<%= account.id %>"><%= account.name %></option>
                <% end %>
              </select>
            </div>
          </div>

          <!-- Amount Section -->
          <div id="edit-installment-fields" class="hidden space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div class="md:col-span-2">
                <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">总金额</label>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
                  <input type="number" id="edit-plan-total-amount" name="plan[total_amount]" step="0.01" class="w-full pl-8 pr-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">期数</label>
                <input type="number" id="edit-plan-installments" name="plan[installments_total]" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
              </div>
            </div>
            <div class="bg-surface-inset dark:bg-surface-dark-inset rounded-lg p-3 text-sm text-primary dark:text-primary-dark">
              💡 每期还款: <span id="edit-per-installment" class="font-semibold">¥0.00</span>
            </div>
            <input type="hidden" id="edit-plan-amount-hidden" name="plan[amount]">
          </div>

          <div id="edit-amount-field">
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">金额</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
              <input type="number" id="edit-plan-amount" name="plan[amount]" step="0.01" class="w-full pl-8 pr-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
            </div>
          </div>

          <!-- Day of Month -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">每月执行日</label>
              <select id="edit-plan-day" name="plan[day_of_month]" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
                <% (1..31).each do |d| %>
                  <option value="<%= d %>"><%= d %>日</option>
                <% end %>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">货币</label>
              <select id="edit-plan-currency" name="plan[currency]" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
                <option value="CNY">CNY</option>
                <option value="USD">USD</option>
                <option value="EUR">EUR</option>
                <option value="JPY">JPY</option>
                <option value="GBP">GBP</option>
              </select>
            </div>
          </div>

          <!-- Active Status -->
          <div class="flex items-center gap-2">
            <input type="checkbox" id="edit-plan-active" name="plan[active]" class="h-4 w-4 text-primary dark:text-primary-dark focus:ring-blue-500 border-border dark:border-border-dark rounded">
            <label for="edit-plan-active" class="text-sm text-primary dark:text-primary-dark">启用计划</label>
          </div>
        </div>
        <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-border dark:border-border-dark">
          <button type="button" onclick="document.getElementById('edit-plan-modal').classList.add('hidden')" class="px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">取消</button>
          <button type="submit" class="px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">保存</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  // Plan type labels
  document.querySelectorAll('.plan-type-label').forEach(label => {
    label.addEventListener('click', function() {
      document.querySelectorAll('.plan-type-label').forEach(l => {
        l.classList.remove('border-inverse', 'bg-surface', 'dark:bg-surface-dark')
        l.classList.add('border-border', 'dark:border-border-dark')
      })
      this.classList.remove('border-border', 'dark:border-border-dark')
      this.classList.add('border-inverse', 'bg-surface', 'dark:bg-surface-dark')
      
      const type = this.dataset.type
      const installmentFields = document.getElementById('installment-fields')
      const amountField = document.getElementById('amount-field')
      
      if (type === 'INSTALLMENT') {
        installmentFields.classList.remove('hidden')
        amountField.classList.add('hidden')
      } else {
        installmentFields.classList.add('hidden')
        amountField.classList.remove('hidden')
      }
    })
  })

  // Calculate per installment
  function calculatePerInstallment(totalId, installmentsId, displayId, amountId) {
    const total = parseFloat(document.getElementById(totalId)?.value) || 0
    const installments = parseInt(document.getElementById(installmentsId)?.value) || 1
    const perInstallment = total / installments
    
    const display = document.getElementById(displayId)
    if (display) display.textContent = '¥' + perInstallment.toFixed(2)
    
    const amount = document.getElementById(amountId)
    if (amount) amount.value = perInstallment.toFixed(2)
  }

  document.getElementById('new-plan-total-amount')?.addEventListener('input', () => {
    calculatePerInstallment('new-plan-total-amount', 'new-plan-installments', 'new-per-installment', 'new-plan-amount')
  })
  document.getElementById('new-plan-installments')?.addEventListener('input', () => {
    calculatePerInstallment('new-plan-total-amount', 'new-plan-installments', 'new-per-installment', 'new-plan-amount')
  })

  document.getElementById('edit-plan-total-amount')?.addEventListener('input', () => {
    calculatePerInstallment('edit-plan-total-amount', 'edit-plan-installments', 'edit-per-installment', 'edit-plan-amount-hidden')
  })
  document.getElementById('edit-plan-installments')?.addEventListener('input', () => {
    calculatePerInstallment('edit-plan-total-amount', 'edit-plan-installments', 'edit-per-installment', 'edit-plan-amount-hidden')
  })

  function openNewPlanModal() {
    document.getElementById('new-plan-modal').classList.remove('hidden')
  }

  function openEditPlanModal(id, name, type, accountId, amount, totalAmount, installments, dayOfMonth, currency, active) {
    const form = document.getElementById('edit-plan-form')
    form.action = '/plans/' + id
    
    // Set type display
    const typeLabels = { 'INSTALLMENT': '💳 分期还款', 'RECURRING': '🔄 周期支出', 'ONE_TIME': '🔄 周期支出' }
    document.getElementById('edit-plan-type-display').textContent = typeLabels[type] || type
    
    // Set fields
    document.getElementById('edit-plan-name').value = name
    document.getElementById('edit-plan-account').value = accountId
    document.getElementById('edit-plan-day').value = dayOfMonth
    document.getElementById('edit-plan-currency').value = currency
    document.getElementById('edit-plan-active').checked = active
    
    const installmentFields = document.getElementById('edit-installment-fields')
    const amountField = document.getElementById('edit-amount-field')
    
    if (type === 'INSTALLMENT') {
      installmentFields.classList.remove('hidden')
      amountField.classList.add('hidden')
      document.getElementById('edit-plan-total-amount').value = totalAmount
      document.getElementById('edit-plan-installments').value = installments
      calculatePerInstallment('edit-plan-total-amount', 'edit-plan-installments', 'edit-per-installment', 'edit-plan-amount-hidden')
    } else {
      installmentFields.classList.add('hidden')
      amountField.classList.remove('hidden')
      document.getElementById('edit-plan-amount').value = amount
    }
    
    document.getElementById('edit-plan-modal').classList.remove('hidden')
  }
</script>

<div class="space-y-6">
  <h1 class="text-2xl font-bold text-gray-900"><%= t("plans.new_plan") %></h1>

  <div class="bg-white rounded-lg shadow p-6">
    <%= form_with model: @plan, local: true, class: "space-y-4" do |f| %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <%= f.label :name, t("accounts.name"), class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_field :name, class: "mt-1 block w-full border rounded-md px-3 py-2" %>
        </div>

        <div>
          <%= f.label :account_type, t("transactions.type"), class: "block text-sm font-medium text-gray-700" %>
          <%= f.select :account_type, options_for_select(["INCOME", "EXPENSE"]), {}, class: "mt-1 block w-full border rounded-md px-3 py-2" %>
        </div>

        <div>
          <%= f.label :amount, t("transactions.amount"), class: "block text-sm font-medium text-gray-700" %>
          <%= f.number_field :amount, step: "0.01", class: "mt-1 block w-full border rounded-md px-3 py-2" %>
        </div>

        <div>
          <%= f.label :account_id, t("transactions.account"), class: "block text-sm font-medium text-gray-700" %>
          <%= f.collection_select :account_id, @accounts, :id, :name, { include_blank: true }, class: "mt-1 block w-full border rounded-md px-3 py-2" %>
        </div>

        <div>
          <%= f.label :day_of_month, t("plans.day_of_month"), class: "block text-sm font-medium text-gray-700" %>
          <%= f.number_field :day_of_month, in: 1..31, class: "mt-1 block w-full border rounded-md px-3 py-2" %>
        </div>
      </div>

      <div class="flex justify-end space-x-4">
        <%= link_to t("common.cancel"), plans_path, class: "px-4 py-2 border rounded-md hover:bg-gray-50" %>
        <%= f.submit t("common.create"), class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
      </div>
    <% end %>
  </div>
</div>

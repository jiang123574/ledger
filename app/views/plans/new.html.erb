<div class="space-y-6">
  <div class="flex items-center gap-4">
    <%= link_to "← 返回", plans_path, class: "text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark" %>
    <h1 class="text-2xl font-bold text-primary dark:text-primary-dark">新建计划</h1>
  </div>

  <div class="bg-container dark:bg-container-dark rounded-lg shadow p-6 max-w-2xl">
    <%= form_with model: @plan, local: true, class: "space-y-6" do |f| %>
      <% if @plan.errors.any? %>
        <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 px-4 py-3 rounded">
          <ul class="list-disc list-inside">
            <% @plan.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <!-- Plan Type -->
      <div>
        <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-2">计划类型</label>
        <div class="grid grid-cols-3 gap-4">
          <label class="relative flex items-center justify-center p-4 border-2 rounded-lg cursor-pointer hover:bg-surface-inset dark:hover:bg-surface-dark-inset <%= @plan.type == 'ONE_TIME' ? 'border-inverse bg-surface dark:bg-surface-dark' : 'border-border dark:border-border-dark' %>">
            <%= f.radio_button :type, 'ONE_TIME', class: "sr-only" %>
            <div class="text-center">
              <div class="text-2xl mb-1">📌</div>
              <div class="font-medium text-primary dark:text-primary-dark">一次性</div>
              <div class="text-xs text-secondary dark:text-secondary-dark">单次支出计划</div>
            </div>
          </label>
          <label class="relative flex items-center justify-center p-4 border-2 rounded-lg cursor-pointer hover:bg-surface-inset dark:hover:bg-surface-dark-inset <%= @plan.type == 'INSTALLMENT' ? 'border-inverse bg-surface dark:bg-surface-dark' : 'border-border dark:border-border-dark' %>">
            <%= f.radio_button :type, 'INSTALLMENT', class: "sr-only" %>
            <div class="text-center">
              <div class="text-2xl mb-1">💳</div>
              <div class="font-medium text-primary dark:text-primary-dark">分期还款</div>
              <div class="text-xs text-secondary dark:text-secondary-dark">信用卡分期等</div>
            </div>
          </label>
          <label class="relative flex items-center justify-center p-4 border-2 rounded-lg cursor-pointer hover:bg-surface-inset dark:hover:bg-surface-dark-inset <%= @plan.type == 'RECURRING' ? 'border-inverse bg-surface dark:bg-surface-dark' : 'border-border dark:border-border-dark' %>">
            <%= f.radio_button :type, 'RECURRING', class: "sr-only" %>
            <div class="text-center">
              <div class="text-2xl mb-1">🔄</div>
              <div class="font-medium text-primary dark:text-primary-dark">周期支出</div>
              <div class="text-xs text-secondary dark:text-secondary-dark">房租、订阅等</div>
            </div>
          </label>
        </div>
      </div>

      <!-- Basic Info -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">计划名称</label>
          <%= render Ds::InputComponent.new(form: f, field: :name, placeholder: "例如: 花呗分期") %>
        </div>

        <div>
          <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">关联账户</label>
          <%= render Ds::InputComponent.new(form: f, field: :account_id, type: :select, 
                choices: @accounts.map { |a| [a.name, a.id] },
                include_blank: "选择账户...") %>
        </div>
      </div>

      <!-- Amount Section -->
      <div class="space-y-4">
        <% if @plan.type == 'INSTALLMENT' %>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">总金额</label>
              <%= render Ds::InputComponent.new(form: f, field: :total_amount, type: :number, 
                    placeholder: "0.00", prefix: "¥") %>
            </div>

            <div>
              <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">期数</label>
              <%= render Ds::InputComponent.new(form: f, field: :installments_total, type: :number, placeholder: "12") %>
            </div>
          </div>

          <div class="bg-surface-inset dark:bg-surface-dark-inset rounded-lg p-3 text-sm text-primary dark:text-primary-dark">
            💡 每期还款: <span id="per-installment" class="font-semibold">¥0.00</span>
          </div>

          <%= f.hidden_field :amount %>
        <% else %>
          <div>
            <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">金额</label>
            <%= render Ds::InputComponent.new(form: f, field: :amount, type: :number, 
                  placeholder: "0.00", prefix: "¥") %>
          </div>
        <% end %>
      </div>

      <!-- Day of Month -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">每月还款日</label>
          <%= render Ds::InputComponent.new(form: f, field: :day_of_month, type: :select,
                choices: (1..31).to_a.map { |d| ["#{d}日", d] },
                include_blank: false) %>
        </div>

        <div>
          <label class="block text-sm font-medium text-primary dark:text-primary-dark mb-1.5">货币</label>
          <%= render Ds::InputComponent.new(form: f, field: :currency, type: :select,
                choices: ['CNY', 'USD', 'EUR', 'JPY', 'GBP'],
                include_blank: false) %>
        </div>
      </div>

      <!-- Active Status -->
      <div class="flex items-center gap-2">
        <%= f.check_box :active, class: "h-4 w-4 text-primary dark:text-primary-dark focus:ring-blue-500 border-border dark:border-border-dark rounded" %>
        <%= f.label :active, "启用计划", class: "text-sm text-primary dark:text-primary-dark" %>
      </div>

      <div class="flex justify-end gap-3 pt-4 border-t border-border dark:border-border-dark">
        <%= link_to "取消", plans_path, class: "px-4 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth btn-modern" %>
        <%= f.submit "创建计划", class: "px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover dark:hover:bg-inverse-dark-hover transition-smooth btn-modern" %>
      </div>
    <% end %>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const typeInputs = document.querySelectorAll('input[name="plan[type]"]');
  const totalAmountInput = document.getElementById('plan_total_amount');
  const installmentsInput = document.getElementById('plan_installments_total');
  const amountInput = document.getElementById('plan_amount');
  const perInstallmentSpan = document.getElementById('per-installment');

  function updatePerInstallment() {
    const total = parseFloat(totalAmountInput?.value) || 0;
    const installments = parseInt(installmentsInput?.value) || 1;
    const perInstallment = total / installments;
    
    if (perInstallmentSpan) {
      perInstallmentSpan.textContent = '¥' + perInstallment.toFixed(2);
    }
    if (amountInput) {
      amountInput.value = perInstallment.toFixed(2);
    }
  }

  if (totalAmountInput) {
    totalAmountInput.addEventListener('input', updatePerInstallment);
  }
  if (installmentsInput) {
    installmentsInput.addEventListener('input', updatePerInstallment);
  }

  // Style radio buttons on change
  typeInputs.forEach(input => {
    input.addEventListener('change', function() {
      document.querySelectorAll('input[name="plan[type]"]').forEach(radio => {
        radio.closest('label').classList.remove('border-inverse', 'bg-surface dark:bg-surface-dark');
        radio.closest('label').classList.add('border-border dark:border-border-dark');
      });
      this.closest('label').classList.remove('border-border dark:border-border-dark');
      this.closest('label').classList.add('border-inverse', 'bg-surface dark:bg-surface-dark');
    });
  });
});
</script>

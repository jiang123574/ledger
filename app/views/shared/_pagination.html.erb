<%#
  Simple pagination partial
  Usage: render "shared/pagination", pagy: @pagy
%>

<% if defined?(pagy) && pagy %>
  <nav class="flex items-center justify-between">
    <div class="text-sm text-secondary dark:text-secondary dark:text-secondary-dark">
      共 <%= pagy.count %> 条
    </div>
    <div class="flex items-center gap-1">
      <% if pagy.prev %>
        <%= link_to "上一页", pagy_url_for(pagy, pagy.prev), 
            class: "px-3 py-1.5 text-sm rounded-lg hover:bg-surface-inset text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark transition-smooth" %>
      <% else %>
        <span class="px-3 py-1.5 text-sm rounded-lg text-gray-300 cursor-not-allowed">上一页</span>
      <% end %>

      <% pagy.series.each do |item| %>
        <% if item.is_a?(Integer) %>
          <%= link_to item, pagy_url_for(pagy, item), 
              class: "px-3 py-1.5 text-sm rounded-lg hover:bg-surface-inset text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark transition-smooth #{pagy.page == item ? 'bg-surface dark:bg-surface-dark dark:bg-surface-dark text-primary dark:text-primary-dark dark:text-secondary dark:text-secondary dark:text-secondary-dark' : ''}" %>
        <% elsif item == :gap %>
          <span class="px-2 text-secondary dark:text-secondary dark:text-secondary-dark">...</span>
        <% end %>
      <% end %>

      <% if pagy.next %>
        <%= link_to "下一页", pagy_url_for(pagy, pagy.next), 
            class: "px-3 py-1.5 text-sm rounded-lg hover:bg-surface-inset text-secondary dark:text-secondary-dark hover:text-primary dark:text-primary-dark transition-smooth" %>
      <% else %>
        <span class="px-3 py-1.5 text-sm rounded-lg text-gray-300 cursor-not-allowed">下一页</span>
      <% end %>
    </div>
  </nav>
<% end %>

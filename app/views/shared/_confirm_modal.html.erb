<!-- 通用确认弹窗 -->
<!-- 使用 window.showConfirmDialog({ title, content, confirmText, cancelText, danger }) 调用 -->
<div id="confirm-modal"
     class="hidden fixed inset-0 z-50 overflow-y-auto"
     data-controller="confirm-modal"
     data-confirm-modal-target="modal"
     data-confirm-modal-title-value="确认操作"
     data-confirm-modal-confirm-text-value="确认"
     data-confirm-modal-cancel-text-value="取消">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50 modal-overlay-bg" data-action="click->confirm-modal#closeOnBackground"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-lg shadow-xl w-full max-w-sm p-5 z-10">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-primary dark:text-primary-dark" data-confirm-modal-target="title">确认操作</h3>
        <button type="button" data-action="click->confirm-modal#cancel" class="inline-flex items-center justify-center p-2 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      <p class="text-sm text-secondary dark:text-secondary-dark mb-6" data-confirm-modal-target="content"></p>
      <div class="flex justify-end gap-3">
        <button type="button" data-action="click->confirm-modal#cancel" class="px-4 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover transition-smooth" data-confirm-modal-target="cancelBtn">取消</button>
        <button type="button" data-action="click->confirm-modal#confirm" class="px-4 py-2 text-sm font-medium rounded-lg bg-expense text-white hover:bg-expense-dark transition-smooth" data-confirm-modal-target="confirmBtn">确认</button>
      </div>
    </div>
  </div>
</div>
<% content_for :page_title, "应付款" %>

<div class="space-y-4 sm:space-y-6">
  <div class="flex flex-col gap-3 sm:flex-row sm:justify-between sm:items-center sm:gap-4">
    <div>
      <h1 class="text-xl sm:text-2xl font-semibold text-primary dark:text-primary-dark">应付款</h1>
      <p class="text-xs sm:text-sm text-secondary dark:text-secondary-dark mt-0.5 sm:mt-1">追踪待付款与已付款款项</p>
    </div>
    <button type="button" onclick="openNewPayableModal()" class="inline-flex items-center justify-center gap-2 font-medium transition-smooth btn-modern focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed px-4 py-1.5 text-sm rounded-lg bg-inverse text-white hover:bg-inverse-hover">
      <%= render(Ds::IconComponent.new(name: "plus", size: :sm)) %>
      新建应付款
    </button>
  </div>

  <% total_amount = @payables.sum { |r| r.original_amount.to_d } %>
  <% pending_amount = @unsettled.sum { |r| r.remaining_amount.to_d } %>
  <% reimbursed_amount = @payables.sum { |r| (r.original_amount.to_d - r.remaining_amount.to_d) } %>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
    <%= render(Ds::CardComponent.new(padding: false, rounded: :xl, class: "p-3")) do %>
      <p class="text-xs sm:text-sm font-medium text-secondary dark:text-secondary-dark">应付总额</p>
      <p class="text-lg sm:text-2xl font-semibold text-primary dark:text-primary-dark mt-0.5 sm:mt-1"><%= format_currency(total_amount) %></p>
    <% end %>
    <%= render(Ds::CardComponent.new(padding: false, rounded: :xl, class: "p-3")) do %>
      <p class="text-xs sm:text-sm font-medium text-secondary dark:text-secondary-dark">待付款金额</p>
      <p class="text-lg sm:text-2xl font-semibold text-expense mt-0.5 sm:mt-1"><%= format_currency(pending_amount) %></p>
    <% end %>
    <%= render(Ds::CardComponent.new(padding: false, rounded: :xl, class: "p-3")) do %>
      <p class="text-xs sm:text-sm font-medium text-secondary dark:text-secondary-dark">已付款金额</p>
      <p class="text-lg sm:text-2xl font-semibold text-income mt-0.5 sm:mt-1"><%= format_currency(reimbursed_amount) %></p>
    <% end %>
  </div>

  <% if @unsettled_counterparty_stats.any? %>
    <section class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs p-3">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-sm font-semibold text-primary dark:text-primary-dark">待付款按联系人</h2>
        <span class="text-xs text-secondary dark:text-secondary-dark">Top <%= @unsettled_counterparty_stats.size %></span>
      </div>
      <div class="flex gap-2 overflow-x-auto pb-1">
        <%= link_to payables_path, class: "shrink-0 min-w-[140px] px-3 py-2 rounded-lg border #{ @selected_counterparty_id.blank? ? 'bg-blue-50 dark:bg-blue-900/20 border-blue-200 dark:border-blue-800' : 'bg-surface dark:bg-surface-dark border-border dark:border-border-dark' }" do %>
          <p class="text-sm font-medium text-primary dark:text-primary-dark">全部联系人</p>
          <p class="text-xs text-secondary dark:text-secondary-dark mt-0.5"><%= @unsettled.size %> 条待付款</p>
          <p class="text-sm font-semibold text-expense mt-1"><%= format_currency(@unsettled.sum { |r| r.remaining_amount.to_d }) %></p>
        <% end %>
        <% @unsettled_counterparty_stats.each do |item| %>
          <%= link_to payables_path(counterparty_id: item[:filter_value], anchor: "unsettled-payables"), class: "shrink-0 min-w-[170px] px-3 py-2 rounded-lg border #{ @selected_counterparty_id.to_s == item[:filter_value].to_s ? 'bg-blue-50 dark:bg-blue-900/20 border-blue-200 dark:border-blue-800' : 'bg-surface dark:bg-surface-dark border-border dark:border-border-dark' }" do %>
            <p class="text-sm font-medium text-primary dark:text-primary-dark truncate"><%= item[:name] %></p>
            <p class="text-xs text-secondary dark:text-secondary-dark mt-0.5"><%= item[:count] %> 条待付款</p>
            <p class="text-sm font-semibold text-expense mt-1"><%= format_currency(item[:amount]) %></p>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>

  <section id="unsettled-payables" class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs transition-all group focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2">
    <div class="px-4 py-3 flex items-center justify-between border-b border-border dark:border-border-dark">
      <h2 class="text-base font-semibold text-primary dark:text-primary-dark">待付款</h2>
      <span class="text-xs text-secondary dark:text-secondary-dark"><%= @filtered_unsettled.size %> 条</span>
    </div>
    <div class="px-4 py-2 border-b border-border dark:border-border-dark bg-surface-inset/40 dark:bg-surface-dark-inset/40">
      <form method="get" action="<%= payables_path %>" class="flex items-center gap-2">
        <label for="payable-counterparty-filter" class="text-xs text-secondary dark:text-secondary-dark shrink-0">联系人</label>
        <select id="payable-counterparty-filter" name="counterparty_id" onchange="this.form.submit()" class="w-full sm:w-auto px-2 py-1 text-xs rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark">
          <option value="">全部联系人</option>
          <option value="none" <%= "selected" if @selected_counterparty_id == "none" %>>未设置联系人</option>
          <% @counterparties.each do |c| %>
            <option value="<%= c.id %>" <%= "selected" if [c.id.to_s, "id:#{c.id}"].include?(@selected_counterparty_id.to_s) %>><%= c.name %></option>
          <% end %>
        </select>
      </form>
    </div>
    <div class="divide-y divide-border">
      <% if @filtered_unsettled.any? %>
        <% @filtered_unsettled.each do |payable| %>
          <% reimbursed = payable.original_amount.to_d - payable.remaining_amount.to_d %>
          <div class="px-3 py-3 hover:bg-surface dark:hover:bg-surface-dark transition-smooth">
            <%# Mobile layout %>
            <div class="lg:hidden space-y-2">
              <div class="flex items-start justify-between gap-2">
                <h3 class="font-medium text-sm text-primary dark:text-primary-dark flex-1 min-w-0 truncate"><%= payable.description %></h3>
                <span class="text-expense font-medium text-sm shrink-0">待付 <%= format_currency(payable.remaining_amount) %></span>
              </div>
              <% if payable.source_entry.present? %>
                <p class="text-[10px] text-secondary dark:text-secondary-dark">源交易: <%= payable.source_entry.account&.name %> @ <%= payable.source_entry.date&.strftime("%m/%d") %></p>
              <% end %>
              <div class="flex items-center gap-2 text-[11px] text-secondary dark:text-secondary-dark flex-wrap">
                <span><%= payable.date&.strftime("%Y-%m-%d") %></span>
                <% if payable.category.present? %>
                  <span class="px-1 py-0.5 rounded bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark"><%= payable.category %></span>
                <% end %>
                <% if payable.account.present? %>
                  <span class="truncate"><%= payable.account.name %></span>
                <% end %>
                <span class="text-income">已付 <%= format_currency(reimbursed) %></span>
                <span>总额 <%= format_currency(payable.original_amount) %></span>
              </div>
              <div class="flex items-center gap-2">
                <button type="button" onclick="openSettleModal('<%= payable.id %>', '<%= j payable.description %>', '<%= payable.remaining_amount %>')" class="flex-1 px-3 py-1.5 text-xs font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth btn-modern min-h-[36px]">付款</button>
                <button type="button" onclick="openEditPayableModal('<%= payable.id %>', '<%= j payable.description %>', '<%= payable.date %>', '<%= payable.original_amount %>', '<%= j(payable.category || '') %>', '<%= payable.counterparty_id %>', '<%= payable.account_id %>', '<%= j(payable.note || '') %>')" class="px-3 py-1.5 text-xs font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface dark:hover:bg-surface-dark transition-smooth btn-modern min-h-[36px]">编辑</button>
                <button type="button" onclick="if(confirm('确定删除此付款记录？')) { document.getElementById('delete-payable-form-<%= payable.id %>').submit(); }" class="px-3 py-1.5 text-xs font-medium rounded-lg border border-expense-soft text-expense hover:bg-expense-soft transition-smooth btn-modern min-h-[36px]">删除</button>
                <form id="delete-payable-form-<%= payable.id %>" method="post" action="/payables/<%= payable.id %>" style="display:none">
                  <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
                  <input type="hidden" name="_method" value="delete">
                </form>
              </div>
            </div>
            <%# Desktop layout %>
            <div class="hidden lg:flex items-center gap-2">
              <div class="w-44 shrink-0">
                <h3 class="font-medium text-sm text-primary dark:text-primary-dark truncate"><%= payable.description %></h3>
                <% if payable.source_entry.present? %>
                  <p class="text-[10px] text-secondary dark:text-secondary-dark mt-0.5">
                    源交易: <%= payable.source_entry.account&.name %> @ <%= payable.source_entry.date&.strftime("%m/%d") %>
                  </p>
                <% end %>
              </div>
              <div class="text-[11px] text-secondary dark:text-secondary-dark shrink-0"><%= payable.date&.strftime("%Y-%m-%d") %></div>
              <% if payable.category.present? %>
                <div class="px-1 py-0.5 rounded bg-surface dark:bg-surface-dark text-[11px] text-primary dark:text-primary-dark shrink-0"><%= payable.category %></div>
              <% end %>
              <% if payable.account.present? %>
                <div class="text-[11px] text-secondary dark:text-secondary-dark truncate max-w-28"><%= payable.account.name %></div>
              <% end %>
              <div class="ml-auto flex items-center gap-2 text-[11px] shrink-0">
                <span class="text-secondary dark:text-secondary-dark">总额 <span class="font-medium text-primary dark:text-primary-dark"><%= format_currency(payable.original_amount) %></span></span>
                <span class="text-income">已付 <span class="font-medium"><%= format_currency(reimbursed) %></span></span>
                <span class="text-expense">待付 <span class="font-medium"><%= format_currency(payable.remaining_amount) %></span></span>
              </div>
              <div class="flex items-center gap-1 shrink-0">
                <button type="button" onclick="openSettleModal('<%= payable.id %>', '<%= j payable.description %>', '<%= payable.remaining_amount %>')" class="px-2 py-1 text-xs font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-blue-500 transition-smooth btn-modern">付款</button>
                <button type="button" onclick="openEditPayableModal('<%= payable.id %>', '<%= j payable.description %>', '<%= payable.date %>', '<%= payable.original_amount %>', '<%= j(payable.category || '') %>', '<%= payable.counterparty_id %>', '<%= payable.account_id %>', '<%= j(payable.note || '') %>')" class="px-2 py-1 text-xs font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface dark:hover:bg-surface-dark focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-blue-500 transition-smooth btn-modern">编辑</button>
                <button type="button" onclick="if(confirm('确定删除此付款记录？')) { document.getElementById('delete-payable-form-<%= payable.id %>').submit(); }" class="px-2 py-1 text-xs font-medium rounded-lg border border-expense-soft text-expense hover:bg-expense-soft focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-blue-500 transition-smooth btn-modern">删除</button>
                <form id="delete-payable-form-<%= payable.id %>" method="post" action="/payables/<%= payable.id %>" style="display:none">
                  <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
                  <input type="hidden" name="_method" value="delete">
                </form>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="p-8 text-center">
          <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-surface-inset dark:bg-surface-dark-inset flex items-center justify-center">
            <%= render(Ds::IconComponent.new(name: "receipt", size: :lg, color: :secondary)) %>
          </div>
          <p class="text-secondary dark:text-secondary-dark">暂无待付款记录</p>
        </div>
      <% end %>
    </div>
  </section>

  <section class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs transition-all group focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2">
    <div class="px-4 py-3 flex items-center justify-between border-b border-border dark:border-border-dark">
      <h2 class="text-base font-semibold text-primary dark:text-primary-dark">已完成</h2>
      <span class="text-xs text-secondary dark:text-secondary-dark"><%= @settled.size %> 条</span>
    </div>
    <div class="divide-y divide-border">
      <% if @settled.any? %>
        <% @settled.each do |payable| %>
          <% reimbursed = payable.original_amount.to_d - payable.remaining_amount.to_d %>
          <div class="px-3 py-2 hover:bg-surface dark:hover:bg-surface-dark transition-smooth">
            <div class="flex items-center justify-between gap-2 text-sm">
              <div class="flex-1 min-w-0 flex items-center gap-2">
                <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[11px] font-medium bg-income-soft text-income whitespace-nowrap shrink-0">已完成</span>
                <h3 class="font-medium text-primary dark:text-primary-dark truncate"><%= payable.description %></h3>
                <span class="text-[11px] text-secondary dark:text-secondary-dark shrink-0"><%= payable.settled_at&.strftime("%Y-%m-%d") %></span>
                <% if payable.category.present? %>
                  <span class="px-1 py-0.5 rounded text-[11px] bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark shrink-0"><%= payable.category %></span>
                <% end %>
                <% if payable.counterparty.present? %>
                  <span class="text-[11px] text-secondary dark:text-secondary-dark shrink-0">(<%= payable.counterparty.name %>)</span>
                <% end %>
              </div>
              <div class="flex items-center gap-1 shrink-0 text-[11px]">
                <span class="text-secondary dark:text-secondary-dark">¥<%= format_currency(payable.original_amount, unit: "") %></span>
                <span class="text-income">已付¥<%= format_currency(reimbursed, unit: "") %></span>
              </div>
              <div class="flex items-center gap-1 shrink-0">
                <%= button_to "撤销", revert_payable_path(payable), method: :post, onclick: "if(!confirm('确定撤销此付款？撤销后可重新付款')) return false", class: "px-2 py-1 text-xs font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface dark:hover:bg-surface-dark focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-blue-500 transition-smooth btn-modern" %>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="p-8 text-center">
          <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-surface-inset dark:bg-surface-dark-inset flex items-center justify-center">
            <%= render(Ds::IconComponent.new(name: "check", size: :lg, color: :secondary)) %>
          </div>
          <p class="text-secondary dark:text-secondary-dark">暂无已完成记录</p>
        </div>
      <% end %>
    </div>
  </section>
</div>

<!-- 新建应付款弹窗 -->
<div id="add-payable-modal" class="hidden fixed inset-0 z-50 overflow-y-auto modal-overlay">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('add-payable-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-xl shadow-xl w-full max-w-md p-4">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-base font-semibold text-primary dark:text-primary-dark">新建应付款</h3>
        <button type="button" onclick="document.getElementById('add-payable-modal').classList.add('hidden')" class="p-1 hover:bg-surface dark:hover:bg-surface-dark rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      
      <form id="new-payable-form" method="post" action="<%= payables_path %>">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">描述 *</label>
            <input type="text" name="payable[description]" required placeholder="如：出差北京交通费" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">日期 *</label>
              <input type="date" name="payable[date]" required value="<%= Date.today %>" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">金额 *</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
                <input type="number" name="payable[original_amount]" step="0.01" placeholder="0.00" required class="w-full pl-8 pr-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">类别</label>
            <input type="hidden" name="payable[category]" id="new-payable-category-id" value="">
            <div class="relative">
              <input type="text" id="new-payable-category-search"
                     class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 cursor-pointer"
                     placeholder="选择类别"
                     autocomplete="off"
                     readonly>
              <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-secondary dark:text-secondary-dark pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
              <div id="new-payable-category-dropdown" class="hidden absolute z-50 w-full mt-1 bg-white dark:bg-container-dark rounded-lg border border-border dark:border-border-dark shadow-lg max-h-60 overflow-y-auto">
                <div class="p-2 border-b border-border dark:border-border-dark">
                  <input type="text" id="new-payable-category-filter"
                         class="w-full px-2 py-1 text-sm rounded border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500"
                         placeholder="搜索分类..."
                         autocomplete="off">
                </div>
                <div id="new-payable-category-options" class="py-1"></div>
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">联系人</label>
            <select name="payable[counterparty_id]" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
              <option value="">选择联系人</option>
              <% @counterparties.each do |c| %>
                <option value="<%= c.id %>"><%= c.name %></option>
              <% end %>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">支出账户</label>
            <input type="hidden" name="payable[account_id]" id="new-payable-account-id" value="">
            <div class="relative">
              <input type="text" id="new-payable-account-search"
                     class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 cursor-pointer"
                     placeholder="选择账户"
                     autocomplete="off"
                     readonly>
              <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-secondary dark:text-secondary-dark pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
              <div id="new-payable-account-dropdown" class="hidden absolute z-50 w-full mt-1 bg-white dark:bg-container-dark rounded-lg border border-border dark:border-border-dark shadow-lg max-h-60 overflow-y-auto">
                <div class="p-2 border-b border-border dark:border-border-dark">
                  <input type="text" id="new-payable-account-filter"
                         class="w-full px-2 py-1 text-sm rounded border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500"
                         placeholder="搜索账户..."
                         autocomplete="off">
                </div>
                <div id="new-payable-account-options" class="py-1"></div>
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">备注</label>
            <input type="text" name="payable[note]" placeholder="可选" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
          </div>
        </div>

        <div class="flex justify-end gap-3 mt-5">
          <button type="button" onclick="document.getElementById('add-payable-modal').classList.add('hidden')" class="px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface dark:hover:bg-surface-dark transition-smooth">取消</button>
          <button type="submit" class="px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth">保存</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- 编辑应付款弹窗 -->
<div id="edit-payable-modal" class="hidden fixed inset-0 z-50 overflow-y-auto modal-overlay">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('edit-payable-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-xl shadow-xl w-full max-w-md p-4">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-base font-semibold text-primary dark:text-primary-dark">编辑应付款</h3>
        <button type="button" onclick="document.getElementById('edit-payable-modal').classList.add('hidden')" class="p-1 hover:bg-surface dark:hover:bg-surface-dark rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      
      <form id="edit-payable-form" method="post">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <input type="hidden" name="_method" value="patch">
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">描述 *</label>
            <input type="text" id="edit-payable-description" name="payable[description]" required class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">日期 *</label>
              <input type="date" id="edit-payable-date" name="payable[date]" required class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">金额 *</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
                <input type="number" id="edit-payable-amount" name="payable[original_amount]" step="0.01" required class="w-full pl-8 pr-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">类别</label>
            <input type="hidden" name="payable[category]" id="edit-payable-category-id" value="">
            <div class="relative">
              <input type="text" id="edit-payable-category-search"
                     class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 cursor-pointer"
                     placeholder="选择类别"
                     autocomplete="off"
                     readonly>
              <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-secondary dark:text-secondary-dark pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
              <div id="edit-payable-category-dropdown" class="hidden absolute z-50 w-full mt-1 bg-white dark:bg-container-dark rounded-lg border border-border dark:border-border-dark shadow-lg max-h-60 overflow-y-auto">
                <div class="p-2 border-b border-border dark:border-border-dark">
                  <input type="text" id="edit-payable-category-filter"
                         class="w-full px-2 py-1 text-sm rounded border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500"
                         placeholder="搜索分类..."
                         autocomplete="off">
                </div>
                <div id="edit-payable-category-options" class="py-1"></div>
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">联系人</label>
            <select id="edit-payable-counterparty" name="payable[counterparty_id]" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
              <option value="">选择联系人</option>
              <% @counterparties.each do |c| %>
                <option value="<%= c.id %>"><%= c.name %></option>
              <% end %>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">支出账户</label>
            <input type="hidden" name="payable[account_id]" id="edit-payable-account-id" value="">
            <div class="relative">
              <input type="text" id="edit-payable-account-search"
                     class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 cursor-pointer"
                     placeholder="选择账户"
                     autocomplete="off"
                     readonly>
              <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-secondary dark:text-secondary-dark pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
              <div id="edit-payable-account-dropdown" class="hidden absolute z-50 w-full mt-1 bg-white dark:bg-container-dark rounded-lg border border-border dark:border-border-dark shadow-lg max-h-60 overflow-y-auto">
                <div class="p-2 border-b border-border dark:border-border-dark">
                  <input type="text" id="edit-payable-account-filter"
                         class="w-full px-2 py-1 text-sm rounded border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500"
                         placeholder="搜索账户..."
                         autocomplete="off">
                </div>
                <div id="edit-payable-account-options" class="py-1"></div>
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">备注</label>
            <input type="text" id="edit-payable-note" name="payable[note]" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
          </div>
        </div>

        <div class="flex justify-end gap-3 mt-5">
          <button type="button" onclick="document.getElementById('edit-payable-modal').classList.add('hidden')" class="px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface dark:hover:bg-surface-dark transition-smooth">取消</button>
          <button type="submit" class="px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth">保存</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- 付款应付款弹窗 -->
<div id="settle-payable-modal" class="hidden fixed inset-0 z-50 overflow-y-auto modal-overlay">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('settle-payable-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-xl shadow-xl w-full max-w-md p-4">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-base font-semibold text-primary dark:text-primary-dark">付款应付款</h3>
        <button type="button" onclick="document.getElementById('settle-payable-modal').classList.add('hidden')" class="p-1 hover:bg-surface dark:hover:bg-surface-dark rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      
      <p id="settle-description" class="text-secondary dark:text-secondary-dark mb-4"></p>
      <input type="hidden" id="settle-remaining-amount-payable" value="0">
      
      <form id="settle-form" method="post">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">付款金额 *</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
              <input type="number" name="amount" id="settle-amount-payable" step="0.01" placeholder="0.00" required class="w-full pl-8 pr-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
            </div>
            <button type="button" onclick="setFullAmountPayable()" class="mt-2 text-xs px-2 py-1 rounded bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark hover:bg-surface-inset dark:hover:bg-surface-dark-inset transition-smooth">全额付款</button>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">日期 *</label>
            <input type="date" name="settlement_date" id="settle-date-payable" required class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">账户 *</label>
            <input type="hidden" name="account_id" id="settle-account-id-payable" value="">
            <div class="relative">
              <input type="text" id="settle-account-search-payable"
                     class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 cursor-pointer"
                     placeholder="搜索账户..."
                     autocomplete="off"
                     readonly>
              <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-secondary dark:text-secondary-dark pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
              <div id="settle-account-dropdown-payable" class="hidden absolute z-[60] w-full mt-1 bg-white dark:bg-container-dark rounded-lg border border-border dark:border-border-dark shadow-lg max-h-60 overflow-y-auto">
                <div class="p-2 border-b border-border dark:border-border-dark">
                  <input type="text" id="settle-account-filter-payable"
                         class="w-full px-2 py-1 text-sm rounded border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500"
                         placeholder="搜索账户..."
                         autocomplete="off">
                </div>
                <div id="settle-account-options-payable" class="py-1"></div>
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">备注</label>
            <input type="text" name="note" placeholder="可选" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
          </div>
        </div>

        <div class="flex justify-end gap-3 mt-5">
          <button type="button" onclick="document.getElementById('settle-payable-modal').classList.add('hidden')" class="px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface dark:hover:bg-surface-dark transition-smooth">取消</button>
          <button type="submit" class="px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">确认付款</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script id="payable-accounts-data" type="application/json">
  <%= raw @accounts.map { |a| { id: a.id, name: a.name, pinyin: PinYin.abbr(a.name).downcase } }.to_json %>
</script>
<script id="payable-categories-data" type="application/json">
  <%= raw @expense_categories.map { |c| full_name = c.full_name; { name: c.name, full_name: full_name, pinyin: PinYin.abbr(full_name).downcase } }.to_json %>
</script>
<script type="module">
import { initSelectorWithData } from 'selectors';
function openNewPayableModal() {
  const form = document.getElementById('new-payable-form');
  if (form) {
    form.reset();
    const dateInput = form.querySelector('input[name="payable[date]"]');
    if (dateInput) dateInput.value = '<%= Date.today %>';
  }
  const accountIdInput = document.getElementById('new-payable-account-id');
  const accountSearchInput = document.getElementById('new-payable-account-search');
  if (accountIdInput) accountIdInput.value = '';
  if (accountSearchInput) accountSearchInput.value = '';
  const categoryIdInput = document.getElementById('new-payable-category-id');
  const categorySearchInput = document.getElementById('new-payable-category-search');
  if (categoryIdInput) categoryIdInput.value = '';
  if (categorySearchInput) categorySearchInput.value = '';
  const modal = document.getElementById('add-payable-modal');
  if (modal) modal.classList.remove('hidden');
}

function openEditPayableModal(id, description, date, amount, category, counterpartyId, accountId, note) {
  const form = document.getElementById('edit-payable-form');
  form.action = '/payables/' + id;
  document.getElementById('edit-payable-description').value = description;
  document.getElementById('edit-payable-date').value = date;
  document.getElementById('edit-payable-amount').value = amount;
  const categoryIdInput = document.getElementById('edit-payable-category-id');
  const categorySearchInput = document.getElementById('edit-payable-category-search');
  if (categoryIdInput) categoryIdInput.value = category || '';
  if (categorySearchInput) categorySearchInput.value = category || '';
  document.getElementById('edit-payable-counterparty').value = counterpartyId || '';
  const accountIdInput = document.getElementById('edit-payable-account-id');
  const accountSearchInput = document.getElementById('edit-payable-account-search');
  if (accountIdInput) accountIdInput.value = accountId || '';
  if (accountSearchInput) accountSearchInput.value = findPayableAccountName(accountId) || '';
  document.getElementById('edit-payable-note').value = note;
  document.getElementById('edit-payable-modal').classList.remove('hidden');
}

function openSettleModal(id, description, remainingAmount) {
  document.getElementById('settle-description').textContent = description + ' (剩余: ¥' + remainingAmount + ')';
  document.getElementById('settle-remaining-amount-payable').value = remainingAmount;
  document.getElementById('settle-amount-payable').value = remainingAmount;
  document.getElementById('settle-date-payable').value = new Date().toISOString().split('T')[0];
  document.getElementById('settle-form').action = '/payables/' + id + '/settle';
  document.getElementById('settle-payable-modal').classList.remove('hidden');
  // Re-initialize account selector
  setTimeout(function() {
    initSelectorWithData({
      searchInputId: 'settle-account-search-payable',
      dropdownId: 'settle-account-dropdown-payable',
      filterInputId: 'settle-account-filter-payable',
      optionsId: 'settle-account-options-payable',
      hiddenInputId: 'settle-account-id-payable',
      dataSource: allAccountsForSelector,
      noMatchText: '无匹配账户'
    });
  }, 0);
}

function setFullAmountPayable() {
  const remainingAmount = document.getElementById('settle-remaining-amount-payable').value;
  document.getElementById('settle-amount-payable').value = remainingAmount;
}

<% if params[:open_modal] == "true" %>
document.addEventListener('DOMContentLoaded', function() {
  document.getElementById('add-payable-modal').classList.remove('hidden');
  <% if params[:counterparty].present? %>
    <% cp = @counterparties.find { |c| c.name == params[:counterparty] } %>
    <% if cp %>
      document.querySelector('select[name="payable[counterparty_id]"]').value = '<%= cp.id %>';
    <% end %>
  <% end %>
});
<% end %>

var allAccountsForSelector = [];
var allCategoriesForSelector = [];
const payableAccountsDataEl = document.getElementById('payable-accounts-data');
if (payableAccountsDataEl) {
  allAccountsForSelector = JSON.parse(payableAccountsDataEl.textContent);
}
const payableCategoriesDataEl = document.getElementById('payable-categories-data');
if (payableCategoriesDataEl) {
  allCategoriesForSelector = JSON.parse(payableCategoriesDataEl.textContent);
}

function findPayableAccountName(accountId) {
  if (!accountId) return '';
  const matched = allAccountsForSelector.find(function(acc) { return String(acc.id) === String(accountId); });
  return matched ? matched.name : '';
}

const categorySelectorData = allCategoriesForSelector.map(function(cat) {
  return {
    id: cat.name,
    name: cat.name,
    full_name: cat.full_name || cat.name,
    pinyin: cat.pinyin || ''
  };
});

initSelectorWithData({
  searchInputId: 'new-payable-account-search',
  dropdownId: 'new-payable-account-dropdown',
  filterInputId: 'new-payable-account-filter',
  optionsId: 'new-payable-account-options',
  hiddenInputId: 'new-payable-account-id',
  dataSource: allAccountsForSelector,
  noMatchText: '无匹配账户'
});
initSelectorWithData({
  searchInputId: 'settle-account-search-payable',
  dropdownId: 'settle-account-dropdown-payable',
  filterInputId: 'settle-account-filter-payable',
  optionsId: 'settle-account-options-payable',
  hiddenInputId: 'settle-account-id-payable',
  dataSource: allAccountsForSelector,
  noMatchText: '无匹配账户'
});
initSelectorWithData({
  searchInputId: 'edit-payable-account-search',
  dropdownId: 'edit-payable-account-dropdown',
  filterInputId: 'edit-payable-account-filter',
  optionsId: 'edit-payable-account-options',
  hiddenInputId: 'edit-payable-account-id',
  dataSource: allAccountsForSelector,
  noMatchText: '无匹配账户'
});
initSelectorWithData({
  searchInputId: 'new-payable-category-search',
  dropdownId: 'new-payable-category-dropdown',
  filterInputId: 'new-payable-category-filter',
  optionsId: 'new-payable-category-options',
  hiddenInputId: 'new-payable-category-id',
  dataSource: categorySelectorData,
  emptyOption: { label: '不设置分类', value: '', display: '' },
  noMatchText: '无匹配分类'
});
initSelectorWithData({
  searchInputId: 'edit-payable-category-search',
  dropdownId: 'edit-payable-category-dropdown',
  filterInputId: 'edit-payable-category-filter',
  optionsId: 'edit-payable-category-options',
  hiddenInputId: 'edit-payable-category-id',
  dataSource: categorySelectorData,
  emptyOption: { label: '不设置分类', value: '', display: '' },
  noMatchText: '无匹配分类'
});

// Expose functions to global scope for onclick handlers
window.openNewPayableModal = openNewPayableModal;
window.openEditPayableModal = openEditPayableModal;
window.openSettleModal = openSettleModal;
window.setFullAmountPayable = setFullAmountPayable;
</script>

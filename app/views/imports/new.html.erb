<div class="space-y-6">
  <div class="flex items-center gap-4">
    <%= link_to "← 返回", transactions_path, class: "text-gray-500 hover:text-gray-700 dark:text-gray-300" %>
    <h1 class="text-2xl font-bold text-gray-900">导入交易</h1>
  </div>

  <!-- Info Cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="bg-container dark:bg-gray-800 rounded-lg shadow p-4">
      <div class="text-sm text-gray-500">支持的格式</div>
      <div class="mt-1 flex flex-wrap gap-2">
        <% @supported_formats.each do |format| %>
          <span class="px-2 py-1 bg-surface dark:bg-gray-600 text-primary dark:text-gray-300 dark:text-gray-300 rounded text-sm uppercase"><%= format %></span>
        <% end %>
      </div>
    </div>
    <div class="bg-container dark:bg-gray-800 rounded-lg shadow p-4">
      <div class="text-sm text-gray-500">文件大小限制</div>
      <div class="text-lg font-medium">10 MB</div>
    </div>
    <div class="bg-container dark:bg-gray-800 rounded-lg shadow p-4">
      <div class="text-sm text-gray-500">预览限制</div>
      <div class="text-lg font-medium">前 100 行</div>
    </div>
  </div>

  <!-- Upload Form -->
  <div class="bg-container dark:bg-gray-800 rounded-lg shadow p-6">
    <h2 class="text-lg font-semibold mb-4">步骤 1: 选择文件</h2>
    
    <%= form_with url: preview_imports_path, local: true, multipart: true, id: "upload-form" do |f| %>
      <div class="space-y-4">
        <div class="border-2 border-dashed border-gray-300 rounded-lg p-8 text-center hover:border-inverse transition" id="drop-zone">
          <div class="text-gray-500">
            <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
              <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <p class="mt-2">拖拽文件到此处，或点击选择文件</p>
            <p class="text-sm text-gray-400 mt-1">支持 CSV, Excel, OFX, QIF 格式</p>
          </div>
          <%= f.file_field :file, accept: ".csv,.xlsx,.xls,.ofx,.qif", class: "hidden", id: "file-input" %>
        </div>

        <div id="file-info" class="hidden bg-surface-inset dark:bg-gray-800 rounded-lg p-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="text-gray-500">📄</div>
              <div>
                <div id="file-name" class="font-medium text-gray-900"></div>
                <div id="file-size" class="text-sm text-gray-500"></div>
              </div>
            </div>
            <button type="button" id="remove-file" class="px-3 py-1.5 text-sm font-medium rounded-lg bg-red-100 text-red-600 hover:bg-red-200 transition-smooth btn-modern">移除</button>
          </div>
        </div>

        <!-- Account Selection -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">导入到账户（可选）</label>
          <%= f.collection_select :account_name, Account.order(:name), :name, :name, { include_blank: "自动创建账户" }, class: "border border-gray-300 rounded-lg px-3 py-1.5 focus:ring-blue-500 focus:border-blue-500" %>
        </div>

        <!-- Template Selection -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">字段映射模板</label>
          <select id="template-select" class="border border-gray-300 rounded-lg px-3 py-1.5 focus:ring-blue-500 focus:border-blue-500">
            <option value="">自动检测</option>
            <% @templates.each do |template| %>
              <option value="<%= template[:mapping].to_json %>"><%= template[:name] %></option>
            <% end %>
          </select>
        </div>

        <div class="flex justify-end">
          <%= f.submit "预览导入", class: "px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth btn-modern" %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Templates Info -->
  <div class="bg-container dark:bg-gray-800 rounded-lg shadow p-6">
    <h2 class="text-lg font-semibold mb-4">导入模板说明</h2>
    <div class="grid gap-4 md:grid-cols-2">
      <% @templates.each do |template| %>
        <div class="border rounded-lg p-4">
          <h3 class="font-medium text-gray-900"><%= template[:name] %></h3>
          <div class="mt-2 text-sm text-gray-600">
            字段: <%= template[:mapping].keys.join(", ") %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input');
  const fileInfo = document.getElementById('file-info');
  const fileName = document.getElementById('file-name');
  const fileSize = document.getElementById('file-size');
  const removeBtn = document.getElementById('remove-file');

  // Click to select file
  dropZone.addEventListener('click', () => fileInput.click());

  // Drag and drop
  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-inverse', 'bg-surface-inset dark:bg-gray-800');
  });

  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-inverse', 'bg-surface-inset dark:bg-gray-800');
  });

  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-inverse', 'bg-surface-inset dark:bg-gray-800');
    
    const files = e.dataTransfer.files;
    if (files.length > 0) {
      fileInput.files = files;
      showFileInfo(files[0]);
    }
  });

  // File input change
  fileInput.addEventListener('change', () => {
    if (fileInput.files.length > 0) {
      showFileInfo(fileInput.files[0]);
    }
  });

  // Show file info
  function showFileInfo(file) {
    fileName.textContent = file.name;
    fileSize.textContent = formatFileSize(file.size);
    fileInfo.classList.remove('hidden');
    dropZone.classList.add('hidden');
  }

  // Remove file
  removeBtn.addEventListener('click', () => {
    fileInput.value = '';
    fileInfo.classList.add('hidden');
    dropZone.classList.remove('hidden');
  });

  // Format file size
  function formatFileSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
  }
});
</script>

<!-- app/views/imports/pixiu.html.erb -->

<div class="min-h-screen bg-gradient-to-br from-background to-background-dark dark:from-background-dark dark:to-background-darker">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-primary dark:text-primary-dark mb-2">
        🐷 贔貅记账导入
      </h1>
      <p class="text-secondary dark:text-secondary-dark">
        将贔貅记账的交易流水导入到本系统
      </p>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
      <% steps = [
        { num: 1, title: "上传文件", icon: "📤" },
        { num: 2, title: "预览数据", icon: "👀" },
        { num: 3, title: "配置映射", icon: "🔗" },
        { num: 4, title: "导入完成", icon: "✅" }
      ] %>
      <% steps.each do |step| %>
        <div class="bg-container dark:bg-container-dark rounded-lg p-4 border-2 <%= @current_step == step[:num] ? 'border-inverse' : 'border-border dark:border-border-dark' %>">
          <div class="text-2xl mb-2"><%= step[:icon] %></div>
          <div class="text-sm font-medium text-primary dark:text-primary-dark"><%= step[:num] %>. <%= step[:title] %></div>
        </div>
      <% end %>
    </div>

    <!-- Content -->
    <div class="bg-container dark:bg-container-dark rounded-xl shadow-lg p-8">
      <% if @current_step == 1 %>
        <!-- Step 1: Upload -->
        <div>
          <h2 class="text-xl font-semibold text-primary dark:text-primary-dark mb-4">
            第1步：上传贔貅记账导出文件
          </h2>
          
          <div class="bg-surface-inset dark:bg-surface-dark-inset rounded-lg p-6 mb-6">
            <p class="text-sm text-secondary dark:text-secondary-dark mb-4">
              📋 <strong>文件要求：</strong>
            </p>
            <ul class="text-sm text-secondary dark:text-secondary-dark space-y-2 ml-4">
              <li>✓ CSV 格式（.csv）</li>
              <li>✓ 包含以下列：日期、收支大类、交易分类、交易类型、流入金额、流出金额、币种、资金账户、标签、备注</li>
              <li>✓ 文件大小 &lt; 50MB</li>
              <li>✓ 编码：UTF-8</li>
            </ul>
          </div>

          <%= form_with url: imports_pixiu_upload_path, method: :post, local: true, multipart: true do |f| %>
            <div class="border-2 border-dashed border-border dark:border-border-dark rounded-lg p-8 text-center hover:border-inverse transition-colors cursor-pointer" id="drop-zone">
              <div class="text-4xl mb-4">📁</div>
              <p class="text-primary dark:text-primary-dark font-medium mb-2">
                拖拽文件到此处或点击选择
              </p>
              <p class="text-sm text-secondary dark:text-secondary-dark mb-4">
                支持 CSV 格式
              </p>
              <%= f.file_field :file, accept: '.csv', class: "hidden", id: "file-input" %>
              <button type="button" class="px-4 py-2 bg-inverse text-white rounded-lg hover:bg-inverse-hover transition-colors" onclick="document.getElementById('file-input').click()">
                选择文件
              </button>
            </div>

            <div id="file-info" class="mt-4 hidden">
              <div class="bg-green-100 dark:bg-green-900/20 border border-green-300 dark:border-green-700 rounded-lg p-4">
                <p class="text-sm text-green-700 dark:text-green-300">
                  ✅ 已选择：<span id="file-name" class="font-medium"></span>
                </p>
              </div>
            </div>

            <div class="mt-6 flex gap-4">
              <%= f.submit "下一步", class: "px-6 py-2 bg-inverse text-white rounded-lg hover:bg-inverse-hover transition-colors font-medium" %>
            </div>
          <% end %>
        </div>

      <% elsif @current_step == 2 %>
        <!-- Step 2: Preview -->
        <div>
          <h2 class="text-xl font-semibold text-primary dark:text-primary-dark mb-4">
            第2步：预览数据
          </h2>

          <div class="bg-surface-inset dark:bg-surface-dark-inset rounded-lg p-4 mb-6">
            <p class="text-sm text-secondary dark:text-secondary-dark">
              📊 <strong>导入统计：</strong>
            </p>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-4">
              <div class="bg-container dark:bg-container-dark rounded p-3">
                <div class="text-2xl font-bold text-primary dark:text-primary-dark"><%= @stats[:total] %></div>
                <div class="text-xs text-secondary dark:text-secondary-dark">总行数</div>
              </div>
              <div class="bg-container dark:bg-container-dark rounded p-3">
                <div class="text-2xl font-bold text-income"><%= @stats[:valid] %></div>
                <div class="text-xs text-secondary dark:text-secondary-dark">有效交易</div>
              </div>
              <div class="bg-container dark:bg-container-dark rounded p-3">
                <div class="text-2xl font-bold text-expense"><%= @stats[:transfers] %></div>
                <div class="text-xs text-secondary dark:text-secondary-dark">转账（双向记录）</div>
              </div>
              <div class="bg-container dark:bg-container-dark rounded p-3">
                <div class="text-2xl font-bold text-warning"><%= @stats[:invalid] %></div>
                <div class="text-xs text-secondary dark:text-secondary-dark">无效行</div>
              </div>
            </div>
          </div>

          <!-- Sample data table -->
          <div class="overflow-x-auto mb-6">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-border dark:border-border-dark">
                  <th class="text-left py-2 px-3 text-secondary dark:text-secondary-dark font-medium">日期</th>
                  <th class="text-left py-2 px-3 text-secondary dark:text-secondary-dark font-medium">分类</th>
                  <th class="text-left py-2 px-3 text-secondary dark:text-secondary-dark font-medium">账户</th>
                  <th class="text-right py-2 px-3 text-secondary dark:text-secondary-dark font-medium">金额</th>
                  <th class="text-left py-2 px-3 text-secondary dark:text-secondary-dark font-medium">备注</th>
                </tr>
              </thead>
              <tbody>
                <% @sample_data.each do |row| %>
                  <tr class="border-b border-border dark:border-border-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover">
                    <td class="py-2 px-3 text-primary dark:text-primary-dark"><%= row[:date] %></td>
                    <td class="py-2 px-3 text-primary dark:text-primary-dark"><%= row[:category] %></td>
                    <td class="py-2 px-3 text-primary dark:text-primary-dark"><%= row[:account] %></td>
                    <td class="py-2 px-3 text-right font-medium <%= row[:type] == 'INCOME' ? 'text-income' : 'text-expense' %>">
                      <%= row[:type] == 'INCOME' ? '+' : '-' %><%= number_to_currency(row[:amount], unit: '¥', format: '%u%n') %>
                    </td>
                    <td class="py-2 px-3 text-secondary dark:text-secondary-dark text-xs"><%= truncate(row[:note], length: 30) %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

          <div class="flex gap-4">
            <%= link_to "上一步", pixiu_imports_path(step: 1), class: "px-6 py-2 border border-border dark:border-border-dark text-primary dark:text-primary-dark rounded-lg hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-colors font-medium" %>
            <%= link_to "下一步", pixiu_imports_path(step: 3), class: "px-6 py-2 bg-inverse text-white rounded-lg hover:bg-inverse-hover transition-colors font-medium" %>
          </div>
        </div>

      <% elsif @current_step == 3 %>
        <!-- Step 3: Configure Mapping -->
        <div>
          <h2 class="text-xl font-semibold text-primary dark:text-primary-dark mb-4">
            第3步：配置账户和分类映射
          </h2>

          <div class="bg-surface-inset dark:bg-surface-dark-inset rounded-lg p-4 mb-6">
            <p class="text-sm text-secondary dark:text-secondary-dark">
              🔗 <strong>映射配置：</strong>
            </p>
            <p class="text-xs text-secondary dark:text-secondary-dark mt-2">
              系统已自动识别并创建了所需的账户和分类。如需调整，请在下方修改。
            </p>
          </div>

          <%= form_with url: pixiu_confirm_imports_path, method: :post, local: true do |f| %>
            <!-- Accounts -->
            <div class="mb-8">
              <h3 class="text-lg font-semibold text-primary dark:text-primary-dark mb-4">
                📋 账户映射
              </h3>
              <div class="space-y-3">
                <% @accounts_map.each do |pixiu_name, account| %>
                  <div class="flex items-center gap-3 p-3 bg-surface dark:bg-surface-dark rounded-lg">
                    <div class="flex-1">
                      <p class="text-sm font-medium text-primary dark:text-primary-dark"><%= pixiu_name %></p>
                      <p class="text-xs text-secondary dark:text-secondary-dark">贔貅账户</p>
                    </div>
                    <div class="text-xl">→</div>
                    <div class="flex-1">
                      <select name="accounts[<%= pixiu_name %>]" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark">
                        <% Account.order(:name).each do |acc| %>
                          <option value="<%= acc.id %>" <%= acc.id == account.id ? 'selected' : '' %>>
                            <%= acc.name %>
                          </option>
                        <% end %>
                      </select>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>

            <!-- Categories -->
            <div class="mb-8">
              <h3 class="text-lg font-semibold text-primary dark:text-primary-dark mb-4">
                📂 分类映射
              </h3>
              <div class="space-y-3">
                <% @categories_map.each do |pixiu_name, category| %>
                  <div class="flex items-center gap-3 p-3 bg-surface dark:bg-surface-dark rounded-lg">
                    <div class="flex-1">
                      <p class="text-sm font-medium text-primary dark:text-primary-dark"><%= pixiu_name %></p>
                      <p class="text-xs text-secondary dark:text-secondary-dark">贔貅分类</p>
                    </div>
                    <div class="text-xl">→</div>
                    <div class="flex-1">
                      <select name="categories[<%= pixiu_name %>]" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark">
                        <% Category.order(:name).each do |cat| %>
                          <option value="<%= cat.id %>" <%= cat.id == category.id ? 'selected' : '' %>>
                            <%= cat.name %> (<%= cat.category_type %>)
                          </option>
                        <% end %>
                      </select>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>

            <div class="flex gap-4">
              <%= link_to "上一步", pixiu_imports_path(step: 2), class: "px-6 py-2 border border-border dark:border-border-dark text-primary dark:text-primary-dark rounded-lg hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-colors font-medium" %>
              <%= f.submit "开始导入", class: "px-6 py-2 bg-inverse text-white rounded-lg hover:bg-inverse-hover transition-colors font-medium" %>
            </div>
          <% end %>
        </div>

      <% elsif @current_step == 4 %>
        <!-- Step 4: Complete -->
        <div class="text-center">
          <div class="text-6xl mb-4">✨</div>
          <h2 class="text-2xl font-bold text-primary dark:text-primary-dark mb-2">
            导入完成！
          </h2>
          <p class="text-secondary dark:text-secondary-dark mb-8">
            已成功导入 <span class="font-bold text-inverse"><%= @import_result[:imported] %></span> 条交易
          </p>

          <div class="grid grid-cols-3 gap-4 mb-8">
            <div class="bg-surface dark:bg-surface-dark rounded-lg p-4">
              <div class="text-2xl font-bold text-income"><%= @import_result[:imported] %></div>
              <div class="text-xs text-secondary dark:text-secondary-dark">已导入</div>
            </div>
            <div class="bg-surface dark:bg-surface-dark rounded-lg p-4">
              <div class="text-2xl font-bold text-warning"><%= @import_result[:skipped] %></div>
              <div class="text-xs text-secondary dark:text-secondary-dark">已跳过</div>
            </div>
            <div class="bg-surface dark:bg-surface-dark rounded-lg p-4">
              <div class="text-2xl font-bold text-expense"><%= @import_result[:errors] %></div>
              <div class="text-xs text-secondary dark:text-secondary-dark">错误</div>
            </div>
          </div>

          <div class="flex gap-4 justify-center">
            <%= link_to "查看交易", transactions_path, class: "px-6 py-2 bg-inverse text-white rounded-lg hover:bg-inverse-hover transition-colors font-medium" %>
            <%= link_to "返回首页", root_path, class: "px-6 py-2 border border-border dark:border-border-dark text-primary dark:text-primary-dark rounded-lg hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-colors font-medium" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  // File upload drag & drop
  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input');
  const fileInfo = document.getElementById('file-info');
  const fileName = document.getElementById('file-name');

  if (dropZone) {
    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropZone.classList.add('border-inverse', 'bg-surface-inset');
    });

    dropZone.addEventListener('dragleave', () => {
      dropZone.classList.remove('border-inverse', 'bg-surface-inset');
    });

    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('border-inverse', 'bg-surface-inset');
      
      const files = e.dataTransfer.files;
      if (files.length > 0) {
        fileInput.files = files;
        updateFileInfo();
      }
    });

    fileInput.addEventListener('change', updateFileInfo);
  }

  function updateFileInfo() {
    if (fileInput.files.length > 0) {
      fileName.textContent = fileInput.files[0].name;
      fileInfo.classList.remove('hidden');
    }
  }
</script>

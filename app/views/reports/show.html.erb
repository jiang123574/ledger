<% year_label = @report_type == :yearly ? "#{@year}年" : "#{@year}年#{@month}月" %>

<div class="space-y-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
    <h1 class="text-2xl font-semibold text-primary"><%= year_label %>财务报表</h1>
    <div class="flex items-center gap-2">
      <% if @report_type == :monthly %>
        <%= link_to "年度报表", report_path(year: @year), class: "btn btn-ghost btn-sm" %>
      <% end %>
      <%= link_to dashboard_path, class: "btn btn-ghost btn-sm" do %>
        ← 返回
      <% end %>
    </div>
  </div>

  <!-- Year/Month Navigation -->
  <div class="flex items-center gap-2">
    <% if @report_type == :yearly %>
      <%= link_to report_path(year: @year - 1), class: "p-2 rounded-lg hover:bg-surface-inset" do %>
        ← <%= @year - 1 %>年
      <% end %>
      <span class="px-4 py-2 bg-container rounded-lg font-medium"><%= @year %>年</span>
      <%= link_to report_path(year: @year + 1), class: "p-2 rounded-lg hover:bg-surface-inset" do %>
        <%= @year + 1 %>年 →
      <% end %>
    <% else %>
      <%= link_to report_path(year: @year, month: @month - 1), class: "p-2 rounded-lg hover:bg-surface-inset" do %>
        ← 上月
      <% end %>
      <span class="px-4 py-2 bg-container rounded-lg font-medium"><%= @year %>年<%= @month %>月</span>
      <%= link_to report_path(year: @year, month: @month + 1), class: "p-2 rounded-lg hover:bg-surface-inset" do %>
        下月 →
      <% end %>
    <% end %>
  </div>

  <!-- Summary Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <%= render(Ds::CardComponent.new) do %>
      <div class="flex items-start justify-between">
        <div>
          <p class="text-sm font-medium text-secondary">总收入</p>
          <p class="text-2xl font-semibold text-income mt-1"><%= format_currency(@total_income) %></p>
        </div>
        <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
          <%= render(Ds::IconComponent.new(name: "arrow-right", size: :md, color: :income)) %>
        </div>
      </div>
    <% end %>

    <%= render(Ds::CardComponent.new) do %>
      <div class="flex items-start justify-between">
        <div>
          <p class="text-sm font-medium text-secondary">总支出</p>
          <p class="text-2xl font-semibold text-expense mt-1"><%= format_currency(@total_expense) %></p>
        </div>
        <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center">
          <%= render(Ds::IconComponent.new(name: "arrow-left", size: :md, color: :expense)) %>
        </div>
      </div>
    <% end %>

    <%= render(Ds::CardComponent.new) do %>
      <div class="flex items-start justify-between">
        <div>
          <p class="text-sm font-medium text-secondary">结余</p>
          <% balance_info = format_balance(@net_balance) %>
          <p class="text-2xl font-semibold mt-1 <%= balance_info[:css_class] %>">
            <%= balance_info[:amount] %>
          </p>
        </div>
        <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
          <%= render(Ds::IconComponent.new(name: "chart-bar", size: :md, color: :primary)) %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Income/Expense Trend -->
    <%= render(Ds::CardComponent.new) do %>
      <h2 class="text-lg font-semibold text-primary mb-4">
        <%= @report_type == :yearly ? "月度趋势" : "周趋势" %>
      </h2>
      <div class="space-y-4">
        <% @monthly_trend.each do |period| %>
          <div class="flex items-center gap-4">
            <span class="w-16 text-sm text-secondary"><%= period[:label] %></span>
            <div class="flex-1 space-y-1">
              <% max_value = [period[:income], period[:expense]].max %>
              <% next if max_value == 0 %>
              <div class="flex items-center gap-2">
                <span class="text-xs text-income w-16">+<%= format_currency(period[:income]) %></span>
                <div class="flex-1 bg-surface rounded-full h-2">
                  <div class="bg-income h-2 rounded-full" style="width: <%= period[:income] > 0 ? (period[:income].to_f / max_value * 100).round : 0 %>%"></div>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-xs text-expense w-16">-<%= format_currency(period[:expense]) %></span>
                <div class="flex-1 bg-surface rounded-full h-2">
                  <div class="bg-expense h-2 rounded-full" style="width: <%= period[:expense] > 0 ? (period[:expense].to_f / max_value * 100).round : 0 %>%"></div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Expense by Category -->
    <%= render(Ds::CardComponent.new) do %>
      <h2 class="text-lg font-semibold text-primary mb-4">支出分类</h2>
      <% if @expense_by_category.any? %>
        <div class="space-y-3">
          <% @expense_by_category.first(8).each do |category, amount| %>
            <% percentage = @total_expense > 0 ? (amount / @total_expense * 100).round : 0 %>
            <div>
              <div class="flex justify-between text-sm mb-1">
                <span class="text-primary"><%= category || "未分类" %></span>
                <span class="text-expense"><%= format_currency(amount) %> (<%= percentage %>%)</span>
              </div>
              <div class="w-full bg-surface rounded-full h-2">
                <div class="bg-expense h-2 rounded-full" style="width: <%= percentage %>%"></div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-secondary text-center py-8">暂无数据</p>
      <% end %>
    <% end %>

    <!-- Income by Category -->
    <%= render(Ds::CardComponent.new) do %>
      <h2 class="text-lg font-semibold text-primary mb-4">收入分类</h2>
      <% if @income_by_category.any? %>
        <div class="space-y-3">
          <% @income_by_category.first(8).each do |category, amount| %>
            <% percentage = @total_income > 0 ? (amount / @total_income * 100).round : 0 %>
            <div>
              <div class="flex justify-between text-sm mb-1">
                <span class="text-primary"><%= category || "未分类" %></span>
                <span class="text-income"><%= format_currency(amount) %> (<%= percentage %>%)</span>
              </div>
              <div class="w-full bg-surface rounded-full h-2">
                <div class="bg-income h-2 rounded-full" style="width: <%= percentage %>%"></div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-secondary text-center py-8">暂无数据</p>
      <% end %>
    <% end %>

    <!-- Account Balances -->
    <%= render(Ds::CardComponent.new) do %>
      <h2 class="text-lg font-semibold text-primary mb-4">账户余额</h2>
      <div class="space-y-3">
        <% @account_balances.each do |item| %>
          <div class="flex justify-between items-center">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center">
                <span class="text-xs font-semibold text-blue-600"><%= item[:account].name[0] %></span>
              </div>
              <span class="text-primary"><%= item[:account].name %></span>
            </div>
            <span class="font-semibold text-primary"><%= format_currency(item[:balance]) %></span>
          </div>
        <% end %>
        <div class="pt-3 mt-3 border-t border-border flex justify-between items-center">
          <span class="font-medium text-primary">总资产</span>
          <span class="text-xl font-bold text-primary"><%= format_currency(@account_balances.sum { |i| i[:balance] }) %></span>
        </div>
      </div>
    <% end %>

    <!-- Budget Progress (Monthly only) -->
    <% if @report_type == :monthly && @budget_progress&.any? %>
      <%= render(Ds::CardComponent.new) do %>
        <h2 class="text-lg font-semibold text-primary mb-4">预算进度</h2>
        <div class="space-y-4">
          <% @budget_progress.each do |item| %>
            <div>
              <div class="flex justify-between text-sm mb-1.5">
                <span class="text-primary"><%= item[:budget].category&.name || "未知分类" %></span>
                <span class="<%= item[:percentage] > 100 ? 'text-expense' : 'text-primary' %>">
                  <%= format_currency(item[:spent]) %> / <%= format_currency(item[:budget].amount) %>
                </span>
              </div>
              <div class="w-full bg-surface rounded-full h-3">
                <div class="<%= item[:percentage] > 100 ? 'bg-red-500' : (item[:percentage] > 80 ? 'bg-yellow-500' : 'bg-blue-500') %> h-3 rounded-full" style="width: <%= [item[:percentage], 100].min %>%"></div>
              </div>
              <p class="text-xs text-secondary mt-1"><%= item[:percentage] %>% 已使用</p>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
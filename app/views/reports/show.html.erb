<% year_label = @report_type == :yearly ? "#{@year}年" : "#{@year}年#{@month}月" %>
<% if @report_type == :monthly %>
  <% current_period = Date.new(@year, @month, 1) %>
  <% prev_period = current_period.prev_month %>
  <% next_period = current_period.next_month %>
<% end %>

<div class="space-y-4 sm:space-y-6">
  <div class="flex flex-col gap-3 sm:flex-row sm:justify-between sm:items-center sm:gap-4">
    <div>
      <h1 class="text-xl sm:text-2xl font-semibold text-primary dark:text-primary-dark"><%= year_label %>财务报表</h1>
      <p class="text-xs sm:text-sm text-secondary dark:text-secondary-dark mt-0.5 sm:mt-1">查看收支趋势、分类分布与资产概览</p>
    </div>
    <div class="flex items-center gap-2">
      <% if @report_type == :monthly %>
        <%= link_to "年度", reports_path(year: @year), class: "px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface dark:hover:bg-surface-dark transition-smooth" %>
      <% end %>
      <%= link_to dashboard_path, class: "px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface dark:hover:bg-surface-dark transition-smooth" do %>
        返回仪表盘
      <% end %>
    </div>
  </div>

  <div class="flex items-center gap-2">
    <% if @report_type == :yearly %>
      <%= link_to report_year_path(@year - 1), class: "p-2 rounded-lg hover:bg-surface-inset text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark transition-smooth" do %>
        <%= render(Ds::IconComponent.new(name: "chevron-left", size: :md)) %>
      <% end %>
      <span class="px-4 py-2 bg-container dark:bg-container-dark rounded-lg font-medium min-w-[120px] text-center shadow-border-xs dark:shadow-dark-border-xs"><%= @year %>年</span>
      <%= link_to report_year_path(@year + 1), class: "p-2 rounded-lg hover:bg-surface-inset text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark transition-smooth" do %>
        <%= render(Ds::IconComponent.new(name: "chevron-right", size: :md)) %>
      <% end %>
    <% else %>
      <%= link_to report_month_path(prev_period.year, prev_period.month), class: "p-2 rounded-lg hover:bg-surface-inset text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark transition-smooth" do %>
        <%= render(Ds::IconComponent.new(name: "chevron-left", size: :md)) %>
      <% end %>
      <span class="px-4 py-2 bg-container dark:bg-container-dark rounded-lg font-medium min-w-[120px] text-center shadow-border-xs dark:shadow-dark-border-xs"><%= @year %>年<%= @month %>月</span>
      <%= link_to report_month_path(next_period.year, next_period.month), class: "p-2 rounded-lg hover:bg-surface-inset text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark transition-smooth" do %>
        <%= render(Ds::IconComponent.new(name: "chevron-right", size: :md)) %>
      <% end %>
    <% end %>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
    <%= render(Ds::CardComponent.new(padding: false, rounded: :xl, class: "p-3")) do %>
      <div class="flex items-start justify-between">
        <div>
          <p class="text-xs sm:text-sm font-medium text-secondary dark:text-secondary-dark">总收入</p>
          <p class="text-lg sm:text-2xl font-semibold text-income mt-0.5 sm:mt-1"><%= format_currency(@total_income) %></p>
        </div>
        <div class="ie-icon-chip ie-icon-chip-md ie-icon-income">
          <%= render(Ds::IconComponent.new(name: "arrow-right", size: :md, color: :income)) %>
        </div>
      </div>
    <% end %>

    <%= render(Ds::CardComponent.new(padding: false, rounded: :xl, class: "p-3")) do %>
      <div class="flex items-start justify-between">
        <div>
          <p class="text-xs sm:text-sm font-medium text-secondary dark:text-secondary-dark">总支出</p>
          <p class="text-lg sm:text-2xl font-semibold text-expense mt-0.5 sm:mt-1"><%= format_currency(@total_expense) %></p>
        </div>
        <div class="ie-icon-chip ie-icon-chip-md ie-icon-expense">
          <%= render(Ds::IconComponent.new(name: "arrow-left", size: :md, color: :expense)) %>
        </div>
      </div>
    <% end %>

    <%= render(Ds::CardComponent.new(padding: false, rounded: :xl, class: "p-3")) do %>
      <div class="flex items-start justify-between">
        <div>
          <p class="text-xs sm:text-sm font-medium text-secondary dark:text-secondary-dark">结余</p>
          <% balance_info = format_balance(@net_balance) %>
          <p class="text-lg sm:text-2xl font-semibold mt-0.5 sm:mt-1 <%= balance_info[:css_class] %>"><%= balance_info[:amount] %></p>
        </div>
        <div class="w-10 h-10 bg-surface dark:bg-surface-dark rounded-lg flex items-center justify-center">
          <%= render(Ds::IconComponent.new(name: "chart-bar", size: :md, color: :primary)) %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <section class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs transition-all">
      <div class="px-4 py-3 border-b border-border dark:border-border-dark">
        <h2 class="text-base font-semibold text-primary dark:text-primary-dark"><%= @report_type == :yearly ? "月度趋势" : "周趋势" %></h2>
      </div>
      <div class="p-4">
        <% has_trend_data = @trend_chart_data[:income].any? { |v| v > 0 } || @trend_chart_data[:expense].any? { |v| v > 0 } %>
        <% if has_trend_data %>
          <div data-controller="trend-line-chart"
               data-trend-line-chart-labels-value="<%= @trend_chart_data[:labels].to_json %>"
               data-trend-line-chart-income-data-value="<%= @trend_chart_data[:income].to_json %>"
               data-trend-line-chart-expense-data-value="<%= @trend_chart_data[:expense].to_json %>"
               class="h-64">
            <canvas data-trend-line-chart-target="canvas"></canvas>
          </div>
        <% else %>
          <div class="h-64 flex items-center justify-center text-secondary dark:text-secondary-dark">暂无数据</div>
        <% end %>
      </div>
    </section>

    <section class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs transition-all">
      <div class="px-4 py-3 border-b border-border dark:border-border-dark">
        <h2 class="text-base font-semibold text-primary dark:text-primary-dark">支出分类</h2>
      </div>
      <div class="p-4">
        <% if @expense_chart_data.any? %>
          <div data-controller="category-donut-chart"
               data-category-donut-chart-data-value="<%= @expense_chart_data.to_json %>"
               class="h-64">
            <canvas data-category-donut-chart-target="canvas"></canvas>
          </div>
        <% else %>
          <div class="h-64 flex items-center justify-center text-secondary dark:text-secondary-dark">暂无数据</div>
        <% end %>
      </div>
    </section>

    <section class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs transition-all">
      <div class="px-4 py-3 border-b border-border dark:border-border-dark">
        <h2 class="text-base font-semibold text-primary dark:text-primary-dark">收入分类</h2>
      </div>
      <div class="p-4">
        <% if @income_chart_data.any? %>
          <div data-controller="category-donut-chart"
               data-category-donut-chart-data-value="<%= @income_chart_data.to_json %>"
               class="h-64">
            <canvas data-category-donut-chart-target="canvas"></canvas>
          </div>
        <% else %>
          <div class="h-64 flex items-center justify-center text-secondary dark:text-secondary-dark">暂无数据</div>
        <% end %>
      </div>
    </section>

    <section class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs transition-all">
      <div class="px-4 py-3 border-b border-border dark:border-border-dark">
        <h2 class="text-base font-semibold text-primary dark:text-primary-dark">账户余额</h2>
      </div>
      <div class="divide-y divide-border">
        <% if @account_balances.any? %>
          <% @account_balances.each do |item| %>
            <div class="flex justify-between items-center gap-2 min-w-0 p-4 hover:bg-surface dark:hover:bg-surface-dark transition-smooth">
              <div class="flex items-center gap-2 min-w-0">
                <div class="w-8 h-8 shrink-0 rounded-full bg-surface dark:bg-surface-dark flex items-center justify-center">
                  <span class="text-xs font-semibold text-primary dark:text-primary-dark"><%= item[:account].name[0] %></span>
                </div>
                <span class="text-primary dark:text-primary-dark truncate"><%= item[:account].name %></span>
              </div>
              <span class="font-semibold text-primary dark:text-primary-dark shrink-0"><%= format_currency(item[:balance]) %></span>
            </div>
          <% end %>
          <div class="p-4 flex justify-between items-center bg-surface/40 dark:bg-surface-dark/40">
            <span class="font-medium text-primary dark:text-primary-dark">总资产</span>
            <span class="text-lg font-semibold text-primary dark:text-primary-dark"><%= format_currency(@account_balances.sum { |i| i[:balance] }) %></span>
          </div>
        <% else %>
          <div class="p-8 text-center text-secondary dark:text-secondary-dark">暂无账户数据</div>
        <% end %>
      </div>
    </section>

    <% if @report_type == :monthly && @budget_progress&.any? %>
      <section class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs transition-all">
        <div class="px-4 py-3 border-b border-border dark:border-border-dark">
          <h2 class="text-base font-semibold text-primary dark:text-primary-dark">预算进度</h2>
        </div>
        <div class="p-4 space-y-4">
          <% @budget_progress.each do |item| %>
            <div class="min-w-0">
              <div class="flex justify-between text-sm mb-1.5 gap-2">
                <span class="text-primary dark:text-primary-dark truncate"><%= item[:budget].category&.name || "未知分类" %></span>
                <span class="<%= item[:percentage] > 100 ? 'text-expense' : 'text-primary dark:text-primary-dark' %> shrink-0">
                  <%= format_currency(item[:spent]) %> / <%= format_currency(item[:budget].amount) %>
                </span>
              </div>
              <div class="w-full bg-surface dark:bg-surface-dark rounded-full h-2.5">
                <div class="<%= item[:percentage] > 100 ? 'bg-expense' : (item[:percentage] > 80 ? 'bg-income' : 'bg-inverse') %> h-2.5 rounded-full transition-all" style="width: <%= [item[:percentage], 100].min %>%"></div>
              </div>
              <p class="text-xs text-secondary dark:text-secondary-dark mt-1"><%= item[:percentage] %>% 已使用</p>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>
</div>

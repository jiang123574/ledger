<% year_label = @report_type == :yearly ? "#{@year}年" : "#{@year}年#{@month}月" %>
<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-preview">
<% end %>
<% if @report_type == :monthly %>
  <% current_period = Date.new(@year, @month, 1) %>
  <% prev_period = current_period.prev_month %>
  <% next_period = current_period.next_month %>
<% end %>

<div data-controller="report-tabs native-bridge" class="flex flex-col lg:flex-row gap-4 lg:gap-5">
  <!-- ========== 左侧导航栏（仿设置页） ========== -->
  <aside class="lg:w-44 lg:shrink-0">
    <div class="bg-container dark:bg-container-dark rounded-lg shadow-border-xs dark:shadow-dark-border-xs lg:sticky lg:top-20 overflow-x-auto">
      <nav class="flex lg:flex-col p-2 gap-1 lg:gap-0 min-w-max lg:min-w-0" aria-label="报表导航">

        <a href="#trend" data-report-tabs-target="navItem" data-panel-id="trend"
           data-action="report-tabs#switchPanel"
           class="settings-nav-item active shrink-0">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"></path></svg>
          <span class="hidden lg:inline">收支趋势</span>
        </a>

        <a href="#category-stats" data-report-tabs-target="navItem" data-panel-id="category-stats"
           data-action="report-tabs#switchPanel"
           class="settings-nav-item shrink-0">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
          <span class="hidden lg:inline">分类统计</span>
        </a>

        <a href="#expense" data-report-tabs-target="navItem" data-panel-id="expense"
           data-action="report-tabs#switchPanel"
           class="settings-nav-item shrink-0">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
          <span class="hidden lg:inline">支出分类</span>
        </a>

        <a href="#income" data-report-tabs-target="navItem" data-panel-id="income"
           data-action="report-tabs#switchPanel"
           class="settings-nav-item shrink-0">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <span class="hidden lg:inline">收入分类</span>
        </a>

        <% if @report_type == :monthly && @budget_progress&.any? %>
        <a href="#budget" data-report-tabs-target="navItem" data-panel-id="budget"
           data-action="report-tabs#switchPanel"
           class="settings-nav-item shrink-0">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
          <span class="hidden lg:inline">预算进度</span>
        </a>
        <% end %>

        <% if @report_type == :yearly && @asset_trend&.any? %>
        <a href="#assets" data-report-tabs-target="navItem" data-panel-id="assets"
           data-action="report-tabs#switchPanel"
           class="settings-nav-item shrink-0">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
          <span class="hidden lg:inline">资产走势</span>
        </a>
        <% end %>

        <% if @report_type == :yearly && @category_monthly_comparison[:categories]&.any? %>
        <a href="#comparison" data-report-tabs-target="navItem" data-panel-id="comparison"
           data-action="report-tabs#switchPanel"
           class="settings-nav-item shrink-0">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"></path></svg>
          <span class="hidden lg:inline">月度对比</span>
        </a>
        <% end %>

        <% if @report_type == :yearly && @sankey_data&.any? %>
        <a href="#sankey" data-report-tabs-target="navItem" data-panel-id="sankey"
           data-action="report-tabs#switchPanel"
           class="settings-nav-item shrink-0">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6 6"></path></svg>
          <span class="hidden lg:inline">收支流向</span>
        </a>
        <% end %>

        <% if @report_type == :yearly && @calendar_heatmap_data&.any? %>
        <a href="#heatmap" data-report-tabs-target="navItem" data-panel-id="heatmap"
           data-action="report-tabs#switchPanel"
           class="settings-nav-item shrink-0">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          <span class="hidden lg:inline">消费日历</span>
        </a>
        <% end %>

        <% if @report_type == :yearly && @waterfall_data&.any? %>
        <a href="#waterfall" data-report-tabs-target="navItem" data-panel-id="waterfall"
           data-action="report-tabs#switchPanel"
           class="settings-nav-item shrink-0">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3v18h18M7 16v-4m4 4v-8m4 4v-6m4 6v-2"></path></svg>
          <span class="hidden lg:inline">余额变动</span>
        </a>
        <% end %>

      </nav>
    </div>
  </aside>

  <!-- ========== 右侧内容区 ========== -->
  <main class="flex-1 min-w-0 space-y-4 sm:space-y-6 pb-20 lg:pb-0">
    <!-- 页头 -->
    <div class="flex flex-col gap-3 sm:flex-row sm:justify-between sm:items-center sm:gap-4">
      <div>
        <h1 class="text-xl sm:text-2xl font-semibold text-primary dark:text-primary-dark"><%= year_label %>统计报表</h1>
        <p class="text-xs sm:text-sm text-secondary dark:text-secondary-dark mt-0.5 sm:mt-1">查看收支趋势、分类分布与资产概览</p>
      </div>
      <div class="flex items-center gap-2">
        <% if @report_type == :monthly %>
          <%= link_to "年度", reports_path(year: @year), class: "px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface dark:hover:bg-surface-dark transition-smooth" %>
        <% end %>
        <button type="button" data-action="native-bridge#share" data-native-bridge-share-title-value="<%= year_label %>统计报表" data-native-bridge-share-text-value="查看 <%= year_label %> 收支趋势、分类分布与资产概览" class="hidden items-center gap-1 px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface dark:hover:bg-surface-dark transition-smooth" data-native-bridge-target="shareBtn">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path></svg>
          分享
        </button>
        <%= link_to dashboard_path, class: "px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface dark:hover:bg-surface-dark transition-smooth" do %>
          返回仪表盘
        <% end %>
      </div>
    </div>

    <!-- 时间切换 + 汇总卡片（始终显示） -->
    <div class="flex items-center gap-2">
      <% if @report_type == :yearly %>
        <%= link_to report_year_path(@year - 1), class: "p-2 rounded-lg hover:bg-surface-inset text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark transition-smooth" do %>
          <%= render(Ds::IconComponent.new(name: "chevron-left", size: :md)) %>
        <% end %>
        <span class="px-4 py-2 bg-container dark:bg-container-dark rounded-lg font-medium min-w-[120px] text-center shadow-border-xs dark:shadow-dark-border-xs"><%= @year %>年</span>
        <%= link_to report_year_path(@year + 1), class: "p-2 rounded-lg hover:bg-surface-inset text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark transition-smooth" do %>
          <%= render(Ds::IconComponent.new(name: "chevron-right", size: :md)) %>
        <% end %>
      <% else %>
        <%= link_to report_month_path(prev_period.year, prev_period.month), class: "p-2 rounded-lg hover:bg-surface-inset text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark transition-smooth" do %>
          <%= render(Ds::IconComponent.new(name: "chevron-left", size: :md)) %>
        <% end %>
        <span class="px-4 py-2 bg-container dark:bg-container-dark rounded-lg font-medium min-w-[120px] text-center shadow-border-xs dark:shadow-dark-border-xs"><%= @year %>年<%= @month %>月</span>
        <%= link_to report_month_path(next_period.year, next_period.month), class: "p-2 rounded-lg hover:bg-surface-inset text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark transition-smooth" do %>
          <%= render(Ds::IconComponent.new(name: "chevron-right", size: :md)) %>
        <% end %>
      <% end %>
    </div>

    <!-- 汇总卡片 -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
      <%= render(Ds::CardComponent.new(padding: false, rounded: :xl, class: "p-3")) do %>
        <div class="flex items-start justify-between">
          <div>
            <p class="text-xs sm:text-sm font-medium text-secondary dark:text-secondary-dark">总收入</p>
            <p class="text-lg sm:text-2xl font-semibold text-income mt-0.5 sm:mt-1"><%= format_currency(@total_income) %></p>
          </div>
          <div class="ie-icon-chip ie-icon-chip-md ie-icon-income">
            <%= render(Ds::IconComponent.new(name: "arrow-right", size: :md, color: :income)) %>
          </div>
        </div>
      <% end %>

      <%= render(Ds::CardComponent.new(padding: false, rounded: :xl, class: "p-3")) do %>
        <div class="flex items-start justify-between">
          <div>
            <p class="text-xs sm:text-sm font-medium text-secondary dark:text-secondary-dark">总支出</p>
            <p class="text-lg sm:text-2xl font-semibold text-expense mt-0.5 sm:mt-1"><%= format_currency(@total_expense) %></p>
          </div>
          <div class="ie-icon-chip ie-icon-chip-md ie-icon-expense">
            <%= render(Ds::IconComponent.new(name: "arrow-left", size: :md, color: :expense)) %>
          </div>
        </div>
      <% end %>

      <%= render(Ds::CardComponent.new(padding: false, rounded: :xl, class: "p-3")) do %>
        <div class="flex items-start justify-between">
          <div>
            <p class="text-xs sm:text-sm font-medium text-secondary dark:text-secondary-dark">结余</p>
            <% balance_info = format_balance(@net_balance) %>
            <p class="text-lg sm:text-2xl font-semibold mt-0.5 sm:mt-1 <%= balance_info[:css_class] %>"><%= balance_info[:amount] %></p>
          </div>
          <div class="w-10 h-10 bg-surface dark:bg-surface-dark rounded-lg flex items-center justify-center">
            <%= render(Ds::IconComponent.new(name: "chart-bar", size: :md, color: :primary)) %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- ====== 面板 1: 收支趋势 ====== -->
    <div data-report-tabs-target="panel" data-panel-name="trend" role="tabpanel" aria-label="收支趋势">
      <section class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs">
        <div class="p-4">
          <% has_trend_data = @trend_chart_data[:income].any? { |v| v > 0 } || @trend_chart_data[:expense].any? { |v| v > 0 } %>
          <% if has_trend_data %>
            <div data-controller="trend-line-chart"
                 data-trend-line-chart-labels-value="<%= @trend_chart_data[:labels].to_json %>"
                 data-trend-line-chart-income-data-value="<%= @trend_chart_data[:income].to_json %>"
                 data-trend-line-chart-expense-data-value="<%= @trend_chart_data[:expense].to_json %>"
                 class="h-80">
              <canvas data-trend-line-chart-target="canvas"></canvas>
            </div>
          <% else %>
            <div class="h-64 flex items-center justify-center text-secondary dark:text-secondary-dark">暂无数据</div>
          <% end %>
        </div>
      </section>
    </div>

    <!-- ====== 面板: 分类统计 ====== -->
    <div data-report-tabs-target="panel" data-panel-name="category-stats" class="hidden" role="tabpanel" aria-label="分类统计"
         data-controller="category-stats category-filter"
         data-category-filter-storage-key-value="category-stats-selected-ids"
         data-category-stats-year-value="<%= @year %>"
         data-category-stats-month-value="<%= @month %>"
         data-category-stats-start-date-value="<%= @start_date %>"
         data-category-stats-end-date-value="<%= @end_date %>">
      <!-- 筛选栏 -->
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <!-- 时间筛选 -->
        <% period_type_labels = { 'month' => '按月', 'year' => '按年', 'custom' => '自定义' } %>
        <% selected_period_type = 'month' %>
        <div data-controller="period-picker" data-action="period-picker:change->category-stats#refresh" class="flex items-center gap-2">
          <div class="w-24 relative" data-controller="select">
            <input type="hidden" id="category-stats-period-type" data-category-stats-target="periodType" data-period-picker-target="periodType" data-select-target="input" value="<%= selected_period_type %>" data-action="change->period-picker#onPeriodTypeChange">
            <button type="button" data-select-target="button" data-action="click->select#toggle"
                    class="w-full px-3 py-1.5 h-9 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth flex items-center justify-between">
              <span><%= period_type_labels[selected_period_type] %></span>
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </button>
            <div data-select-target="menu" class="hidden absolute left-0 top-full mt-1 w-full z-20 bg-white dark:bg-surface-dark border border-border dark:border-border-dark rounded-lg shadow-lg py-1 max-h-60 overflow-auto">
              <% period_type_labels.each do |value, label| %>
                <div data-action="click->select#select" data-value="<%= value %>"
                     class="px-3 py-1.5 text-sm cursor-pointer hover:bg-surface-hover dark:hover:bg-surface-dark-hover <%= 'bg-gray-100 dark:bg-gray-700' if selected_period_type == value %>"
                     data-period-type-option="<%= value %>">
                  <%= label %>
                </div>
              <% end %>
            </div>
          </div>
          <div id="category-stats-period-nav" data-period-picker-target="navWrapper" data-category-stats-target="periodNav" class="flex items-center gap-1 relative w-[220px]">
            <input type="hidden" id="category-stats-period-value" value="<%= @year %>-<%= @month || '01' %>" data-category-stats-target="periodValue" data-period-picker-target="periodValue">
            <button type="button" data-action="click->period-picker#shiftPeriod" data-direction="-1" class="px-2.5 py-1.5 h-9 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth" aria-label="上一期">‹</button>
            <div id="category-stats-period-display" data-period-picker-target="display"
                 class="flex-1 min-w-0 px-3 py-1.5 h-9 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark flex items-center justify-center cursor-pointer hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth font-medium"
                 data-action="click->period-picker#toggle">
              <%= @year %>年<%= @month ? "#{@month}月" : '' %>
            </div>
            <div id="category-stats-picker-panel" data-period-picker-target="panel" class="hidden absolute left-8 top-full mt-1 z-30 bg-white dark:bg-surface-dark border border-border dark:border-border-dark rounded-lg shadow-lg p-2 w-[200px]">
              <div class="flex items-center justify-between mb-2">
                <button type="button" data-action="click->period-picker#shiftPickerYear" data-direction="-1" class="p-1 rounded hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                </button>
                <span id="category-stats-picker-year-display" data-period-picker-target="yearDisplay" class="text-sm font-medium text-primary dark:text-primary-dark"></span>
                <button type="button" data-action="click->period-picker#shiftPickerYear" data-direction="1" class="p-1 rounded hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </button>
              </div>
              <div id="category-stats-picker-grid" data-period-picker-target="grid" class="grid grid-cols-4 gap-1">
              </div>
            </div>
            <button type="button" data-action="click->period-picker#shiftPeriod" data-direction="1" class="px-2.5 py-1.5 h-9 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth" aria-label="下一期">›</button>
          </div>
          <div data-category-stats-target="customDateRange" data-period-picker-target="customDateRange" class="hidden flex items-center gap-2">
            <input type="date" data-category-stats-target="startDate" data-action="category-stats#onDateChange"
                   value="<%= @start_date %>"
                   class="px-3 py-1.5 h-9 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500/30">
            <span class="text-secondary dark:text-secondary-dark">至</span>
            <input type="date" data-category-stats-target="endDate" data-action="category-stats#onDateChange"
                   value="<%= @end_date %>"
                   class="px-3 py-1.5 h-9 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500/30">
          </div>
        </div>
        <!-- 分类筛选 -->
        <button type="button" id="open-category-stats-filter"
                data-action="click->category-filter#open"
                class="h-9 px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth inline-flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
          分类筛选
          <span id="category-stats-filter-count" data-category-filter-target="countBadge" class="px-1.5 py-0.5 text-xs rounded-full bg-surface-inset dark:bg-surface-dark-inset text-secondary dark:text-secondary-dark"><%= @categories.size %></span>
        </button>
        <!-- 隐藏的 checkbox 供 Stimulus controller 使用 -->
        <div class="hidden" data-category-stats-target="categoryCheckboxContainer" data-category-filter-target="hiddenCheckbox">
          <% @categories.each do |cat| %>
            <input type="checkbox" value="<%= cat.id %>" data-category-stats-target="categoryCheckbox" data-category-filter-target="hiddenCheckbox" checked>
          <% end %>
        </div>
      </div>

      <!-- 左右分栏图表区域 -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <!-- 左侧: 收入 -->
        <section class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs">
          <div class="px-4 py-3 border-b border-border dark:border-border-dark">
            <h3 class="text-base font-semibold text-income">收入统计</h3>
          </div>
          <div class="p-4">
            <!-- 总金额 -->
            <div class="mb-4 flex items-center justify-between">
              <span class="text-sm text-secondary dark:text-secondary-dark">总收入</span>
              <span data-category-stats-target="incomeTotal" class="text-xl font-semibold text-income">¥0</span>
            </div>
            <!-- 柱状图 -->
            <div class="mb-4">
              <div data-category-stats-target="incomeBarChart" class="h-48">
                <canvas data-category-stats-target="incomeBarCanvas"></canvas>
              </div>
            </div>
            <!-- 环形图 -->
            <div>
              <div data-category-stats-target="incomeDonutChart" class="h-48">
                <canvas data-category-stats-target="incomeDonutCanvas"></canvas>
              </div>
            </div>
            <!-- 无数据提示 -->
            <div data-category-stats-target="incomeEmpty" class="hidden h-64 flex items-center justify-center text-secondary dark:text-secondary-dark">
              暂无收入数据
            </div>
          </div>
        </section>

        <!-- 右侧: 支出 -->
        <section class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs">
          <div class="px-4 py-3 border-b border-border dark:border-border-dark">
            <h3 class="text-base font-semibold text-expense">支出统计</h3>
          </div>
          <div class="p-4">
            <!-- 总金额 -->
            <div class="mb-4 flex items-center justify-between">
              <span class="text-sm text-secondary dark:text-secondary-dark">总支出</span>
              <span data-category-stats-target="expenseTotal" class="text-xl font-semibold text-expense">¥0</span>
            </div>
            <!-- 柱状图 -->
            <div class="mb-4">
              <div data-category-stats-target="expenseBarChart" class="h-48">
                <canvas data-category-stats-target="expenseBarCanvas"></canvas>
              </div>
            </div>
            <!-- 环形图 -->
            <div>
              <div data-category-stats-target="expenseDonutChart" class="h-48">
                <canvas data-category-stats-target="expenseDonutCanvas"></canvas>
              </div>
            </div>
            <!-- 无数据提示 -->
            <div data-category-stats-target="expenseEmpty" class="hidden h-64 flex items-center justify-center text-secondary dark:text-secondary-dark">
              暂无支出数据
            </div>
          </div>
        </section>
      </div>

      <!-- 分类统计筛选弹窗 -->
      <div id="category-stats-filter-modal" data-category-filter-target="modal" class="hidden fixed inset-0 z-50 overflow-y-auto modal-overlay">
        <div class="flex min-h-screen items-center justify-center p-4">
          <div class="fixed inset-0 bg-black/50" data-action="click->category-filter#close"></div>
          <div class="relative bg-container dark:bg-container-dark rounded-lg shadow-xl w-full max-w-sm lg:max-w-md xl:max-w-lg p-5">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-semibold text-primary dark:text-primary-dark">选择分类（可多选）</h3>
              <button type="button" data-action="click->category-filter#close" class="p-1 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth">
                <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
              </button>
            </div>
            <input type="text" id="category-stats-filter-search" data-category-filter-target="searchInput" data-action="input->category-filter#search" placeholder="搜索分类（支持拼音）" class="w-full px-3 py-2 mb-3 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-surface-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <div id="category-stats-filter-options" class="max-h-80 overflow-y-auto border border-border dark:border-border-dark rounded-lg">
              <% if expense_cats.any? %>
              <div class="category-type-section <%= income_cats.any? ? 'border-b border-border dark:border-border-dark' : '' %>">
                <div class="px-3 py-2 bg-expense/10 dark:bg-expense/20 text-xs font-medium text-expense uppercase tracking-wide">支出分类</div>
                <%= render_category_filter_tree(expense_cats, all_cat_ids, true) %>
              </div>
              <% end %>
              <% if income_cats.any? %>
              <div class="category-type-section">
                <div class="px-3 py-2 bg-income/10 dark:bg-income/20 text-xs font-medium text-income uppercase tracking-wide">收入分类</div>
                <%= render_category_filter_tree(income_cats, all_cat_ids, true) %>
              </div>
              <% end %>
            </div>
            <div class="flex justify-between mt-4">
              <div class="flex gap-2">
                <button type="button" id="category-stats-select-all" data-category-filter-target="selectAllBtn" data-action="click->category-filter#selectAll" class="px-3 py-1.5 text-xs font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover transition-smooth">全选</button>
                <button type="button" id="category-stats-clear-all" data-category-filter-target="clearBtn" data-action="click->category-filter#clearAll" class="px-3 py-1.5 text-xs font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover transition-smooth">清除</button>
              </div>
              <div class="flex gap-3">
                <button type="button" data-action="click->category-filter#close" class="px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover transition-smooth">取消</button>
                <button type="button" id="confirm-category-stats-filter" data-category-filter-target="confirmBtn" data-action="click->category-filter#confirm" class="px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">确定</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ====== 面板 2: 支出分类 ====== -->
    <div data-report-tabs-target="panel" data-panel-name="expense" class="hidden" role="tabpanel" aria-label="支出分类">
      <% expense_cats = @categories.select { |c| c.category_type == 'EXPENSE' && c.parent_id.nil? }.sort_by(&:name) %>
      <% expense_cat_ids = @categories.select { |c| c.category_type == 'EXPENSE' }.map(&:id).map(&:to_s) %>
      <% expense_filter_active_ids = @filter_categories[:expense].map { |c| c[:id].to_s } %>
      <!-- 筛选按钮 -->
      <div class="relative mb-4">
        <button type="button" id="open-expense-filter" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface dark:hover:bg-surface-dark transition-smooth">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
          筛选分类
          <span id="expense-filter-count" class="ml-0.5 px-1.5 py-0.5 text-xs rounded-full bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark"><%= expense_filter_active_ids.size %></span>
        </button>
        <div class="hidden" data-filter-group="expense">
          <% expense_filter_active_ids.each do |id| %>
            <input type="checkbox" value="<%= id %>" data-tab-filter checked class="hidden">
          <% end %>
        </div>
      </div>

      <section class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs">
        <div class="px-4 py-3 border-b border-border dark:border-border-dark flex items-center justify-between">
          <h2 class="text-base font-semibold text-primary dark:text-primary-dark">支出分类明细</h2>
          <span class="text-xs text-secondary dark:text-secondary-dark"><%= @expense_chart_data.size %> 项分类</span>
        </div>
        <div class="p-4">
          <% if @expense_chart_data.any? %>
            <% total_exp = @expense_chart_data.sum { |d| d[:value] } %>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
              <div class="space-y-1 overflow-y-auto max-h-[400px] pr-1" id="expense-category-list">
                <% @expense_chart_data.each_with_index do |cat, idx| %>
                  <% percentage = total_exp > 0 ? (cat[:value] / total_exp * 100).round(1) : 0 %>
                  <% bar_width = [percentage, 95].min %>
                  <div class="flex items-center gap-2 py-1.5 px-2 rounded-lg hover:bg-surface dark:hover:bg-surface-dark transition-smooth cursor-default group"
                       data-category-row data-category-index="<%= idx %>" data-category-id="<%= cat[:id] %>">
                    <span class="text-xs text-secondary dark:text-secondary-dark w-5 text-right shrink-0"><%= idx + 1 %></span>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center justify-between mb-0.5">
                        <span class="text-sm font-medium text-primary dark:text-primary-dark truncate"><%= cat[:label] %></span>
                        <span class="text-xs text-secondary dark:text-secondary-dark ml-2 shrink-0"><%= percentage %>%</span>
                      </div>
                      <div class="w-full h-1.5 bg-surface dark:bg-surface-dark rounded-full overflow-hidden">
                        <div class="h-full rounded-full transition-all duration-300 group-hover:opacity-80"
                             style="width: <%= bar_width %>%; background-color: var(--color-expense, #ef4444); opacity: <%= [0.4 + (idx * 0.05), 1].min %>"></div>
                      </div>
                    </div>
                    <span class="text-sm font-medium text-expense w-24 text-right shrink-0 ml-2"><%= format_currency(cat[:value]) %></span>
                  </div>
                <% end %>
              </div>
              <div data-controller="category-donut-chart"
                   data-category-donut-chart-data-value="<%= @expense_chart_data.to_json %>"
                   class="h-72 flex items-center justify-center">
                <canvas data-category-donut-chart-target="canvas"></canvas>
              </div>
            </div>
          <% else %>
            <div class="h-64 flex items-center justify-center text-secondary dark:text-secondary-dark">暂无数据</div>
          <% end %>
        </div>
      </section>
    </div>

    <!-- ====== 面板 3: 收入分类 ====== -->
    <div data-report-tabs-target="panel" data-panel-name="income" class="hidden" role="tabpanel" aria-label="收入分类">
      <% income_cats = @categories.select { |c| c.category_type == 'INCOME' && c.parent_id.nil? }.sort_by(&:name) %>
      <% income_cat_ids = @categories.select { |c| c.category_type == 'INCOME' }.map(&:id).map(&:to_s) %>
      <% income_filter_active_ids = @filter_categories[:income].map { |c| c[:id].to_s } %>
      <!-- 筛选按钮 -->
      <div class="relative mb-4">
        <button type="button" id="open-income-filter" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface dark:hover:bg-surface-dark transition-smooth">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
          筛选分类
          <span id="income-filter-count" class="ml-0.5 px-1.5 py-0.5 text-xs rounded-full bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark"><%= income_filter_active_ids.size %></span>
        </button>
        <div class="hidden" data-filter-group="income">
          <% income_filter_active_ids.each do |id| %>
            <input type="checkbox" value="<%= id %>" data-tab-filter checked class="hidden">
          <% end %>
        </div>
      </div>

      <section class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs">
        <div class="px-4 py-3 border-b border-border dark:border-border-dark flex items-center justify-between">
          <h2 class="text-base font-semibold text-primary dark:text-primary-dark">收入分类明细</h2>
          <span class="text-xs text-secondary dark:text-secondary-dark"><%= @income_chart_data.size %> 项分类</span>
        </div>
        <div class="p-4">
          <% if @income_chart_data.any? %>
            <% total_inc = @income_chart_data.sum { |d| d[:value] } %>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
              <div class="space-y-1 overflow-y-auto max-h-[360px] pr-1" id="income-category-list">
                <% @income_chart_data.each_with_index do |cat, idx| %>
                  <% percentage = total_inc > 0 ? (cat[:value] / total_inc * 100).round(1) : 0 %>
                  <% bar_width = [percentage, 95].min %>
                  <div class="flex items-center gap-2 py-1.5 px-2 rounded-lg hover:bg-surface dark:hover:bg-surface-dark transition-smooth cursor-default group"
                       data-income-row data-category-index="<%= idx %>" data-category-id="<%= cat[:id] %>">
                    <span class="text-xs text-secondary dark:text-secondary-dark w-5 text-right shrink-0"><%= idx + 1 %></span>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center justify-between mb-0.5">
                        <span class="text-sm font-medium text-primary dark:text-primary-dark truncate"><%= cat[:label] %></span>
                        <span class="text-xs text-secondary dark:text-secondary-dark ml-2 shrink-0"><%= percentage %>%</span>
                      </div>
                      <div class="w-full h-1.5 bg-surface dark:bg-surface-dark rounded-full overflow-hidden">
                        <div class="h-full rounded-full transition-all duration-300 group-hover:opacity-80"
                             style="width: <%= bar_width %>%; background-color: var(--color-income, #22c55e); opacity: <%= [0.4 + (idx * 0.05), 1].min %>"></div>
                      </div>
                    </div>
                    <span class="text-sm font-medium text-income w-24 text-right shrink-0 ml-2"><%= format_currency(cat[:value]) %></span>
                  </div>
                <% end %>
              </div>
              <div data-controller="category-donut-chart"
                   data-category-donut-chart-data-value="<%= @income_chart_data.to_json %>"
                   class="h-64 flex items-center justify-center">
                <canvas data-category-donut-chart-target="canvas"></canvas>
              </div>
            </div>
          <% else %>
            <div class="h-64 flex items-center justify-center text-secondary dark:text-secondary-dark">暂无数据</div>
          <% end %>
        </div>
      </section>
    </div>

    <!-- ====== 面板 4: 预算进度（仅月度） ====== -->
    <% if @report_type == :monthly && @budget_progress&.any? %>
    <div data-report-tabs-target="panel" data-panel-name="budget" class="hidden" role="tabpanel" aria-label="预算进度">
      <section class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs">
        <div class="px-4 py-3 border-b border-border dark:border-border-dark">
          <h2 class="text-base font-semibold text-primary dark:text-primary-dark">预算进度</h2>
        </div>
        <div class="p-4 space-y-4">
          <% @budget_progress.each do |item| %>
            <div class="min-w-0">
              <div class="flex justify-between text-sm mb-1.5 gap-2">
                <span class="text-primary dark:text-primary-dark truncate"><%= item[:budget].category&.name || "未知分类" %></span>
                <span class="<%= item[:percentage] > 100 ? 'text-expense' : 'text-primary dark:text-primary-dark' %> shrink-0">
                  <%= format_currency(item[:spent]) %> / <%= format_currency(item[:budget].amount) %>
                </span>
              </div>
              <div class="w-full bg-surface dark:bg-surface-dark rounded-full h-2.5">
                <div class="<%= item[:percentage] > 100 ? 'bg-expense' : (item[:percentage] > 80 ? 'bg-income' : 'bg-inverse') %> h-2.5 rounded-full transition-all" style="width: <%= [item[:percentage], 100].min %>%"></div>
              </div>
              <p class="text-xs text-secondary dark:text-secondary-dark mt-1"><%= item[:percentage] %>% 已使用</p>
            </div>
          <% end %>
        </div>
      </section>
    </div>
    <% end %>

    <!-- ====== 面板 5: 资产走势（仅年度） ====== -->
    <% if @report_type == :yearly && @asset_trend&.any? %>
    <div data-report-tabs-target="panel" data-panel-name="assets" class="hidden" role="tabpanel" aria-label="资产走势">
      <section class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs">
        <div class="px-4 py-3 border-b border-border dark:border-border-dark">
          <h2 class="text-base font-semibold text-primary dark:text-primary-dark">资产走势图</h2>
        </div>
        <div class="p-4">
          <div id="asset-trend-chart" class="h-80"
               data-controller="asset-trend-chart"
               data-asset-trend-chart-labels-value="<%= @asset_trend.map { |d| d[:label] }.to_json %>"
               data-asset-trend-chart-assets-value="<%= @asset_trend.map { |d| d[:assets] }.to_json %>"
               data-asset-trend-chart-liabilities-value="<%= @asset_trend.map { |d| d[:liabilities] }.to_json %>"
               data-asset-trend-chart-net-worth-value="<%= @asset_trend.map { |d| d[:net_worth] }.to_json %>">
            <canvas data-asset-trend-chart-target="canvas"></canvas>
          </div>
          <div class="flex items-center justify-center gap-6 mt-3 text-sm">
            <div class="flex items-center gap-1.5">
              <span class="w-3 h-0.5 rounded" style="background-color: var(--color-chart-asset)"></span>
              <span class="text-secondary dark:text-secondary-dark">资产</span>
            </div>
            <div class="flex items-center gap-1.5">
              <span class="w-3 h-0.5 rounded" style="background-color: var(--color-chart-liability)"></span>
              <span class="text-secondary dark:text-secondary-dark">负债</span>
            </div>
            <div class="flex items-center gap-1.5">
              <span class="w-3 h-0.5 rounded" style="background-color: var(--color-chart-net-worth)"></span>
              <span class="text-secondary dark:text-secondary-dark">净资产</span>
            </div>
          </div>
        </div>
      </section>
    </div>
    <% end %>

    <!-- ====== 面板 6: 年度月度对比（仅年度） ====== -->
    <% if @report_type == :yearly && @category_monthly_comparison[:categories]&.any? %>
    <div data-report-tabs-target="panel" data-panel-name="comparison" class="hidden" role="tabpanel" aria-label="分类月度对比">
      <% comparison_cat_ids = @category_monthly_comparison[:categories].keys.map(&:to_s) %>
      <!-- 筛选按钮 -->
      <div class="relative mb-4">
        <button type="button" id="open-comparison-filter" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface dark:hover:bg-surface-dark transition-smooth">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
          筛选分类
          <span id="comparison-filter-count" class="ml-0.5 px-1.5 py-0.5 text-xs rounded-full bg-surface dark:bg-surface-dark text-secondary dark:text-secondary-dark"><%= comparison_cat_ids.size %></span>
        </button>
        <div class="hidden" data-filter-group="comparison">
          <% comparison_cat_ids.each do |id| %>
            <input type="checkbox" value="<%= id %>" data-tab-filter checked class="hidden">
          <% end %>
        </div>
      </div>

      <section class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs overflow-hidden">
        <div class="px-4 py-3 border-b border-border dark:border-border-dark flex items-center justify-between">
          <h2 class="text-base font-semibold text-primary dark:text-primary-dark">年度分类月度对比</h2>
          <div class="flex items-center gap-2 text-xs text-secondary dark:text-secondary-dark">
            <label class="flex items-center gap-1 cursor-pointer">
              <input type="checkbox" id="toggle-comparison-chart" checked class="w-3.5 h-3.5 rounded border-border text-blue-600 focus:ring-blue-500">
              显示趋势图
            </label>
          </div>
        </div>
        <div class="p-4 overflow-x-auto">
          <% comparison_cats = @category_monthly_comparison[:categories] %>
          <% comparison_totals = @category_monthly_comparison[:monthly_totals] %>
          <% comparison_max_val = comparison_cats.values.map { |c| c[:monthly].values.max }.compact.max || 1 %>
          <div id="category-comparison-wrapper" data-controller="category-comparison"
               data-category-comparison-categories-value="<%= comparison_cats.to_json %>">
            <table class="w-full text-xs">
              <thead>
                <tr class="border-b border-border dark:border-border-dark">
                  <th class="text-left py-1.5 px-2 font-medium text-secondary dark:text-secondary-dark sticky left-0 bg-container dark:bg-container-dark z-10 min-w-[80px]">分类名称</th>
                  <th class="text-right py-1.5 px-2 font-medium text-secondary dark:text-secondary-dark">合计</th>
                  <% (1..12).each do |m| %>
                    <th class="text-right py-1.5 px-1.5 font-medium text-secondary dark:text-secondary-dark"><%= m %>月</th>
                  <% end %>
                </tr>
              </thead>
              <tbody id="comparison-table-body">
                <% comparison_cats.each_with_index do |(cat_id, cat_data), idx| %>
                <% is_income = cat_data[:kind] == 'income' %>
                <tr class="border-b border-border/50 dark:border-border-dark/50 hover:bg-surface dark:hover:bg-surface-dark transition-smooth cursor-pointer comparison-row"
                    data-category-id="<%= cat_id %>"
                    data-row-index="<%= idx %>">
                  <td class="py-1.5 px-2 font-medium text-primary dark:text-primary-dark sticky left-0 bg-inherit z-5 whitespace-nowrap">
                    <span class="inline-flex items-center gap-1">
                      <span class="text-[10px] px-1 py-px rounded leading-none <%= is_income ? 'bg-income/10 text-income' : 'bg-expense/10 text-expense' %>"><%= is_income ? '收' : '支' %></span>
                      <%= cat_data[:name] %>
                    </span>
                  </td>
                  <td class="py-1.5 px-2 text-right font-semibold <%= is_income ? 'text-income' : 'text-expense' %> whitespace-nowrap"><%= format_currency(cat_data[:total]) %></td>
                  <% (1..12).each do |m| %>
                    <% val = cat_data[:monthly][m] %>
                    <% has_value = val && val > 0 %>
                    <td class="py-1.5 px-1.5 text-right whitespace-nowrap monthly-cell" data-month="<%= m %>">
                      <% if has_value %>
                        <span class="<%= is_income ? 'text-income' : 'text-expense' %>"><%= format_currency(val) %></span>
                        <div class="mt-0.5 h-0.5 bg-surface dark:bg-surface-dark rounded-full overflow-hidden" style="width: 48px" title="<%= val %>">
                          <div class="h-full <%= is_income ? 'bg-income/60' : 'bg-expense/60' %> rounded-full transition-all duration-200" style="width: <%= [(val / [comparison_max_val, val].max * 100).round, 100].min %>%; opacity: 0.7"></div>
                        </div>
                      <% else %>
                        <span class="text-gray-300 dark:text-gray-600">—</span>
                      <% end %>
                    </td>
                  <% end %>
                </tr>
                <% end %>

                <%# 总计行 %>
                <tr class="border-t-2 border-border dark:border-border-dark bg-surface/50 dark:bg-surface-dark/50 font-semibold">
                  <td class="py-2 px-2 text-primary dark:text-primary-dark sticky left-0 bg-inherit z-5">支出总计</td>
                  <td class="py-2 px-2 text-right text-expense"><%= format_currency(comparison_totals.values.sum { |t| t[:expense] }) %></td>
                  <% (1..12).each do |m| %>
                    <td class="py-2 px-1.5 text-right text-expense"><%= format_currency(comparison_totals.dig(m, :expense)) %></td>
                  <% end %>
                </tr>
                <tr class="border-b border-border/50 dark:border-border-dark/50 bg-surface/50 dark:bg-surface-dark/50 font-semibold">
                  <td class="py-2 px-2 text-primary dark:text-primary-dark sticky left-0 bg-inherit z-5">收入总计</td>
                  <td class="py-2 px-2 text-right text-income"><%= format_currency(comparison_totals.values.sum { |t| t[:income] }) %></td>
                  <% (1..12).each do |m| %>
                    <td class="py-2 px-1.5 text-right text-income"><%= format_currency(comparison_totals.dig(m, :income)) %></td>
                  <% end %>
                </tr>
                <tr class="border-b-2 border-border dark:border-border-dark bg-surface dark:bg-surface-dark font-bold">
                  <td class="py-2 px-2 text-primary dark:text-primary-dark sticky left-0 bg-inherit z-10">差额</td>
                  <% total_diff = comparison_totals.values.sum { |t| t[:income] - t[:expense] } %>
                  <td class="py-2 px-2 text-right <%= total_diff >= 0 ? 'text-income' : 'text-expense' %>"><%= format_currency(total_diff) %></td>
                  <% (1..12).each do |m| %>
                    <% diff = comparison_totals.dig(m, :income) - comparison_totals.dig(m, :expense) %>
                    <td class="py-2 px-1.5 text-right <%= diff >= 0 ? 'text-income' : 'text-expense' %>"><%= format_currency(diff) %></td>
                  <% end %>
                </tr>
              </tbody>
            </table>

            <div id="comparison-chart-area" class="mt-6 hidden">
              <h3 class="text-sm font-medium text-secondary dark:text-secondary-dark mb-3">
                趋势图：<span id="selected-category-name" class="text-primary dark:text-primary-dark font-semibold">—</span>
              </h3>
              <div class="h-56">
                <canvas id="comparison-line-chart"></canvas>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
    <% end %>

    <!-- ====== 面板 7: 收支流向桑基图（仅年度） ====== -->
    <% if @report_type == :yearly && @sankey_data&.any? %>
    <div data-report-tabs-target="panel" data-panel-name="sankey" class="hidden" role="tabpanel" aria-label="收支流向">
      <section class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs">
        <div class="px-4 py-3 border-b border-border dark:border-border-dark">
          <h2 class="text-base font-semibold text-primary dark:text-primary-dark">收支流向图（桑基图）</h2>
          <p class="text-xs text-secondary dark:text-secondary-dark mt-1">展示收入来源如何流向各类支出</p>
        </div>
        <div class="p-4 overflow-x-auto">
          <% if @sankey_data[:nodes]&.any? && @sankey_data[:links]&.any? %>
            <div data-controller="sankey-chart"
                 data-sankey-chart-data-value="<%= @sankey_data.to_json %>"

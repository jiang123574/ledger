    </div>
    <% end %>

    <!-- ====== 面板 8: 消费日历热力图（仅年度） ====== -->
    <% if @report_type == :yearly && @calendar_heatmap_data&.any? %>
    <div data-report-tabs-target="panel" data-panel-name="heatmap" class="hidden" role="tabpanel" aria-label="消费日历">
      <section class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs">
        <div class="px-4 py-3 border-b border-border dark:border-border-dark">
          <h2 class="text-base font-semibold text-primary dark:text-primary-dark">消费日历热力图</h2>
          <p class="text-xs text-secondary dark:text-secondary-dark mt-1">每日消费金额分布（颜色越深消费越高）</p>
        </div>
        <div class="p-4">
          <div data-controller="calendar-heatmap"
               data-calendar-heatmap-data-value="<%= @calendar_heatmap_data.to_json %>"
               data-calendar-heatmap-year-value="<%= @year %>"
               class="overflow-x-auto">
            <svg data-calendar-heatmap-target="chart"></svg>
          </div>
        </div>
      </section>
    </div>
    <% end %>

    <!-- ====== 面板 9: 净资产瀑布图（仅年度） ====== -->
    <% if @report_type == :yearly && @waterfall_data&.any? %>
    <div data-report-tabs-target="panel" data-panel-name="waterfall" class="hidden" role="tabpanel" aria-label="余额变动">
      <section class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs">
        <div class="px-4 py-3 border-b border-border dark:border-border-dark">
          <h2 class="text-base font-semibold text-primary dark:text-primary-dark">净资产变动瀑布图</h2>
          <p class="text-xs text-secondary dark:text-secondary-dark mt-1">展示全年净资产从年初到年末的月度变化</p>
        </div>
        <div class="p-4">
          <div data-controller="waterfall-chart"
               data-waterfall-chart-labels-value="<%= @waterfall_data[:labels].to_json %>"
               data-waterfall-chart-data-value="<%= @waterfall_data[:data].to_json %>"
               data-waterfall-chart-totals-value="<%= @waterfall_data[:totals].to_json %>"
               class="h-72">
            <canvas data-waterfall-chart-target="canvas"></canvas>
          </div>
        </div>
      </section>
    </div>
    <% end %>
  </main>
</div>


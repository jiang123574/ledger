<div class="space-y-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
    <h1 class="text-2xl font-semibold text-primary">应收款</h1>
    <%= render(Ds::ButtonComponent.new(href: new_receivable_path, icon: "plus", variant: :primary)) do %>
      新建应收款
    <% end %>
  </div>

  <!-- Unsettled Section -->
  <% if @unsettled.any? %>
    <div class="space-y-4">
      <h2 class="text-lg font-medium text-primary">待报销</h2>
      <div class="grid gap-4">
        <% @unsettled.each do |receivable| %>
          <%= render(Ds::CardComponent.new, padding: false) do %>
            <div class="p-4">
              <div class="flex items-start justify-between">
                <div class="flex items-center gap-3">
                  <div class="w-12 h-12 rounded-full bg-orange-100 flex items-center justify-center">
                    <span class="text-lg font-bold text-orange-600">¥</span>
                  </div>
                  <div>
                    <h3 class="font-semibold text-primary"><%= receivable.description %></h3>
                    <p class="text-sm text-secondary"><%= receivable.date&.strftime("%Y-%m-%d") %></p>
                    <% if receivable.category.present? %>
                      <%= render(Ds::BadgeComponent.new(variant: :default, size: :xs)) do %>
                        <%= receivable.category %>
                      <% end %>
                    <% end %>
                  </div>
                </div>
                <div class="text-right">
                  <p class="text-xl font-bold text-orange-600"><%= format_currency(receivable.remaining_amount) %></p>
                  <p class="text-sm text-secondary">剩余 / <%= format_currency(receivable.original_amount) %> 总额</p>
                </div>
              </div>

              <!-- Progress Bar -->
              <div class="mt-4">
                <% progress = receivable.original_amount > 0 ? (receivable.remaining_amount.to_f / receivable.original_amount.to_f * 100).round : 0 %>
                <div class="w-full bg-surface rounded-full h-2">
                  <div class="bg-orange-500 h-2 rounded-full" style="width: <%= progress %>%"></div>
                </div>
              </div>

              <!-- Actions -->
              <div class="mt-4 flex justify-end gap-2">
                <%= link_to "报销", settle_receivable_path(receivable), class: "px-3 py-1.5 text-sm font-medium rounded-lg bg-green-600 text-white hover:bg-green-700 transition-smooth btn-modern" %>
                <%= link_to "编辑", edit_receivable_path(receivable), class: "px-3 py-1.5 text-sm font-medium rounded-lg border border-border text-primary hover:bg-surface-hover transition-smooth btn-modern" %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Settled Section -->
  <% if @settled.any? %>
    <div class="space-y-4">
      <h2 class="text-lg font-medium text-primary">已完成</h2>
      <div class="grid gap-4">
        <% @settled.each do |receivable| %>
          <%= render(Ds::CardComponent.new, padding: false) do %>
            <div class="p-4 opacity-60">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center">
                    <%= render(Ds::IconComponent.new(name: "check", size: :md, color: :success)) %>
                  </div>
                  <div>
                    <h3 class="font-medium text-primary"><%= receivable.description %></h3>
                    <p class="text-sm text-secondary">完成于 <%= receivable.settled_at&.strftime("%Y-%m-%d") %></p>
                  </div>
                </div>
                <span class="font-medium text-secondary"><%= format_currency(receivable.original_amount) %></span>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Empty State -->
  <% if @receivables.empty? %>
    <%= render(Ds::CardComponent.new) do %>
      <%= render(Ds::EmptyStateComponent.new(
        icon: "receipt",
        title: "暂无应收款",
        description: "添加应收款来追踪待报销的费用",
        action: new_receivable_path,
        action_label: "新建应收款"
      )) %>
    <% end %>
  <% end %>
</div>

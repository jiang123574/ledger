<div class="space-y-6">
  <!-- Header -->
  <div class="flex justify-between items-center">
    <h1 class="text-2xl font-bold text-primary dark:text-primary-dark">应收款</h1>
    <button type="button" onclick="document.getElementById('add-receivable-modal').classList.remove('hidden')" class="inline-flex items-center justify-center gap-2 font-medium transition-smooth btn-modern focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed px-4 py-1.5 text-sm rounded-lg bg-inverse text-white hover:bg-inverse-hover">
      <%= render(Ds::IconComponent.new(name: "plus", size: :sm)) %>
      新建应收款
    </button>
  </div>

  <!-- Unsettled Section -->
  <% if @unsettled.any? %>
    <div class="space-y-4">
      <h2 class="text-lg font-semibold text-primary dark:text-primary-dark">待报销</h2>
      <div class="grid gap-4">
        <% @unsettled.each do |receivable| %>
          <div class="bg-container dark:bg-container-dark rounded-lg shadow p-4 border-l-4 border-orange-500">
            <div class="flex justify-between items-start">
              <div class="flex-1">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-full bg-orange-100 dark:bg-orange-900/20 flex items-center justify-center shrink-0">
                    <span class="text-lg font-bold text-orange-600 dark:text-orange-400">¥</span>
                  </div>
                  <div>
                    <h3 class="font-semibold text-primary dark:text-primary-dark"><%= receivable.description %></h3>
                    <div class="flex items-center gap-2 mt-1">
                      <span class="text-sm text-secondary dark:text-secondary-dark"><%= receivable.date&.strftime("%Y-%m-%d") %></span>
                      <% if receivable.category.present? %>
                        <span class="px-2 py-0.5 text-xs rounded-full bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark">
                          <%= receivable.category %>
                        </span>
                      <% end %>
                    </div>
                  </div>
                </div>

                <!-- Progress Bar -->
                <% progress = receivable.original_amount > 0 ? (receivable.remaining_amount.to_f / receivable.original_amount.to_f * 100).round : 0 %>
                <div class="mt-3">
                  <div class="flex justify-between text-sm text-secondary dark:text-secondary-dark mb-1">
                    <span>剩余 <%= format_currency(receivable.remaining_amount) %> / <%= format_currency(receivable.original_amount) %> 总额</span>
                    <span><%= progress %>%</span>
                  </div>
                  <div class="w-full bg-surface dark:bg-surface-dark rounded-full h-2">
                    <div class="bg-orange-500 dark:bg-orange-400 h-2 rounded-full transition-all" style="width: <%= progress %>"></div>
                  </div>
                </div>
              </div>

              <div class="flex items-center gap-2 ml-4">
                <button type="button" onclick="openSettleModal('<%= receivable.id %>', '<%= receivable.description %>', '<%= receivable.remaining_amount %>')" class="px-3 py-1.5 text-sm font-medium rounded-lg bg-green-600 dark:bg-green-500 text-white hover:bg-green-700 dark:hover:bg-green-600 transition-smooth btn-modern">报销</button>
                <%= link_to "编辑", edit_receivable_path(receivable), class: "px-3 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth btn-modern" %>
                <%= button_to "删除", receivable, method: :delete, onclick: "if(!confirm('确定删除此报销记录？')) return false", class: "px-3 py-1.5 text-sm font-medium rounded-lg bg-red-100 dark:bg-red-900/20 text-red-600 dark:text-red-400 hover:bg-red-200 dark:hover:bg-red-900/40 transition-smooth btn-modern" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Settled Section -->
  <% if @settled.any? %>
    <div class="space-y-4">
      <h2 class="text-lg font-semibold text-primary dark:text-primary-dark">已完成</h2>
      <div class="grid gap-4">
        <% @settled.each do |receivable| %>
          <div class="bg-container dark:bg-container-dark rounded-lg shadow p-4 border-l-4 border-green-500 opacity-75">
            <div class="flex justify-between items-center">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-green-100 dark:bg-green-900/20 flex items-center justify-center shrink-0">
                  <%= render(Ds::IconComponent.new(name: "check", size: :md, color: :success)) %>
                </div>
                <div>
                  <h3 class="font-medium text-primary dark:text-primary-dark"><%= receivable.description %></h3>
                  <p class="text-sm text-secondary dark:text-secondary-dark">完成于 <%= receivable.settled_at&.strftime("%Y-%m-%d") %></p>
                </div>
              </div>
              <span class="font-medium text-secondary dark:text-secondary-dark"><%= format_currency(receivable.original_amount) %></span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Empty State -->
  <% if @receivables.empty? %>
    <div class="bg-container dark:bg-container-dark rounded-lg shadow p-8 text-center">
      <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-surface dark:bg-surface-dark flex items-center justify-center">
        <%= render(Ds::IconComponent.new(name: "receipt", size: :xl, color: :secondary)) %>
      </div>
      <p class="text-secondary dark:text-secondary-dark">暂无应收款</p>
      <p class="text-secondary dark:text-secondary-dark text-sm mt-2">添加应收款来追踪待报销的费用</p>
      <button type="button" onclick="document.getElementById('add-receivable-modal').classList.remove('hidden')" class="inline-flex items-center justify-center gap-2 font-medium transition-smooth btn-modern focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed px-4 py-1.5 text-sm rounded-lg bg-inverse text-white hover:bg-inverse-hover mt-4">
        <%= render(Ds::IconComponent.new(name: "plus", size: :sm)) %>
        新建应收款
      </button>
    </div>
  <% end %>
</div>

<!-- Add Receivable Modal -->
<div id="add-receivable-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('add-receivable-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-lg shadow-xl w-full max-w-md p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-primary dark:text-primary-dark">新建应收款</h3>
        <button type="button" onclick="document.getElementById('add-receivable-modal').classList.add('hidden')" class="p-1 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth">
          <%= render Ds::IconComponent.new(name: "x-mark", size: :md) %>
        </button>
      </div>
      
      <%= form_with model: @receivable || Receivable.new, url: receivables_path, method: :post, local: true, id: "quick-receivable-form" do |f| %>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">描述 *</label>
            <%= f.text_field :description, placeholder: "如：出差北京交通费", required: true,
                class: "w-full px-3 py-2.5 text-base rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 focus:border-blue-500 dark:focus:border-blue-400" %>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">日期 *</label>
              <%= f.date_field :date, required: true, value: Date.today,
                  class: "w-full px-3 py-2.5 text-base rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 focus:border-blue-500 dark:focus:border-blue-400" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">金额 *</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
                <%= f.number_field :original_amount, step: "0.01", placeholder: "0.00", required: true,
                    class: "w-full pl-8 pr-3 py-2.5 text-base rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 focus:border-blue-500 dark:focus:border-blue-400" %>
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">类别</label>
            <%= f.select :category, 
              ["差旅", "餐饮", "交通", "办公用品", "其他"],
              { include_blank: "选择类别" },
              class: "w-full px-3 py-2.5 text-base rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 focus:border-blue-500 dark:focus:border-blue-400" %>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">联系人</label>
            <%= f.collection_select :counterparty_id, @counterparties, :id, :name, { include_blank: "选择联系人" },
                class: "w-full px-3 py-2.5 text-base rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 focus:border-blue-500 dark:focus:border-blue-400" %>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">支出账户</label>
            <%= f.collection_select :account_id, @accounts, :id, :name, { include_blank: "选择账户" },
                class: "w-full px-3 py-2.5 text-base rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 focus:border-blue-500 dark:focus:border-blue-400" %>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">备注</label>
            <%= f.text_field :note, placeholder: "可选",
                class: "w-full px-3 py-2.5 text-base rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 focus:border-blue-500 dark:focus:border-blue-400" %>
          </div>
        </div>

        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="document.getElementById('add-receivable-modal').classList.add('hidden')" class="px-4 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">取消</button>
          <button type="submit" class="px-4 py-2 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover dark:hover:bg-inverse-dark-hover transition-smooth">保存</button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Settle Receivable Modal -->
<div id="settle-receivable-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('settle-receivable-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-lg shadow-xl w-full max-w-md p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-primary dark:text-primary-dark">报销应收款</h3>
        <button type="button" onclick="document.getElementById('settle-receivable-modal').classList.add('hidden')" class="p-1 hover:bg-surface-hover dark:hover:bg-surface-dark-hover rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      
      <p id="settle-description" class="text-secondary dark:text-secondary-dark mb-4"></p>
      
      <%= form_with url: settle_receivable_path(0), method: :post, local: true, id: "settle-form" do |f| %>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">报销金额 *</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
              <%= f.number_field :amount, step: "0.01", placeholder: "0.00", required: true,
                  class: "w-full pl-8 pr-3 py-2.5 text-base rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 focus:border-blue-500 dark:focus:border-blue-400" %>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">账户 *</label>
            <%= f.collection_select :account_id, @accounts, :id, :name, { include_blank: "选择账户" }, required: true,
                class: "w-full px-3 py-2.5 text-base rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 focus:border-blue-500 dark:focus:border-blue-400" %>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1.5">备注</label>
            <%= f.text_field :note, placeholder: "可选",
                class: "w-full px-3 py-2.5 text-base rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 focus:border-blue-500 dark:focus:border-blue-400" %>
          </div>
        </div>

        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="document.getElementById('settle-receivable-modal').classList.add('hidden')" class="px-4 py-2 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">取消</button>
          <button type="submit" class="px-4 py-2 text-sm font-medium rounded-lg bg-green-600 text-white hover:bg-green-700 transition-smooth">确认报销</button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
function openSettleModal(id, description, remainingAmount) {
  document.getElementById('settle-description').textContent = description + ' (剩余: ¥' + remainingAmount + ')';
  document.getElementById('settle-form').action = '/receivables/' + id + '/settle';
  document.getElementById('settle-receivable-modal').classList.remove('hidden');
}
</script>

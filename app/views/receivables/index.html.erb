<% content_for :page_title, "应收款" %>

<div class="space-y-4 sm:space-y-6">
  <div class="flex flex-col gap-3 sm:flex-row sm:justify-between sm:items-center sm:gap-4">
    <div>
      <h1 class="text-xl sm:text-2xl font-semibold text-primary dark:text-primary-dark">应收款</h1>
      <p class="text-xs sm:text-sm text-secondary dark:text-secondary-dark mt-0.5 sm:mt-1">追踪待报销与已报销款项</p>
    </div>
    <button type="button" onclick="openNewReceivableModal()" class="inline-flex items-center justify-center gap-2 font-medium transition-smooth btn-modern focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed px-4 py-1.5 text-sm rounded-lg bg-inverse text-white hover:bg-inverse-hover">
      <%= render(Ds::IconComponent.new(name: "plus", size: :sm)) %>
      新建应收款
    </button>
  </div>

  <% total_amount = @receivables.sum { |r| r.original_amount.to_d } %>
  <% pending_amount = @unsettled.sum { |r| r.remaining_amount.to_d } %>
  <% reimbursed_amount = @receivables.sum { |r| (r.original_amount.to_d - r.remaining_amount.to_d) } %>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
    <%= render(Ds::CardComponent.new(padding: false, rounded: :xl, class: "p-3")) do %>
      <p class="text-xs sm:text-sm font-medium text-secondary dark:text-secondary-dark">应收总额</p>
      <p class="text-lg sm:text-2xl font-semibold text-primary dark:text-primary-dark mt-0.5 sm:mt-1"><%= format_currency(total_amount) %></p>
    <% end %>
    <%= render(Ds::CardComponent.new(padding: false, rounded: :xl, class: "p-3")) do %>
      <p class="text-xs sm:text-sm font-medium text-secondary dark:text-secondary-dark">待报销金额</p>
      <p class="text-lg sm:text-2xl font-semibold text-expense mt-0.5 sm:mt-1"><%= format_currency(pending_amount) %></p>
    <% end %>
    <%= render(Ds::CardComponent.new(padding: false, rounded: :xl, class: "p-3")) do %>
      <p class="text-xs sm:text-sm font-medium text-secondary dark:text-secondary-dark">已报销金额</p>
      <p class="text-lg sm:text-2xl font-semibold text-income mt-0.5 sm:mt-1"><%= format_currency(reimbursed_amount) %></p>
    <% end %>
  </div>

  <% if @unsettled_counterparty_stats.any? %>
    <section class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs p-3">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-sm font-semibold text-primary dark:text-primary-dark">待报销按联系人</h2>
        <span class="text-xs text-secondary dark:text-secondary-dark">Top <%= @unsettled_counterparty_stats.size %></span>
      </div>
      <div class="flex gap-2 overflow-x-auto pb-1">
        <%= link_to receivables_path, class: "shrink-0 min-w-[140px] px-3 py-2 rounded-lg border #{ @selected_counterparty_id.blank? ? 'bg-blue-50 dark:bg-blue-900/20 border-blue-200 dark:border-blue-800' : 'bg-surface dark:bg-surface-dark border-border dark:border-border-dark' }" do %>
          <p class="text-sm font-medium text-primary dark:text-primary-dark">全部联系人</p>
          <p class="text-xs text-secondary dark:text-secondary-dark mt-0.5"><%= @unsettled.size %> 条待报销</p>
          <p class="text-sm font-semibold text-expense mt-1"><%= format_currency(@unsettled.sum { |r| r.remaining_amount.to_d }) %></p>
        <% end %>
        <% @unsettled_counterparty_stats.each do |item| %>
          <%= link_to receivables_path(counterparty_id: item[:filter_value], anchor: "unsettled-receivables"), class: "shrink-0 min-w-[170px] px-3 py-2 rounded-lg border #{ @selected_counterparty_id.to_s == item[:filter_value].to_s ? 'bg-blue-50 dark:bg-blue-900/20 border-blue-200 dark:border-blue-800' : 'bg-surface dark:bg-surface-dark border-border dark:border-border-dark' }" do %>
            <p class="text-sm font-medium text-primary dark:text-primary-dark truncate"><%= item[:name] %></p>
            <p class="text-xs text-secondary dark:text-secondary-dark mt-0.5"><%= item[:count] %> 条待报销</p>
            <p class="text-sm font-semibold text-expense mt-1"><%= format_currency(item[:amount]) %></p>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>

  <section id="unsettled-receivables" class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs transition-all group focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2">
    <div class="px-4 py-3 flex items-center justify-between border-b border-border dark:border-border-dark">
      <h2 class="text-base font-semibold text-primary dark:text-primary-dark">待报销</h2>
      <span class="text-xs text-secondary dark:text-secondary-dark"><%= @filtered_unsettled.size %> 条</span>
    </div>
    <div class="px-4 py-2 border-b border-border dark:border-border-dark bg-surface-inset/40 dark:bg-surface-dark-inset/40">
      <form method="get" action="<%= receivables_path %>" class="flex items-center gap-2">
        <label for="receivable-counterparty-filter" class="text-xs text-secondary dark:text-secondary-dark shrink-0">联系人</label>
        <select id="receivable-counterparty-filter" name="counterparty_id" onchange="this.form.submit()" class="w-full sm:w-auto px-2 py-1 text-xs rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark">
          <option value="">全部联系人</option>
          <option value="none" <%= "selected" if @selected_counterparty_id == "none" %>>未设置联系人</option>
          <% @counterparties.each do |c| %>
            <option value="<%= c.id %>" <%= "selected" if [c.id.to_s, "id:#{c.id}"].include?(@selected_counterparty_id.to_s) %>><%= c.name %></option>
          <% end %>
        </select>
      </form>
    </div>
    <div class="divide-y divide-border">
      <% if @filtered_unsettled.any? %>
        <% @filtered_unsettled.each do |receivable| %>
          <% reimbursed = receivable.original_amount.to_d - receivable.remaining_amount.to_d %>
          <div class="px-3 py-2 hover:bg-surface dark:hover:bg-surface-dark transition-smooth">
            <div class="flex items-center gap-2">
              <div class="w-44 shrink-0">
                <h3 class="font-medium text-sm text-primary dark:text-primary-dark truncate"><%= receivable.description %></h3>
              </div>
              <div class="text-[11px] text-secondary dark:text-secondary-dark shrink-0"><%= receivable.date&.strftime("%Y-%m-%d") %></div>
              <% if receivable.category.present? %>
                <div class="px-1 py-0.5 rounded bg-surface dark:bg-surface-dark text-[11px] text-primary dark:text-primary-dark shrink-0"><%= receivable.category %></div>
              <% end %>
              <% if receivable.account.present? %>
                <div class="text-[11px] text-secondary dark:text-secondary-dark truncate max-w-28"><%= receivable.account.name %></div>
              <% end %>
              <div class="ml-auto flex items-center gap-2 text-[11px] shrink-0">
                <span class="text-secondary dark:text-secondary-dark">总额 <span class="font-medium text-primary dark:text-primary-dark"><%= format_currency(receivable.original_amount) %></span></span>
                <span class="text-income">已报 <span class="font-medium"><%= format_currency(reimbursed) %></span></span>
                <span class="text-expense">待报 <span class="font-medium"><%= format_currency(receivable.remaining_amount) %></span></span>
              </div>
              <div class="flex items-center gap-1 shrink-0">
                <button type="button" onclick="openSettleModal('<%= receivable.id %>', '<%= j receivable.description %>', '<%= receivable.remaining_amount %>')" class="px-2 py-1 text-xs font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-blue-500 transition-smooth btn-modern">报销</button>
                <button type="button" onclick="openEditReceivableModal('<%= receivable.id %>', '<%= j receivable.description %>', '<%= receivable.date %>', '<%= receivable.original_amount %>', '<%= j(receivable.category || '') %>', '<%= receivable.counterparty_id %>', '<%= receivable.account_id %>', '<%= j(receivable.note || '') %>')" class="px-2 py-1 text-xs font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface dark:hover:bg-surface-dark focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-blue-500 transition-smooth btn-modern">编辑</button>
                <button type="button" onclick="if(confirm('确定删除此报销记录？')) { document.getElementById('delete-receivable-form-<%= receivable.id %>').submit(); }" class="px-2 py-1 text-xs font-medium rounded-lg border border-expense-soft text-expense hover:bg-expense-soft focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-blue-500 transition-smooth btn-modern">删除</button>
                <form id="delete-receivable-form-<%= receivable.id %>" method="post" action="/receivables/<%= receivable.id %>" style="display:none">
                  <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
                  <input type="hidden" name="_method" value="delete">
                </form>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="p-8 text-center">
          <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-surface-inset dark:bg-surface-dark-inset flex items-center justify-center">
            <%= render(Ds::IconComponent.new(name: "receipt", size: :lg, color: :secondary)) %>
          </div>
          <p class="text-secondary dark:text-secondary-dark">暂无待报销记录</p>
        </div>
      <% end %>
    </div>
  </section>

  <section class="bg-container dark:bg-container-dark rounded-xl shadow-border-xs dark:shadow-dark-border-xs transition-all group focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2">
    <div class="px-4 py-3 flex items-center justify-between border-b border-border dark:border-border-dark">
      <h2 class="text-base font-semibold text-primary dark:text-primary-dark">已完成</h2>
      <span class="text-xs text-secondary dark:text-secondary-dark"><%= @settled.size %> 条</span>
    </div>
    <div class="divide-y divide-border">
      <% if @settled.any? %>
        <% @settled.each do |receivable| %>
          <% reimbursed = receivable.original_amount.to_d - receivable.remaining_amount.to_d %>
          <div class="p-4 hover:bg-surface dark:hover:bg-surface-dark transition-smooth">
            <div class="flex items-start justify-between gap-3">
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <h3 class="font-medium text-primary dark:text-primary-dark truncate"><%= receivable.description %></h3>
                  <span class="px-2 py-0.5 text-xs rounded-full bg-income-soft text-income whitespace-nowrap">已完成</span>
                </div>
                <div class="mt-1 flex flex-wrap items-center gap-2 text-xs text-secondary dark:text-secondary-dark">
                  <span>完成于 <%= receivable.settled_at&.strftime("%Y-%m-%d") %></span>
                  <% if receivable.category.present? %>
                    <span class="px-1.5 py-0.5 rounded bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark"><%= receivable.category %></span>
                  <% end %>
                  <% if receivable.counterparty.present? %>
                    <span>联系人：<%= receivable.counterparty.name %></span>
                  <% end %>
                  <% if receivable.account.present? %>
                    <span>账户：<%= receivable.account.name %></span>
                  <% end %>
                </div>
                <div class="mt-1.5 flex flex-wrap items-center gap-x-3 gap-y-0.5 text-xs">
                  <span class="text-secondary dark:text-secondary-dark">总额 <span class="font-medium text-primary dark:text-primary-dark"><%= format_currency(receivable.original_amount) %></span></span>
                  <span class="text-income">已报销 <span class="font-medium"><%= format_currency(reimbursed) %></span></span>
                </div>
                <% if receivable.note.present? %>
                  <p class="mt-1.5 text-xs text-secondary dark:text-secondary-dark truncate">备注：<%= receivable.note %></p>
                <% end %>
              </div>
              <div class="flex items-center gap-1.5 shrink-0">
                <%= button_to "撤销", revert_receivable_path(receivable), method: :post, onclick: "if(!confirm('确定撤销此报销？撤销后可重新报销')) return false", class: "px-3 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface dark:hover:bg-surface-dark focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-blue-500 transition-smooth btn-modern" %>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="p-8 text-center">
          <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-surface-inset dark:bg-surface-dark-inset flex items-center justify-center">
            <%= render(Ds::IconComponent.new(name: "check", size: :lg, color: :secondary)) %>
          </div>
          <p class="text-secondary dark:text-secondary-dark">暂无已完成记录</p>
        </div>
      <% end %>
    </div>
  </section>
</div>

<!-- 新建应收款弹窗 -->
<div id="add-receivable-modal" class="hidden fixed inset-0 z-50 overflow-y-auto modal-overlay">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('add-receivable-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-xl shadow-xl w-full max-w-md p-4">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-base font-semibold text-primary dark:text-primary-dark">新建应收款</h3>
        <button type="button" onclick="document.getElementById('add-receivable-modal').classList.add('hidden')" class="p-1 hover:bg-surface dark:hover:bg-surface-dark rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      
      <form id="new-receivable-form" method="post" action="<%= receivables_path %>">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">描述 *</label>
            <input type="text" name="receivable[description]" required placeholder="如：出差北京交通费" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">日期 *</label>
              <input type="date" name="receivable[date]" required value="<%= Date.today %>" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">金额 *</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
                <input type="number" name="receivable[original_amount]" step="0.01" placeholder="0.00" required class="w-full pl-8 pr-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">类别</label>
            <input type="hidden" name="receivable[category]" id="new-receivable-category-id" value="">
            <div class="relative">
              <input type="text" id="new-receivable-category-search"
                     class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 cursor-pointer"
                     placeholder="选择类别"
                     autocomplete="off"
                     readonly>
              <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-secondary dark:text-secondary-dark pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
              <div id="new-receivable-category-dropdown" class="hidden absolute z-50 w-full mt-1 bg-white dark:bg-container-dark rounded-lg border border-border dark:border-border-dark shadow-lg max-h-60 overflow-y-auto">
                <div class="p-2 border-b border-border dark:border-border-dark">
                  <input type="text" id="new-receivable-category-filter"
                         class="w-full px-2 py-1 text-sm rounded border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500"
                         placeholder="搜索分类..."
                         autocomplete="off">
                </div>
                <div id="new-receivable-category-options" class="py-1"></div>
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">联系人</label>
            <select name="receivable[counterparty_id]" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
              <option value="">选择联系人</option>
              <% @counterparties.each do |c| %>
                <option value="<%= c.id %>"><%= c.name %></option>
              <% end %>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">支出账户</label>
            <input type="hidden" name="receivable[account_id]" id="new-receivable-account-id" value="">
            <div class="relative">
              <input type="text" id="new-receivable-account-search"
                     class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 cursor-pointer"
                     placeholder="选择账户"
                     autocomplete="off"
                     readonly>
              <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-secondary dark:text-secondary-dark pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
              <div id="new-receivable-account-dropdown" class="hidden absolute z-50 w-full mt-1 bg-white dark:bg-container-dark rounded-lg border border-border dark:border-border-dark shadow-lg max-h-60 overflow-y-auto">
                <div class="p-2 border-b border-border dark:border-border-dark">
                  <input type="text" id="new-receivable-account-filter"
                         class="w-full px-2 py-1 text-sm rounded border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500"
                         placeholder="搜索账户..."
                         autocomplete="off">
                </div>
                <div id="new-receivable-account-options" class="py-1"></div>
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">备注</label>
            <input type="text" name="receivable[note]" placeholder="可选" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
          </div>
        </div>

        <div class="flex justify-end gap-3 mt-5">
          <button type="button" onclick="document.getElementById('add-receivable-modal').classList.add('hidden')" class="px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface dark:hover:bg-surface-dark transition-smooth">取消</button>
          <button type="submit" class="px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth">保存</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- 编辑应收款弹窗 -->
<div id="edit-receivable-modal" class="hidden fixed inset-0 z-50 overflow-y-auto modal-overlay">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('edit-receivable-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-xl shadow-xl w-full max-w-md p-4">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-base font-semibold text-primary dark:text-primary-dark">编辑应收款</h3>
        <button type="button" onclick="document.getElementById('edit-receivable-modal').classList.add('hidden')" class="p-1 hover:bg-surface dark:hover:bg-surface-dark rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      
      <form id="edit-receivable-form" method="post">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <input type="hidden" name="_method" value="patch">
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">描述 *</label>
            <input type="text" id="edit-receivable-description" name="receivable[description]" required class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">日期 *</label>
              <input type="date" id="edit-receivable-date" name="receivable[date]" required class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">金额 *</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
                <input type="number" id="edit-receivable-amount" name="receivable[original_amount]" step="0.01" required class="w-full pl-8 pr-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">类别</label>
            <input type="hidden" name="receivable[category]" id="edit-receivable-category-id" value="">
            <div class="relative">
              <input type="text" id="edit-receivable-category-search"
                     class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 cursor-pointer"
                     placeholder="选择类别"
                     autocomplete="off"
                     readonly>
              <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-secondary dark:text-secondary-dark pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
              <div id="edit-receivable-category-dropdown" class="hidden absolute z-50 w-full mt-1 bg-white dark:bg-container-dark rounded-lg border border-border dark:border-border-dark shadow-lg max-h-60 overflow-y-auto">
                <div class="p-2 border-b border-border dark:border-border-dark">
                  <input type="text" id="edit-receivable-category-filter"
                         class="w-full px-2 py-1 text-sm rounded border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500"
                         placeholder="搜索分类..."
                         autocomplete="off">
                </div>
                <div id="edit-receivable-category-options" class="py-1"></div>
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">联系人</label>
            <select id="edit-receivable-counterparty" name="receivable[counterparty_id]" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
              <option value="">选择联系人</option>
              <% @counterparties.each do |c| %>
                <option value="<%= c.id %>"><%= c.name %></option>
              <% end %>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">支出账户</label>
            <input type="hidden" name="receivable[account_id]" id="edit-receivable-account-id" value="">
            <div class="relative">
              <input type="text" id="edit-receivable-account-search"
                     class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500 cursor-pointer"
                     placeholder="选择账户"
                     autocomplete="off"
                     readonly>
              <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-secondary dark:text-secondary-dark pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
              <div id="edit-receivable-account-dropdown" class="hidden absolute z-50 w-full mt-1 bg-white dark:bg-container-dark rounded-lg border border-border dark:border-border-dark shadow-lg max-h-60 overflow-y-auto">
                <div class="p-2 border-b border-border dark:border-border-dark">
                  <input type="text" id="edit-receivable-account-filter"
                         class="w-full px-2 py-1 text-sm rounded border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500"
                         placeholder="搜索账户..."
                         autocomplete="off">
                </div>
                <div id="edit-receivable-account-options" class="py-1"></div>
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">备注</label>
            <input type="text" id="edit-receivable-note" name="receivable[note]" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
          </div>
        </div>

        <div class="flex justify-end gap-3 mt-5">
          <button type="button" onclick="document.getElementById('edit-receivable-modal').classList.add('hidden')" class="px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface dark:hover:bg-surface-dark transition-smooth">取消</button>
          <button type="submit" class="px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth">保存</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- 报销应收款弹窗 -->
<div id="settle-receivable-modal" class="hidden fixed inset-0 z-50 overflow-y-auto modal-overlay">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('settle-receivable-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-xl shadow-xl w-full max-w-md p-4">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-base font-semibold text-primary dark:text-primary-dark">报销应收款</h3>
        <button type="button" onclick="document.getElementById('settle-receivable-modal').classList.add('hidden')" class="p-1 hover:bg-surface dark:hover:bg-surface-dark rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      
      <p id="settle-description" class="text-secondary dark:text-secondary-dark mb-4"></p>
      
      <form id="settle-form" method="post">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">报销金额 *</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
              <input type="number" name="amount" step="0.01" placeholder="0.00" required class="w-full pl-8 pr-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">账户 *</label>
            <select name="account_id" required class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
              <option value="">选择账户</option>
              <% @accounts.each do |a| %>
                <option value="<%= a.id %>"><%= a.name %></option>
              <% end %>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">备注</label>
            <input type="text" name="note" placeholder="可选" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
          </div>
        </div>

        <div class="flex justify-end gap-3 mt-5">
          <button type="button" onclick="document.getElementById('settle-receivable-modal').classList.add('hidden')" class="px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface dark:hover:bg-surface-dark transition-smooth">取消</button>
          <button type="submit" class="px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">确认报销</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script id="receivable-accounts-data" type="application/json">
  <%= raw @accounts.map { |a| { id: a.id, name: a.name, pinyin: PinYin.abbr(a.name).downcase } }.to_json %>
</script>
<script id="receivable-categories-data" type="application/json">
  <%= raw @expense_categories.map { |c| full_name = c.full_name; { name: c.name, full_name: full_name, pinyin: PinYin.abbr(full_name).downcase } }.to_json %>
</script>
<script>
function openNewReceivableModal() {
  document.getElementById('new-receivable-form').reset();
  document.getElementById('new-receivable-form').querySelector('input[name="receivable[date]"]').value = '<%= Date.today %>';
  document.getElementById('add-receivable-modal').classList.remove('hidden');
}

function openEditReceivableModal(id, description, date, amount, category, counterpartyId, accountId, note) {
  const form = document.getElementById('edit-receivable-form');
  form.action = '/receivables/' + id;
  document.getElementById('edit-receivable-description').value = description;
  document.getElementById('edit-receivable-date').value = date;
  document.getElementById('edit-receivable-amount').value = amount;
  var categoryIdInput = document.getElementById('edit-receivable-category-id');
  var categorySearchInput = document.getElementById('edit-receivable-category-search');
  if (categoryIdInput) categoryIdInput.value = category || '';
  if (categorySearchInput) categorySearchInput.value = category || '';
  document.getElementById('edit-receivable-counterparty').value = counterpartyId || '';
  var accountIdInput = document.getElementById('edit-receivable-account-id');
  var accountSearchInput = document.getElementById('edit-receivable-account-search');
  if (accountIdInput) accountIdInput.value = accountId || '';
  if (accountSearchInput) accountSearchInput.value = findAccountName(accountId) || '';
  document.getElementById('edit-receivable-note').value = note;
  document.getElementById('edit-receivable-modal').classList.remove('hidden');
}

function openSettleModal(id, description, remainingAmount) {
  document.getElementById('settle-description').textContent = description + ' (剩余: ¥' + remainingAmount + ')';
  document.getElementById('settle-form').action = '/receivables/' + id + '/settle';
  document.getElementById('settle-receivable-modal').classList.remove('hidden');
}

<% if params[:open_modal] == "true" %>
document.addEventListener('DOMContentLoaded', function() {
  document.getElementById('add-receivable-modal').classList.remove('hidden');
  <% if params[:counterparty].present? %>
    <% cp = @counterparties.find { |c| c.name == params[:counterparty] } %>
    <% if cp %>
      document.querySelector('select[name="receivable[counterparty_id]"]').value = '<%= cp.id %>';
    <% end %>
  <% end %>
});
<% end %>

var receivableAllAccounts = [];
var receivableAllCategories = [];
var receivableAccountsDataEl = document.getElementById('receivable-accounts-data');
if (receivableAccountsDataEl) {
  receivableAllAccounts = JSON.parse(receivableAccountsDataEl.textContent);
}
var receivableCategoriesDataEl = document.getElementById('receivable-categories-data');
if (receivableCategoriesDataEl) {
  receivableAllCategories = JSON.parse(receivableCategoriesDataEl.textContent);
}

function findAccountName(accountId) {
  if (!accountId) return '';
  var matched = receivableAllAccounts.find(function(acc) { return String(acc.id) === String(accountId); });
  return matched ? matched.name : '';
}

function initReceivableAccountSelector(searchInputId, dropdownId, filterInputId, optionsId, hiddenInputId) {
  var searchInput = document.getElementById(searchInputId);
  var dropdown = document.getElementById(dropdownId);
  var filterInput = document.getElementById(filterInputId);
  var optionsContainer = document.getElementById(optionsId);
  var hiddenInput = document.getElementById(hiddenInputId);

  if (!searchInput || !dropdown || !optionsContainer || !hiddenInput) return;

  function renderOptions(filterText) {
    var filtered = receivableAllAccounts.filter(function(acc) {
      if (!filterText) return true;
      var query = filterText.toLowerCase();
      return (acc.name && acc.name.toLowerCase().includes(query)) || (acc.pinyin && acc.pinyin.includes(query));
    });

    if (filtered.length === 0) {
      return '<div class="px-3 py-2 text-sm text-secondary dark:text-secondary-dark">无匹配账户</div>';
    }

    return filtered.map(function(acc) {
      var selected = String(hiddenInput.value) === String(acc.id) ? 'bg-blue-50 dark:bg-blue-900/20' : '';
      var name = String(acc.name).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      return '<div class="receivable-account-option px-3 py-1.5 text-sm cursor-pointer hover:bg-surface dark:hover:bg-surface-dark text-primary dark:text-primary-dark ' + selected + '" data-id="' + acc.id + '" data-name="' + name + '">' + name + '</div>';
    }).join('');
  }

  function updateOptions() {
    var filterText = filterInput ? filterInput.value : '';
    optionsContainer.innerHTML = renderOptions(filterText);
    optionsContainer.querySelectorAll('.receivable-account-option').forEach(function(option) {
      option.addEventListener('click', function() {
        hiddenInput.value = this.dataset.id;
        searchInput.value = this.dataset.name;
        if (filterInput) filterInput.value = '';
        dropdown.classList.add('hidden');
      });
    });
  }

  searchInput.addEventListener('click', function() {
    dropdown.classList.toggle('hidden');
    if (!dropdown.classList.contains('hidden')) {
      updateOptions();
      if (filterInput) filterInput.focus();
    }
  });

  if (filterInput) {
    filterInput.addEventListener('input', updateOptions);
  }

  document.addEventListener('click', function(e) {
    if (!dropdown.contains(e.target) && e.target !== searchInput) {
      dropdown.classList.add('hidden');
    }
  });
}

function initReceivableCategorySelector(searchInputId, dropdownId, filterInputId, optionsId, hiddenInputId) {
  var searchInput = document.getElementById(searchInputId);
  var dropdown = document.getElementById(dropdownId);
  var filterInput = document.getElementById(filterInputId);
  var optionsContainer = document.getElementById(optionsId);
  var hiddenInput = document.getElementById(hiddenInputId);

  if (!searchInput || !dropdown || !optionsContainer || !hiddenInput) return;

  function renderOptions(filterText) {
    var filtered = receivableAllCategories.filter(function(cat) {
      if (!filterText) return true;
      var query = filterText.toLowerCase();
      return (cat.name && cat.name.toLowerCase().includes(query)) ||
             (cat.full_name && cat.full_name.toLowerCase().includes(query)) ||
             (cat.pinyin && cat.pinyin.includes(query));
    });

    var rows = ['<div class="receivable-category-option px-3 py-1.5 text-sm cursor-pointer hover:bg-surface dark:hover:bg-surface-dark text-secondary dark:text-secondary-dark" data-name="" data-display="">不设置分类</div>'];
    rows = rows.concat(filtered.map(function(cat) {
      var selected = hiddenInput.value === cat.name ? 'bg-blue-50 dark:bg-blue-900/20' : '';
      var name = String(cat.name).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      var displayName = String(cat.full_name || cat.name).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      return '<div class="receivable-category-option px-3 py-1.5 text-sm cursor-pointer hover:bg-surface dark:hover:bg-surface-dark text-primary dark:text-primary-dark ' + selected + '" data-name="' + name + '" data-display="' + displayName + '">' + displayName + '</div>';
    }));

    return rows.join('');
  }

  function updateOptions() {
    var filterText = filterInput ? filterInput.value : '';
    optionsContainer.innerHTML = renderOptions(filterText);
    optionsContainer.querySelectorAll('.receivable-category-option').forEach(function(option) {
      option.addEventListener('click', function() {
        hiddenInput.value = this.dataset.name || '';
        searchInput.value = this.dataset.display || '';
        if (filterInput) filterInput.value = '';
        dropdown.classList.add('hidden');
      });
    });
  }

  searchInput.addEventListener('click', function() {
    dropdown.classList.toggle('hidden');
    if (!dropdown.classList.contains('hidden')) {
      updateOptions();
      if (filterInput) filterInput.focus();
    }
  });

  if (filterInput) {
    filterInput.addEventListener('input', updateOptions);
  }

  document.addEventListener('click', function(e) {
    if (!dropdown.contains(e.target) && e.target !== searchInput) {
      dropdown.classList.add('hidden');
    }
  });
}

initReceivableAccountSelector('new-receivable-account-search', 'new-receivable-account-dropdown', 'new-receivable-account-filter', 'new-receivable-account-options', 'new-receivable-account-id');
initReceivableAccountSelector('edit-receivable-account-search', 'edit-receivable-account-dropdown', 'edit-receivable-account-filter', 'edit-receivable-account-options', 'edit-receivable-account-id');
initReceivableCategorySelector('new-receivable-category-search', 'new-receivable-category-dropdown', 'new-receivable-category-filter', 'new-receivable-category-options', 'new-receivable-category-id');
initReceivableCategorySelector('edit-receivable-category-search', 'edit-receivable-category-dropdown', 'edit-receivable-category-filter', 'edit-receivable-category-options', 'edit-receivable-category-id');
</script>

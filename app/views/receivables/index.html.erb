<!-- 报销应收款弹窗 -->
<div id="settle-receivable-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('settle-receivable-modal').classList.add('hidden')"></div>
    <div class="relative bg-container dark:bg-container-dark rounded-xl shadow-xl w-full max-w-md p-4">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-base font-semibold text-primary dark:text-primary-dark">报销应收款</h3>
        <button type="button" onclick="document.getElementById('settle-receivable-modal').classList.add('hidden')" class="p-1 hover:bg-surface dark:hover:bg-surface-dark rounded-lg transition-smooth">
          <svg class="w-5 h-5 text-secondary dark:text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      
      <p id="settle-description" class="text-secondary dark:text-secondary-dark mb-4"></p>
      
      <form id="settle-form" method="post">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">报销金额 *</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary dark:text-secondary-dark">¥</span>
              <input type="number" name="amount" step="0.01" placeholder="0.00" required class="w-full pl-8 pr-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">账户 *</label>
            <select name="account_id" required class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
              <option value="">选择账户</option>
              <% @accounts.each do |a| %>
                <option value="<%= a.id %>"><%= a.name %></option>
              <% end %>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-secondary dark:text-secondary-dark mb-1">备注</label>
            <input type="text" name="note" placeholder="可选" class="w-full px-3 py-1.5 text-sm rounded-lg border border-border dark:border-border-dark bg-white dark:bg-container-dark text-primary dark:text-primary-dark focus:ring-2 focus:ring-blue-500">
          </div>
        </div>

        <div class="flex justify-end gap-3 mt-5">
          <button type="button" onclick="document.getElementById('settle-receivable-modal').classList.add('hidden')" class="px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface dark:hover:bg-surface-dark transition-smooth">取消</button>
          <button type="submit" class="px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white dark:bg-inverse-dark dark:text-inverse hover:bg-inverse-hover transition-smooth">确认报销</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function openNewReceivableModal() {
  document.getElementById('new-receivable-form').reset();
  document.getElementById('new-receivable-form').querySelector('input[name="receivable[date]"]').value = '<%= Date.today %>';
  document.getElementById('add-receivable-modal').classList.remove('hidden');
}

function openEditReceivableModal(id, description, date, amount, category, counterpartyId, accountId, note) {
  const form = document.getElementById('edit-receivable-form');
  form.action = '/receivables/' + id;
  document.getElementById('edit-receivable-description').value = description;
  document.getElementById('edit-receivable-date').value = date;
  document.getElementById('edit-receivable-amount').value = amount;
  document.getElementById('edit-receivable-category').value = category;
  document.getElementById('edit-receivable-counterparty').value = counterpartyId || '';
  document.getElementById('edit-receivable-account').value = accountId || '';
  document.getElementById('edit-receivable-note').value = note;
  document.getElementById('edit-receivable-modal').classList.remove('hidden');
}

function openSettleModal(id, description, remainingAmount) {
  document.getElementById('settle-description').textContent = description + ' (剩余: ¥' + remainingAmount + ')';
  document.getElementById('settle-form').action = '/receivables/' + id + '/settle';
  document.getElementById('settle-receivable-modal').classList.remove('hidden');
}

<% if params[:open_modal] == "true" %>
document.addEventListener('DOMContentLoaded', function() {
  document.getElementById('add-receivable-modal').classList.remove('hidden');
  <% if params[:counterparty].present? %>
    <% cp = @counterparties.find { |c| c.name == params[:counterparty] } %>
    <% if cp %>
      document.querySelector('select[name="receivable[counterparty_id]"]').value = '<%= cp.id %>';
    <% end %>
  <% end %>
});
<% end %>
</script>

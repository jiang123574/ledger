<%= form_with model: receivable, class: "space-y-6" do |f| %>
  <% if receivable.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <ul class="list-disc list-inside text-red-600">
        <% receivable.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= f.label :date, "日期", class: "block text-sm font-medium text-secondary mb-1" %>
      <%= f.date_field :date, class: "w-full px-3 py-2 border border-border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
    </div>

    <div>
      <%= f.label :category, "类别", class: "block text-sm font-medium text-secondary mb-1" %>
      <%= f.select :category, 
        ["差旅", "餐饮", "交通", "办公用品", "其他"],
        { prompt: "选择类别" },
        class: "w-full px-3 py-2 border border-border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :description, "描述", class: "block text-sm font-medium text-secondary mb-1" %>
      <%= f.text_field :description, class: "w-full px-3 py-2 border border-border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent", placeholder: "如：出差北京交通费" %>
    </div>

    <div>
      <%= f.label :original_amount, "金额", class: "block text-sm font-medium text-secondary mb-1" %>
      <div class="relative">
        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary">¥</span>
        <%= f.number_field :original_amount, step: "0.01", class: "w-full pl-8 pr-3 py-2 border border-border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent", placeholder: "0.00" %>
      </div>
    </div>

    <div>
      <%= f.label :note, "备注", class: "block text-sm font-medium text-secondary mb-1" %>
      <%= f.text_field :note, class: "w-full px-3 py-2 border border-border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent", placeholder: "可选" %>
    </div>
  </div>

  <div class="flex justify-end gap-3 pt-4 border-t border-border">
    <%= link_to "取消", receivables_path, class: "px-4 py-2 text-secondary hover:text-primary" %>
    <%= f.submit "保存", class: "px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-medium" %>
  </div>
<% end %>
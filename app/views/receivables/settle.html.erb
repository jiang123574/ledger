<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <h1 class="text-2xl font-semibold text-primary">报销</h1>
    <p class="text-secondary mt-1"><%= @receivable.description %></p>
  </div>

  <div class="bg-container rounded-xl p-6 shadow-border-xs mb-6">
    <div class="flex justify-between items-center mb-4">
      <span class="text-secondary">原始金额</span>
      <span class="font-semibold text-primary"><%= format_currency(@receivable.original_amount) %></span>
    </div>
    <div class="flex justify-between items-center mb-4">
      <span class="text-secondary">剩余金额</span>
      <span class="font-semibold text-orange-600"><%= format_currency(@receivable.remaining_amount) %></span>
    </div>
  </div>

  <%= form_with url: settle_receivable_path(@receivable), method: :post, class: "space-y-6" do |f| %>
    <div>
      <%= f.label :amount, "报销金额", class: "block text-sm font-medium text-secondary mb-1" %>
      <div class="relative">
        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-secondary">¥</span>
        <%= f.number_field :amount, step: "0.01", value: @receivable.remaining_amount, class: "w-full pl-8 pr-3 py-2 border border-border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
      </div>
    </div>

    <div>
      <%= f.label :account_id, "收款账户", class: "block text-sm font-medium text-secondary mb-1" %>
      <%= f.select :account_id, 
        Account.visible.map { |a| [a.name, a.id] },
        { prompt: "选择账户" },
        class: "w-full px-3 py-2 border border-border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
    </div>

    <div class="flex justify-end gap-3 pt-4 border-t border-border">
      <%= link_to "取消", receivables_path, class: "px-4 py-2 text-secondary hover:text-primary" %>
      <%= f.submit "确认报销", class: "px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 font-medium" %>
    </div>
  <% end %>
</div>
<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h1 class="text-2xl font-bold text-primary dark:text-primary-dark">备份管理</h1>
    <div class="flex gap-2">
      <%= button_to "创建备份", backups_path, method: :post, class: "px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth btn-modern" %>
    </div>
  </div>

  <!-- Status Cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="bg-container dark:bg-container-dark rounded-lg shadow-sm p-4">
      <div class="flex justify-between items-start">
        <div>
          <div class="text-sm text-secondary dark:text-secondary-dark">本地备份</div>
          <div class="text-2xl font-bold"><%= @backups.size %></div>
        </div>
        <div class="text-3xl">💾</div>
      </div>
    </div>

    <div class="bg-container dark:bg-container-dark rounded-lg shadow-sm p-4">
      <div class="flex justify-between items-start">
        <div>
          <div class="text-sm text-secondary dark:text-secondary-dark">WebDAV 状态</div>
          <div class="text-lg font-medium <%= @webdav_configured ? 'text-green-600' : 'text-secondary dark:text-secondary-dark' %>">
            <%= @webdav_configured ? '已连接' : '未配置' %>
          </div>
        </div>
        <div class="text-3xl">☁️</div>
      </div>
    </div>

    <div class="bg-container dark:bg-container-dark rounded-lg shadow-sm p-4">
      <div class="flex justify-between items-start">
        <div>
          <div class="text-sm text-secondary dark:text-secondary-dark">自动备份</div>
          <div class="text-lg font-medium <%= @auto_backup_enabled ? 'text-green-600' : 'text-secondary dark:text-secondary-dark' %>">
            <%= @auto_backup_enabled ? '已启用' : '未启用' %>
          </div>
        </div>
        <div class="text-3xl">🔄</div>
      </div>
    </div>
  </div>

  <!-- WebDAV Configuration -->
  <div class="bg-container dark:bg-container-dark rounded-lg shadow-sm p-6">
    <h2 class="text-lg font-semibold mb-4">WebDAV 云备份</h2>

    <% if @webdav_configured %>
      <div class="space-y-4">
        <div class="flex items-center justify-between bg-green-50 dark:bg-green-900/20 rounded-lg p-4">
          <div class="flex items-center gap-3">
            <div class="text-green-500 text-2xl">✓</div>
            <div>
              <div class="font-medium text-green-800 dark:text-green-200">已连接</div>
              <div class="text-sm text-green-600 dark:text-green-400"><%= @webdav_config[:url] %></div>
            </div>
          </div>
          <div class="flex gap-2">
            <%= link_to "测试连接", webdav_test_backups_path, remote: true, class: "px-3 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth" %>
            <button onclick="document.getElementById('webdav-edit-form').classList.toggle('hidden')" class="px-3 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">
              修改配置
            </button>
          </div>
        </div>

        <!-- 修改配置表单 -->
        <div id="webdav-edit-form" class="hidden border rounded-lg p-4">
          <h3 class="font-medium mb-3 text-primary dark:text-primary-dark">修改 WebDAV 配置</h3>
          <%= form_with url: webdav_connect_backups_path, local: true, class: "space-y-4" do |f| %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <%= f.label :url, "WebDAV 地址", class: "block text-sm font-medium text-primary dark:text-primary-dark" %>
                <%= f.text_field :url, value: @webdav_config[:url], placeholder: "https://dav.example.com", class: "mt-1 block w-full border border-border dark:border-border-dark rounded-lg px-3 py-2 bg-white dark:bg-surface-dark text-primary dark:text-primary-dark" %>
              </div>
              <div>
                <%= f.label :directory, "目录", class: "block text-sm font-medium text-primary dark:text-primary-dark" %>
                <%= f.text_field :directory, value: @webdav_config[:directory], class: "mt-1 block w-full border border-border dark:border-border-dark rounded-lg px-3 py-2 bg-white dark:bg-surface-dark text-primary dark:text-primary-dark" %>
              </div>
              <div>
                <%= f.label :username, "用户名", class: "block text-sm font-medium text-primary dark:text-primary-dark" %>
                <%= f.text_field :username, value: @webdav_config[:username], class: "mt-1 block w-full border border-border dark:border-border-dark rounded-lg px-3 py-2 bg-white dark:bg-surface-dark text-primary dark:text-primary-dark" %>
              </div>
              <div>
                <%= f.label :password, "密码（留空保持不变）", class: "block text-sm font-medium text-primary dark:text-primary-dark" %>
                <%= f.password_field :password, placeholder: "输入新密码或留空", class: "mt-1 block w-full border border-border dark:border-border-dark rounded-lg px-3 py-2 bg-white dark:bg-surface-dark text-primary dark:text-primary-dark" %>
              </div>
            </div>
            <div class="flex gap-2">
              <%= f.submit "保存修改", class: "px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth" %>
              <button type="button" onclick="document.getElementById('webdav-edit-form').classList.add('hidden')" class="px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">
                取消
              </button>
            </div>
          <% end %>
        </div>

        <% if @webdav_backups&.any? %>
          <div class="border border-border dark:border-border-dark rounded-lg p-4">
            <h3 class="font-medium mb-2 text-primary dark:text-primary-dark">云端备份 (<%= @webdav_backups.size %>)</h3>
            <div class="space-y-2 max-h-40 overflow-y-auto">
              <% @webdav_backups.each do |backup| %>
                <div class="flex justify-between items-center text-sm">
                  <span class="text-primary dark:text-primary-dark"><%= backup[:name] %></span>
                  <div class="flex gap-1">
                    <%= link_to "下载", webdav_download_backups_path(filename: backup[:name]), class: "px-2 py-1 text-xs font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth" %>
                    <%= button_to "删除", webdav_delete_backup_path(filename: backup[:name]),
                        method: :post,
                        form: { data: { turbo_confirm: "确定要删除云端备份吗？\n\n#{backup[:name]}" } },
                        class: "px-2 py-1 text-xs font-medium rounded-lg bg-red-100 text-red-700 hover:bg-red-200 dark:bg-red-900/30 dark:text-red-400 dark:hover:bg-red-900/50 transition-smooth" %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-secondary dark:text-secondary-dark text-center py-8">
        <div class="text-4xl mb-2">☁️</div>
        <p>配置 WebDAV 以启用云备份</p>
        <button onclick="document.getElementById('webdav-form').classList.toggle('hidden')" class="mt-4 px-4 py-1.5 text-sm font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth">
          配置 WebDAV
        </button>
      </div>

      <div id="webdav-form" class="hidden mt-4 border-t border-border dark:border-border-dark pt-4">
        <%= form_with url: webdav_connect_backups_path, local: true, class: "space-y-4" do |f| %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <%= f.label :url, "WebDAV 地址", class: "block text-sm font-medium text-primary dark:text-primary-dark" %>
              <%= f.text_field :url, placeholder: "https://dav.example.com", class: "mt-1 block w-full border border-border dark:border-border-dark rounded-lg px-3 py-2 bg-white dark:bg-surface-dark text-primary dark:text-primary-dark" %>
            </div>
            <div>
              <%= f.label :directory, "目录", class: "block text-sm font-medium text-primary dark:text-primary-dark" %>
              <%= f.text_field :directory, value: "/ledger-backups", class: "mt-1 block w-full border border-border dark:border-border-dark rounded-lg px-3 py-2 bg-white dark:bg-surface-dark text-primary dark:text-primary-dark" %>
            </div>
            <div>
              <%= f.label :username, "用户名", class: "block text-sm font-medium text-primary dark:text-primary-dark" %>
              <%= f.text_field :username, class: "mt-1 block w-full border border-border dark:border-border-dark rounded-lg px-3 py-2 bg-white dark:bg-surface-dark text-primary dark:text-primary-dark" %>
            </div>
            <div>
              <%= f.label :password, "密码", class: "block text-sm font-medium text-primary dark:text-primary-dark" %>
              <%= f.password_field :password, class: "mt-1 block w-full border border-border dark:border-border-dark rounded-lg px-3 py-2 bg-white dark:bg-surface-dark text-primary dark:text-primary-dark" %>
            </div>
          </div>
          <%= f.submit "连接", class: "px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Auto Backup -->
  <div class="bg-container dark:bg-container-dark rounded-lg shadow-sm p-6">
    <h2 class="text-lg font-semibold mb-4">自动备份</h2>

    <% auto_backup_config = BackupConfig.auto_backup_config %>

    <% if @auto_backup_enabled %>
      <div class="space-y-4">
        <div class="flex items-center justify-between bg-green-50 dark:bg-green-900/20 rounded-lg p-4">
          <div class="flex items-center gap-3">
            <div class="text-green-500 text-2xl">🔄</div>
            <div>
              <div class="font-medium text-green-800 dark:text-green-200">自动备份已启用</div>
              <div class="text-sm text-secondary dark:text-secondary-dark">
                每日自动备份，保留最近 <%= auto_backup_config['retention_count'] || 10 %> 个
                <% if auto_backup_config['webdav_sync'] && @webdav_configured %>
                  · 自动上传到云端
                <% end %>
              </div>
            </div>
          </div>
          <%= button_to "禁用", disable_auto_backup_backups_path, method: :post, class: "px-4 py-1.5 text-sm font-medium rounded-lg bg-red-100 text-red-600 hover:bg-red-200 dark:bg-red-900/30 dark:text-red-400 dark:hover:bg-red-900/50 transition-smooth" %>
        </div>

        <% if @webdav_configured %>
          <div class="border border-border dark:border-border-dark rounded-lg p-4">
            <h3 class="font-medium mb-3 text-primary dark:text-primary-dark">同步设置</h3>
            <%= form_with url: enable_auto_backup_backups_path, method: :post, local: true do |f| %>
              <div class="flex items-center gap-4">
                <label class="flex items-center gap-2">
                  <%= f.check_box :webdav_sync, checked: auto_backup_config['webdav_sync'], class: "w-4 h-4 rounded border-border dark:border-border-dark" %>
                  <span class="text-sm text-primary dark:text-primary-dark">自动同步到 WebDAV 云端</span>
                </label>
                <%= f.hidden_field :frequency, value: auto_backup_config['frequency'] || 'daily' %>
                <%= f.hidden_field :retention, value: auto_backup_config['retention_count'] || 10 %>
                <%= f.submit "更新设置", class: "px-4 py-1.5 text-sm font-medium rounded-lg bg-inverse text-white hover:bg-inverse-hover transition-smooth" %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-4">
        <p class="text-secondary dark:text-secondary-dark mb-4">启用自动备份，每日自动创建数据备份</p>
        <% if @webdav_configured %>
          <%= form_with url: enable_auto_backup_backups_path, method: :post, local: true, class: "space-y-3" do |f| %>
            <label class="flex items-center gap-2 justify-center">
              <%= f.check_box :webdav_sync, class: "w-4 h-4 rounded border-border dark:border-border-dark" %>
              <span class="text-sm text-primary dark:text-primary-dark">同时上传到 WebDAV 云端</span>
            </label>
            <%= f.submit "启用自动备份", class: "px-4 py-1.5 text-sm font-medium rounded-lg bg-green-600 text-white hover:bg-green-700 transition-smooth" %>
          <% end %>
        <% else %>
          <%= button_to "启用自动备份", enable_auto_backup_backups_path, method: :post, class: "px-4 py-1.5 text-sm font-medium rounded-lg bg-green-600 text-white hover:bg-green-700 transition-smooth" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Backup List -->
  <div class="bg-container dark:bg-container-dark rounded-lg shadow-sm overflow-x-auto">
    <div class="px-6 py-4 border-b">
      <h2 class="text-lg font-semibold">备份历史</h2>
    </div>

    <% if @backups.empty? %>
      <div class="p-8 text-center text-secondary dark:text-secondary-dark">
        <div class="text-4xl mb-2">📭</div>
        <p>暂无备份</p>
      </div>
    <% else %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-surface dark:bg-surface-dark dark:bg-gray-900">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-secondary dark:text-secondary-dark uppercase">文件名</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-secondary dark:text-secondary-dark uppercase">类型</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-secondary dark:text-secondary-dark uppercase">大小</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-secondary dark:text-secondary-dark uppercase">创建时间</th>
            <th class="px-6 py-3 text-center text-xs font-medium text-secondary dark:text-secondary-dark uppercase">云端</th>
            <th class="px-6 py-3 actions"></th>
          </tr>
        </thead>
        <tbody class="bg-container dark:bg-container-dark divide-y divide-gray-200">
          <% @backups.each do |backup| %>
            <tr class="hover:bg-surface dark:bg-surface-dark dark:bg-gray-900">
              <td class="px-6 py-4 whitespace-nowrap font-medium text-primary dark:text-primary-dark">
                <%= backup[:name] %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="px-2 py-1 rounded text-xs bg-surface dark:bg-surface-dark text-primary dark:text-primary-dark dark:text-secondary-dark">
                  <%= backup[:type] == 'auto' ? '自动' : '手动' %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-secondary dark:text-secondary-dark">
                <%= number_to_human_size(backup[:size]) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary dark:text-secondary-dark">
                <%= l(backup[:created_at], format: :short) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-center">
                <% if backup[:webdav_url].present? %>
                  <span class="text-green-500">✓</span>
                <% else %>
                  <span class="text-secondary dark:text-secondary-dark">-</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                  <div class="flex gap-1 justify-end">
                    <%= link_to "下载", download_backup_path(backup[:id]), class: "px-2 py-1 text-xs font-medium rounded-lg border border-border dark:border-border-dark text-primary dark:text-primary-dark hover:bg-surface-hover dark:hover:bg-surface-dark-hover transition-smooth" %>
                    <%= button_to "恢复", restore_backup_path(backup[:id]),
                        method: :post,
                        form: { data: { turbo_confirm: "确定要从备份恢复数据吗？\n\n文件：#{backup[:name]}\n\n⚠️ 警告：当前数据将被完全覆盖，此操作不可逆！" } },
                        class: "px-2 py-1 text-xs font-medium rounded-lg bg-orange-100 text-orange-700 hover:bg-orange-200 transition-smooth" %>
                    <% if @webdav_configured && backup[:webdav_url].blank? %>
                      <%= button_to "上传", webdav_upload_backup_path(backup[:id]), method: :post, class: "px-2 py-1 text-xs font-medium rounded-lg bg-green-600 text-white hover:bg-green-700 transition-smooth" %>
                    <% end %>
                    <%= button_to "删除", backup_path(backup[:id]),
                        method: :delete,
                        form: { data: { turbo_confirm: "确定要删除此备份吗？\n\n#{backup[:name]}" } },
                        class: "px-2 py-1 text-xs font-medium rounded-lg bg-red-100 text-red-700 hover:bg-red-200 transition-smooth" %>
                  </div>
                </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</div>
